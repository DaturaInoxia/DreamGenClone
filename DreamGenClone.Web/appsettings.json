{
  "LmStudio": {
    "BaseUrl": "http://127.0.0.1:1234",
    "ChatCompletionsPath": "/v1/chat/completions",
    "Model": "Dolphin3.0-Llama3.1-8B",
    "TimeoutSeconds": 120
  },
  "Persistence": {
    "Provider": "SQLite",
    "ConnectionString": "Data Source=data/dreamgenclone.db",
    "TemplateImageRoot": "data/template-images"
  },
  "StoryParser": {
    "TimeoutSeconds": 10,
    "MaxHtmlBytes": 5242880,
    "MaxPageCount": 20,
    "ErrorModeDefault": "FailFast",
    "SupportedDomains": [
      "www.literotica.com",
      "literotica.com"
    ]
  },
  "StoryAnalysis": {
    "Model": "qwen2.5-14b-instruct-1m",
    "SummarizeTemperature": 0.3,
    "SummarizeMaxTokens": 500,
    "AnalyzeTemperature": 0.3,
    "AnalyzeMaxTokens": 800,
    "RankTemperature": 0.1,
    "RankMaxTokens": 200,
    "MaxStoryTextLength": 12000,
    "RankConfidenceThreshold": 0.5,
    "RpThemeMarkdownSourcePath": "specs/v2/ThemeDefinitaions",
    "AdaptiveThemeAffinityStackLimit": 1,
    "AdaptiveEarlyTurnInteractionThreshold": 3,
    "AdaptiveEarlyTurnPerStatDeltaCap": 2,
    "AdaptivePerInteractionTotalDeltaBudget": 10,
    "AdaptiveThemeAffinityCapBuildUp": 0,
    "AdaptiveThemeAffinityCapCommitted": 1,
    "AdaptiveThemeAffinityCapApproaching": 1,
    "AdaptiveThemeAffinityCapClimax": 2,
    "AdaptiveThemeAffinityCapReset": 0,
    "SuppressedEvidenceMultiplier": 0.20,
    "SuppressedEvidencePerTurnCap": 1.5,
    "BuildUpSelectionFitScoreStrategy": "weighted-blend",
    "BuildUpSelectionTieBreakStrategy": "tie-window",
    "BuildUpSelectionTieDeltaThreshold": 0.10,
    "BuildUpSelectionCommitThreshold": 0.60,
    "BuildUpSelectionCandidateGateStrategy": "dominant-role",
    "BuildUpSelectionDominantRoleMinScore": 0.85,
    "GateFailScorePenaltyMultiplier": 0.35,
    "CompletedScenarioRepeatPenaltyPerRun": 0.20,
    "CompletedScenarioRepeatPenaltyFloor": 0.40,
    "CompletedScenarioRecentPenaltyMultiplier": 0.65,
    "CompletedScenarioThemeScorePenalty": 10,
    "ResetDecayReductionPerCycle": 0.10,
    "ResetDecayReductionCap": 0.60,
    "ResetStatBaselines": {
      "Desire": 40,
      "Restraint": 50,
      "Tension": 40,
      "Connection": 50,
      "Dominance": 50,
      "Loyalty": 50,
      "SelfRespect": 50
    },
    "ResetStatBaselinePullSchedule": [
      0.8333,
      0.5833,
      0.3333,
      0.2,
      0.1667
    ],
    "ResetDesireBaseline": 40,
    "ResetDesireBaselinePullSchedule": [
      0.8333,
      0.5833,
      0.3333,
      0.2,
      0.1667
    ],
    "BuildUpMinInteractionsBeforeCommit": 2
  },
  "ScenarioAdaptation": {
    "Model": "Dolphin3.0-Llama3.1-8B",
    "PreviewTemperature": 0.6,
    "PreviewTopP": 0.95,
    "PreviewMaxTokens": 1200,
    "AdaptTemperature": 0.5,
    "AdaptTopP": 0.95,
    "AdaptMaxTokens": 2000
  },
  "RolePlayDecision": {
    "SuppressNarrativeAfterDecision": true,
    "SuppressNarrativeAfterPhaseChange": true,
    "EnableAiDecisionQuestionText": false,
    "EnableDecisionPrompts": false
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "DreamGenClone": "Information",
        "DreamGenClone.Infrastructure.StoryParser": "Information",
        "DreamGenClone.Infrastructure.ModelManager": "Information",
        "DreamGenClone.Infrastructure.Models": "Information",
        "DreamGenClone.Infrastructure.RolePlay": "Information",
        "DreamGenClone.Infrastructure.RolePlay.Diagnostics": "Information",
        "DreamGenClone.Domain.RolePlay": "Information",
        "DreamGenClone.Application.RolePlay": "Information",
        "DreamGenClone.Web.Application.StoryParser": "Information",
        "DreamGenClone.Web.Application.RolePlay": "Information",
        "DreamGenClone.Web.Application.ModelManager": "Information",
        "DreamGenClone.Web.Components.Pages.RolePlayWorkspace": "Information",
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/dreamgenclone-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

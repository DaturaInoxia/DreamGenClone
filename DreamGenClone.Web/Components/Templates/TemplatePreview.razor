@using DreamGenClone.Domain.Templates

@if (Template is null)
{
    <p>Select a template to preview.</p>
}
else
{
    <div class="card mt-3">
        <div class="card-header">Template Preview</div>
        <div class="card-body">
            <p><strong>Type:</strong> @Template.TemplateType</p>
            <p><strong>Name:</strong> @Template.Name</p>
            <p><strong>Last Updated (UTC):</strong> @Template.UpdatedUtc.ToString("u")</p>
            <p><strong>Image Path:</strong> @(string.IsNullOrWhiteSpace(Template.ImagePath) ? "(none)" : Template.ImagePath)</p>
            @if (Template.TemplateType == TemplateType.Character || Template.TemplateType == TemplateType.Persona)
            {
                <p><strong>Gender:</strong> @Template.Gender</p>
                <p><strong>Base Stats:</strong> @string.Join(" | ", Template.BaseStats.OrderBy(x => x.Key).Select(x => $"{x.Key}:{x.Value}"))</p>
            }
            <hr />
            <pre class="template-preview-content">@Template.Content</pre>
        </div>
    </div>
}

@code {
    [Parameter]
    public TemplateDefinition? Template { get; set; }
}

<style>
    .template-preview-content {
        white-space: pre-wrap;
        word-break: break-word;
        overflow-x: auto;
        max-width: 100%;
        margin-bottom: 0;
    }
</style>

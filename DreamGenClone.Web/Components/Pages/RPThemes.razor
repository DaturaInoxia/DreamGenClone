    private async Task RemoveThemeFromProfileAsync(string themeId)
    {
        await RunBusyAsync(async () =>
        {
            var assignment = _assignments.FirstOrDefault(x => string.Equals(x.ThemeId, themeId, StringComparison.OrdinalIgnoreCase));
            if (assignment is null)
            {
                return;
            }


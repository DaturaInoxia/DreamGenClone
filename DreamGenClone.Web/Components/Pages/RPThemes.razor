    private async Task DeleteThemeDefinitionAsync(string themeId)
    {
        await RunBusyAsync(async () =>
        {
            var deleted = await RPThemeService.DeleteThemeAsync(themeId);
            _status = deleted
                ? "Theme deleted."
                : "Theme cannot be deleted because it is referenced by one or more profiles.";

            await ReloadAllAsync();
        });
    }

    private async Task AssignImportedThemesToCurrentProfileAsync(IReadOnlyList<RPThemeImportResult> results)
    {
        if (_selectedProfile is null)
        {
            return;
        }

        var current = await RPThemeService.ListProfileAssignmentsAsync(_selectedProfile.Id);
        var byTheme = current.ToDictionary(x => x.ThemeId, StringComparer.OrdinalIgnoreCase);
        var nextSort = current.Count == 0 ? 1 : current.Max(x => x.SortOrder) + 1;

        foreach (var result in results.Where(x => x.Imported && !string.IsNullOrWhiteSpace(x.ThemeId)))
        {
            if (byTheme.ContainsKey(result.ThemeId))
            {
                continue;
            }

            await RPThemeService.SaveProfileAssignmentAsync(new RPThemeProfileThemeAssignment
            {
                Id = Guid.NewGuid().ToString("N"),
                ProfileId = _selectedProfile.Id,
                ThemeId = result.ThemeId,
                Tier = RPThemeTier.Neutral,
                SortOrder = nextSort++,
                IsEnabled = true
            });
        }
    }

    private void ResetThemeForm()
    {
        _isEditingTheme = false;
        _editingThemeId = null;
        _themeFormId = string.Empty;
        _themeFormLabel = string.Empty;
        _themeFormCategory = string.Empty;
        _themeFormWeight = 1;
        _themeFormDescription = string.Empty;
    }

    private static string ToThemeId(string label)
    {
        var chars = label.Trim().ToLowerInvariant().Select(ch =>
        {
            if ((ch >= 'a' && ch <= 'z') || (ch >= '0' && ch <= '9'))
            {
                return ch;
            }

            return '-';
        }).ToArray();

        var collapsed = new string(chars);
        while (collapsed.Contains("--", StringComparison.Ordinal))
        {
            collapsed = collapsed.Replace("--", "-", StringComparison.Ordinal);
        }

        return collapsed.Trim('-');
    }

    private async Task RunBusyAsync(Func<Task> action)
    {
        if (_isBusy)
        {
            return;
        }

        _isBusy = true;
        _error = string.Empty;

        try
        {
            await action();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }
}

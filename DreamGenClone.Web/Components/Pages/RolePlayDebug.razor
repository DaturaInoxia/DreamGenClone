    private void StartRefreshLoop()
    {
        _loopCts?.Cancel();
        _loopCts?.Dispose();
        _loopCts = new CancellationTokenSource();

        _ = Task.Run(async () =>
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
            while (!(_loopCts?.IsCancellationRequested ?? true))
            {
                try
                {
                    if (!await timer.WaitForNextTickAsync(_loopCts!.Token))
                    {
                        break;
                    }

                    if (!_autoRefresh)
                    {
                        continue;
                    }

                    await InvokeAsync(async () =>
                    {
                        await RefreshAsync();
                        StateHasChanged();
                    });
                }
                catch (OperationCanceledException)
                {
                    break;
                }
            }
        });
    }

    public ValueTask DisposeAsync()
    {
        _loopCts?.Cancel();
        _loopCts?.Dispose();
        return ValueTask.CompletedTask;
    }

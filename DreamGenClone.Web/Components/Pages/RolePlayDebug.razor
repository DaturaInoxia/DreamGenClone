@page "/roleplay/debug/{sessionId}"
@rendermode InteractiveServer

@using System.Text.Json
@using DreamGenClone.Application.Abstractions
@using DreamGenClone.Application.RolePlay
@using DreamGenClone.Web.Application.RolePlay

@inject RolePlayDebugEventService DebugEvents
@inject IRolePlayV2StateRepository V2StateRepository
@inject NavigationManager Navigation

@implements IAsyncDisposable

<PageTitle>Role-Play Debug</PageTitle>

<div class="rpd-shell">
    <header class="rpd-header">
        <div class="rpd-header-left">
            <button class="rpd-btn rpd-btn-secondary" @onclick="GoBack">Back to Workspace</button>
            <div>
                <h1>Role-Play Debug</h1>
                <p>Session @sessionId</p>
            </div>
        </div>
        <div class="rpd-header-right">
            <label>
                <input type="checkbox" @bind="_autoRefresh" /> Auto refresh
            </label>
            <button class="rpd-btn" @onclick="RefreshAsync" disabled="@_isLoading">Refresh</button>
        </div>
    </header>

    <section class="rpd-filters">
        <input class="rpd-input" placeholder="Search summary or json" @bind="_search" @bind:event="oninput" />
        <select class="rpd-select" @bind="_activeTab">
            <option value="overview">Overview</option>
            <option value="timeline">Timeline</option>
            <option value="adaptive">Adaptive State</option>
            <option value="locations">Locations</option>
            <option value="decisions">Decisions</option>
            <option value="prompts">Prompts</option>
            <option value="requests">Requests</option>
            <option value="responses">Responses</option>
            <option value="logs">Logs</option>
        </select>
        <select class="rpd-select" @bind="_eventKindFilter">
            <option value="">All event kinds</option>
            @foreach (var kind in _knownEventKinds)
            {
                <option value="@kind">@kind</option>
            }
        </select>
    </section>

    <div class="rpd-grid">
        <aside class="rpd-list">
            @if (_isLoading)
            {
                <div class="rpd-empty">Loading...</div>
            }
            else if (FilteredEvents.Count == 0)
            {
                <div class="rpd-empty">No matching events.</div>
            }
            else
            {
                @foreach (var evt in FilteredEvents)
                {
                    var selected = _selectedEvent?.EventId == evt.EventId ? "is-selected" : string.Empty;
                    <button class="rpd-row @selected" @onclick="(() => SelectEvent(evt))">
                        <span class="rpd-kind">@evt.EventKind</span>
                        <span class="rpd-summary">@evt.Summary</span>
                        <span class="rpd-meta">@evt.CreatedUtc.ToLocalTime().ToString("HH:mm:ss")</span>
                    </button>
                }
            }
        </aside>

        <main class="rpd-details">
            @if (_activeTab == "overview")
            {
                <div class="rpd-cards">
                    <article class="rpd-card">
                        <h3>Total events</h3>
                        <p>@_events.Count</p>
                    </article>
                    <article class="rpd-card">
                        <h3>Adaptive updates</h3>
                        <p>@_events.Count(x => x.EventKind == "AdaptiveStateUpdated")</p>
                    </article>
                    <article class="rpd-card">
                        <h3>LLM requests</h3>
                        <p>@_events.Count(x => x.EventKind == "LlmRequestSent")</p>
                    </article>
                    <article class="rpd-card">
                        <h3>LLM responses</h3>
                        <p>@_events.Count(x => x.EventKind == "LlmResponseReceived")</p>
                    </article>
                </div>

                <div class="rpd-panel">
                    <h3>Top Event Kinds</h3>
                    @foreach (var group in _events.GroupBy(x => x.EventKind).OrderByDescending(x => x.Count()).Take(10))
                    {
                        <div class="rpd-kv"><span>@group.Key</span><strong>@group.Count()</strong></div>
                    }
                </div>

                <div class="rpd-panel">
                    <h3>Latest Runtime Fit Scores</h3>
                    @if (_latestFitScores.Count == 0)
                    {
                        <div class="rpd-empty">No recent candidate fit score lines found yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Time</th>
                                        <th>Scenario</th>
                                        <th>Tier</th>
                                        <th>Eligible</th>
                                        <th>FitScore</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in _latestFitScores)
                                    {
                                        <tr>
                                            <td>@row.TimeLabel</td>
                                            <td>@row.ScenarioId</td>
                                            <td>@row.Tier</td>
                                            <td>@(row.Eligible ? "Y" : "N")</td>
                                            <td>@row.FitScore.ToString("0.###")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <div class="rpd-panel">
                    <h3>Fit Score Breakdown</h3>
                    @if (_fitScoreBreakdownRows.Count == 0)
                    {
                        <div class="rpd-empty">No candidate evaluations with component breakdown found yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Time</th>
                                        <th>Scenario</th>
                                        <th>Tier</th>
                                        <th>Gate</th>
                                        <th>Character</th>
                                        <th>Narrative</th>
                                        <th>Preference</th>
                                        <th>Weighted Subtotal</th>
                                        <th>Penalty</th>
                                        <th>Final FitScore</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in _fitScoreBreakdownRows)
                                    {
                                        <tr>
                                            <td>@row.TimeLabel</td>
                                            <td>@row.ScenarioId</td>
                                            <td>@row.Tier</td>
                                            <td>@(row.GatePassed ? "Y" : "N")</td>
                                            <td>@row.CharacterScore.ToString("0.###") (@row.CharacterPoints.ToString("0.###"))</td>
                                            <td>@row.NarrativeScore.ToString("0.###") (@row.NarrativePoints.ToString("0.###"))</td>
                                            <td>@row.PreferenceScore.ToString("0.###") (@row.PreferencePoints.ToString("0.###"))</td>
                                            <td>@row.WeightedSubtotal.ToString("0.###")</td>
                                            <td>@row.PenaltyMultiplierLabel</td>
                                            <td>@row.FinalFitScore.ToString("0.###")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <div class="rpd-panel">
                    <h3>Role Weight Contributions</h3>
                    @if (_roleFitBreakdownRows.Count == 0)
                    {
                        <div class="rpd-empty">No candidate fit breakdown rows found yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead>
                                    <tr>
                                        <th>Time</th>
                                        <th>Scenario</th>
                                        <th>Source</th>
                                        <th>Role</th>
                                        <th>Bound Character</th>
                                        <th>Role Score</th>
                                        <th>Role Weight</th>
                                        <th>Weighted Contribution</th>
                                        <th>Failed Clauses</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in _roleFitBreakdownRows)
                                    {
                                        <tr>
                                            <td>@row.TimeLabel</td>
                                            <td>@row.ScenarioId</td>
                                            <td>@row.FitRuleSource</td>
                                            <td>@row.RoleName</td>
                                            <td>@row.BoundCharacter</td>
                                            <td>@row.RoleScore.ToString("0.###")</td>
                                            <td>@row.RoleWeight.ToString("0.###")</td>
                                            <td>@row.WeightedContribution.ToString("0.###")</td>
                                            <td>@row.FailedClauseCount</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
            else if (_activeTab == "logs")
            {
                <div class="rpd-panel">
                    <h3>Log Entries</h3>
                    @if (_logLines.Count == 0)
                    {
                        <div class="rpd-empty">No matching log lines found for this session yet.</div>
                    }
                    else
                    {
                        <pre class="rpd-json">@string.Join(Environment.NewLine, _logLines)</pre>
                    }
                </div>
            }
            else if (_selectedEvent is null)
            {
                <div class="rpd-empty">Select an event to inspect details.</div>
            }
            else
            {
                <div class="rpd-panel">
                    <h3>@_selectedEvent.EventKind</h3>
                    <div class="rpd-kv"><span>Severity</span><strong>@_selectedEvent.Severity</strong></div>
                    <div class="rpd-kv"><span>Actor</span><strong>@(_selectedEvent.ActorName ?? "-")</strong></div>
                    <div class="rpd-kv"><span>Model</span><strong>@(_selectedEvent.ModelIdentifier ?? "-")</strong></div>
                    <div class="rpd-kv"><span>Provider</span><strong>@(_selectedEvent.ProviderName ?? "-")</strong></div>
                    <div class="rpd-kv"><span>Duration</span><strong>@(_selectedEvent.DurationMs?.ToString() ?? "-") ms</strong></div>
                    <div class="rpd-kv"><span>Correlation</span><strong>@(_selectedEvent.CorrelationId ?? "-")</strong></div>
                </div>

                <div class="rpd-panel">
                    <h3>Summary</h3>
                    <p class="rpd-summary-block">@_selectedEvent.Summary</p>
                </div>

                @if (string.Equals(_selectedEvent.EventKind, "AdaptiveStateUpdated", StringComparison.OrdinalIgnoreCase))
                {
                    var deltaRows = BuildAdaptiveDeltaRows(_selectedEvent.MetadataJson);
                    <div class="rpd-panel">
                        <h3>Adaptive Stat Deltas</h3>
                        @if (deltaRows.Count == 0)
                        {
                            <div class="rpd-empty">No adaptive stat deltas in metadata.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead>
                                        <tr>
                                            <th>Stat</th>
                                            <th>Raw</th>
                                            <th>Applied</th>
                                            <th>Policy Adjustment</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in deltaRows)
                                        {
                                            <tr>
                                                <td>@row.StatName</td>
                                                <td>@row.RawDelta</td>
                                                <td>@row.AppliedDelta</td>
                                                <td>@(row.PolicyAdjustment ?? "-")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }

                @if (string.Equals(_selectedEvent.EventKind, "AdaptiveCommitGateEvaluated", StringComparison.OrdinalIgnoreCase))
                {
                    var gateDetails = BuildAdaptiveCommitGateDetails(_selectedEvent.MetadataJson);
                    <div class="rpd-panel">
                        <h3>Adaptive Commit Gate</h3>
                        <div class="rpd-kv"><span>Phase</span><strong>@(gateDetails.Phase ?? "-")</strong></div>
                        <div class="rpd-kv"><span>Gate Result</span><strong>@gateDetails.GateResultLabel</strong></div>
                        <div class="rpd-kv"><span>Configured</span><strong>@(gateDetails.Configured ? "Yes" : "No")</strong></div>
                        <div class="rpd-kv"><span>Profile</span><strong>@gateDetails.ProfileLabel</strong></div>
                        <div class="rpd-kv"><span>Profile Source</span><strong>@(gateDetails.ProfileSource ?? "-")</strong></div>
                        <div class="rpd-kv"><span>Interaction Count</span><strong>@gateDetails.InteractionCount</strong></div>
                        <div class="rpd-kv"><span>Candidate Count</span><strong>@gateDetails.CandidateCount</strong></div>
                        <div class="rpd-kv"><span>Selected Scenario</span><strong>@(gateDetails.SelectedScenarioId ?? "-")</strong></div>
                        <div class="rpd-kv"><span>Committed</span><strong>@(gateDetails.Committed ? "Yes" : "No")</strong></div>
                        <div class="rpd-kv"><span>Reason</span><strong>@(gateDetails.Reason ?? "-")</strong></div>

                        <h4>Rule Outcomes</h4>
                        @if (gateDetails.Rules.Count == 0)
                        {
                            <div class="rpd-empty">No rule-level outcomes in metadata.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Metric</th>
                                            <th>Comparator</th>
                                            <th>Threshold</th>
                                            <th>Actual</th>
                                            <th>Result</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in gateDetails.Rules)
                                        {
                                            <tr>
                                                <td>@row.SortOrder</td>
                                                <td>@row.MetricKey</td>
                                                <td>@row.Comparator</td>
                                                <td>@row.ThresholdLabel</td>
                                                <td>@row.ActualLabel</td>
                                                <td>@(row.Passed ? "Pass" : "Fail")</td>
                                                <td>@row.Status</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }

                @if (string.Equals(_selectedEvent.EventKind, "LocationStateUpdated", StringComparison.OrdinalIgnoreCase))
                {
                    var locationRows = BuildLocationTruthRows(_selectedEvent.MetadataJson);
                    var perceptionRows = BuildLocationPerceptionRows(_selectedEvent.MetadataJson);

                    <div class="rpd-panel">
                        <h3>Location Truth</h3>
                        @if (locationRows.Count == 0)
                        {
                            <div class="rpd-empty">No location truth rows in metadata.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead>
                                        <tr>
                                            <th>Character</th>
                                            <th>Type</th>
                                            <th>True Location</th>
                                            <th>Hidden</th>
                                            <th>Updated</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in locationRows)
                                        {
                                            <tr>
                                                <td>@(string.IsNullOrWhiteSpace(row.CharacterLabel) ? row.CharacterId : row.CharacterLabel)</td>
                                                <td>@row.CharacterType</td>
                                                <td>@(string.IsNullOrWhiteSpace(row.TrueLocation) ? "(unknown)" : row.TrueLocation)</td>
                                                <td>@(row.IsHidden ? "Yes" : "No")</td>
                                                <td>@(row.UpdatedUtc?.ToLocalTime().ToString("HH:mm:ss") ?? "-")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>

                    <div class="rpd-panel">
                        <h3>Location Perceptions</h3>
                        @if (perceptionRows.Count == 0)
                        {
                            <div class="rpd-empty">No location perception rows in metadata.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle">
                                    <thead>
                                        <tr>
                                            <th>Observer</th>
                                            <th>Observer Type</th>
                                            <th>Target</th>
                                            <th>Target Type</th>
                                            <th>Perceived Location</th>
                                            <th>Confidence</th>
                                            <th>LOS</th>
                                            <th>Near</th>
                                            <th>Source</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in perceptionRows)
                                        {
                                            <tr>
                                                <td>@(string.IsNullOrWhiteSpace(row.ObserverLabel) ? row.ObserverCharacterId : row.ObserverLabel)</td>
                                                <td>@row.ObserverType</td>
                                                <td>@(string.IsNullOrWhiteSpace(row.TargetLabel) ? row.TargetCharacterId : row.TargetLabel)</td>
                                                <td>@row.TargetType</td>
                                                <td>@(string.IsNullOrWhiteSpace(row.PerceivedLocation) ? "(unknown)" : row.PerceivedLocation)</td>
                                                <td>@row.Confidence</td>
                                                <td>@(row.HasLineOfSight ? "Y" : "N")</td>
                                                <td>@(row.IsInProximity ? "Y" : "N")</td>
                                                <td>@(string.IsNullOrWhiteSpace(row.KnowledgeSource) ? "-" : row.KnowledgeSource)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }

                @if (string.Equals(_selectedEvent.EventKind, "DecisionInstructionInjected", StringComparison.OrdinalIgnoreCase)
                    || string.Equals(_selectedEvent.EventKind, "DecisionInstructionSkipped", StringComparison.OrdinalIgnoreCase))
                {
                    var decisionData = BuildDecisionInstructionDetails(_selectedEvent.MetadataJson);
                    <div class="rpd-panel">
                        <h3>Decision Instruction</h3>
                        <div class="rpd-kv"><span>Decision Point</span><strong>@(decisionData.DecisionPointId ?? "-")</strong></div>
                        <div class="rpd-kv"><span>Option</span><strong>@(decisionData.OptionId ?? "-")</strong></div>
                        <div class="rpd-kv"><span>Trigger</span><strong>@(decisionData.Trigger ?? "-")</strong></div>
                        <div class="rpd-kv"><span>Target Actor</span><strong>@(decisionData.TargetActorId ?? "-")</strong></div>
                        <div class="rpd-kv"><span>Asking Actor</span><strong>@(decisionData.AskingActorId ?? "-")</strong></div>
                        <div class="rpd-kv"><span>Dialogue Source</span><strong>@(decisionData.SelectedDialogueSource ?? "-")</strong></div>

                        <h4>Selected Dialogue</h4>
                        <pre class="rpd-json">@(string.IsNullOrWhiteSpace(decisionData.SelectedDialogue) ? "(none)" : decisionData.SelectedDialogue)</pre>

                        <h4>Injected Instruction</h4>
                        <pre class="rpd-json">@(string.IsNullOrWhiteSpace(decisionData.InjectedInstruction) ? "(none)" : decisionData.InjectedInstruction)</pre>

                        <h4>Option Text/Preview</h4>
                        <div class="rpd-kv"><span>Display Text</span><strong>@(decisionData.DisplayText ?? "-")</strong></div>
                        <div class="rpd-kv"><span>Response Preview</span><strong>@(decisionData.ResponsePreview ?? "-")</strong></div>
                    </div>
                }

                <div class="rpd-panel">
                    <h3>Metadata JSON</h3>
                    <pre class="rpd-json">@FormatJson(_selectedEvent.MetadataJson)</pre>
                </div>
            }
        </main>
    </div>
</div>

@code {
    [Parameter]
    public string sessionId { get; set; } = string.Empty;

    private readonly List<RolePlayDebugEventRecord> _events = [];
    private readonly List<string> _logLines = [];
    private readonly List<FitScoreRow> _latestFitScores = [];
    private readonly List<FitScoreBreakdownRow> _fitScoreBreakdownRows = [];
    private readonly List<RoleFitBreakdownRow> _roleFitBreakdownRows = [];
    private readonly List<string> _knownEventKinds = [];
    private RolePlayDebugEventRecord? _selectedEvent;
    private string _activeTab = "timeline";
    private string _eventKindFilter = string.Empty;
    private string _search = string.Empty;
    private bool _isLoading;
    private bool _autoRefresh = true;
    private CancellationTokenSource? _loopCts;

    private List<RolePlayDebugEventRecord> FilteredEvents => _events
        .Where(MatchesTab)
        .Where(x => string.IsNullOrWhiteSpace(_eventKindFilter) || string.Equals(x.EventKind, _eventKindFilter, StringComparison.OrdinalIgnoreCase))
        .Where(x => string.IsNullOrWhiteSpace(_search)
            || x.Summary.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || x.MetadataJson.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(x => x.CreatedUtc)
        .ToList();

    protected override async Task OnParametersSetAsync()
    {
        await RefreshAsync();
        StartRefreshLoop();
    }

    private async Task RefreshAsync()
    {
        _isLoading = true;

        var items = await DebugEvents.QuerySessionEventsAsync(
            sessionId,
            eventKind: string.IsNullOrWhiteSpace(_eventKindFilter) ? null : _eventKindFilter,
            search: string.IsNullOrWhiteSpace(_search) ? null : _search,
            take: 700);

        _events.Clear();
        _events.AddRange(items);

        _knownEventKinds.Clear();
        _knownEventKinds.AddRange(_events.Select(x => x.EventKind).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x));

        _logLines.Clear();
        _logLines.AddRange(await DebugEvents.GetRecentLogLinesAsync(sessionId, _selectedEvent?.CorrelationId, 250));

        var sessionLogLines = await DebugEvents.GetRecentLogLinesAsync(sessionId, null, 400);
        _latestFitScores.Clear();
        _latestFitScores.AddRange(ParseFitScoreRows(sessionLogLines)
            .OrderByDescending(x => x.Time)
            .Take(20)
            .ToList());

        var candidateEvaluations = await V2StateRepository.LoadCandidateEvaluationsAsync(sessionId, take: 80);
        _roleFitBreakdownRows.Clear();
        _roleFitBreakdownRows.AddRange(ParseRoleFitBreakdownRows(candidateEvaluations)
            .OrderByDescending(x => x.Time)
            .ThenBy(x => x.ScenarioId, StringComparer.OrdinalIgnoreCase)
            .ThenBy(x => x.RoleName, StringComparer.OrdinalIgnoreCase)
            .Take(120)
            .ToList());

        _fitScoreBreakdownRows.Clear();
        _fitScoreBreakdownRows.AddRange(BuildFitScoreBreakdownRows(candidateEvaluations)
            .OrderByDescending(x => x.Time)
            .ThenBy(x => x.ScenarioId, StringComparer.OrdinalIgnoreCase)
            .Take(60)
            .ToList());

        if (_selectedEvent is not null)
        {
            _selectedEvent = _events.FirstOrDefault(x => x.EventId == _selectedEvent.EventId);
        }

        if (_selectedEvent is null)
        {
            _selectedEvent = _events.LastOrDefault();
        }

        _isLoading = false;
    }

    private bool MatchesTab(RolePlayDebugEventRecord evt)
    {
        return _activeTab switch
        {
            "adaptive" => evt.EventKind.Contains("Adaptive", StringComparison.OrdinalIgnoreCase),
            "locations" => evt.EventKind.Contains("Location", StringComparison.OrdinalIgnoreCase),
            "decisions" => evt.EventKind.Contains("Decision", StringComparison.OrdinalIgnoreCase),
            "prompts" => evt.EventKind.Contains("Prompt", StringComparison.OrdinalIgnoreCase),
            "requests" => evt.EventKind.Contains("Request", StringComparison.OrdinalIgnoreCase),
            "responses" => evt.EventKind.Contains("Response", StringComparison.OrdinalIgnoreCase),
            "logs" => true,
            _ => true
        };
    }

    private static string FormatJson(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
        {
            return "{}";
        }

        try
        {
            using var doc = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return json;
        }
    }

    private static List<AdaptiveDeltaRow> BuildAdaptiveDeltaRows(string? metadataJson)
    {
        var rows = new List<AdaptiveDeltaRow>();
        if (string.IsNullOrWhiteSpace(metadataJson))
        {
            return rows;
        }

        try
        {
            using var doc = JsonDocument.Parse(metadataJson);
            var root = doc.RootElement;

            var rawDeltas = ReadIntMap(root, "rawStatDeltas");
            var appliedDeltas = ReadIntMap(root, "statDeltas");
            var reasons = ReadReasonsMap(root, "statDeltaReasons");

            var keys = rawDeltas.Keys
                .Concat(appliedDeltas.Keys)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(x => x, StringComparer.OrdinalIgnoreCase);

            foreach (var key in keys)
            {
                rawDeltas.TryGetValue(key, out var raw);
                appliedDeltas.TryGetValue(key, out var applied);
                reasons.TryGetValue(key, out var statReasons);

                var policyAdjustment = statReasons?
                    .Where(x => x.StartsWith("policy:", StringComparison.OrdinalIgnoreCase))
                    .ToArray();

                rows.Add(new AdaptiveDeltaRow(
                    key,
                    raw,
                    applied,
                    policyAdjustment is { Length: > 0 } ? string.Join("; ", policyAdjustment) : null));
            }
        }
        catch
        {
            return rows;
        }

        return rows;
    }

    private static AdaptiveCommitGateDetails BuildAdaptiveCommitGateDetails(string? metadataJson)
    {
        if (string.IsNullOrWhiteSpace(metadataJson))
        {
            return AdaptiveCommitGateDetails.Empty;
        }

        try
        {
            using var doc = JsonDocument.Parse(metadataJson);
            var root = doc.RootElement;

            var details = new AdaptiveCommitGateDetails
            {
                Phase = ReadString(root, "phase"),
                InteractionCount = ReadInt(root, "interactionCount"),
                CandidateCount = ReadInt(root, "candidateCount"),
                SelectedScenarioId = ReadString(root, "selectedScenarioId"),
                Committed = ReadBool(root, "committed"),
                Reason = ReadString(root, "reason")
            };

            if (!TryGetPropertyIgnoreCase(root, "gateAudit", out var gateAuditElement)
                || gateAuditElement.ValueKind != JsonValueKind.String)
            {
                return details;
            }

            var gateAuditJson = gateAuditElement.GetString();
            if (string.IsNullOrWhiteSpace(gateAuditJson))
            {
                return details;
            }

            using var gateDoc = JsonDocument.Parse(gateAuditJson);
            var gateRoot = gateDoc.RootElement;

            details.Passed = ReadNullableBool(gateRoot, "passed");
            details.Configured = ReadBool(gateRoot, "configured");
            details.ProfileId = ReadString(gateRoot, "profileId");
            details.ProfileName = ReadString(gateRoot, "profileName");
            details.ProfileSource = ReadString(gateRoot, "profileSource");
            details.Reason = ReadString(gateRoot, "reason") ?? details.Reason;

            if (TryGetPropertyIgnoreCase(gateRoot, "rules", out var rulesElement)
                && rulesElement.ValueKind == JsonValueKind.Array)
            {
                foreach (var item in rulesElement.EnumerateArray())
                {
                    details.Rules.Add(new AdaptiveCommitGateRuleRow(
                        SortOrder: ReadInt(item, "sortOrder"),
                        MetricKey: ReadString(item, "metricKey") ?? "-",
                        Comparator: ReadString(item, "comparator") ?? "-",
                        ThresholdLabel: ReadDecimalLabel(item, "threshold"),
                        ActualLabel: ReadDecimalLabel(item, "actual"),
                        Passed: ReadBool(item, "passed"),
                        Status: ReadString(item, "status") ?? "-"));
                }
            }

            return details;
        }
        catch
        {
            return AdaptiveCommitGateDetails.Empty;
        }
    }

    private static Dictionary<string, int> ReadIntMap(JsonElement root, string propertyName)
    {
        var result = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        if (!root.TryGetProperty(propertyName, out var mapElement) || mapElement.ValueKind != JsonValueKind.Object)
        {
            return result;
        }

        foreach (var prop in mapElement.EnumerateObject())
        {
            if (prop.Value.ValueKind == JsonValueKind.Number && prop.Value.TryGetInt32(out var intValue))
            {
                result[prop.Name] = intValue;
            }
        }

        return result;
    }

    private static Dictionary<string, List<string>> ReadReasonsMap(JsonElement root, string propertyName)
    {
        var result = new Dictionary<string, List<string>>(StringComparer.OrdinalIgnoreCase);
        if (!root.TryGetProperty(propertyName, out var mapElement) || mapElement.ValueKind != JsonValueKind.Object)
        {
            return result;
        }

        foreach (var prop in mapElement.EnumerateObject())
        {
            if (prop.Value.ValueKind != JsonValueKind.Array)
            {
                continue;
            }

            var values = new List<string>();
            foreach (var item in prop.Value.EnumerateArray())
            {
                if (item.ValueKind == JsonValueKind.String)
                {
                    values.Add(item.GetString() ?? string.Empty);
                }
            }

            result[prop.Name] = values;
        }

        return result;
    }


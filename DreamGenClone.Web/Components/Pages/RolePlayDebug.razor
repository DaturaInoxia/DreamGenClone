    private static string? ReadString(JsonElement element, string propertyName)
    {
        if (!TryGetPropertyIgnoreCase(element, propertyName, out var value) || value.ValueKind != JsonValueKind.String)
        {
            return null;
        }

        return value.GetString();
    }

    private static int ReadInt(JsonElement element, string propertyName)
    {
        if (!TryGetPropertyIgnoreCase(element, propertyName, out var value) || value.ValueKind != JsonValueKind.Number)
        {
            return 0;
        }

        return value.TryGetInt32(out var result) ? result : 0;
    }

    private static bool ReadBool(JsonElement element, string propertyName)
    {
        if (!TryGetPropertyIgnoreCase(element, propertyName, out var value))
        {
            return false;
        }

        return value.ValueKind == JsonValueKind.True;
    }

    private static bool? ReadNullableBool(JsonElement element, string propertyName)
    {
        if (!TryGetPropertyIgnoreCase(element, propertyName, out var value))
        {
            return null;
        }

        return value.ValueKind switch
        {
            JsonValueKind.True => true,
            JsonValueKind.False => false,
            _ => null
        };
    }

    private static string ReadDecimalLabel(JsonElement element, string propertyName)
    {
        if (!TryGetPropertyIgnoreCase(element, propertyName, out var value)
            || value.ValueKind != JsonValueKind.Number)
        {
            return "-";
        }

        return value.TryGetDecimal(out var parsed)
            ? parsed.ToString("0.###")
            : value.ToString();
    }

    private static DateTime? ReadDateTime(JsonElement element, string propertyName)
    {
        if (!TryGetPropertyIgnoreCase(element, propertyName, out var value) || value.ValueKind != JsonValueKind.String)
        {
            return null;
        }

        var text = value.GetString();
        if (string.IsNullOrWhiteSpace(text))
        {
            return null;
        }

        return DateTime.TryParse(text, out var parsed) ? parsed : null;
    }

    private static bool TryGetPropertyIgnoreCase(JsonElement element, string propertyName, out JsonElement value)
    {
        if (element.ValueKind != JsonValueKind.Object)
        {
            value = default;
            return false;
        }

        foreach (var property in element.EnumerateObject())
        {
            if (string.Equals(property.Name, propertyName, StringComparison.OrdinalIgnoreCase))
            {
                value = property.Value;
                return true;
            }
        }

        value = default;
        return false;
    }

    private static List<FitScoreRow> ParseFitScoreRows(IReadOnlyList<string> lines)
    {
        var rows = new List<FitScoreRow>();
        foreach (var line in lines)
        {
            if (!line.Contains("RolePlayV2 scenario candidate evaluated:", StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            var scenarioId = ExtractToken(line, "ScenarioId=");
            var tier = ExtractToken(line, "Tier=");
            var eligibleText = ExtractToken(line, "Eligible=");
            var fitScoreText = ExtractToken(line, "FitScore=");
            if (string.IsNullOrWhiteSpace(scenarioId)
                || string.IsNullOrWhiteSpace(fitScoreText)
                || !decimal.TryParse(fitScoreText, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out var fitScore))
            {
                continue;
            }

            var timestampText = line.Length >= 23 ? line[..23] : string.Empty;
            DateTime.TryParse(timestampText, out var timestamp);

            rows.Add(new FitScoreRow(
                Time: timestamp,
                TimeLabel: timestamp == default ? "-" : timestamp.ToLocalTime().ToString("HH:mm:ss"),
                ScenarioId: scenarioId,
                Tier: string.IsNullOrWhiteSpace(tier) ? "-" : tier,
                Eligible: string.Equals(eligibleText, "true", StringComparison.OrdinalIgnoreCase),
                FitScore: fitScore));
        }

        return rows;
    }

    private static string ExtractToken(string line, string token)
    {
        var idx = line.IndexOf(token, StringComparison.OrdinalIgnoreCase);
        if (idx < 0)
        {
            return string.Empty;
        }

        var start = idx + token.Length;
        if (start >= line.Length)
        {
            return string.Empty;
        }

        var end = line.IndexOf(' ', start);
        if (end < 0)
        {
            end = line.Length;
        }

        return line[start..end].Trim();
    }

    private static List<RoleFitBreakdownRow> ParseRoleFitBreakdownRows(
        IReadOnlyList<DreamGenClone.Domain.RolePlay.ScenarioCandidateEvaluation> evaluations)
    {
        var rows = new List<RoleFitBreakdownRow>();

        foreach (var evaluation in evaluations)
        {
            if (string.IsNullOrWhiteSpace(evaluation.DetailsJson))
            {
                continue;
            }

            try
            {
                using var doc = JsonDocument.Parse(evaluation.DetailsJson);
                var root = doc.RootElement;

                var fitRuleSource = ReadString(root, "fitRuleSource") ?? "unknown";
                if (!TryGetPropertyIgnoreCase(root, "fitResult", out var fitResult)
                    || fitResult.ValueKind != JsonValueKind.Object)
                {
                    continue;
                }

                if (!TryGetPropertyIgnoreCase(fitResult, "roleScores", out var roleScoresElement)
                    || roleScoresElement.ValueKind != JsonValueKind.Object)
                {
                    continue;
                }

                var roleScores = ReadDoubleMap(roleScoresElement);
                if (roleScores.Count == 0)
                {
                    continue;
                }

                var roleWeights = TryGetPropertyIgnoreCase(fitResult, "roleWeights", out var roleWeightsElement)
                    && roleWeightsElement.ValueKind == JsonValueKind.Object
                    ? ReadDoubleMap(roleWeightsElement)
                    : new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase);

                var roleBindings = TryGetPropertyIgnoreCase(fitResult, "roleCharacterBindings", out var roleBindingsElement)
                    && roleBindingsElement.ValueKind == JsonValueKind.Object
                    ? ReadStringMap(roleBindingsElement)
                    : new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

                var roleFailureCounts = CountRoleFailures(fitResult);

                var totalWeight = 0d;
                foreach (var roleName in roleScores.Keys)
                {
                    var weight = roleWeights.TryGetValue(roleName, out var configuredWeight)
                        ? Math.Max(configuredWeight, 0d)
                        : 1d;
                    totalWeight += weight;
                }

                if (totalWeight <= 0d)
                {
                    totalWeight = roleScores.Count;
                }

                foreach (var (roleName, roleScore) in roleScores.OrderByDescending(x => x.Value))
                {
                    var roleWeight = roleWeights.TryGetValue(roleName, out var configuredWeight)
                        ? Math.Max(configuredWeight, 0d)
                        : 1d;
                    var normalizedContribution = totalWeight > 0d
                        ? (roleScore * roleWeight) / totalWeight
                        : 0d;

                    var time = evaluation.EvaluatedUtc;
                    rows.Add(new RoleFitBreakdownRow(
                        Time: time,
                        TimeLabel: time == default ? "-" : time.ToLocalTime().ToString("HH:mm:ss"),
                        ScenarioId: evaluation.ScenarioId,
                        FitRuleSource: fitRuleSource,
                        RoleName: roleName,
                        BoundCharacter: roleBindings.TryGetValue(roleName, out var boundCharacter)
                            ? boundCharacter
                            : "-",
                        RoleScore: roleScore,
                        RoleWeight: roleWeight,
                        WeightedContribution: normalizedContribution,
                        FailedClauseCount: roleFailureCounts.TryGetValue(roleName, out var failureCount) ? failureCount : 0));
                }
            }
            catch
            {
                // Ignore malformed details rows so the debug page stays responsive.
            }
        }

        return rows;
    }

    private static List<FitScoreBreakdownRow> BuildFitScoreBreakdownRows(
        IReadOnlyList<DreamGenClone.Domain.RolePlay.ScenarioCandidateEvaluation> evaluations)
    {
        var rows = new List<FitScoreBreakdownRow>();

        foreach (var evaluation in evaluations)
        {
            var characterScore = (double)evaluation.CharacterAlignmentScore;
            var narrativeScore = (double)evaluation.NarrativeEvidenceScore;
            var preferenceScore = (double)evaluation.PreferencePriorityScore;

            var characterPoints = characterScore * 50d;
            var narrativePoints = narrativeScore * 30d;
            var preferencePoints = preferenceScore * 20d;
            var weightedSubtotal = characterPoints + narrativePoints + preferencePoints;

            var finalFitScore = (double)evaluation.FitScore;
            var penaltyMultiplier = weightedSubtotal > 0.0001d
                ? finalFitScore / weightedSubtotal
                : 1d;

            var penaltyLabel = evaluation.StageBEligible
                ? "1.000"
                : penaltyMultiplier.ToString("0.###");

            var time = evaluation.EvaluatedUtc;
            rows.Add(new FitScoreBreakdownRow(
                Time: time,
                TimeLabel: time == default ? "-" : time.ToLocalTime().ToString("HH:mm:ss"),
                ScenarioId: evaluation.ScenarioId,
                Tier: string.IsNullOrWhiteSpace(evaluation.StageAWillingnessTier) ? "-" : evaluation.StageAWillingnessTier,
                GatePassed: evaluation.StageBEligible,
                CharacterScore: characterScore,
                NarrativeScore: narrativeScore,
                PreferenceScore: preferenceScore,
                CharacterPoints: characterPoints,
                NarrativePoints: narrativePoints,
                PreferencePoints: preferencePoints,
                WeightedSubtotal: weightedSubtotal,
                PenaltyMultiplierLabel: penaltyLabel,
                FinalFitScore: finalFitScore));
        }

        return rows;
    }

    private static Dictionary<string, int> CountRoleFailures(JsonElement fitResult)
    {
        var result = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        if (!TryGetPropertyIgnoreCase(fitResult, "failures", out var failuresElement)
            || failuresElement.ValueKind != JsonValueKind.Array)
        {
            return result;
        }

        foreach (var item in failuresElement.EnumerateArray())
        {
            if (item.ValueKind != JsonValueKind.String)
            {
                continue;
            }

            var text = item.GetString();
            if (string.IsNullOrWhiteSpace(text))
            {
                continue;
            }

            var splitIndex = text.IndexOf('.', StringComparison.Ordinal);
            var roleName = splitIndex > 0 ? text[..splitIndex] : text;
            roleName = roleName.Trim();
            if (string.IsNullOrWhiteSpace(roleName))
            {
                continue;
            }

            result.TryGetValue(roleName, out var count);
            result[roleName] = count + 1;
        }

        return result;
    }

    private static Dictionary<string, double> ReadDoubleMap(JsonElement mapElement)
    {
        var result = new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase);
        if (mapElement.ValueKind != JsonValueKind.Object)
        {
            return result;
        }

        foreach (var property in mapElement.EnumerateObject())
        {
            if (property.Value.ValueKind == JsonValueKind.Number && property.Value.TryGetDouble(out var value))
            {
                result[property.Name] = value;
            }
        }

        return result;
    }

    private static Dictionary<string, string> ReadStringMap(JsonElement mapElement)
    {
        var result = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (mapElement.ValueKind != JsonValueKind.Object)
        {
            return result;
        }

        foreach (var property in mapElement.EnumerateObject())
        {
            if (property.Value.ValueKind == JsonValueKind.String)
            {
                var value = property.Value.GetString();
                if (!string.IsNullOrWhiteSpace(value))
                {
                    result[property.Name] = value.Trim();
                }
            }
        }

        return result;
    }


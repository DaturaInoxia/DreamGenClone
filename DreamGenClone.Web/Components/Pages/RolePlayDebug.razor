    private sealed class AdaptiveCommitGateDetails
    {
        public string? Phase { get; set; }
        public int InteractionCount { get; set; }
        public int CandidateCount { get; set; }
        public string? SelectedScenarioId { get; set; }
        public bool Committed { get; set; }
        public string? Reason { get; set; }
        public bool Configured { get; set; }
        public bool? Passed { get; set; }
        public string? ProfileId { get; set; }
        public string? ProfileName { get; set; }
        public string? ProfileSource { get; set; }
        public List<AdaptiveCommitGateRuleRow> Rules { get; } = [];

        public string GateResultLabel => Passed switch
        {
            true => "Passed",
            false => "Blocked",
            null => Configured ? "Unknown" : "Not Configured"
        };

        public string ProfileLabel
        {
            get
            {
                if (!string.IsNullOrWhiteSpace(ProfileName) && !string.IsNullOrWhiteSpace(ProfileId))
                {
                    return $"{ProfileName} ({ProfileId})";
                }

                if (!string.IsNullOrWhiteSpace(ProfileName))
                {
                    return ProfileName;
                }

                if (!string.IsNullOrWhiteSpace(ProfileId))
                {
                    return ProfileId;
                }

                return "-";
            }
        }

        public static AdaptiveCommitGateDetails Empty { get; } = new();
    }


    private async Task SummarizeStory()
    {
        if (_isLlmBusy) return;
        _isLlmBusy = true;
        _isSummarizing = true;
        _summaryError = null;
        StateHasChanged();

        try
        {
            var result = await AnalysisFacade.SummarizeAsync(Id);
            if (result.Success)
            {
                _summary = await AnalysisFacade.GetSummaryAsync(Id);
            }
            else
            {
                _summaryError = result.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            _summaryError = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _isSummarizing = false;
            _isLlmBusy = false;
        }
    }

    private async Task AnalyzeStory()
    {
        if (_isLlmBusy) return;
        _isLlmBusy = true;
        _isAnalyzing = true;
        _analysisError = null;
        _analysisDimensionErrors.Clear();
        StateHasChanged();

        try
        {
            var result = await AnalysisFacade.AnalyzeAsync(Id);
            if (result.Success)
            {
                _analysis = await AnalysisFacade.GetAnalysisAsync(Id);
                ParseAnalysisViewModels();
            }
            else
            {
                _analysisError = "Analysis failed for all dimensions.";
            }
            _analysisDimensionErrors = result.DimensionErrors;
        }
        catch (Exception ex)
        {
            _analysisError = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _isAnalyzing = false;
            _isLlmBusy = false;
        }
    }

    private void ParseAnalysisViewModels()
    {
        _parsedCharacters = new();
        _parsedThemes = new();
        _parsedPlotStructure = null;
        _parsedWritingStyle = null;

        if (_analysis is null) return;

        try
        {
            if (!string.IsNullOrEmpty(_analysis.CharactersJson))
            {
                using var doc = JsonDocument.Parse(_analysis.CharactersJson);
                if (doc.RootElement.TryGetProperty("characters", out var chars))
                {
                    foreach (var c in chars.EnumerateArray())
                    {
                        _parsedCharacters.Add(new CharacterEntry(
                            c.TryGetProperty("name", out var n) ? n.GetString() ?? "—" : "—",
                            c.TryGetProperty("role", out var r) ? r.GetString() ?? "—" : "—",
                            c.TryGetProperty("description", out var d) ? d.GetString() ?? "—" : "—"));
                    }
                }
            }
        }
        catch { /* graceful fallback — just leave empty */ }

        try
        {
            if (!string.IsNullOrEmpty(_analysis.ThemesJson))
            {
                using var doc = JsonDocument.Parse(_analysis.ThemesJson);
                if (doc.RootElement.TryGetProperty("themes", out var themes))
                {
                    foreach (var t in themes.EnumerateArray())
                    {
                        _parsedThemes.Add(new ThemeEntry(
                            t.TryGetProperty("name", out var n) ? n.GetString() ?? "—" : "—",
                            t.TryGetProperty("description", out var d) ? d.GetString() ?? "—" : "—",
                            t.TryGetProperty("prevalence", out var p) ? p.GetString() ?? "minor" : "minor"));
                    }
                }
            }
        }
        catch { }

        try
        {
            if (!string.IsNullOrEmpty(_analysis.PlotStructureJson))
            {
                using var doc = JsonDocument.Parse(_analysis.PlotStructureJson);
                var root = doc.RootElement;
                _parsedPlotStructure = new PlotStructureEntry(
                    root.TryGetProperty("exposition", out var ex) ? ex.GetString() ?? "—" : "—",
                    root.TryGetProperty("risingAction", out var ra) ? ra.GetString() ?? "—" : "—",
                    root.TryGetProperty("climax", out var cl) ? cl.GetString() ?? "—" : "—",
                    root.TryGetProperty("fallingAction", out var fa) ? fa.GetString() ?? "—" : "—",
                    root.TryGetProperty("resolution", out var re) ? re.GetString() ?? "—" : "—");
            }
        }
        catch { }

        try
        {
            if (!string.IsNullOrEmpty(_analysis.WritingStyleJson))
            {
                using var doc = JsonDocument.Parse(_analysis.WritingStyleJson);
                var root = doc.RootElement;
                var devices = new List<string>();
                if (root.TryGetProperty("notableDevices", out var nd) && nd.ValueKind == JsonValueKind.Array)
                {
                    foreach (var d in nd.EnumerateArray())
                        devices.Add(d.GetString() ?? "—");
                }
                _parsedWritingStyle = new WritingStyleEntry(
                    root.TryGetProperty("tone", out var t) ? t.GetString() ?? "—" : "—",
                    root.TryGetProperty("perspective", out var p) ? p.GetString() ?? "—" : "—",
                    root.TryGetProperty("pacing", out var pa) ? pa.GetString() ?? "—" : "—",
                    root.TryGetProperty("languageComplexity", out var lc) ? lc.GetString() ?? "—" : "—",
                    devices);
            }
        }
        catch { }
    }

    private sealed record CharacterEntry(string Name, string Role, string Description);
    private sealed record ThemeEntry(string Name, string Description, string Prevalence);
    private sealed record PlotStructureEntry(string Exposition, string RisingAction, string Climax, string FallingAction, string Resolution);
    private sealed record WritingStyleEntry(string Tone, string Perspective, string Pacing, string LanguageComplexity, List<string> NotableDevices);

    private async Task AddTheme()
    {
        if (_selectedProfileId is null) return;
        _themeValidationError = null;
        var name = _newThemeName?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(name))
        {
            _themeValidationError = "Name is required.";
            return;
        }

        _isThemeBusy = true;
        try
        {
            await AnalysisFacade.CreateThemeAsync(_selectedProfileId, name, _newThemeDescription?.Trim() ?? string.Empty, _newThemeTier);
            _themes = await AnalysisFacade.ListThemesByProfileAsync(_selectedProfileId);
            _newThemeName = string.Empty;
            _newThemeDescription = string.Empty;
            _newThemeTier = ThemeTier.NiceToHave;
        }
        catch (Exception ex)
        {
            _themeError = ex.Message;
        }
        finally
        {
            _isThemeBusy = false;
        }
    }

    private void StartEditTheme(ThemePreference t)
    {
        _editingThemeId = t.Id;
        _editThemeName = t.Name;
        _editThemeDescription = t.Description;
        _editThemeTier = t.Tier;
    }

    private void CancelEditTheme()
    {
        _editingThemeId = null;
    }

    private async Task SaveEditTheme()
    {
        if (_editingThemeId is null || _selectedProfileId is null) return;
        _themeValidationError = null;
        var name = _editThemeName?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(name))
        {
            _themeValidationError = "Name is required.";
            return;
        }

        _isThemeBusy = true;
        try
        {
            await AnalysisFacade.UpdateThemeAsync(_editingThemeId, name, _editThemeDescription?.Trim() ?? string.Empty, _editThemeTier);
            _themes = await AnalysisFacade.ListThemesByProfileAsync(_selectedProfileId!);
            _editingThemeId = null;
        }
        catch (Exception ex)
        {
            _themeError = ex.Message;
        }
        finally
        {
            _isThemeBusy = false;
        }
    }

    private async Task DeleteTheme(string id)
    {
        if (_selectedProfileId is null) return;
        _isThemeBusy = true;
        try
        {
            await AnalysisFacade.DeleteThemeAsync(id);
            _themes = await AnalysisFacade.ListThemesByProfileAsync(_selectedProfileId);
        }
        catch (Exception ex)
        {

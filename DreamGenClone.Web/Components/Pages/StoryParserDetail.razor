    private async Task PreviewScenario()
    {
        if (_isLlmBusy) return;
        _isLlmBusy = true;
        _isPreviewing = true;
        _previewError = null;
        _adaptError = null;
        _scenarioPreview = null;
        _showCharacterMapping = false;
        _adaptSavedScenarioId = null;
        _showAdaptPanel = true;
        StateHasChanged();

        try
        {
            _scenarioPreview = await AdaptationService.PreviewScenarioAsync(Id);
            if (!_scenarioPreview.Success)
            {
                _previewError = _scenarioPreview.ErrorMessage;
            }
        }
        catch (Exception ex)
        {
            _previewError = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _isPreviewing = false;
            _isLlmBusy = false;
        }
    }

    private async Task ContinueToCharacterMapping()
    {
        _showCharacterMapping = true;
        await LoadCharacterTemplatesAsync();
    }

    private void CancelAdaptation()
    {
        _showAdaptPanel = false;
        _scenarioPreview = null;
        _showCharacterMapping = false;
        _previewError = null;
        _adaptError = null;
        _adaptSavedScenarioId = null;
    }

    private async Task LoadCharacterTemplatesAsync()
    {
        _characterTemplates = (await TemplateService.GetAllAsync(TemplateType.Character)).ToList();
        if (_adaptCharacterSelections.Count == 0 && _characterTemplates.Count >= 2)
        {
            _adaptCharacterSelections =
            [
                new() { TemplateId = _characterTemplates[0].Id, TargetRole = "protagonist" },
                new() { TemplateId = _characterTemplates[1].Id, TargetRole = "love interest" }
            ];
        }
        else if (_adaptCharacterSelections.Count == 0 && _characterTemplates.Count == 1)
        {
            _adaptCharacterSelections = [new() { TemplateId = _characterTemplates[0].Id }];
        }
        else if (_adaptCharacterSelections.Count == 0)
        {
            _adaptCharacterSelections = [new()];
        }
    }

    private async Task CreateScenarioFromPreview()
    {
        if (_scenarioPreview is null || _isAdapting) return;
        _isAdapting = true;
        _adaptError = null;
        _adaptSavedScenarioId = null;
        StateHasChanged();

        try
        {
            var validSubs = _adaptCharacterSelections
                .Where(s => s.TemplateId != Guid.Empty)
                .ToList();

            if (validSubs.Count == 0)
            {
                _adaptError = "Please select at least one character.";
                return;
            }

            var result = await AdaptationService.BuildScenarioFromPreviewAsync(
                _scenarioPreview, validSubs, Id);

            if (!result.Success)
            {
                _adaptError = result.ErrorMessage;
                return;
            }

            // Auto-save the scenario
            result.GeneratedScenario!.SourceParsedStoryId = Id;
            var saved = await ScenarioService.SaveScenarioAsync(result.GeneratedScenario!);
            _adaptSavedScenarioId = saved.Id;
            _linkedScenarioId = saved.Id;
            _linkedScenarioName = saved.Name;
        }
        catch (Exception ex)
        {
            _adaptError = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _isAdapting = false;
        }
    }

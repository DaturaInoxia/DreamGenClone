        "StronglyPrefer" => "bg-primary",
        "NiceToHave" => "bg-info text-dark",
        "Neutral" => "bg-secondary",
        "Dislike" => "bg-warning text-dark",
        "HardDealBreaker" => "bg-danger",
        _ => "bg-secondary"
    };

    private static string GetScoreBadgeClass(double score) => score switch

    private async Task RankStory()
    {
        if (_isLlmBusy || _selectedProfileId is null) return;
        _isLlmBusy = true;
        _isRanking = true;
        _rankingError = null;
        _rankingErrors.Clear();
        StateHasChanged();

        try
        {
            var result = await AnalysisFacade.RankAsync(Id, _selectedProfileId);
            if (result.Success)
            {
                _ranking = await AnalysisFacade.GetRankingAsync(Id, _selectedProfileId);
                _themeDetections = ParseThemeDetections(_ranking?.ThemeDetectionsJson);
            }
            else
            {
                _rankingError = result.Errors.Count > 0
                    ? string.Join("; ", result.Errors.Select(e => $"{e.Key}: {e.Value}"))
                    : "Ranking failed.";
            }
        }
        catch (Exception ex)
        {
            _rankingError = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            _isRanking = false;
            _isLlmBusy = false;
        }
    }

    private sealed record DetectionEntry(string ThemeName, string Tier, bool Detected, string Intensity, string Evidence);

    private static List<DetectionEntry> ParseThemeDetections(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return new();
        try
        {
            using var doc = JsonDocument.Parse(json);
            var list = new List<DetectionEntry>();
            foreach (var elem in doc.RootElement.EnumerateArray())
            {
                list.Add(new DetectionEntry(
                    elem.TryGetProperty("themeName", out var n) ? n.GetString() ?? "—" : "—",
                    elem.TryGetProperty("tier", out var t) ? t.GetString() ?? "Neutral" : "Neutral",
                    elem.TryGetProperty("detected", out var d) && d.GetBoolean(),
                    elem.TryGetProperty("intensity", out var i) ? i.GetString() ?? "None" : "None",
                    elem.TryGetProperty("evidence", out var e) ? e.GetString() ?? "" : ""
                ));
            }
            return list;
        }
        catch
        {
            return new();
        }
    }

    private static string FormatTier(ThemeTier tier) => tier switch
    {
        ThemeTier.MustHave => "Must-Have",
        ThemeTier.StronglyPrefer => "Strongly Prefer",
        ThemeTier.NiceToHave => "Nice to Have",
        ThemeTier.Neutral => "Neutral",
        ThemeTier.Dislike => "Dislike",
        ThemeTier.HardDealBreaker => "Deal-Breaker",
        _ => tier.ToString()
    };

    private static string GetTierBadgeClass(ThemeTier tier) => tier switch
    {
        ThemeTier.MustHave => "bg-success",
        ThemeTier.StronglyPrefer => "bg-primary",
        ThemeTier.NiceToHave => "bg-info text-dark",
        ThemeTier.Neutral => "bg-secondary",
        ThemeTier.Dislike => "bg-warning text-dark",
        ThemeTier.HardDealBreaker => "bg-danger",
        _ => "bg-secondary"
    };

    private static string GetTierBadgeClassFromString(string tier) => tier switch
    {

@page "/storyparser/detail/{Id}"
@rendermode InteractiveServer
@implements IDisposable

@using DreamGenClone.Web.Application.StoryParser
@using DreamGenClone.Web.Application.StoryAnalysis
@using DreamGenClone.Web.Application.Scenarios
@using DreamGenClone.Domain.StoryAnalysis
@using DreamGenClone.Domain.StoryParser
@using DreamGenClone.Domain.Templates
@using DreamGenClone.Application.StoryAnalysis.Models
@using DreamGenClone.Application.Processing
@using DreamGenClone.Application.Templates
@using DreamGenClone.Infrastructure.StoryAnalysis
@using System.Text.Json
@using System.Linq

@inject StoryParserFacade ParserFacade
@inject StoryCollectionFacade CollectionFacade
@inject StoryAnalysisFacade AnalysisFacade
@inject IModelProcessingQueue ProcessingQueue
@inject IScenarioAdaptationService AdaptationService
@inject IScenarioService ScenarioService
@inject ITemplateService TemplateService
@inject NavigationManager Navigation

<PageTitle>StoryParser Detail</PageTitle>

<div class="container-fluid mt-4">
    <button class="btn btn-outline-secondary mb-3" @onclick="BackToList">Back</button>

    @if (_isLoading)
    {
        <div class="alert alert-info">Loading...</div>
    }
    else if (_detail is null)
    {
        <div class="alert alert-warning">Parsed story not found.</div>
    }
    else
    {
        <h2 class="mb-3">@_detail.Title</h2>

        @* ── Action Bar at Top ── *@
        <div class="card mb-3 border-primary">
            <div class="card-body d-flex flex-wrap align-items-center gap-2">
                <button class="btn btn-primary" @onclick="SummarizeStory" disabled="@_isLlmBusy">
                    @if (_isSummarizing)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        <span>Summarizing...</span>
                    }
                    else
                    {
                        <span>@(_summary is not null ? "Re-Summarize" : "Summarize")</span>
                    }
                </button>
                <button class="btn btn-primary" @onclick="AnalyzeStory" disabled="@_isLlmBusy">
                    @if (_isAnalyzing)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        <span>Analyzing...</span>
                    }
                    else
                    {
                        <span>@(_analysis is not null ? "Re-Analyze" : "Analyze")</span>
                    }
                </button>
                @if (_profiles.Count > 0)
                {
                    <div class="vr"></div>
                    <select class="form-select form-select-sm" style="width: auto; min-width: 180px;" @onchange="OnProfileChanged">
                        @foreach (var p in _profiles)
                        {
                            <option value="@p.Id" selected="@(p.Id == _selectedProfileId)">@p.Name @(p.IsDefault ? "★" : "")</option>
                        }
                    </select>
                    <button class="btn btn-primary" @onclick="RankStory" disabled="@(_isLlmBusy || _themes.Count == 0)">
                        @if (_isRanking)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>Ranking...</span>
                        }
                        else
                        {
                            <span>@(_ranking is not null ? "Re-Rank" : "Rank")</span>
                        }
                    </button>
                    <a href="/profiles" class="btn btn-outline-secondary btn-sm">Manage Profiles</a>
                }
                else
                {
                    <a href="/profiles" class="btn btn-outline-secondary btn-sm">Create Theme Profile</a>
                }

                @if (_summary is not null)
                {
                    <div class="vr"></div>
                    <button class="btn btn-success" @onclick="PreviewScenario" disabled="@_isLlmBusy">
                        @if (_isPreviewing)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>Generating Preview...</span>
                        }
                        else if (_isAdapting)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>Adapting...</span>
                        }
                        else
                        {
                            <span>Adapt as Scenario</span>
                        }
                    </button>
                }

                <div class="vr"></div>
                <div class="btn-group" style="position: relative;">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleManageDropdown">
                        Manage &#x25BE;
                    </button>
                    @if (_showManageDropdown)
                    {
                        <div class="dropdown-menu show" style="position: absolute; right: 0; top: 100%; z-index: 1050;">
                            <button class="dropdown-item" @onclick="ArchiveStoryAsync">&#x1F4E6; Archive</button>
                            <button class="dropdown-item text-warning" @onclick="PurgeStoryAsync">&#x1F5D1; Purge (keep stub)</button>
                            <hr class="dropdown-divider" />
                            <button class="dropdown-item text-danger" @onclick="DeleteStoryAsync">&#x2715; Delete permanently</button>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (_linkedScenarioId is not null)
        {
            <div class="alert alert-info d-flex align-items-center gap-2 mb-3">
                <span>Adapted as scenario: <strong>@(_linkedScenarioName ?? "Scenario")</strong></span>
                <a href="/scenarios/editor/@_linkedScenarioId" class="btn btn-sm btn-outline-primary">Open Scenario</a>
            </div>
        }

        @* ── Adapt as Scenario Panel ── *@
        @if (_showAdaptPanel)
        {
        <div class="card mb-3 border-success">
            <div class="card-header bg-success text-white">Adapt as Scenario</div>
            <div class="card-body">

                @if (!string.IsNullOrEmpty(_adaptError))
                {
                    <div class="alert alert-danger">@_adaptError</div>
                }
                @if (!string.IsNullOrEmpty(_previewError))
                {
                    <div class="alert alert-danger">@_previewError</div>
                }

                @* ── Preview Section ── *@
                @if (_scenarioPreview is not null && _scenarioPreview.Success && !_showCharacterMapping)
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">Title</label>
                        <input class="form-control" @bind="_scenarioPreview.PlotTitle" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Description</label>
                        <textarea class="form-control" rows="3" @bind="_scenarioPreview.PlotDescription"></textarea>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Conflicts</label>
                            @for (var i = 0; i < _scenarioPreview.Conflicts.Count; i++)
                            {
                                var idx = i;
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <input class="form-control form-control-sm" value="@_scenarioPreview.Conflicts[idx]"
                                           @onchange="(e) => _scenarioPreview.Conflicts[idx] = e.Value?.ToString() ?? string.Empty" />
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => _scenarioPreview.Conflicts.RemoveAt(idx)">✕</button>
                                </div>
                            }
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => _scenarioPreview.Conflicts.Add(string.Empty)">+ Add</button>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Goals</label>
                            @for (var i = 0; i < _scenarioPreview.Goals.Count; i++)
                            {
                                var idx = i;
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <input class="form-control form-control-sm" value="@_scenarioPreview.Goals[idx]"
                                           @onchange="(e) => _scenarioPreview.Goals[idx] = e.Value?.ToString() ?? string.Empty" />
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => _scenarioPreview.Goals.RemoveAt(idx)">✕</button>
                                </div>
                            }
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => _scenarioPreview.Goals.Add(string.Empty)">+ Add</button>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Setting</label>
                        <textarea class="form-control" rows="2" @bind="_scenarioPreview.SettingSummary"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Style</label>
                        <textarea class="form-control" rows="2" @bind="_scenarioPreview.StyleSummary"></textarea>
                    </div>
                    @if (_scenarioPreview.SuggestedRoles.Count > 0)
                    {
                        <p class="mb-2"><strong>Suggested Roles:</strong> @string.Join(", ", _scenarioPreview.SuggestedRoles)</p>
                    }
                    <div class="d-flex gap-2">
                        <button class="btn btn-success" @onclick="ContinueToCharacterMapping">
                            Continue to Character Mapping
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="PreviewScenario" disabled="@_isLlmBusy">
                            Regenerate Preview
                        </button>
                        <button class="btn btn-outline-danger" @onclick="CancelAdaptation">
                            Cancel
                        </button>
                    </div>
                }

                @* ── Character Mapping + Create Section (gated behind preview) ── *@
                @if (_showCharacterMapping)
                {
                    @if (_scenarioPreview is not null && _scenarioPreview.Success)
                    {
                        <div class="alert alert-light border mb-3">
                            <strong>@(_scenarioPreview.PlotTitle ?? "Preview")</strong> — @_scenarioPreview.PlotDescription
                            @if (_scenarioPreview.SuggestedRoles.Count > 0)
                            {
                                <br /><small class="text-muted">Suggested roles: @string.Join(", ", _scenarioPreview.SuggestedRoles)</small>
                            }
                        </div>
                    }

                    @if (_adaptSavedScenarioId is not null)
                    {
                        <div class="alert alert-success">
                            Scenario <strong>@(_scenarioPreview?.PlotTitle ?? "Scenario")</strong> created!
                            <a href="/scenarios/editor/@_adaptSavedScenarioId" class="alert-link">Open in Editor</a>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-2">Select characters to cast into the scenario roles.</p>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Characters</label>
                                @if (_characterTemplates.Count == 0)
                                {
                                    <p class="text-muted">No character templates found. <a href="/templates">Create character templates</a> first.</p>
                                }
                                else
                                {
                                    @for (var i = 0; i < _adaptCharacterSelections.Count; i++)
                                    {
                                        var idx = i;
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                            <select class="form-select form-select-sm" style="max-width: 200px;"
                                                    value="@_adaptCharacterSelections[idx].TemplateId"
                                                    @onchange="(e) => _adaptCharacterSelections[idx].TemplateId = Guid.TryParse(e.Value?.ToString(), out var g) ? g : Guid.Empty">
                                                <option value="@Guid.Empty">-- Select --</option>
                                                @foreach (var t in _characterTemplates)
                                                {
                                                    <option value="@t.Id">@t.Name</option>
                                                }
                                            </select>
                                            <input class="form-control form-control-sm" style="max-width: 150px;"
                                                   placeholder="Role (optional)"
                                                   @bind="_adaptCharacterSelections[idx].TargetRole" />
                                            @if (_adaptCharacterSelections.Count > 1)
                                            {
                                                <button class="btn btn-outline-danger btn-sm" @onclick="() => _adaptCharacterSelections.RemoveAt(idx)">✕</button>
                                            }
                                        </div>
                                    }
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => _adaptCharacterSelections.Add(new CharacterSubstitution())">
                                        + Add Character
                                    </button>
                                }
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Guidance (optional)</label>
                                <textarea class="form-control" rows="3" placeholder="e.g., Focus on the jealousy theme, set it on vacation..."
                                          @bind="_adaptGuidance"></textarea>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-success" @onclick="CreateScenarioFromPreview" disabled="@(_isAdapting || _characterTemplates.Count == 0)">
                                @if (_isAdapting)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    <span>Creating...</span>
                                }
                                else
                                {
                                    <span>Create Scenario</span>
                                }
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="() => { _showCharacterMapping = false; }">
                                Back to Preview
                            </button>
                        </div>
                    }
                }
            </div>
        </div>
        }

        @* ── Summary Section ── *@
        <div class="card mb-3">
            <div class="card-header cursor-pointer" @onclick="() => _showSummary = !_showSummary">
                @(_showSummary ? "▼" : "▶") Summary
            </div>
            @if (_showSummary)
            {
            <div class="card-body">
                @if (!string.IsNullOrEmpty(_summaryError))
                {
                    <div class="alert alert-danger">@_summaryError</div>
                }
                @if (_summary is not null)
                {
                    <p style="white-space: pre-wrap;">@_summary.SummaryText</p>
                    <small class="text-muted">Generated: @_summary.GeneratedUtc.ToLocalTime().ToString("g")</small>
                }
                else if (!_isSummarizing)
                {
                    <p class="text-muted">No summary yet. Click Summarize to generate one.</p>
                }
            </div>
            }
        </div>

        @* ── Analysis Section ── *@
        <div class="card mb-3">
            <div class="card-header cursor-pointer" @onclick="() => _showAnalysis = !_showAnalysis">
                @(_showAnalysis ? "▼" : "▶") Analysis
            </div>
            @if (_showAnalysis)
            {
            <div class="card-body">
                @if (!string.IsNullOrEmpty(_analysisError))
                {
                    <div class="alert alert-danger">@_analysisError</div>
                }
                @if (_analysisDimensionErrors.Count > 0)
                {
                    @foreach (var err in _analysisDimensionErrors)
                    {
                        <div class="alert alert-warning">@err.Key: @err.Value</div>
                    }
                }
                @if (_analysis is not null)
                {
                    @if (_parsedCharacters.Count > 0)
                    {
                        <div class="mb-3">
                            <h6 class="cursor-pointer" @onclick="() => _showCharacters = !_showCharacters">
                                @(_showCharacters ? "▼" : "▶") Characters
                            </h6>
                            @if (_showCharacters)
                            {
                                <table class="table table-sm table-striped">
                                    <thead><tr><th>Name</th><th>Role</th><th>Description</th></tr></thead>
                                    <tbody>
                                        @foreach (var ch in _parsedCharacters)
                                        {
                                            <tr><td>@ch.Name</td><td><span class="badge bg-secondary">@ch.Role</span></td><td>@ch.Description</td></tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    }
                    @if (_parsedThemes.Count > 0)
                    {
                        <div class="mb-3">
                            <h6 class="cursor-pointer" @onclick="() => _showThemes = !_showThemes">
                                @(_showThemes ? "▼" : "▶") Themes
                            </h6>
                            @if (_showThemes)
                            {
                                <table class="table table-sm table-striped">
                                    <thead><tr><th>Theme</th><th>Prevalence</th><th>Description</th></tr></thead>
                                    <tbody>
                                        @foreach (var th in _parsedThemes)
                                        {
                                            <tr>
                                                <td>@th.Name</td>
                                                <td><span class="badge @(th.Prevalence == "primary" ? "bg-primary" : th.Prevalence == "secondary" ? "bg-info" : "bg-light text-dark")">@th.Prevalence</span></td>
                                                <td>@th.Description</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    }
                    @if (_parsedPlotStructure is not null)
                    {
                        <div class="mb-3">
                            <h6 class="cursor-pointer" @onclick="() => _showPlotStructure = !_showPlotStructure">
                                @(_showPlotStructure ? "▼" : "▶") Plot Structure
                            </h6>
                            @if (_showPlotStructure)
                            {
                                <dl class="row mb-0">
                                    <dt class="col-sm-3">Exposition</dt>
                                    <dd class="col-sm-9">@_parsedPlotStructure.Exposition</dd>
                                    <dt class="col-sm-3">Rising Action</dt>
                                    <dd class="col-sm-9">@_parsedPlotStructure.RisingAction</dd>
                                    <dt class="col-sm-3">Climax</dt>
                                    <dd class="col-sm-9">@_parsedPlotStructure.Climax</dd>
                                    <dt class="col-sm-3">Falling Action</dt>
                                    <dd class="col-sm-9">@_parsedPlotStructure.FallingAction</dd>
                                    <dt class="col-sm-3">Resolution</dt>
                                    <dd class="col-sm-9">@_parsedPlotStructure.Resolution</dd>
                                </dl>
                            }
                        </div>
                    }
                    @if (_parsedWritingStyle is not null)
                    {
                        <div class="mb-3">
                            <h6 class="cursor-pointer" @onclick="() => _showWritingStyle = !_showWritingStyle">
                                @(_showWritingStyle ? "▼" : "▶") Writing Style
                            </h6>
                            @if (_showWritingStyle)
                            {
                                <dl class="row mb-0">
                                    <dt class="col-sm-3">Tone</dt>
                                    <dd class="col-sm-9">@_parsedWritingStyle.Tone</dd>
                                    <dt class="col-sm-3">Perspective</dt>
                                    <dd class="col-sm-9">@_parsedWritingStyle.Perspective</dd>
                                    <dt class="col-sm-3">Pacing</dt>
                                    <dd class="col-sm-9">@_parsedWritingStyle.Pacing</dd>
                                    <dt class="col-sm-3">Language Complexity</dt>
                                    <dd class="col-sm-9">@_parsedWritingStyle.LanguageComplexity</dd>
                                    <dt class="col-sm-3">Notable Devices</dt>
                                    <dd class="col-sm-9">
                                        @if (_parsedWritingStyle.NotableDevices.Count > 0)
                                        {
                                            @foreach (var d in _parsedWritingStyle.NotableDevices)
                                            {
                                                <span class="badge bg-light text-dark me-1">@d</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">None identified</span>
                                        }
                                    </dd>
                                </dl>
                            }
                        </div>
                    }
                    <small class="text-muted">Generated: @_analysis.GeneratedUtc.ToLocalTime().ToString("g")</small>
                }
                else if (!_isAnalyzing)
                {
                    <p class="text-muted">No analysis yet. Click Analyze to generate one.</p>
                }
            </div>
            }
        </div>

        @* ── Ranking Section (Profile-aware) ── *@
        <div class="card mb-3">
            <div class="card-header cursor-pointer" @onclick="() => _showRanking = !_showRanking">
                @(_showRanking ? "▼" : "▶") Ranking
                @if (_ranking is not null && !_showRanking)
                {
                    @if (_ranking.IsDisqualified)
                    {
                        <span class="badge bg-danger ms-2">DISQUALIFIED</span>
                    }
                    else
                    {
                        <span class="badge @GetScoreBadgeClass(_ranking.Score) ms-2">@_ranking.Score.ToString("F1")</span>
                    }
                }
            </div>
            @if (_showRanking)
            {
            <div class="card-body">
                @if (_profiles.Count == 0)
                {
                    <p class="text-muted">No theme profiles yet. <a href="/profiles">Create a profile</a> first.</p>
                }
                else
                {

                    @if (!string.IsNullOrEmpty(_rankingError))
                    {
                        <div class="alert alert-danger">@_rankingError</div>
                    }
                    @if (_rankingErrors.Count > 0)
                    {
                        @foreach (var err in _rankingErrors)
                        {
                            <div class="alert alert-warning">@err.Key: @err.Value</div>
                        }
                    }

                    @* ── Theme Preferences for Selected Profile (inline edit) ── *@
                    <div class="mb-3">
                        <h6 class="cursor-pointer" @onclick="() => _showThemePrefs = !_showThemePrefs">
                            @(_showThemePrefs ? "▼" : "▶") Themes (@_themes.Count)
                        </h6>
                        @if (_showThemePrefs)
                        {
                            @if (!string.IsNullOrEmpty(_themeError))
                            {
                                <div class="alert alert-danger">@_themeError</div>
                            }
                            @if (_themes.Count > 0)
                            {
                                <table class="table table-sm">
                                    <thead><tr><th>Name</th><th>Description</th><th style="width: 140px;">Tier</th><th style="width: 140px;">Actions</th></tr></thead>
                                    <tbody>
                                        @foreach (var t in _themes)
                                        {
                                            @if (_editingThemeId == t.Id)
                                            {
                                                <tr>
                                                    <td><input type="text" class="form-control form-control-sm" @bind="_editThemeName" /></td>
                                                    <td><input type="text" class="form-control form-control-sm" @bind="_editThemeDescription" /></td>
                                                    <td>
                                                        <select class="form-select form-select-sm" @bind="_editThemeTier">
                                                            @foreach (var tier in Enum.GetValues<ThemeTier>())
                                                            {
                                                                <option value="@tier">@FormatTier(tier)</option>
                                                            }
                                                        </select>
                                                    </td>
                                                    <td>
                                                        <button class="btn btn-sm btn-success me-1" @onclick="SaveEditTheme" disabled="@_isThemeBusy">Save</button>
                                                        <button class="btn btn-sm btn-secondary" @onclick="CancelEditTheme">Cancel</button>
                                                    </td>
                                                </tr>
                                            }
                                            else
                                            {
                                                <tr>
                                                    <td>@t.Name</td>
                                                    <td class="text-muted small">@t.Description</td>
                                                    <td><span class="badge @GetTierBadgeClass(t.Tier)">@FormatTier(t.Tier)</span></td>
                                                    <td>
                                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartEditTheme(t)" disabled="@_isThemeBusy">Edit</button>
                                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTheme(t.Id)" disabled="@_isThemeBusy">Delete</button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <p class="text-muted">No themes in this profile.</p>
                            }
                            <div class="border rounded p-2 mt-2">
                                <div class="row g-2 align-items-end">
                                    <div class="col">
                                        <input type="text" class="form-control form-control-sm" @bind="_newThemeName" placeholder="Theme name..." />
                                    </div>
                                    <div class="col">
                                        <input type="text" class="form-control form-control-sm" @bind="_newThemeDescription" placeholder="LLM guidance..." />
                                    </div>
                                    <div class="col-auto">
                                        <select class="form-select form-select-sm" @bind="_newThemeTier" style="width: 140px;">
                                            @foreach (var tier in Enum.GetValues<ThemeTier>())
                                            {
                                                <option value="@tier">@FormatTier(tier)</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-auto">
                                        <button class="btn btn-sm btn-primary" @onclick="AddTheme" disabled="@_isThemeBusy">Add</button>
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(_themeValidationError))
                                {
                                    <div class="text-danger mt-1 small">@_themeValidationError</div>
                                }
                            </div>
                        }
                    </div>

                    @* ── Ranking Results ── *@
                    @if (_ranking is not null)
                    {
                        <div class="mb-3">
                            @if (_ranking.IsDisqualified)
                            {
                                <h5>Score: <span class="badge bg-danger fs-5">DISQUALIFIED</span>
                                    @if (IsAllVerified) { <span class="badge bg-success ms-1">Verified</span> }
                                </h5>
                            }
                            else
                            {
                                <h5>Score: <span class="badge @GetScoreBadgeClass(_ranking.Score) fs-5">@_ranking.Score.ToString("F1")</span> / 100
                                    @if (IsAllVerified) { <span class="badge bg-success ms-1">Verified</span> }
                                </h5>
                            }
                        </div>
                        @if (_themeDetections.Count > 0)
                        {
                            <div class="mb-2">
                                @foreach (var d in _themeDetections)
                                {
                                    @if (d.Detected)
                                    {
                                        <span class="badge @GetDetectionBadgeClass(d.Tier) me-1 mb-1" title="@d.Evidence">
                                            @d.ThemeName <small>(@d.Intensity)</small>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border me-1 mb-1">@d.ThemeName — not detected</span>
                                    }
                                }
                            </div>
                            <h6 class="cursor-pointer" @onclick="() => _showThemeDetails = !_showThemeDetails">
                                @(_showThemeDetails ? "▼" : "▶") Theme Details
                            </h6>
                            @if (_showThemeDetails)
                            {
                            <table class="table table-sm">
                                <thead><tr><th>Theme</th><th>Tier</th><th>Detected</th><th>Intensity</th><th>Confidence</th><th>Evidence</th><th style="width: 150px;">Status</th></tr></thead>
                                <tbody>
                                    @foreach (var d in _themeDetections)
                                    {
                                        var verStatus = GetVerificationStatus(d.ThemeId);
                                        <tr class="@(d.Tier == "HardDealBreaker" && d.Detected ? "table-danger" : "") @(verStatus == ThemeVerificationStatus.Dismissed ? "text-decoration-line-through opacity-50" : "")">
                                            <td>@d.ThemeName</td>
                                            <td><span class="badge @GetTierBadgeClassFromString(d.Tier)">@d.Tier</span></td>
                                            <td>@(d.Detected ? "Yes" : "No")</td>
                                            <td>@d.Intensity</td>
                                            <td>@(d.Confidence.ToString("P0"))</td>
                                            <td class="small">@d.Evidence</td>
                                            <td>
                                                <select class="form-select form-select-sm" value="@verStatus" disabled="@_isSavingVerification"
                                                        @onchange="async (e) => { if (Enum.TryParse<ThemeVerificationStatus>(e.Value?.ToString(), true, out var s)) await SetThemeVerificationAsync(d.ThemeId, s); }">
                                                    @foreach (var vs in Enum.GetValues<ThemeVerificationStatus>())
                                                    {
                                                        <option value="@vs">@vs</option>
                                                    }
                                                </select>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            }
                        }
                        <small class="text-muted">Generated: @_ranking.GeneratedUtc.ToLocalTime().ToString("g")</small>
                    }
                    else if (!_isRanking && _themes.Count > 0)
                    {
                        <p class="text-muted">No ranking yet for this profile. Click Rank to score this story.</p>
                    }
                }
            </div>
            }
        </div>

        @* ── My Rating Section ── *@
        <div class="card mb-3">
            <div class="card-header cursor-pointer" @onclick="() => _showRating = !_showRating">
                @(_showRating ? "▼" : "▶") My Rating
                @if (_userRating is not null && _userRating.Stars.HasValue && !_showRating)
                {
                    <span class="ms-2">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span style="color: @(i <= _userRating.Stars.Value ? "#ffc107" : "#dee2e6"); font-size: 0.9rem;">★</span>
                        }
                    </span>
                }
            </div>
            @if (_showRating)
            {
                <div class="card-body">
                    <div class="mb-2">
                        @for (int s = 1; s <= 5; s++)
                        {
                            var star = s;
                            <span style="cursor: pointer; font-size: 1.5rem; color: @(_ratingStars.HasValue && star <= _ratingStars.Value ? "#ffc107" : "#dee2e6");"
                                  @onclick="() => _ratingStars = _ratingStars == star ? null : star"
                                  title="@star star(s)">★</span>
                        }
                        <span class="ms-2 text-muted small">@(_ratingStars.HasValue ? $"{_ratingStars.Value} / 5" : "Not rated")</span>
                    </div>
                    <div class="mb-2">
                        <textarea class="form-control form-control-sm" rows="2" placeholder="Optional comment..."
                                  @bind="_ratingComment"></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-primary" @onclick="SaveRating" disabled="@_isRatingSaving">
                            @(_userRating is not null ? "Update Rating" : "Save Rating")
                        </button>
                        @if (_userRating is not null)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="DeleteRating" disabled="@_isRatingSaving">Remove</button>
                        }
                    </div>
                    @if (_userRating is not null)
                    {
                        <small class="text-muted d-block mt-1">Rated: @_userRating.UpdatedUtc.ToLocalTime().ToString("g")</small>
                    }
                </div>
            }
        </div>

        @* ── Parsed Story Detail ── *@
        <div class="card mb-3">
            <div class="card-header">Parsed Story Detail</div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(_detail.Title))
                {
                    <div><strong>Title:</strong> @_detail.Title</div>
                }
                @if (!string.IsNullOrWhiteSpace(_detail.Author))
                {
                    <div><strong>Author:</strong> @_detail.Author</div>
                }
                <div><strong>Source URL:</strong> @_detail.SourceUrl</div>
                <div><strong>Parsed Date:</strong> @_detail.ParsedUtc.ToLocalTime().ToString("g")</div>
                <div><strong>Page Count:</strong> @_detail.PageCount</div>
                <div><strong>Status:</strong> @_detail.ParseStatus</div>
            </div>
        </div>

        @* ── Collections ── *@
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Collections</span>
                <button class="btn btn-sm btn-outline-primary" @onclick="ToggleAddToCollectionPicker">@(_showCollectionPicker ? "Cancel" : "+ Add to Collection")</button>
            </div>
            <div class="card-body">
                @if (_showCollectionPicker)
                {
                    <div class="mb-3 d-flex gap-2 align-items-center flex-wrap">
                        @foreach (var col in _availableCollections)
                        {
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => AddToCollectionAsync(col.Id)">@col.Name</button>
                        }
                        @if (_availableCollections.Count == 0)
                        {
                            <span class="text-muted small">No collections available.</span>
                        }
                    </div>
                }
                @if (_storyCollections.Count == 0 && !_showCollectionPicker)
                {
                    <p class="text-muted mb-0">This story is not part of any collection.</p>
                }
                else
                {
                    @foreach (var col in _storyCollections)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span>
                                <span class="badge bg-info me-1">Collection</span>
                                <strong>@col.Name</strong>
                                @if (!string.IsNullOrWhiteSpace(col.Description))
                                {
                                    <small class="text-muted ms-1">— @col.Description</small>
                                }
                            </span>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveFromCollectionAsync(col.Id)">Remove</button>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Combined Text</span>
                @if (!_isEditingCombinedText)
                {
                    <button class="btn btn-sm btn-outline-primary" @onclick="StartEditCombinedText">Edit</button>
                }
            </div>
            @if (_isEditingCombinedText)
            {
                <div class="card-body">
                    <textarea class="form-control" rows="20" style="font-family: monospace; white-space: pre-wrap;" @bind="_editCombinedText" @bind:event="oninput"></textarea>
                    <div class="mt-2 d-flex gap-2">
                        <button class="btn btn-sm btn-primary" @onclick="SaveCombinedText" disabled="@_isSavingCombinedText">Save</button>
                        <button class="btn btn-sm btn-secondary" @onclick="CancelEditCombinedText">Cancel</button>
                    </div>
                </div>
            }
            else
            {
                <div class="card-body" style="white-space: pre-wrap;">@_detail.CombinedText</div>
            }
        </div>

        <div class="card">
            <div class="card-header">Diagnostics</div>
            <div class="card-body">
                <div><strong>Warnings:</strong> @_detail.Diagnostics.Warnings.Count</div>
                <div><strong>Errors:</strong> @_detail.Diagnostics.Errors.Count</div>
                @if (_detail.Diagnostics.Warnings.Count > 0)
                {
                    <ul>
                        @foreach (var item in _detail.Diagnostics.Warnings)
                        {
                            <li>@item.Code - @item.Message</li>
                        }
                    </ul>
                }
                @if (_detail.Diagnostics.Errors.Count > 0)
                {
                    <ul>
                        @foreach (var item in _detail.Diagnostics.Errors)
                        {
                            <li>@item.Code - @item.Message</li>
                        }
                    </ul>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private DreamGenClone.Application.StoryParser.Models.ParsedStoryDetail? _detail;
    private bool _isLoading = true;
    private bool _isLlmBusy;

    // Summary state
    private StorySummary? _summary;
    private bool _isSummarizing;
    private string? _summaryError;
    private bool _showSummary = true;

    // Analysis state
    private StoryAnalysisResult? _analysis;
    private bool _isAnalyzing;
    private string? _analysisError;
    private Dictionary<AnalysisDimension, string> _analysisDimensionErrors = new();
    private bool _showAnalysis;
    private bool _showCharacters = true;
    private bool _showThemes = true;
    private bool _showPlotStructure = true;
    private bool _showWritingStyle = true;

    // Parsed analysis view models
    private List<CharacterEntry> _parsedCharacters = new();
    private List<ThemeEntry> _parsedThemes = new();
    private PlotStructureEntry? _parsedPlotStructure;
    private WritingStyleEntry? _parsedWritingStyle;

    // Ranking profiles state
    private List<ThemeProfile> _profiles = new();
    private string? _selectedProfileId;
    private bool _showRanking;
    private bool _showThemePrefs;

    // Theme preferences state
    private List<ThemePreference> _themes = new();
    private bool _isThemeBusy;
    private string? _themeError;
    private string? _themeValidationError;
    private string _newThemeName = string.Empty;
    private string _newThemeDescription = string.Empty;
    private ThemeTier _newThemeTier = ThemeTier.NiceToHave;
    private string? _editingThemeId;
    private string _editThemeName = string.Empty;
    private string _editThemeDescription = string.Empty;
    private ThemeTier _editThemeTier = ThemeTier.NiceToHave;

    // Ranking state
    private StoryRankingResult? _ranking;
    private List<DetectionEntry> _themeDetections = new();
    private bool _isRanking;
    private bool _showThemeDetails = true;
    private Dictionary<string, ThemeVerificationStatus> _themeVerificationStatuses = new();
    private bool _isSavingVerification;
    private string? _rankingError;
    private Dictionary<string, string> _rankingErrors = new();
    private bool _showManageDropdown;

    // Collection state
    private List<StoryCollection> _storyCollections = new();
    private List<StoryCollection> _availableCollections = new();
    private bool _showCollectionPicker;

    // User rating state
    private UserStoryRating? _userRating;
    private int? _ratingStars;
    private string _ratingComment = string.Empty;
    private bool _showRating = true;
    private bool _isRatingSaving;

    // Combined text edit state
    private bool _isEditingCombinedText;
    private bool _isSavingCombinedText;
    private string _editCombinedText = string.Empty;

    // Scenario adaptation state
    private bool _showAdaptPanel;
    private bool _isPreviewing;
    private string? _previewError;
    private ScenarioPreviewResult? _scenarioPreview;
    private bool _showCharacterMapping;
    private bool _isAdapting;
    private string? _adaptError;
    private string? _adaptSavedScenarioId;
    private string? _linkedScenarioId;
    private string? _linkedScenarioName;
    private string _adaptGuidance = string.Empty;
    private List<CharacterSubstitution> _adaptCharacterSelections = new();
    private List<TemplateDefinition> _characterTemplates = new();

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        ProcessingQueue.OnStatusChanged += OnProcessingStatusChanged;
        _detail = await ParserFacade.GetByIdAsync(Id);

        if (_detail is not null)
        {
            _summary = await AnalysisFacade.GetSummaryAsync(Id);
            _analysis = await AnalysisFacade.GetAnalysisAsync(Id);
            ParseAnalysisViewModels();
            _profiles = await AnalysisFacade.ListProfilesAsync();
            await LoadCharacterTemplatesAsync();
            if (_profiles.Count > 0)
            {
                _selectedProfileId ??= _profiles[0].Id;
                await LoadProfileData();
            }
            await LoadCollectionsAsync();
            await LoadUserRatingAsync();

            // Check if a scenario was already adapted from this story
            var allScenarios = await ScenarioService.GetAllScenariosAsync();
            var linked = allScenarios.FirstOrDefault(s => s.SourceParsedStoryId == Id);
            if (linked is not null)
            {
                _linkedScenarioId = linked.Id;
                _linkedScenarioName = linked.Name;
            }
        }

        _isLoading = false;
    }

    private async Task LoadProfileData()
    {
        if (_selectedProfileId is null) return;
        _themes = await AnalysisFacade.ListThemesByProfileAsync(_selectedProfileId);
        _ranking = await AnalysisFacade.GetRankingAsync(Id, _selectedProfileId);
        _themeDetections = ParseThemeDetections(_ranking?.ThemeDetectionsJson);
        _themeVerificationStatuses = ParseVerificationStatuses(_ranking?.ThemeVerificationStatusJson);
        _editingThemeId = null;
        _rankingError = null;
        _rankingErrors.Clear();
    }

    private async Task OnProfileChanged(ChangeEventArgs e)
    {
        _selectedProfileId = e.Value?.ToString();
        await LoadProfileData();
    }

    private async void OnProcessingStatusChanged(ModelProcessingTask task)
    {
        if (task.ParsedStoryId != Id) return;

        if (task.Status is ModelProcessingStatus.Completed or ModelProcessingStatus.Failed)
        {
            await InvokeAsync(async () =>
            {
                // Refresh results for the completed task type
                if (task.TaskType == ModelProcessingTaskType.Summarize)
                {
                    _isSummarizing = false;
                    if (task.Status == ModelProcessingStatus.Completed)
                        _summary = await AnalysisFacade.GetSummaryAsync(Id);
                    else
                        _summaryError = task.ErrorMessage;
                }
                else if (task.TaskType == ModelProcessingTaskType.Analyze)
                {
                    _isAnalyzing = false;
                    if (task.Status == ModelProcessingStatus.Completed)
                    {
                        _analysis = await AnalysisFacade.GetAnalysisAsync(Id);
                        ParseAnalysisViewModels();
                    }
                    else
                        _analysisError = task.ErrorMessage;
                }
                else if (task.TaskType == ModelProcessingTaskType.Rank)
                {
                    _isRanking = false;
                    if (task.Status == ModelProcessingStatus.Completed)
                    {
                        _ranking = await AnalysisFacade.GetRankingAsync(Id, _selectedProfileId!);
                        _themeDetections = ParseThemeDetections(_ranking?.ThemeDetectionsJson);
                        _themeVerificationStatuses = ParseVerificationStatuses(_ranking?.ThemeVerificationStatusJson);
                    }
                    else
                        _rankingError = task.ErrorMessage;
                }

                // Update _isLlmBusy: true if any task for this story is still Queued or Processing
                _isLlmBusy = ProcessingQueue.GetTasksForStory(Id)
                    .Any(t => t.Status is ModelProcessingStatus.Queued or ModelProcessingStatus.Processing);

                StateHasChanged();
            });
        }
        else
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        ProcessingQueue.OnStatusChanged -= OnProcessingStatusChanged;
    }

    private async Task LoadCollectionsAsync()
    {
        _storyCollections = (await CollectionFacade.GetCollectionsForStoryAsync(Id)).ToList();
        var allCollections = await CollectionFacade.ListCollectionsAsync();
        var memberIds = _storyCollections.Select(c => c.Id).ToHashSet();
        _availableCollections = allCollections.Where(c => !memberIds.Contains(c.Id)).ToList();
    }

    private void ToggleAddToCollectionPicker()
    {
        _showCollectionPicker = !_showCollectionPicker;
    }

    private async Task AddToCollectionAsync(string collectionId)
    {
        await CollectionFacade.AddStoryToCollectionAsync(collectionId, Id);
        _showCollectionPicker = false;
        await LoadCollectionsAsync();
    }

    private async Task RemoveFromCollectionAsync(string collectionId)
    {
        await CollectionFacade.RemoveStoryFromCollectionAsync(collectionId, Id);
        await LoadCollectionsAsync();
    }

    private async Task LoadUserRatingAsync()
    {
        _userRating = await AnalysisFacade.GetUserRatingAsync(Id);
        if (_userRating is not null)
        {
            _ratingStars = _userRating.Stars;
            _ratingComment = _userRating.Comment;
        }
        else
        {
            _ratingStars = null;
            _ratingComment = string.Empty;
        }
    }

    private async Task SaveRating()
    {
        _isRatingSaving = true;
        try
        {
            var rating = _userRating ?? new UserStoryRating { ParsedStoryId = Id };
            rating.Stars = _ratingStars;
            rating.Comment = _ratingComment?.Trim() ?? string.Empty;
            await AnalysisFacade.SaveUserRatingAsync(rating);
            await LoadUserRatingAsync();
        }
        finally
        {
            _isRatingSaving = false;
        }
    }

    private async Task DeleteRating()
    {
        _isRatingSaving = true;
        try
        {
            await AnalysisFacade.DeleteUserRatingAsync(Id);
            _userRating = null;
            _ratingStars = null;
            _ratingComment = string.Empty;
        }
        finally
        {
            _isRatingSaving = false;
        }
    }

    private void StartEditCombinedText()
    {
        _editCombinedText = _detail!.CombinedText;
        _isEditingCombinedText = true;
    }

    private void CancelEditCombinedText()
    {
        _isEditingCombinedText = false;
    }

    private async Task SaveCombinedText()
    {
        _isSavingCombinedText = true;
        try
        {
            await AnalysisFacade.UpdateCombinedTextAsync(Id, _editCombinedText);
            _detail!.CombinedText = _editCombinedText;
            _isEditingCombinedText = false;
        }
        finally
        {
            _isSavingCombinedText = false;
        }
    }

    private Task SummarizeStory()
    {
        if (_isLlmBusy) return Task.CompletedTask;
        _summaryError = null;

        ProcessingQueue.Enqueue(new ModelProcessingTask
        {
            ParsedStoryId = Id,
            StoryTitle = _detail?.Title,
            TaskType = ModelProcessingTaskType.Summarize
        });
        _isSummarizing = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task AnalyzeStory()
    {
        if (_isLlmBusy) return Task.CompletedTask;
        _analysisError = null;
        _analysisDimensionErrors.Clear();

        ProcessingQueue.Enqueue(new ModelProcessingTask
        {
            ParsedStoryId = Id,
            StoryTitle = _detail?.Title,
            TaskType = ModelProcessingTaskType.Analyze
        });
        _isAnalyzing = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void ParseAnalysisViewModels()
    {
        _parsedCharacters = new();
        _parsedThemes = new();
        _parsedPlotStructure = null;
        _parsedWritingStyle = null;

        if (_analysis is null) return;

        try
        {
            if (!string.IsNullOrEmpty(_analysis.CharactersJson))
            {
                using var doc = JsonDocument.Parse(_analysis.CharactersJson);
                if (doc.RootElement.TryGetProperty("characters", out var chars))
                {
                    foreach (var c in chars.EnumerateArray())
                    {
                        _parsedCharacters.Add(new CharacterEntry(
                            c.TryGetProperty("name", out var n) ? n.GetString() ?? "—" : "—",
                            c.TryGetProperty("role", out var r) ? r.GetString() ?? "—" : "—",
                            c.TryGetProperty("description", out var d) ? d.GetString() ?? "—" : "—"));
                    }
                }
            }
        }
        catch { /* graceful fallback — just leave empty */ }

        try
        {
            if (!string.IsNullOrEmpty(_analysis.ThemesJson))
            {
                using var doc = JsonDocument.Parse(_analysis.ThemesJson);
                if (doc.RootElement.TryGetProperty("themes", out var themes))
                {
                    foreach (var t in themes.EnumerateArray())
                    {
                        _parsedThemes.Add(new ThemeEntry(
                            t.TryGetProperty("name", out var n) ? n.GetString() ?? "—" : "—",
                            t.TryGetProperty("description", out var d) ? d.GetString() ?? "—" : "—",
                            t.TryGetProperty("prevalence", out var p) ? p.GetString() ?? "minor" : "minor"));
                    }
                }
            }
        }
        catch { }

        try
        {
            if (!string.IsNullOrEmpty(_analysis.PlotStructureJson))
            {
                using var doc = JsonDocument.Parse(_analysis.PlotStructureJson);
                var root = doc.RootElement;
                _parsedPlotStructure = new PlotStructureEntry(
                    root.TryGetProperty("exposition", out var ex) ? ex.GetString() ?? "—" : "—",
                    root.TryGetProperty("risingAction", out var ra) ? ra.GetString() ?? "—" : "—",
                    root.TryGetProperty("climax", out var cl) ? cl.GetString() ?? "—" : "—",
                    root.TryGetProperty("fallingAction", out var fa) ? fa.GetString() ?? "—" : "—",
                    root.TryGetProperty("resolution", out var re) ? re.GetString() ?? "—" : "—");
            }
        }
        catch { }

        try
        {
            if (!string.IsNullOrEmpty(_analysis.WritingStyleJson))
            {
                using var doc = JsonDocument.Parse(_analysis.WritingStyleJson);
                var root = doc.RootElement;
                var devices = new List<string>();
                if (root.TryGetProperty("notableDevices", out var nd) && nd.ValueKind == JsonValueKind.Array)
                {
                    foreach (var d in nd.EnumerateArray())
                        devices.Add(d.GetString() ?? "—");
                }
                _parsedWritingStyle = new WritingStyleEntry(
                    root.TryGetProperty("tone", out var t) ? t.GetString() ?? "—" : "—",
                    root.TryGetProperty("perspective", out var p) ? p.GetString() ?? "—" : "—",
                    root.TryGetProperty("pacing", out var pa) ? pa.GetString() ?? "—" : "—",
                    root.TryGetProperty("languageComplexity", out var lc) ? lc.GetString() ?? "—" : "—",
                    devices);
            }
        }
        catch { }
    }

    private sealed record CharacterEntry(string Name, string Role, string Description);
    private sealed record ThemeEntry(string Name, string Description, string Prevalence);
    private sealed record PlotStructureEntry(string Exposition, string RisingAction, string Climax, string FallingAction, string Resolution);
    private sealed record WritingStyleEntry(string Tone, string Perspective, string Pacing, string LanguageComplexity, List<string> NotableDevices);

    private async Task AddTheme()
    {
        if (_selectedProfileId is null) return;
        _themeValidationError = null;
        var name = _newThemeName?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(name))
        {
            _themeValidationError = "Name is required.";
            return;
        }

        _isThemeBusy = true;
        try
        {
            await AnalysisFacade.CreateThemeAsync(_selectedProfileId, name, _newThemeDescription?.Trim() ?? string.Empty, _newThemeTier);
            _themes = await AnalysisFacade.ListThemesByProfileAsync(_selectedProfileId);
            _newThemeName = string.Empty;
            _newThemeDescription = string.Empty;
            _newThemeTier = ThemeTier.NiceToHave;
        }
        catch (Exception ex)
        {
            _themeError = ex.Message;
        }
        finally
        {
            _isThemeBusy = false;
        }
    }

    private void StartEditTheme(ThemePreference t)
    {
        _editingThemeId = t.Id;
        _editThemeName = t.Name;
        _editThemeDescription = t.Description;
        _editThemeTier = t.Tier;
    }

    private void CancelEditTheme()
    {
        _editingThemeId = null;
    }

    private async Task SaveEditTheme()
    {
        if (_editingThemeId is null || _selectedProfileId is null) return;
        _themeValidationError = null;
        var name = _editThemeName?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(name))
        {
            _themeValidationError = "Name is required.";
            return;
        }

        _isThemeBusy = true;
        try
        {
            await AnalysisFacade.UpdateThemeAsync(_editingThemeId, name, _editThemeDescription?.Trim() ?? string.Empty, _editThemeTier);
            _themes = await AnalysisFacade.ListThemesByProfileAsync(_selectedProfileId!);
            _editingThemeId = null;
        }
        catch (Exception ex)
        {
            _themeError = ex.Message;
        }
        finally
        {
            _isThemeBusy = false;
        }
    }

    private async Task DeleteTheme(string id)
    {
        if (_selectedProfileId is null) return;
        _isThemeBusy = true;
        try
        {
            await AnalysisFacade.DeleteThemeAsync(id);
            _themes = await AnalysisFacade.ListThemesByProfileAsync(_selectedProfileId);
        }
        catch (Exception ex)
        {
            _themeError = ex.Message;
        }
        finally
        {
            _isThemeBusy = false;
        }
    }

    private Task RankStory()
    {
        if (_isLlmBusy || _selectedProfileId is null) return Task.CompletedTask;
        _rankingError = null;
        _rankingErrors.Clear();

        ProcessingQueue.Enqueue(new ModelProcessingTask
        {
            ParsedStoryId = Id,
            StoryTitle = _detail?.Title,
            TaskType = ModelProcessingTaskType.Rank,
            ThemeProfileId = _selectedProfileId
        });
        _isRanking = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private sealed record DetectionEntry(string ThemeId, string ThemeName, string Tier, bool Detected, string Intensity, string Evidence, double Confidence);

    private static List<DetectionEntry> ParseThemeDetections(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return new();
        try
        {
            using var doc = JsonDocument.Parse(json);
            var list = new List<DetectionEntry>();
            foreach (var elem in doc.RootElement.EnumerateArray())
            {
                list.Add(new DetectionEntry(
                    elem.TryGetProperty("themeId", out var id) ? id.GetString() ?? "" : "",
                    elem.TryGetProperty("themeName", out var n) ? n.GetString() ?? "—" : "—",
                    elem.TryGetProperty("tier", out var t) ? t.GetString() ?? "Neutral" : "Neutral",
                    elem.TryGetProperty("detected", out var d) && d.GetBoolean(),
                    elem.TryGetProperty("intensity", out var i) ? i.GetString() ?? "None" : "None",
                    elem.TryGetProperty("evidence", out var e) ? e.GetString() ?? "" : "",
                    elem.TryGetProperty("confidence", out var c) && c.TryGetDouble(out var cv) ? cv : 0.0
                ));
            }
            return list;
        }
        catch
        {
            return new();
        }
    }

    private static Dictionary<string, ThemeVerificationStatus> ParseVerificationStatuses(string? json)
    {
        var result = new Dictionary<string, ThemeVerificationStatus>();
        if (string.IsNullOrWhiteSpace(json)) return result;
        try
        {
            using var doc = JsonDocument.Parse(json);
            foreach (var prop in doc.RootElement.EnumerateObject())
            {
                if (Enum.TryParse<ThemeVerificationStatus>(prop.Value.GetString(), true, out var status))
                    result[prop.Name] = status;
            }
        }
        catch { }
        return result;
    }

    private ThemeVerificationStatus GetVerificationStatus(string themeId)
    {
        return _themeVerificationStatuses.TryGetValue(themeId, out var status) ? status : ThemeVerificationStatus.Unverified;
    }

    private bool IsAllVerified =>
        _themeDetections.Count > 0 &&
        _themeDetections.All(d => GetVerificationStatus(d.ThemeId) != ThemeVerificationStatus.Unverified);

    private async Task SetThemeVerificationAsync(string themeId, ThemeVerificationStatus status)
    {
        if (_ranking is null) return;
        _isSavingVerification = true;
        try
        {
            _themeVerificationStatuses[themeId] = status;

            // Serialize statuses to JSON
            var statusDict = _themeVerificationStatuses.ToDictionary(kv => kv.Key, kv => kv.Value.ToString());
            _ranking.ThemeVerificationStatusJson = JsonSerializer.Serialize(statusDict);

            // Recalculate score excluding dismissed themes
            var dismissedIds = _themeVerificationStatuses
                .Where(kv => kv.Value == ThemeVerificationStatus.Dismissed)
                .Select(kv => kv.Key)
                .ToHashSet();

            var detections = _themeDetections.Select(d => new ThemeDetection
            {
                ThemeId = d.ThemeId,
                ThemeName = d.ThemeName,
                Tier = Enum.TryParse<ThemeTier>(d.Tier, true, out var tier) ? tier : ThemeTier.Neutral,
                Detected = d.Detected,
                Intensity = Enum.TryParse<ThemeIntensity>(d.Intensity, true, out var intensity) ? intensity : ThemeIntensity.None,
                Confidence = d.Confidence,
                Evidence = d.Evidence
            }).ToList();

            var (score, isDisqualified, _) = ThemeScoreCalculator.Calculate(detections, dismissedIds);
            _ranking.Score = score;
            _ranking.IsDisqualified = isDisqualified;

            await AnalysisFacade.UpdateThemeVerificationAsync(_ranking);
        }
        finally
        {
            _isSavingVerification = false;
        }
    }


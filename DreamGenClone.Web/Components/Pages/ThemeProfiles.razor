                                            @onclick="() => SelectBaseStatProfile(profile.Id)">
                                        <strong>@profile.Name</strong>
                                        <small class="d-block @(profile.Id == _selectedBaseStatProfileId ? "text-light" : "text-muted")">@Truncate(profile.Description, 100)</small>
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No character state profiles yet.</p>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@(_selectedBaseStatProfileId is null ? "Create Character State Profile" : "Edit Character State Profile")</strong>
                            <div class="text-muted small">Defines default per-character stat seeds for scenario session initialization.</div>
                        </div>
                        @if (_selectedBaseStatProfileId is not null)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="DeleteBaseStatProfile" disabled="@_isBusy">Delete</button>
                        }
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" @bind="_baseStatFormName" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" rows="2" @bind="_baseStatFormDescription"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Default Stats</label>
                                @foreach (var statName in BaseStatNames)
                                {
                                    <div class="input-group input-group-sm mb-2" style="max-width: 360px;">
                                        <span class="input-group-text" style="min-width: 140px;">@statName</span>
                                        <input type="number"
                                               class="form-control"
                                               min="0"
                                               max="100"
                                               value="@GetBaseStatValue(statName)"
                                               @onchange="@(e => SetBaseStatValue(statName, e.Value?.ToString()))" />
                                    </div>
                                }

                                <div class="border rounded p-3 mt-3 bg-light-subtle">
                                    <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                                        <strong>Adaptive Stat Guide</strong>
                                        <span class="badge bg-secondary-subtle text-secondary-emphasis border">Default seed: 50</span>
                                    </div>

                                    <div class="row g-2">
                                        @foreach (var stat in AdaptiveStatCatalog.CanonicalStats)
                                        {
                                            <div class="col-12 col-md-6">
                                                <div class="border rounded p-2 h-100 bg-white">
                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                        <strong>@stat.Name</strong>
                                                        <span class="badge bg-light text-dark border">@stat.DefaultValue</span>
                                                    </div>
                                                    <div class="small text-muted mb-1">@stat.Description</div>
                                                    <div class="small"><span class="text-muted">Low:</span> @stat.LowMeaning</div>
                                                    <div class="small"><span class="text-muted">High:</span> @stat.HighMeaning</div>
                                                    @if (StatEngineEffects.TryGetValue(stat.Name, out var effect))
                                                    {
                                                        <div class="small mt-1"><span class="text-muted">Engine:</span> @effect</div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    <div class="mt-3">
                                        <div class="fw-semibold mb-1">Interaction Patterns</div>
                                        <ul class="small mb-0">
                                            @foreach (var interaction in StatInteractionPatterns)
                                            {
                                                <li><strong>@interaction.Pair:</strong> @interaction.Effect</li>
                                            }
                                        </ul>
                                    </div>

                                    <div class="mt-3">
                                        <div class="fw-semibold mb-1">Cross-Character Behavior (Current)</div>
                                        <ul class="small mb-0">
                                            @foreach (var note in CrossCharacterBehaviorNotes)
                                            {
                                                <li>@note</li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(_baseStatError))
                        {
                            <div class="text-danger mt-3 small">@_baseStatError</div>
                        }
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button class="btn btn-primary" @onclick="SaveBaseStatProfile" disabled="@_isBusy">@(_selectedBaseStatProfileId is null ? "Create Profile" : "Save Changes")</button>
                            <button class="btn btn-outline-secondary" @onclick="StartCreateBaseStatProfile" disabled="@_isBusy">Reset</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var mode in CharacterPerspectiveModes.All)
            {
                <div class="col-12 col-md-6">
                    <div class="card h-100 border-secondary-subtle">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <strong>@mode.DisplayName</strong>
                            <span class="badge bg-dark-subtle text-dark-emphasis border">Reference</span>
                        </div>
                        <div class="card-body d-flex flex-column gap-3">
                            <div>
                                <div class="text-muted small text-uppercase mb-1">Description</div>
                                <div>@mode.Description</div>
                            </div>
                            <div>
                                <div class="text-muted small text-uppercase mb-1">Example</div>
                                <div class="fst-italic">@mode.Example</div>
                            </div>
                            <div>
                                <div class="text-muted small text-uppercase mb-1">Rule of Thumb</div>
                                <div>@mode.RuleOfThumb</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public string? ProfileId { get; set; }

    private string _activeTab = "ranking";
    private bool _isBusy;

    private List<ThemeProfile> _profiles = [];
    private string? _selectedProfileId;
    private ThemeProfile? _selectedProfile;
    private List<ThemePreference> _themes = [];
    private string _newProfileName = string.Empty;
    private string? _profileError;
    private bool _isEditingProfileName;
    private string _editProfileName = string.Empty;
    private string? _themeError;
    private string? _themeValidationError;
    private string _newThemeName = string.Empty;
    private string _newThemeDescription = string.Empty;
    private ThemeTier _newThemeTier = ThemeTier.NiceToHave;
    private string _newThemeCatalogId = string.Empty;
    private string? _editingThemeId;
    private string _editThemeName = string.Empty;
    private string _editThemeDescription = string.Empty;
    private ThemeTier _editThemeTier = ThemeTier.NiceToHave;
    private string _editThemeCatalogId = string.Empty;

    private List<IntensityProfile> _intensityProfiles = [];
    private string? _selectedToneId;
    private string _toneFormName = string.Empty;
    private string _toneFormDescription = string.Empty;
    private IntensityLevel _toneFormIntensity = IntensityLevel.Emotional;
    private string? _toneError;

    private List<SteeringProfile> _steeringProfiles = [];
    private string? _selectedStyleId;
    private string _styleFormName = string.Empty;
    private string _styleFormDescription = string.Empty;
    private string _styleFormExample = string.Empty;
    private string _styleFormRuleOfThumb = string.Empty;
    private Dictionary<string, int> _styleFormThemeAffinities = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> _styleFormEscalatingThemeIds = new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, int> _styleFormStatBias = new(StringComparer.OrdinalIgnoreCase);
    private string? _styleError;

    private IReadOnlyList<ThemeCatalogEntry> _catalogEntries = [];
    private IReadOnlyList<ThemeDefinitionDocument> _themeDefinitions = [];
    private ThemeDefinitionDocument? _selectedThemeDefinition;
    private string? _themeDefinitionsError;

    // Catalog tab state
    private string? _catalogError;
    private bool _isAddingCatalog;
    private string _newCatalogId = string.Empty;
    private string _newCatalogLabel = string.Empty;
    private string _newCatalogDescription = string.Empty;
    private string _newCatalogKeywordsText = string.Empty;
    private string _newCatalogCategory = string.Empty;
    private Dictionary<string, int> _newCatalogStatAffinities = new(StringComparer.OrdinalIgnoreCase);
    private int _newCatalogWeight = 3;
    private string? _editingCatalogId;
    private string _editCatalogLabel = string.Empty;
    private string _editCatalogDescription = string.Empty;
    private string _editCatalogKeywordsText = string.Empty;
    private string _editCatalogCategory = string.Empty;
    private Dictionary<string, int> _editCatalogStatAffinities = new(StringComparer.OrdinalIgnoreCase);
    private int _editCatalogWeight = 3;
    private bool _editCatalogEnabled = true;

    private List<BaseStatProfile> _baseStatProfiles = [];
    private string? _selectedBaseStatProfileId;
    private string _baseStatFormName = string.Empty;
    private string _baseStatFormDescription = string.Empty;
    private Dictionary<string, int> _baseStatFormStats = new(StringComparer.OrdinalIgnoreCase);
    private string? _baseStatError;

    private static readonly IReadOnlyDictionary<string, string> StatEngineEffects = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["Desire"] = "Primary intensity driver. Higher values can raise effective style intensity and reinforce escalation themes.",
        ["Restraint"] = "Restraint brake. Lower values permit bolder progression; higher values slow escalation and preserve caution.",
        ["Tension"] = "Conflict pressure. Higher values bias output toward volatility, uncertainty, and risk-laden beats.",
        ["Connection"] = "Safety confidence. Higher values enable openness and vulnerability; lower values reinforce defensiveness.",
        ["Dominance"] = "Control signal. Higher values favor decisive initiative; lower values bias toward passivity and reduced control."
    };

    private static readonly (string Pair, string Effect)[] StatInteractionPatterns =
    [
        ("High Connection + Low Restraint", "Usually increases openness and accelerates consent-forward progression."),
        ("High Desire + High Restraint", "Creates push-pull tension: strong desire paired with restraint and hesitation."),
        ("High Tension + Low Connection", "Increases conflict tone and defensive reactions; de-escalation cues become more important."),
        ("High Dominance + High Tension", "Biases toward assertive, high-stakes actions and explicit directional choices."),
        ("Low Dominance + High Connection", "Can read as receptive surrender when safety is high, but less initiative from the actor.")
    ];

    private static readonly string[] CrossCharacterBehaviorNotes =
    [
        "Each character currently tracks their own independent stat block.",
        "There is no pairwise relational matrix yet (for example, Connection[A->B] vs Connection[A->C]).",
        "Theme tracking is session-level, so dominant themes can influence style resolution globally.",
        "Direct cross-character stat transfer effects are not implemented in v1; they are planned for a later phase."
    ];

    private static readonly string[] BaseStatNames = GetBaseStatNames();

    protected override async Task OnParametersSetAsync()
    {
        await ReloadAsync();

        if (!string.IsNullOrWhiteSpace(ProfileId))
        {
            await SelectProfile(ProfileId);
        }
        else if (_selectedProfileId is null && _profiles.Count > 0)
        {
            await SelectProfile(_profiles[0].Id);
        }

        if (_selectedToneId is null && _intensityProfiles.Count > 0)
        {
            SelectIntensity(_intensityProfiles[0].Id);
        }

        if (_selectedStyleId is null && _steeringProfiles.Count > 0)
        {
            SelectSteering(_steeringProfiles[0].Id);
        }

        if (_selectedBaseStatProfileId is null && _baseStatProfiles.Count > 0)
        {
            SelectBaseStatProfile(_baseStatProfiles[0].Id);
        }
        else if (_selectedBaseStatProfileId is null && _baseStatProfiles.Count == 0)
        {
            StartCreateBaseStatProfile();
        }
    }

    private static string[] GetBaseStatNames()
    {
        return AdaptiveStatCatalog.CanonicalStatNames.ToArray();
    }

    private async Task ReloadAsync()
    {
        _profiles = await Facade.ListProfilesAsync();
        _intensityProfiles = await Facade.ListIntensityProfilesAsync();
        _steeringProfiles = await Facade.ListSteeringProfilesAsync();
        _baseStatProfiles = await Facade.ListBaseStatProfilesAsync();
        _catalogEntries = await Facade.ListCatalogEntriesAsync(includeDisabled: true);

        try
        {
            _themeDefinitions = await Facade.ListThemeDefinitionsAsync();
            if (_selectedThemeDefinition is null || !_themeDefinitions.Any(d => string.Equals(d.SourceFilePath, _selectedThemeDefinition.SourceFilePath, StringComparison.OrdinalIgnoreCase)))
            {
                _selectedThemeDefinition = _themeDefinitions.FirstOrDefault();
            }

            _themeDefinitionsError = null;
        }
        catch (Exception ex)
        {
            _themeDefinitions = [];
            _selectedThemeDefinition = null;
            _themeDefinitionsError = ex.Message;
        }
    }

    private void SelectThemeDefinition(ThemeDefinitionDocument definition)
    {
        _selectedThemeDefinition = definition;
    }

    private string GetTabClass(string tab) => _activeTab == tab ? "active" : string.Empty;

    private async Task SelectProfile(string profileId)
    {
        _selectedProfileId = profileId;
        _selectedProfile = _profiles.FirstOrDefault(x => x.Id == profileId);
        _themes = _selectedProfile is not null
            ? await Facade.ListThemesByProfileAsync(profileId)
            : [];
        _editingThemeId = null;
        _themeError = null;
        _themeValidationError = null;
    }

    private async Task CreateProfile()
    {
        _profileError = null;
        var name = _newProfileName.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            _profileError = "Name is required.";
            return;
        }

        _isBusy = true;
        try
        {
            var profile = await Facade.CreateProfileAsync(name);
            await ReloadAsync();
            _newProfileName = string.Empty;
            await SelectProfile(profile.Id);
        }
        catch (Exception ex)
        {
            _profileError = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void StartEditProfileName()
    {
        _isEditingProfileName = true;
        _editProfileName = _selectedProfile?.Name ?? string.Empty;
    }

    private async Task SaveProfileName()
    {
        if (_selectedProfileId is null)
        {
            return;
        }

        _profileError = null;
        _isBusy = true;
        try
        {
            await Facade.UpdateProfileAsync(_selectedProfileId, _editProfileName);
            await ReloadAsync();
            _selectedProfile = _profiles.FirstOrDefault(x => x.Id == _selectedProfileId);
            _isEditingProfileName = false;
        }
        catch (Exception ex)
        {
            _profileError = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task DeleteProfile()
    {
        if (_selectedProfileId is null)
        {
            return;
        }

        _profileError = null;
        _isBusy = true;
        try
        {
            await Facade.DeleteProfileAsync(_selectedProfileId);
            await ReloadAsync();
            _selectedProfileId = null;
            _selectedProfile = null;
            _themes = [];
            if (_profiles.Count > 0)
            {
                await SelectProfile(_profiles[0].Id);
            }
        }
        catch (Exception ex)
        {
            _profileError = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task SetAsDefault()
    {
        if (_selectedProfileId is null)
        {
            return;
        }

        _profileError = null;
        _isBusy = true;
        try
        {
            await Facade.SetProfileDefaultAsync(_selectedProfileId);
            await ReloadAsync();
            _selectedProfile = _profiles.FirstOrDefault(x => x.Id == _selectedProfileId);
        }
        catch (Exception ex)
        {
            _profileError = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task AddTheme()
    {
        if (_selectedProfileId is null)
        {
            return;
        }

        _themeValidationError = null;
        var name = _newThemeName.Trim();
        var description = _newThemeDescription.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            _themeValidationError = "Name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(description))
        {
            _themeValidationError = "Description is required.";
            return;
        }

        _isBusy = true;
        try
        {
            var catalogId = string.IsNullOrEmpty(_newThemeCatalogId) ? null : _newThemeCatalogId;
            await Facade.CreateThemeAsync(_selectedProfileId, name, description, _newThemeTier, catalogId);
            _themes = await Facade.ListThemesByProfileAsync(_selectedProfileId);
            _newThemeName = string.Empty;
            _newThemeDescription = string.Empty;
            _newThemeTier = ThemeTier.NiceToHave;
            _newThemeCatalogId = string.Empty;
        }
        catch (Exception ex)
        {
            _themeError = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void StartEditTheme(ThemePreference theme)
    {
        _editingThemeId = theme.Id;
        _editThemeName = theme.Name;
        _editThemeDescription = theme.Description;
        _editThemeTier = theme.Tier;
        _editThemeCatalogId = theme.CatalogId;
    }

    private void CancelEditTheme() => _editingThemeId = null;

    private async Task SaveEditTheme()
    {
        if (_editingThemeId is null || _selectedProfileId is null)
        {
            return;
        }

        _themeValidationError = null;
        if (string.IsNullOrWhiteSpace(_editThemeName.Trim()))
        {
            _themeValidationError = "Name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_editThemeDescription.Trim()))
        {
            _themeValidationError = "Description is required.";
            return;

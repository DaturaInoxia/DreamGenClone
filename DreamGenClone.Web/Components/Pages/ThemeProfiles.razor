                    {
                        <div class="border rounded p-3 mt-3 bg-light-subtle">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <strong>@_selectedThemeDefinition.Label</strong>
                                <span class="badge bg-light text-dark border">@_selectedThemeDefinition.SourceFileName</span>
                            </div>

                            @if (_selectedThemeDefinition.ParseWarnings.Count > 0)
                            {
                                <div class="alert alert-warning py-2 small">
                                    @string.Join(" | ", _selectedThemeDefinition.ParseWarnings)
                                </div>
                            }

                            <label class="form-label small text-muted">Raw markdown dump</label>
                            <pre class="mb-0 p-3 border rounded bg-body-tertiary" style="max-height: 460px; overflow:auto; white-space: pre-wrap;">@_selectedThemeDefinition.RawContent</pre>
                        </div>

    private int GetBaseStatValue(string statName)
    {
        if (!_baseStatFormStats.TryGetValue(statName, out var value))
        {
            value = 50;
            _baseStatFormStats[statName] = value;
        }

        return value;
    }

    private void SetBaseStatValue(string statName, string? rawValue)
    {
        if (!int.TryParse(rawValue, out var value))
        {
            value = 50;
        }

        _baseStatFormStats[statName] = Math.Clamp(value, 0, 100);
    }

    private static string Truncate(string? value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= maxLength)
        {
            return value ?? string.Empty;
        }

        return $"{value[..(maxLength - 1)]}…";
    }


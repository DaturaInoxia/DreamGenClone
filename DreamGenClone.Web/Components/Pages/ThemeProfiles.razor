                                            <label class="form-label small">@statName</label>
                                            <input type="number"
                                                   class="form-control form-control-sm"
                                                   min="-5"
                                                   max="5"
                                                   value="@GetNewCatalogStatAffinityValue(statName)"
                                                   @onchange="@(e => SetNewCatalogStatAffinityValue(statName, e.Value?.ToString()))" />
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-3">
                                <button class="btn btn-sm btn-primary me-1" @onclick="AddCatalogEntry" disabled="@_isBusy">Add</button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => _isAddingCatalog = false">Cancel</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else if (_activeTab == "definitions")
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>Theme Definitions</strong>
                    <div class="text-muted small">Source markdown files loaded from specs/ThemeDefinitaions for future import-ready refactoring.</div>
                </div>
                <span class="badge bg-secondary">@_themeDefinitions.Count files</span>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(_themeDefinitionsError))
                {
                    <div class="alert alert-danger">@_themeDefinitionsError</div>
                }

                @if (_themeDefinitions.Count == 0)
                {
                    <p class="text-muted mb-0">No theme definition markdown files found.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 220px;">ID</th>
                                    <th>Label</th>
                                    <th style="width: 140px;">Category</th>
                                    <th style="width: 90px;">Weight</th>
                                    <th style="width: 180px;">Source</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var definition in _themeDefinitions)
                                {
                                    var isSelected = string.Equals(_selectedThemeDefinition?.SourceFilePath, definition.SourceFilePath, StringComparison.OrdinalIgnoreCase);
                                    <tr class="@(isSelected ? "table-primary" : string.Empty)" style="cursor:pointer" @onclick="() => SelectThemeDefinition(definition)">
                                        <td><code>@definition.Id</code></td>
                                        <td>@definition.Label</td>
                                        <td>@definition.Category</td>
                                        <td>@definition.Weight</td>
                                        <td class="text-muted small">@definition.SourceFileName</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>


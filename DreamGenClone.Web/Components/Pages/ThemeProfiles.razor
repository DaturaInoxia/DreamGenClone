    private void StartCreateNarrativeGateProfile()
    {
        var cloneSource = _narrativeGateProfiles.FirstOrDefault(x => string.Equals(x.Id, _selectedNarrativeGateProfileId, StringComparison.OrdinalIgnoreCase))
            ?? _narrativeGateProfiles.FirstOrDefault();

        _selectedNarrativeGateProfileId = null;
        _narrativeGateFormName = string.Empty;
        _narrativeGateFormDescription = string.Empty;
        _narrativeGateFormIsDefault = false;
        _climaxResetInteractionThreshold = ResolveClimaxResetInteractionThreshold(cloneSource?.Rules ?? []);
        _narrativeGateFormRules = (cloneSource?.Rules ?? [])
            .Where(rule => !IsClimaxResetThresholdRule(rule))
            .OrderBy(rule => rule.SortOrder)
            .Select((rule, index) => new NarrativeGateRule
            {
                SortOrder = index + 1,
                FromPhase = rule.FromPhase,
                ToPhase = rule.ToPhase,
                MetricKey = rule.MetricKey,
                Comparator = rule.Comparator,
                Threshold = rule.Threshold
            })
            .ToList();
        _narrativeGateError = null;
    }

    private void SelectNarrativeGateProfile(string profileId)
    {
        var profile = _narrativeGateProfiles.FirstOrDefault(x => x.Id == profileId);
        if (profile is null)
        {
            return;
        }

        _selectedNarrativeGateProfileId = profile.Id;
        _narrativeGateFormName = profile.Name;
        _narrativeGateFormDescription = profile.Description;
        _narrativeGateFormIsDefault = profile.IsDefault;
        _climaxResetInteractionThreshold = ResolveClimaxResetInteractionThreshold(profile.Rules);
        _narrativeGateFormRules = profile.Rules
            .OrderBy(x => x.SortOrder)
            .Select(x => new NarrativeGateRule
            {
                SortOrder = x.SortOrder,
                FromPhase = x.FromPhase,
                ToPhase = x.ToPhase,
                MetricKey = x.MetricKey,
                Comparator = x.Comparator,
                Threshold = x.Threshold
            })
            .ToList();
        _narrativeGateError = null;
    }

    private void AddNarrativeGateRule()
    {
        _narrativeGateFormRules.Add(new NarrativeGateRule
        {
            SortOrder = _narrativeGateFormRules.Count + 1,
            FromPhase = "Committed",
            ToPhase = "Approaching",
            MetricKey = NarrativeGateMetricKeys.ActiveScenarioScore,
            Comparator = NarrativeGateComparators.GreaterThanOrEqual,
            Threshold = 60m
        });
    }

    private void RemoveNarrativeGateRule(int index)
    {
        if (index < 0 || index >= _narrativeGateFormRules.Count)
        {
            return;
        }

        _narrativeGateFormRules.RemoveAt(index);
    }

    private async Task SaveNarrativeGateProfile()
    {
        _narrativeGateError = null;

        if (_climaxResetInteractionThreshold < 1)
        {
            _narrativeGateError = "Climax completion interaction threshold must be at least 1.";
            return;
        }

        var normalizedRules = _narrativeGateFormRules
            .Where(rule => !IsClimaxResetThresholdRule(rule))
            .Select(rule => new NarrativeGateRule
            {
                SortOrder = rule.SortOrder,
                FromPhase = rule.FromPhase,
                ToPhase = rule.ToPhase,
                MetricKey = rule.MetricKey,
                Comparator = rule.Comparator,
                Threshold = rule.Threshold
            })
            .ToList();

        normalizedRules.Add(new NarrativeGateRule
        {
            SortOrder = normalizedRules.Count + 1,
            FromPhase = "Climax",
            ToPhase = "Reset",
            MetricKey = NarrativeGateMetricKeys.InteractionsSinceCommitment,
            Comparator = NarrativeGateComparators.GreaterThanOrEqual,
            Threshold = decimal.Round(_climaxResetInteractionThreshold, 0, MidpointRounding.AwayFromZero)
        });

        if (normalizedRules.Count == 0)
        {
            _narrativeGateError = "Add at least one gate rule before saving.";
            return;
        }

        _narrativeGateFormRules = normalizedRules;

        var profile = new NarrativeGateProfile
        {
            Id = _selectedNarrativeGateProfileId ?? Guid.NewGuid().ToString(),
            Name = _narrativeGateFormName,
            Description = _narrativeGateFormDescription,
            IsDefault = _narrativeGateFormIsDefault,
            Rules = normalizedRules
                .Select((rule, index) => new NarrativeGateRule
                {
                    SortOrder = index + 1,
                    FromPhase = rule.FromPhase,
                    ToPhase = rule.ToPhase,
                    MetricKey = rule.MetricKey,
                    Comparator = rule.Comparator,
                    Threshold = rule.Threshold
                })
                .ToList()
        };

        _isBusy = true;
        try
        {
            var saved = await Facade.SaveNarrativeGateProfileAsync(profile);
            await ReloadAsync();
            SelectNarrativeGateProfile(saved.Id);
        }
        catch (Exception ex)
        {
            _narrativeGateError = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task DeleteNarrativeGateProfile()
    {
        if (_selectedNarrativeGateProfileId is null)
        {
            return;
        }

        _narrativeGateError = null;
        _isBusy = true;
        try
        {
            await Facade.DeleteNarrativeGateProfileAsync(_selectedNarrativeGateProfileId);
            await ReloadAsync();
            if (_narrativeGateProfiles.Count > 0)
            {
                SelectNarrativeGateProfile(_narrativeGateProfiles[0].Id);
            }
            else
            {
                StartCreateNarrativeGateProfile();
            }
        }
        catch (Exception ex)
        {
            _narrativeGateError = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private static bool IsClimaxResetThresholdRule(NarrativeGateRule rule)
    {
        return string.Equals(rule.FromPhase, "Climax", StringComparison.OrdinalIgnoreCase)
            && string.Equals(rule.ToPhase, "Reset", StringComparison.OrdinalIgnoreCase)
            && string.Equals(rule.MetricKey, NarrativeGateMetricKeys.InteractionsSinceCommitment, StringComparison.OrdinalIgnoreCase);
    }

    private static decimal ResolveClimaxResetInteractionThreshold(IReadOnlyList<NarrativeGateRule> rules)
    {
        var existing = rules
            .Where(IsClimaxResetThresholdRule)
            .OrderBy(x => x.SortOrder)
            .FirstOrDefault();
        return existing is null ? 12m : Math.Max(1m, decimal.Round(existing.Threshold, 0, MidpointRounding.AwayFromZero));
    }


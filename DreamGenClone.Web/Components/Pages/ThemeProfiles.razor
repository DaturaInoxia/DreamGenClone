    private void SetEditCatalogStatAffinityValue(string statName, string? rawValue)
    {
        if (!int.TryParse(rawValue, out var value)) value = 0;
        _editCatalogStatAffinities[statName] = Math.Clamp(value, -5, 5);
    }

    private static List<string> ParseKeywordList(string? rawValue)
    {
        return (rawValue ?? string.Empty)
            .Split([',', '\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static Dictionary<string, int> BuildFilteredAffinities(Dictionary<string, int> values)
    {
        return values
            .Where(kv => kv.Value != 0)
            .ToDictionary(kv => kv.Key, kv => kv.Value, StringComparer.OrdinalIgnoreCase);
    }

    private static string FormatKeywords(IReadOnlyList<string> keywords)
        => keywords.Count == 0 ? "-" : string.Join(", ", keywords);

    private static string FormatStatAffinities(IReadOnlyDictionary<string, int> affinities)
    {
        if (affinities.Count == 0)
        {
            return "-";
        }

        return string.Join(", ", affinities.Select(kv => $"{kv.Key} {(kv.Value >= 0 ? "+" : string.Empty)}{kv.Value}"));
    }

    private static string Slugify(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var slug = value.Trim().ToLowerInvariant();
        slug = System.Text.RegularExpressions.Regex.Replace(slug, "[^a-z0-9]+", "-");
        slug = slug.Trim('-');
        return slug;
    }

    private async Task SaveEditCatalogEntry()
    {
        _catalogError = null;
        if (string.IsNullOrWhiteSpace(_editCatalogLabel))
        {
            _catalogError = "Label is required.";
            return;
        }

        _isBusy = true;
        try
        {
            var existing = _catalogEntries.FirstOrDefault(e => e.Id == _editingCatalogId);
            if (existing is not null)
            {
                existing.Label = _editCatalogLabel.Trim();
                existing.Description = _editCatalogDescription.Trim();
                existing.Keywords = ParseKeywordList(_editCatalogKeywordsText);
                existing.Category = _editCatalogCategory.Trim();
                existing.StatAffinities = BuildFilteredAffinities(_editCatalogStatAffinities);
                existing.Weight = _editCatalogWeight;
                existing.IsEnabled = _editCatalogEnabled;
                existing.UpdatedUtc = DateTime.UtcNow;
                await Facade.SaveCatalogEntryAsync(existing);
            }
            _editingCatalogId = null;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _catalogError = ex.Message;
        }
        finally { _isBusy = false; }
    }

    private void CancelEditCatalogEntry() => _editingCatalogId = null;


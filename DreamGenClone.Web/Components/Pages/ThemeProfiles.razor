    else if (_activeTab == "flow-guide")
    {
        <div class="row g-4">
            <div class="col-12">
                <div class="card border-primary-subtle">
                    <div class="card-header bg-primary-subtle text-primary-emphasis">
                        <strong>Roleplay Flow Guide</strong>
                    </div>
                    <div class="card-body">
                        <p class="mb-2">This guide explains how a session moves through phases and how intensity is recalculated on every interaction.</p>
                        <p class="mb-0 text-muted small">Use this page as a live reference while testing your active roleplay session.</p>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong>Narrative Phase Sequence</strong>
                        <span class="badge bg-secondary">BuildUp -> Committed -> Approaching -> Climax -> Reset</span>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12 col-lg-6">
                                <div class="border rounded p-3 h-100">
                                    <div class="fw-semibold">Committed -> Approaching</div>
                                    <div class="small text-muted mt-1">Requires all of these gates:</div>
                                    <ul class="small mt-2 mb-0">
                                        <li>Active scenario score &gt;= 60</li>
                                        <li>Average desire &gt;= 65</li>
                                        <li>Average restraint &lt;= 45</li>
                                        <li>Interactions since commitment &gt;= 3</li>
                                    </ul>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6">
                                <div class="border rounded p-3 h-100">
                                    <div class="fw-semibold">Approaching -> Climax</div>
                                    <div class="small text-muted mt-1">Normal threshold path requires:</div>
                                    <ul class="small mt-2 mb-2">
                                        <li>Active scenario score &gt;= 80</li>
                                        <li>Average desire &gt;= 75</li>
                                        <li>Average restraint &lt;= 35</li>
                                        <li>Interactions in approaching &gt;= 2</li>
                                    </ul>
                                    <div class="small text-muted">Override path: user interaction includes <span class="font-monospace">/climax</span> or <span class="font-monospace">trigger climax</span>.</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6">
                                <div class="border rounded p-3 h-100">
                                    <div class="fw-semibold">Climax -> Reset</div>
                                    <div class="small text-muted mt-1">Transition requires explicit completion signal in interaction text:</div>
                                    <ul class="small mt-2 mb-0">
                                        <li><span class="font-monospace">/completeclimax</span></li>
                                        <li><span class="font-monospace">climax complete</span></li>
                                    </ul>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6">
                                <div class="border rounded p-3 h-100">
                                    <div class="fw-semibold">Reset -> BuildUp</div>
                                    <div class="small text-muted mt-1">Automatic on next transition evaluation after reset snapshot is applied.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <strong>Adaptive Intensity Flow</strong>
                    </div>
                    <div class="card-body">
                        <p class="mb-2">Each interaction computes a target intensity scale, then maps that scale to the matching intensity profile.</p>
                        <div class="bg-light border rounded p-3 font-monospace small mb-3">
                            targetScale = clamp(selectedScale + phaseOffset + statDelta, floorOverride, ceilingOverride)
                        </div>
                        <div class="row g-3">
                            <div class="col-12 col-lg-4">
                                <div class="border rounded p-3 h-100">
                                    <div class="fw-semibold">selectedScale</div>
                                    <div class="small text-muted mt-1">Scale from selected intensity profile.</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-4">
                                <div class="border rounded p-3 h-100">
                                    <div class="fw-semibold">phaseOffset</div>
                                    <div class="small text-muted mt-1">Per-phase offset from selected profile (BuildUp, Committed, Approaching, Climax, Reset).</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-4">
                                <div class="border rounded p-3 h-100">
                                    <div class="fw-semibold">statDelta</div>
                                    <div class="small text-muted mt-1">Bounded to -1, 0, +1 based on Desire/Restraint/Tension rules.</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6">
                                <div class="border rounded p-3 h-100">
                                    <div class="fw-semibold">Manual Pin</div>
                                    <div class="small text-muted mt-1">When manual pin is enabled, adaptive transitions are suppressed and the reason code is set to manual-pin-suppressed.</div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6">
                                <div class="border rounded p-3 h-100">
                                    <div class="fw-semibold">Floor/Ceiling Overrides</div>
                                    <div class="small text-muted mt-1">Clamp target scale to configured lower/upper bounds. Reason code appends blocked-by-floor or blocked-by-ceiling when applied.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong>Intensity Profile Offsets (All Profiles)</strong>
                        <span class="badge bg-dark">@_intensityProfiles.Count profiles</span>
                    </div>
                    <div class="card-body">
                        @if (_intensityProfiles.Count == 0)
                        {
                            <p class="text-muted mb-0">No intensity profiles available yet.</p>
                        }
                        else
                        {
                            <div class="row g-3">
                                @foreach (var tone in _intensityProfiles.OrderBy(x => x.Name))
                                {
                                    <div class="col-12 col-md-6 col-xl-4">
                                        <div class="border rounded p-3 h-100">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <strong>@tone.Name</strong>
                                                <span class="badge bg-secondary">@DreamGenClone.Domain.StoryAnalysis.IntensityLadder.GetLabel(tone.Intensity)</span>
                                            </div>
                                            <div class="small text-muted mt-1">@tone.Description</div>
                                            <hr class="my-2" />
                                            <div class="small">BuildUp: <span class="font-monospace">@tone.BuildUpPhaseOffset</span></div>
                                            <div class="small">Committed: <span class="font-monospace">@tone.CommittedPhaseOffset</span></div>
                                            <div class="small">Approaching: <span class="font-monospace">@tone.ApproachingPhaseOffset</span></div>
                                            <div class="small">Climax: <span class="font-monospace">@tone.ClimaxPhaseOffset</span></div>
                                            <div class="small">Reset: <span class="font-monospace">@tone.ResetPhaseOffset</span></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (_activeTab == "perspective")
    {
        <div class="row g-4">
            @foreach (var mode in CharacterPerspectiveModes.All)
            {
                <div class="col-12 col-md-6">
                    <div class="card h-100 border-secondary-subtle">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <strong>@mode.DisplayName</strong>
                            <span class="badge bg-dark-subtle text-dark-emphasis border">Reference</span>
                        </div>
                        <div class="card-body d-flex flex-column gap-3">
                            <div>
                                <div class="text-muted small text-uppercase mb-1">Description</div>
                                <div>@mode.Description</div>
                            </div>
                            <div>
                                <div class="text-muted small text-uppercase mb-1">Example</div>
                                <div class="fst-italic">@mode.Example</div>
                            </div>
                            <div>
                                <div class="text-muted small text-uppercase mb-1">Rule of Thumb</div>
                                <div>@mode.RuleOfThumb</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    else if (_activeTab == "selection-engine")
    {
        <div class="row justify-content-center">
            <div class="col-lg-8">

                @if (!string.IsNullOrWhiteSpace(_engineSettingsError))
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        @_engineSettingsError
                        <button type="button" class="btn-close" @onclick="() => _engineSettingsError = null"></button>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_engineSettingsStatus))
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        @_engineSettingsStatus
                        <button type="button" class="btn-close" @onclick="() => _engineSettingsStatus = null"></button>
                    </div>
                }

                <div class="card mb-3">
                    <div class="card-header"><strong>Stage A — Willingness Tier Thresholds</strong></div>
                    <div class="card-body">
                        <p class="text-muted small">Avg Desire determines which willingness tier a session falls into. Below the Low minimum the tier is Blocked and scenario selection is suppressed.</p>
                        <div class="row g-3">
                            <div class="col-sm-4">
                                <label class="form-label">High Desire Min</label>
                                <input type="number" class="form-control" step="1" min="0" max="100" @bind="_engineSettings.StageAHighDesireMin" />
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label">Medium Desire Min</label>
                                <input type="number" class="form-control" step="1" min="0" max="100" @bind="_engineSettings.StageAMediumDesireMin" />
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label">Low Desire Min</label>
                                <input type="number" class="form-control" step="1" min="0" max="100" @bind="_engineSettings.StageALowDesireMin" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header"><strong>Legacy Fit-Score Weights</strong></div>
                    <div class="card-body">
                        <p class="text-muted small">Used when no LLM character-fit result is available. Weights should sum to 1.0.</p>
                        <div class="row g-3">
                            <div class="col-sm-4">
                                <label class="form-label">Desire Weight</label>
                                <input type="number" class="form-control" step="0.05" min="0" max="1" @bind="_engineSettings.LegacyFitDesireWeight" />
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label">Connection Weight</label>
                                <input type="number" class="form-control" step="0.05" min="0" max="1" @bind="_engineSettings.LegacyFitConnectionWeight" />
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label">Tension Weight</label>
                                <input type="number" class="form-control" step="0.05" min="0" max="1" @bind="_engineSettings.LegacyFitTensionWeight" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header"><strong>Candidate Scoring Weights</strong></div>
                    <div class="card-body">
                        <p class="text-muted small">Weights applied when blending character-alignment, narrative-evidence, and preference-priority scores. Should sum to 1.0.</p>
                        <div class="row g-3">
                            <div class="col-sm-4">
                                <label class="form-label">Character Alignment</label>
                                <input type="number" class="form-control" step="0.05" min="0" max="1" @bind="_engineSettings.CandidateCharacterAlignmentWeight" />
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label">Narrative Evidence</label>
                                <input type="number" class="form-control" step="0.05" min="0" max="1" @bind="_engineSettings.CandidateNarrativeEvidenceWeight" />
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label">Preference Priority</label>
                                <input type="number" class="form-control" step="0.05" min="0" max="1" @bind="_engineSettings.CandidatePreferencePriorityWeight" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header"><strong>Hysteresis / Tie-Break</strong></div>
                    <div class="card-body">
                        <p class="text-muted small">Controls how many consecutive cycles a candidate must lead before committing, and the FitScore delta that defines a near-tie.</p>
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label class="form-label">Near-Tie Threshold</label>
                                <input type="number" class="form-control" step="0.1" min="0" max="10" @bind="_engineSettings.NearTieThreshold" />
                                <div class="form-text">Default: 0.8. FitScore gap below which two candidates are treated as tied.</div>
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label">Required Consecutive Lead Count</label>
                                <input type="number" class="form-control" step="1" min="1" max="10" @bind="_engineSettings.RequiredConsecutiveLeadCount" />
                                <div class="form-text">Default: 2. Cycles a candidate must lead before committing when in a near-tie.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary" @onclick="SaveEngineSettingsAsync" disabled="@_isBusy">Save</button>
                    <button class="btn btn-outline-secondary" @onclick="ResetEngineSettingsAsync" disabled="@_isBusy">Reset to Defaults</button>
                </div>
            </div>
        </div>
    }
    else if (_activeTab == "beat-sheet")
    {
        <div class="row justify-content-center">
            <div class="col-lg-10">

                @if (!string.IsNullOrWhiteSpace(_beatSheetError))
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        @_beatSheetError
                        <button type="button" class="btn-close" @onclick="() => _beatSheetError = null"></button>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_beatSheetStatus))
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        @_beatSheetStatus
                        <button type="button" class="btn-close" @onclick="() => _beatSheetStatus = null"></button>
                    </div>
                }

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="text-muted mb-0 small">DB-backed beat sheet. Each row is one sub-beat in the physical escalation sequence (1a → 8g). The cursor advances automatically during Climax phase.</p>
                    <button class="btn btn-outline-danger btn-sm" @onclick="ResetBeatSheetAsync" disabled="@_isBusy">Reset to Defaults</button>

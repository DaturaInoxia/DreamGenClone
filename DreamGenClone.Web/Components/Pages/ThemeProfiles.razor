    {
        _toneError = null;
        if (string.IsNullOrWhiteSpace(_toneFormName.Trim()))
        {
            _toneError = "Intensity profile name is required.";
            return;
        }

        _isBusy = true;
        try
        {
            if (_selectedToneId is null)
            {
                var created = await Facade.CreateIntensityProfileAsync(
                    _toneFormName,
                    _toneFormDescription,
                    _toneFormIntensity,
                    _toneBuildUpOffset,
                    _toneCommittedOffset,
                    _toneApproachingOffset,
                    _toneClimaxOffset,
                    _toneResetOffset,
                    _toneFormSceneDirective);
                await ReloadAsync();
                SelectIntensity(created.Id);
            }
            else
            {
                await Facade.UpdateIntensityProfileAsync(
                    _selectedToneId,
                    _toneFormName,
                    _toneFormDescription,
                    _toneFormIntensity,
                    _toneBuildUpOffset,
                    _toneCommittedOffset,
                    _toneApproachingOffset,
                    _toneClimaxOffset,
                    _toneResetOffset,
                    _toneFormSceneDirective);
                await ReloadAsync();
                SelectIntensity(_selectedToneId);

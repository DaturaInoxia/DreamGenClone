                                        <th style="width: 150px;">From</th>
                                        <th style="width: 150px;">To</th>
                                        <th style="width: 220px;">Metric</th>
                                        <th style="width: 110px;">Compare</th>
                                        <th style="width: 120px;">Threshold</th>
                                        <th style="width: 80px;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!_narrativeGateFormRules.Any(rule => !IsClimaxResetThresholdRule(rule)))
                                    {
                                        <tr>
                                            <td colspan="6" class="text-muted">No gate rules yet. Add at least one rule.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @for (var i = 0; i < _narrativeGateFormRules.Count; i++)
                                        {
                                            var row = _narrativeGateFormRules[i];
                                            if (IsClimaxResetThresholdRule(row))
                                            {
                                                continue;
                                            }
                                            <tr>
                                                <td>
                                                    <select class="form-select form-select-sm" @bind="row.FromPhase">
                                                        @foreach (var option in _narrativeGatePhaseOptions)
                                                        {
                                                            <option value="@option">@option</option>
                                                        }
                                                    </select>
                                                </td>
                                                <td>
                                                    <select class="form-select form-select-sm" @bind="row.ToPhase">
                                                        @foreach (var option in _narrativeGatePhaseOptions)
                                                        {
                                                            <option value="@option">@option</option>
                                                        }
                                                    </select>
                                                </td>
                                                <td>
                                                    <select class="form-select form-select-sm" @bind="row.MetricKey">
                                                        @foreach (var option in _narrativeGateMetricOptions)
                                                        {
                                                            <option value="@option">@option</option>
                                                        }
                                                    </select>
                                                </td>
                                                <td>
                                                    <select class="form-select form-select-sm" @bind="row.Comparator">
                                                        @foreach (var option in _narrativeGateComparatorOptions)
                                                        {
                                                            <option value="@option">@option</option>
                                                        }
                                                    </select>
                                                </td>
                                                <td>
                                                    <input type="number" class="form-control form-control-sm" step="0.01" @bind="row.Threshold" />
                                                </td>
                                                <td>
                                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveNarrativeGateRule(i)">Remove</button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (!string.IsNullOrEmpty(_narrativeGateError))
                        {
                            <div class="text-danger mt-3 small">@_narrativeGateError</div>
                        }
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button class="btn btn-primary" @onclick="SaveNarrativeGateProfile" disabled="@_isBusy">@(_selectedNarrativeGateProfileId is null ? "Create Profile" : "Save Changes")</button>
                            <button class="btn btn-outline-secondary" @onclick="StartCreateNarrativeGateProfile" disabled="@_isBusy">Reset</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (_activeTab == "husband-awareness")

                                                </td>
                                                <td>
                                                    <input class="form-control form-control-sm" @bind="_editBeatSubBeatName" placeholder="Sub-Beat Name" />
                                                    <input class="form-control form-control-sm mt-1" @bind="_editBeatStageName" placeholder="Stage Name" />
                                                    <textarea class="form-control form-control-sm mt-1" rows="3" @bind="_editBeatHints" placeholder="Hints — one per line"></textarea>
                                                </td>
                                                <td>
                                                    @if (_editBeatMinTurns == int.MaxValue)
                                                    {
                                                        <input type="number" class="form-control form-control-sm" style="width:5rem" value="2147483647" disabled />
                                                    }
                                                    else
                                                    {
                                                        <input type="number" class="form-control form-control-sm" style="width:5rem" min="1" @bind="_editBeatMinTurns" />
                                                    }
                                                </td>
                                                <td>
                                                    <input class="form-control form-control-sm" @bind="_editBeatNextCode" placeholder="Next BeatCode or empty" />
                                                </td>
                                                <td>
                                                    <button class="btn btn-success btn-sm me-1" @onclick="SaveBeatEntryAsync" disabled="@_isBusy">Save</button>
                                                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelBeatEdit">Cancel</button>
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            <tr @onclick="() => StartBeatEdit(entry)" style="cursor:pointer">
                                                <td><code>@entry.BeatCode</code></td>
                                                <td><span class="badge bg-secondary">@entry.StageNumber — @entry.StageName</span></td>
                                                <td>@entry.SubBeatName</td>
                                                <td>@(entry.MinTurnsBeforeAdvance == int.MaxValue ? "∞" : entry.MinTurnsBeforeAdvance.ToString())</td>
                                                <td>@(entry.NextBeatCode ?? "—")</td>
                                                <td>
                                                    <button class="btn btn-outline-danger btn-sm" @onclick:stopPropagation="true" @onclick="() => DeleteBeatEntryAsync(entry.BeatCode)" disabled="@_isBusy">×</button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header"><strong>Add Entry</strong></div>
                    <div class="card-body">
                        <div class="row g-2 align-items-end">
                            <div class="col-auto">
                                <label class="form-label">Beat Code</label>
                                <input class="form-control form-control-sm" style="width:5rem" @bind="_newBeatCode" placeholder="e.g. 1c" />
                            </div>
                            <div class="col-auto">
                                <label class="form-label">Stage #</label>
                                <input type="number" class="form-control form-control-sm" style="width:4rem" min="1" max="8" @bind="_newBeatStageNumber" />
                            </div>
                            <div class="col">
                                <label class="form-label">Stage Name</label>
                                <input class="form-control form-control-sm" @bind="_newBeatStageName" placeholder="Stage Name" />
                            </div>
                            <div class="col">
                                <label class="form-label">Sub-Beat Name</label>
                                <input class="form-control form-control-sm" @bind="_newBeatSubBeatName" placeholder="Sub-Beat Name" />
                            </div>
                            <div class="col-auto">
                                <label class="form-label">Min Turns</label>
                                <input type="number" class="form-control form-control-sm" style="width:5rem" min="1" @bind="_newBeatMinTurns" />
                            </div>
                            <div class="col-auto">
                                <label class="form-label">Next Code</label>
                                <input class="form-control form-control-sm" style="width:5rem" @bind="_newBeatNextCode" placeholder="or empty" />
                            </div>
                        </div>
                        <div class="mt-2">
                            <label class="form-label">Hints (one per line)</label>
                            <textarea class="form-control form-control-sm" rows="3" @bind="_newBeatHints" placeholder="One hint per line"></textarea>
                        </div>
                        <div class="mt-2">
                            <button class="btn btn-primary btn-sm" @onclick="AddBeatEntryAsync" disabled="@_isBusy">Add Entry</button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    }
</div>


        if (_selectedRoleDefinitionId is null)
        {
            return;
        }

        _roleDefinitionError = null;
        _isBusy = true;
        try
        {
            await Facade.DeleteRoleDefinitionAsync(_selectedRoleDefinitionId);
            await ReloadAsync();
            if (_roleDefinitions.Count > 0)
            {
                SelectRoleDefinition(_roleDefinitions[0].Id);
            }
            else
            {
                StartCreateRoleDefinition();
            }
        }
        catch (Exception ex)
        {
            _roleDefinitionError = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private IReadOnlyList<string> GetAdaptiveRoleOptions(string? selectedRole = null)
    {
        var options = _roleDefinitions.Count > 0
            ? _roleDefinitions
                .Where(x => x.UseForAdaptiveProfiles)
                .Select(x => x.Name)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(x => x, StringComparer.OrdinalIgnoreCase)
                .ToList()
            : CharacterRoleCatalog.ProfileRoleOptions.ToList();

        var normalizedSelectedRole = CharacterRoleCatalog.Normalize(selectedRole);
        if (!string.IsNullOrWhiteSpace(normalizedSelectedRole)
            && !string.Equals(normalizedSelectedRole, CharacterRoleCatalog.Unknown, StringComparison.OrdinalIgnoreCase)
            && !options.Contains(normalizedSelectedRole, StringComparer.OrdinalIgnoreCase))
        {
            options.Add(normalizedSelectedRole);
        }

        return options;
    }

    private void StartCreateBackgroundCharacterProfile()
    {
        _selectedBackgroundCharacterProfileId = null;
        _backgroundCharacterFormName = string.Empty;
        _backgroundCharacterFormDescription = string.Empty;
        _backgroundCharacterError = null;
    }

    private void SelectBackgroundCharacterProfile(string profileId)
    {
        var profile = _backgroundCharacterProfiles.FirstOrDefault(x => x.Id == profileId);
        if (profile is null)
        {
            return;
        }

        _selectedBackgroundCharacterProfileId = profile.Id;
        _backgroundCharacterFormName = profile.Name;
        _backgroundCharacterFormDescription = profile.Description;
        _backgroundCharacterError = null;
    }

    private async Task SaveBackgroundCharacterProfile()
    {
        _backgroundCharacterError = null;
        var profile = new BackgroundCharacterProfile
        {
            Id = _selectedBackgroundCharacterProfileId ?? Guid.NewGuid().ToString(),
            Name = _backgroundCharacterFormName,
            Description = _backgroundCharacterFormDescription
        };

        _isBusy = true;
        try
        {
            var saved = await Facade.SaveBackgroundCharacterProfileAsync(profile);
            await ReloadAsync();
            SelectBackgroundCharacterProfile(saved.Id);

@page "/profiles"
@page "/profiles/{ProfileId}"
@page "/theme-profiles"
@page "/theme-profiles/{ProfileId}"
@page "/ranking-profiles"
@page "/ranking-profiles/{ProfileId}"
@rendermode InteractiveServer

@using DreamGenClone.Web.Application.StoryAnalysis
@using DreamGenClone.Application.StoryAnalysis
@using DreamGenClone.Application.StoryAnalysis.Models
@using DreamGenClone.Web.Domain.RolePlay
@using DreamGenClone.Domain.StoryAnalysis

@inject StoryAnalysisFacade Facade

<PageTitle>Profiles</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
            <h3 class="mb-1">Profiles</h3>
            <p class="text-muted mb-0">Manage theme, intensity, and writing-style profiles in one place, and keep Character Perspective Modes close at hand as a reference.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <span class="badge bg-primary-subtle text-primary-emphasis border">Theme: @_profiles.Count</span>
            <span class="badge bg-secondary-subtle text-secondary-emphasis border">Intensity: @_intensityProfiles.Count</span>
            <span class="badge bg-dark-subtle text-dark-emphasis border">Steering: @_steeringProfiles.Count</span>
            <span class="badge bg-info-subtle text-info-emphasis border">Catalog: @_catalogEntries.Count</span>
            <span class="badge bg-primary-subtle text-primary-emphasis border">Theme Definitions: @_themeDefinitions.Count</span>
            <span class="badge bg-success-subtle text-success-emphasis border">Character State: @_baseStatProfiles.Count</span>
            <span class="badge bg-light text-dark border">Perspective Modes: @CharacterPerspectiveModes.All.Count</span>
        </div>
    </div>

    <ul class="nav nav-pills flex-nowrap overflow-auto mb-4" role="tablist" style="gap:0.5rem; white-space:nowrap;">
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @GetTabClass("ranking")" @onclick='() => _activeTab = "ranking"'>Theme</button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @GetTabClass("tone")" @onclick='() => _activeTab = "tone"'>Intensity</button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @GetTabClass("style")" @onclick='() => _activeTab = "style"'>Writing Style</button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @GetTabClass("catalog")" @onclick='() => _activeTab = "catalog"'>Theme Catalog</button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @GetTabClass("definitions")" @onclick='() => _activeTab = "definitions"'>Theme Definitions</button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @GetTabClass("base-stats")" @onclick='() => _activeTab = "base-stats"'>Character State</button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @GetTabClass("perspective")" @onclick='() => _activeTab = "perspective"'>Perspective</button>
        </li>
    </ul>

    @if (_activeTab == "ranking")
    {
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Theme Profiles</span>
                        <button class="btn btn-sm btn-primary" @onclick="CreateProfile" disabled="@_isBusy">Create</button>
                    </div>
                    <div class="card-body">
                        @if (_profiles.Count > 0)
                        {
                            <div class="list-group">
                                @foreach (var profile in _profiles)
                                {
                                    var themeCount = _selectedProfileId == profile.Id ? _themes.Count : (int?)null;
                                    <button type="button"
                                            class="list-group-item list-group-item-action @(profile.Id == _selectedProfileId ? "active" : "")"
                                            @onclick="() => SelectProfile(profile.Id)">
                                        <div class="d-flex justify-content-between align-items-start gap-2">
                                            <div>
                                                <strong>@profile.Name</strong>
                                                @if (profile.IsDefault)
                                                {
                                                    <span class="badge bg-warning text-dark ms-1">Default</span>
                                                }
                                                <small class="d-block @(profile.Id == _selectedProfileId ? "text-light" : "text-muted")">
                                                    Created @profile.CreatedUtc.ToLocalTime().ToString("g")
                                                </small>
                                            </div>
                                            @if (themeCount.HasValue)
                                            {
                                                <span class="badge @(profile.Id == _selectedProfileId ? "bg-light text-dark" : "bg-secondary")">@themeCount.Value themes</span>
                                            }
                                        </div>
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No theme profiles yet. Create one to define what the story should lean toward.</p>
                        }

                        <div class="border rounded p-3 mt-3 bg-light-subtle">
                            <label class="form-label">New Theme Profile</label>
                            <div class="input-group input-group-sm">
                                <input type="text" class="form-control" placeholder="e.g. Voyeur Suspense" @bind="_newProfileName" />
                                <button class="btn btn-primary" @onclick="CreateProfile" disabled="@_isBusy">Add</button>
                            </div>
                            @if (!string.IsNullOrEmpty(_profileError))
                            {
                                <div class="text-danger mt-2 small">@_profileError</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                @if (_selectedProfile is not null)
                {
                    <div class="card">
                        <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                            <div>
                                @if (_isEditingProfileName)
                                {
                                    <div class="input-group input-group-sm" style="max-width: 420px;">
                                        <input type="text" class="form-control" @bind="_editProfileName" />
                                        <button class="btn btn-success" @onclick="SaveProfileName" disabled="@_isBusy">Save</button>
                                        <button class="btn btn-outline-secondary" @onclick="() => _isEditingProfileName = false">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex flex-wrap align-items-center gap-2">
                                        <strong>@_selectedProfile.Name</strong>
                                        @if (_selectedProfile.IsDefault)
                                        {
                                            <span class="badge bg-warning text-dark">Default</span>
                                        }
                                    </div>
                                    <small class="text-muted">Theme preferences shape ranking and prompt steering across the app.</small>
                                }
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                @if (!_isEditingProfileName)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="StartEditProfileName">Rename</button>
                                }
                                @if (!_selectedProfile.IsDefault)
                                {
                                    <button class="btn btn-sm btn-outline-warning" @onclick="SetAsDefault" disabled="@_isBusy">Set Default</button>
                                }
                                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteProfile" disabled="@_isBusy">Delete</button>
                            </div>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(_themeError))
                            {
                                <div class="alert alert-danger">@_themeError</div>
                            }

                            <h6>Theme Preferences</h6>
                            @if (_themes.Count > 0)
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Description</th>
                                                <th style="width: 170px;">Tier</th>
                                                <th style="width: 150px;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var theme in _themes)
                                            {
                                                if (_editingThemeId == theme.Id)
                                                {
                                                    <tr>
                                                        <td>
                                                            <select class="form-select form-select-sm" @bind="_editThemeCatalogId" @bind:after="OnEditCatalogChanged">
                                                                <option value="">-- Custom --</option>
                                                                @foreach (var entry in _catalogEntries)
                                                                {
                                                                    <option value="@entry.Id">@entry.Label</option>
                                                                }
                                                            </select>
                                                            @if (string.IsNullOrEmpty(_editThemeCatalogId))
                                                            {
                                                                <input type="text" class="form-control form-control-sm mt-1" @bind="_editThemeName" placeholder="Custom theme name" />
                                                            }
                                                        </td>
                                                        <td><input type="text" class="form-control form-control-sm" @bind="_editThemeDescription" /></td>
                                                        <td>
                                                            <select class="form-select form-select-sm" @bind="_editThemeTier">
                                                                @foreach (var tier in Enum.GetValues<ThemeTier>())
                                                                {
                                                                    <option value="@tier">@FormatTier(tier)</option>
                                                                }
                                                            </select>
                                                        </td>
                                                        <td>
                                                            <button class="btn btn-sm btn-success me-1" @onclick="SaveEditTheme" disabled="@_isBusy">Save</button>
                                                            <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditTheme">Cancel</button>
                                                        </td>
                                                    </tr>
                                                }
                                                else
                                                {
                                                    <tr>
                                                        <td>
                                                            @theme.Name
                                                            @if (string.IsNullOrWhiteSpace(theme.CatalogId))
                                                            {
                                                                <span class="badge bg-warning text-dark ms-1" title="Not linked to theme catalog">⚠ unlinked</span>
                                                            }
                                                        </td>
                                                        <td class="text-muted small">@theme.Description</td>
                                                        <td><span class="badge @GetTierBadgeClass(theme.Tier)">@FormatTier(theme.Tier)</span></td>
                                                        <td>
                                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartEditTheme(theme)" disabled="@_isBusy">Edit</button>
                                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTheme(theme.Id)" disabled="@_isBusy">Delete</button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">No theme preferences in this profile yet.</p>
                            }

                            <div class="border rounded p-3 mt-3 bg-light-subtle">
                                <h6 class="mb-3">Add Theme</h6>
                                <div class="row g-2 align-items-end">
                                    <div class="col-md-4">
                                        <label class="form-label">Theme</label>
                                        <select class="form-select form-select-sm" @bind="_newThemeCatalogId" @bind:after="OnNewCatalogChanged">
                                            <option value="">-- Custom --</option>
                                            @foreach (var entry in _catalogEntries)
                                            {
                                                <option value="@entry.Id">@entry.Label</option>
                                            }
                                        </select>
                                        @if (string.IsNullOrEmpty(_newThemeCatalogId))
                                        {
                                            <input type="text" class="form-control form-control-sm mt-1" @bind="_newThemeName" placeholder="Custom theme name" />
                                        }
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Description</label>
                                        <input type="text" class="form-control form-control-sm" @bind="_newThemeDescription" placeholder="LLM guidance for this theme" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label">Tier</label>
                                        <select class="form-select form-select-sm" @bind="_newThemeTier">
                                            @foreach (var tier in Enum.GetValues<ThemeTier>())
                                            {
                                                <option value="@tier">@FormatTier(tier)</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <button class="btn btn-sm btn-primary w-100" @onclick="AddTheme" disabled="@_isBusy">Add</button>
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(_themeValidationError))
                                {
                                    <div class="text-danger mt-2 small">@_themeValidationError</div>
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-body text-muted">Select a theme profile to edit its theme preferences.</div>
                    </div>
                }
            </div>
        </div>
    }
    else if (_activeTab == "tone")
    {
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Intensity Profiles</span>
                        <button class="btn btn-sm btn-primary" @onclick="StartCreateIntensity">New</button>
                    </div>
                    <div class="card-body">
                        @if (_intensityProfiles.Count > 0)
                        {
                            <div class="list-group">
                                @foreach (var tone in _intensityProfiles)
                                {
                                    <button type="button"
                                            class="list-group-item list-group-item-action @(tone.Id == _selectedToneId ? "active" : "")"
                                            @onclick="() => SelectIntensity(tone.Id)">
                                        <div class="d-flex justify-content-between align-items-start gap-2">
                                            <div>
                                                <strong>@DreamGenClone.Domain.StoryAnalysis.IntensityLadder.GetLabel(tone.Intensity)</strong>
                                                <small class="d-block @(tone.Id == _selectedToneId ? "text-light" : "text-muted")">@Truncate(tone.Description, 90)</small>
                                            </div>
                                            <span class="badge @(tone.Id == _selectedToneId ? "bg-light text-dark" : "bg-secondary")">@DreamGenClone.Domain.StoryAnalysis.IntensityLadder.GetLabel(tone.Intensity)</span>
                                        </div>
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No intensity profiles yet.</p>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@(_selectedToneId is null ? "Create Intensity Profile" : "Edit Intensity Profile")</strong>
                            <div class="text-muted small">Intensity profiles set the baseline rung on the shared intensity ladder and work with intensity floor and ceiling clamps.</div>
                        </div>
                        @if (_selectedToneId is not null)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="DeleteIntensity" disabled="@_isBusy">Delete</button>
                        }
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" @bind="_toneFormName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Intensity</label>
                                <select class="form-select" @bind="_toneFormIntensity">
                                    @foreach (var intensity in Enum.GetValues<IntensityLevel>())
                                    {
                                        <option value="@intensity">@DreamGenClone.Domain.StoryAnalysis.IntensityLadder.GetLabel(intensity)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" rows="3" @bind="_toneFormDescription"></textarea>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(_toneError))
                        {
                            <div class="text-danger mt-3 small">@_toneError</div>
                        }
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button class="btn btn-primary" @onclick="SaveIntensity" disabled="@_isBusy">@(_selectedToneId is null ? "Create Intensity Profile" : "Save Changes")</button>
                            <button class="btn btn-outline-secondary" @onclick="StartCreateIntensity" disabled="@_isBusy">Reset</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (_activeTab == "style")
    {
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Writing Style Profiles</span>
                        <button class="btn btn-sm btn-primary" @onclick="StartCreateSteering">New</button>
                    </div>
                    <div class="card-body">
                        @if (_steeringProfiles.Count > 0)
                        {
                            <div class="list-group">
                                @foreach (var style in _steeringProfiles)
                                {
                                    <button type="button"
                                            class="list-group-item list-group-item-action @(style.Id == _selectedStyleId ? "active" : "")"
                                            @onclick="() => SelectSteering(style.Id)">
                                        <strong>@style.Name</strong>
                                        <small class="d-block @(style.Id == _selectedStyleId ? "text-light" : "text-muted")">@Truncate(style.Description, 100)</small>
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No writing-style profiles yet.</p>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@(_selectedStyleId is null ? "Create Writing Style Profile" : "Edit Writing Style Profile")</strong>
                            <div class="text-muted small">Writing-style profiles capture prose voice, adaptive weighting, escalation behavior, and authoring guidance.</div>
                        </div>
                        @if (_selectedStyleId is not null)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSteering" disabled="@_isBusy">Delete</button>
                        }
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" @bind="_styleFormName" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" rows="3" @bind="_styleFormDescription"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Example</label>
                                <textarea class="form-control" rows="3" @bind="_styleFormExample"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Rule of Thumb</label>
                                <textarea class="form-control" rows="2" @bind="_styleFormRuleOfThumb"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Theme Affinities</label>
                                <div class="small text-muted mb-2">Set per-theme score multiplier bias (-10 to +10). Positive values boost that theme during scoring.</div>
                                @foreach (var entry in _catalogEntries)
                                {
                                    <div class="input-group input-group-sm mb-1" style="max-width: 400px;">
                                        <span class="input-group-text" style="min-width: 180px;">@entry.Label</span>
                                        <input type="number"
                                               class="form-control"
                                               min="-10"
                                               max="10"
                                               value="@GetThemeAffinityValue(entry.Id)"
                                               @onchange="@(e => SetThemeAffinityValue(entry.Id, e.Value?.ToString()))" />
                                    </div>
                                }
                            </div>
                            <div class="col-12">
                                <label class="form-label">Escalating Theme IDs</label>
                                <div class="small text-muted mb-2">Select themes considered escalating for this writing-style profile.</div>
                                @foreach (var entry in _catalogEntries)
                                {
                                    var isChecked = _styleFormEscalatingThemeIds.Contains(entry.Id);
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="esc-@entry.Id"
                                               checked="@isChecked"
                                               @onchange="@(e => ToggleEscalatingTheme(entry.Id, (bool)(e.Value ?? false)))" />
                                        <label class="form-check-label" for="esc-@entry.Id">@entry.Label</label>
                                    </div>
                                }
                            </div>
                            <div class="col-12">
                                <label class="form-label">Stat Bias</label>
                                <div class="small text-muted mb-2">Additive character-state bias applied to all characters when this writing-style profile is active (-20 to +20).</div>
                                @foreach (var statName in BaseStatNames)
                                {
                                    <div class="input-group input-group-sm mb-1" style="max-width: 400px;">
                                        <span class="input-group-text" style="min-width: 180px;">@statName</span>
                                        <input type="number"
                                               class="form-control"
                                               min="-20"
                                               max="20"
                                               value="@GetStatBiasValue(statName)"
                                               @onchange="@(e => SetStatBiasValue(statName, e.Value?.ToString()))" />
                                    </div>
                                }
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(_styleError))
                        {
                            <div class="text-danger mt-3 small">@_styleError</div>
                        }
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button class="btn btn-primary" @onclick="SaveSteering" disabled="@_isBusy">@(_selectedStyleId is null ? "Create Writing Style Profile" : "Save Changes")</button>
                            <button class="btn btn-outline-secondary" @onclick="StartCreateSteering" disabled="@_isBusy">Reset</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (_activeTab == "catalog")
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>Theme Catalog</strong>
                    <div class="text-muted small">Shared list of recognized themes used for scoring. Built-in entries cannot be deleted.</div>
                </div>
                <button class="btn btn-sm btn-primary" @onclick="StartAddCatalogEntry" disabled="@_isBusy">Add Entry</button>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(_catalogError))
                {
                    <div class="alert alert-danger">@_catalogError</div>
                }
                @if (_catalogEntries.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th style="width:160px;">Id</th>
                                    <th>Label</th>
                                    <th>Description</th>
                                    <th style="width:220px;">Keywords</th>
                                    <th style="width:140px;">Category</th>
                                    <th style="width:220px;">Stat Affinities</th>
                                    <th style="width:100px;">Weight</th>
                                    <th style="width:100px;">Enabled</th>
                                    <th style="width:160px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in _catalogEntries)
                                {
                                    if (_editingCatalogId == entry.Id)
                                    {
                                        <tr>
                                            <td><input type="text" class="form-control form-control-sm" value="@entry.Id" disabled /></td>
                                            <td><input type="text" class="form-control form-control-sm" @bind="_editCatalogLabel" /></td>
                                            <td><input type="text" class="form-control form-control-sm" @bind="_editCatalogDescription" /></td>
                                            <td><textarea class="form-control form-control-sm" rows="2" @bind="_editCatalogKeywordsText"></textarea></td>
                                            <td><input type="text" class="form-control form-control-sm" @bind="_editCatalogCategory" /></td>
                                            <td>
                                                @foreach (var statName in BaseStatNames)
                                                {
                                                    <div class="input-group input-group-sm mb-1">
                                                        <span class="input-group-text" style="min-width: 100px;">@statName</span>
                                                        <input type="number"
                                                               class="form-control"
                                                               min="-5"
                                                               max="5"
                                                               value="@GetEditCatalogStatAffinityValue(statName)"
                                                               @onchange="@(e => SetEditCatalogStatAffinityValue(statName, e.Value?.ToString()))" />
                                                    </div>
                                                }
                                            </td>
                                            <td><input type="number" class="form-control form-control-sm" min="1" max="10" @bind="_editCatalogWeight" /></td>
                                            <td>
                                                <select class="form-select form-select-sm" @bind="_editCatalogEnabled">
                                                    <option value="True">Yes</option>
                                                    <option value="False">No</option>
                                                </select>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-success me-1" @onclick="SaveEditCatalogEntry" disabled="@_isBusy">Save</button>
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditCatalogEntry">Cancel</button>
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        <tr class="@(entry.IsEnabled ? "" : "table-secondary")">
                                            <td>
                                                <code>@entry.Id</code>
                                            </td>
                                            <td>
                                                @entry.Label
                                                @if (entry.IsBuiltIn)
                                                {
                                                    <span class="badge bg-info text-dark ms-1">built-in</span>
                                                }
                                            </td>
                                            <td class="text-muted small">@Truncate(entry.Description, 80)</td>
                                            <td class="text-muted small">@FormatKeywords(entry.Keywords)</td>
                                            <td class="text-muted small">@entry.Category</td>
                                            <td class="text-muted small">@FormatStatAffinities(entry.StatAffinities)</td>

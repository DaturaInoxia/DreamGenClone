    // Catalog management
    private void StartAddCatalogEntry()
    {
        _isAddingCatalog = true;
        _catalogError = null;
        _newCatalogId = string.Empty;
        _newCatalogLabel = string.Empty;
        _newCatalogDescription = string.Empty;
        _newCatalogKeywordsText = string.Empty;
        _newCatalogCategory = string.Empty;
        _newCatalogStatAffinities = new(StringComparer.OrdinalIgnoreCase);
        _newCatalogWeight = 3;
    }

    private async Task AddCatalogEntry()
    {
        _catalogError = null;
        if (string.IsNullOrWhiteSpace(_newCatalogLabel))
        {
            _catalogError = "Label is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_newCatalogKeywordsText))
        {
            _catalogError = "At least one keyword is required for enabled catalog entries.";
            return;
        }

        _isBusy = true;
        try
        {
            var entry = new ThemeCatalogEntry
            {
                Id = string.IsNullOrWhiteSpace(_newCatalogId) ? Slugify(_newCatalogLabel) : _newCatalogId.Trim().ToLowerInvariant(),
                Label = _newCatalogLabel.Trim(),
                Description = _newCatalogDescription.Trim(),
                Keywords = ParseKeywordList(_newCatalogKeywordsText),
                Category = _newCatalogCategory.Trim(),
                StatAffinities = BuildFilteredAffinities(_newCatalogStatAffinities),
                Weight = _newCatalogWeight,
                IsEnabled = true,
                IsBuiltIn = false,
                CreatedUtc = DateTime.UtcNow,
                UpdatedUtc = DateTime.UtcNow
            };
            await Facade.SaveCatalogEntryAsync(entry);
            _isAddingCatalog = false;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _catalogError = ex.Message;
        }
        finally { _isBusy = false; }
    }

    private void StartEditCatalogEntry(ThemeCatalogEntry entry)
    {
        _editingCatalogId = entry.Id;
        _editCatalogLabel = entry.Label;
        _editCatalogDescription = entry.Description;
        _editCatalogKeywordsText = string.Join(", ", entry.Keywords);
        _editCatalogCategory = entry.Category;
        _editCatalogStatAffinities = new(entry.StatAffinities, StringComparer.OrdinalIgnoreCase);
        _editCatalogWeight = entry.Weight;
        _editCatalogEnabled = entry.IsEnabled;
        _catalogError = null;
    }


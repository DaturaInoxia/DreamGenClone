    private async Task ReloadAsync()
    {
        _profiles = await Facade.ListProfilesAsync();
        _intensityProfiles = (await Facade.ListIntensityProfilesAsync())
            .Where(x => x.Intensity != IntensityLevel.Intro)
            .ToList();
        _steeringProfiles = await Facade.ListSteeringProfilesAsync();
        _baseStatProfiles = await Facade.ListBaseStatProfilesAsync();
        _scenarioDefinitions = (await Facade.ListScenarioDefinitionsAsync(includeDisabled: true)).ToList();
        _willingnessProfiles = await Facade.ListStatWillingnessProfilesAsync();
        _narrativeGateProfiles = await Facade.ListNarrativeGateProfilesAsync();
        _husbandAwarenessProfiles = await Facade.ListHusbandAwarenessProfilesAsync();
        _roleDefinitions = await Facade.ListRoleDefinitionsAsync();
        _backgroundCharacterProfiles = await Facade.ListBackgroundCharacterProfilesAsync();
        _catalogEntries = await Facade.ListCatalogEntriesAsync(includeDisabled: true);

        try

        _isBusy = true;
        try
        {
            if (_selectedBaseStatProfileId is null)
            {
                var created = await Facade.CreateBaseStatProfileAsync(_baseStatFormName, _baseStatFormDescription, _baseStatFormStats);
                await ReloadAsync();
                SelectBaseStatProfile(created.Id);
            }
            else
            {
                await Facade.UpdateBaseStatProfileAsync(_selectedBaseStatProfileId, _baseStatFormName, _baseStatFormDescription, _baseStatFormStats);

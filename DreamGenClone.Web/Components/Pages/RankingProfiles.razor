    private static readonly string[] BaseStatNames = GetBaseStatNames();

    protected override async Task OnParametersSetAsync()
    {
        await ReloadAsync();

        if (!string.IsNullOrWhiteSpace(ProfileId))
        {
            await SelectProfile(ProfileId);
        }
        else if (_selectedProfileId is null && _profiles.Count > 0)
        {
            await SelectProfile(_profiles[0].Id);
        }

        if (_selectedToneId is null && _toneProfiles.Count > 0)
        {
            SelectTone(_toneProfiles[0].Id);
        }

        if (_selectedStyleId is null && _styleProfiles.Count > 0)
        {
            SelectStyle(_styleProfiles[0].Id);
        }

        if (_selectedBaseStatProfileId is null && _baseStatProfiles.Count > 0)
        {
            SelectBaseStatProfile(_baseStatProfiles[0].Id);
        }
        else if (_selectedBaseStatProfileId is null && _baseStatProfiles.Count == 0)
        {
            StartCreateBaseStatProfile();
        }
    }

    private static string[] GetBaseStatNames()
    {
        return AdaptiveStatCatalog.CanonicalStatNames.ToArray();
    }

    private async Task ReloadAsync()
    {
        _profiles = await Facade.ListProfilesAsync();
        _toneProfiles = await Facade.ListToneProfilesAsync();
        _styleProfiles = await Facade.ListStyleProfilesAsync();
        _baseStatProfiles = await Facade.ListBaseStatProfilesAsync();
    }

    private string GetTabClass(string tab) => _activeTab == tab ? "active" : string.Empty;

    private async Task SelectProfile(string profileId)
    {
        _selectedProfileId = profileId;
        _selectedProfile = _profiles.FirstOrDefault(x => x.Id == profileId);
        _themes = _selectedProfile is not null
            ? await Facade.ListThemesByProfileAsync(profileId)
            : [];
        _editingThemeId = null;
        _themeError = null;
        _themeValidationError = null;
    }

    private async Task CreateProfile()
    {
        _profileError = null;
        var name = _newProfileName.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            _profileError = "Name is required.";
            return;
        }

        _isBusy = true;
        try
        {
            var profile = await Facade.CreateProfileAsync(name);
            await ReloadAsync();
            _newProfileName = string.Empty;
            await SelectProfile(profile.Id);
        }
        catch (Exception ex)
        {
            _profileError = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void StartEditProfileName()
    {
        _isEditingProfileName = true;
        _editProfileName = _selectedProfile?.Name ?? string.Empty;
    }

    private async Task SaveProfileName()
    {
        if (_selectedProfileId is null)
        {
            return;
        }

        _profileError = null;
        _isBusy = true;
        try
        {
            await Facade.UpdateProfileAsync(_selectedProfileId, _editProfileName);
            await ReloadAsync();
            _selectedProfile = _profiles.FirstOrDefault(x => x.Id == _selectedProfileId);
            _isEditingProfileName = false;
        }
        catch (Exception ex)
        {
            _profileError = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task DeleteProfile()
    {
        if (_selectedProfileId is null)
        {
            return;
        }

        _profileError = null;
        _isBusy = true;
        try
        {
            await Facade.DeleteProfileAsync(_selectedProfileId);
            await ReloadAsync();
            _selectedProfileId = null;
            _selectedProfile = null;
            _themes = [];
            if (_profiles.Count > 0)
            {
                await SelectProfile(_profiles[0].Id);
            }
        }
        catch (Exception ex)
        {
            _profileError = ex.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }


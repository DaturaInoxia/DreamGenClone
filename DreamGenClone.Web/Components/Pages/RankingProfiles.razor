    private void StartCreateBaseStatProfile()
    {
        _selectedBaseStatProfileId = null;
        _baseStatFormName = string.Empty;
        _baseStatFormDescription = string.Empty;
        _baseStatError = null;
        _baseStatFormStats = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        foreach (var statName in BaseStatNames)
        {
            _baseStatFormStats[statName] = 50;
        }
    }

    private void SelectBaseStatProfile(string profileId)
    {
        var profile = _baseStatProfiles.FirstOrDefault(x => x.Id == profileId);
        if (profile is null)
        {
            return;
        }

        _selectedBaseStatProfileId = profile.Id;
        _baseStatFormName = profile.Name;
        _baseStatFormDescription = profile.Description;
        _baseStatError = null;
        _baseStatFormStats = new Dictionary<string, int>(profile.DefaultStats, StringComparer.OrdinalIgnoreCase);
        foreach (var statName in BaseStatNames)
        {
            if (!_baseStatFormStats.ContainsKey(statName))
            {
                _baseStatFormStats[statName] = 50;
            }
        }
    }

    private async Task SaveBaseStatProfile()
    {
        _baseStatError = null;
        if (string.IsNullOrWhiteSpace(_baseStatFormName.Trim()))
        {
            _baseStatError = "Base stat profile name is required.";
            return;

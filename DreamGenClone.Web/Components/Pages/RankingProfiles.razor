@page "/profiles"
@page "/profiles/{ProfileId}"
@page "/ranking-profiles"
@page "/ranking-profiles/{ProfileId}"
@rendermode InteractiveServer

@using DreamGenClone.Web.Application.StoryAnalysis
@using DreamGenClone.Application.StoryAnalysis
@using DreamGenClone.Web.Domain.RolePlay
@using DreamGenClone.Domain.StoryAnalysis

@inject StoryAnalysisFacade Facade

<PageTitle>Profiles</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
            <h3 class="mb-1">Profiles</h3>
            <p class="text-muted mb-0">Manage ranking, tone, and style profiles in one place, and keep Character Perspective Modes close at hand as a reference.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <span class="badge bg-primary-subtle text-primary-emphasis border">Ranking: @_profiles.Count</span>
            <span class="badge bg-secondary-subtle text-secondary-emphasis border">Tone: @_toneProfiles.Count</span>
            <span class="badge bg-dark-subtle text-dark-emphasis border">Style: @_styleProfiles.Count</span>
            <span class="badge bg-success-subtle text-success-emphasis border">Base Stats: @_baseStatProfiles.Count</span>
            <span class="badge bg-light text-dark border">Perspective Modes: @CharacterPerspectiveModes.All.Count</span>
        </div>
    </div>

    <ul class="nav nav-pills flex-nowrap overflow-auto mb-4" role="tablist" style="gap:0.5rem; white-space:nowrap;">
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @GetTabClass("ranking")" @onclick='() => _activeTab = "ranking"'>Ranking</button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @GetTabClass("tone")" @onclick='() => _activeTab = "tone"'>Tone</button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @GetTabClass("style")" @onclick='() => _activeTab = "style"'>Style</button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @GetTabClass("base-stats")" @onclick='() => _activeTab = "base-stats"'>Base Stats</button>
        </li>
        <li class="nav-item" role="presentation">
            <button type="button" class="nav-link @GetTabClass("perspective")" @onclick='() => _activeTab = "perspective"'>Perspective</button>
        </li>
    </ul>

    @if (_activeTab == "ranking")
    {
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Ranking Profiles</span>
                        <button class="btn btn-sm btn-primary" @onclick="CreateProfile" disabled="@_isBusy">Create</button>
                    </div>
                    <div class="card-body">
                        @if (_profiles.Count > 0)
                        {
                            <div class="list-group">
                                @foreach (var profile in _profiles)
                                {
                                    var themeCount = _selectedProfileId == profile.Id ? _themes.Count : (int?)null;
                                    <button type="button"
                                            class="list-group-item list-group-item-action @(profile.Id == _selectedProfileId ? "active" : "")"
                                            @onclick="() => SelectProfile(profile.Id)">
                                        <div class="d-flex justify-content-between align-items-start gap-2">
                                            <div>
                                                <strong>@profile.Name</strong>
                                                @if (profile.IsDefault)
                                                {
                                                    <span class="badge bg-warning text-dark ms-1">Default</span>
                                                }
                                                <small class="d-block @(profile.Id == _selectedProfileId ? "text-light" : "text-muted")">
                                                    Created @profile.CreatedUtc.ToLocalTime().ToString("g")
                                                </small>
                                            </div>
                                            @if (themeCount.HasValue)
                                            {
                                                <span class="badge @(profile.Id == _selectedProfileId ? "bg-light text-dark" : "bg-secondary")">@themeCount.Value themes</span>
                                            }
                                        </div>
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No ranking profiles yet. Create one to start steering themes.</p>
                        }

                        <div class="border rounded p-3 mt-3 bg-light-subtle">
                            <label class="form-label">New Ranking Profile</label>
                            <div class="input-group input-group-sm">
                                <input type="text" class="form-control" placeholder="e.g. Voyeur Suspense" @bind="_newProfileName" />
                                <button class="btn btn-primary" @onclick="CreateProfile" disabled="@_isBusy">Add</button>
                            </div>
                            @if (!string.IsNullOrEmpty(_profileError))
                            {
                                <div class="text-danger mt-2 small">@_profileError</div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                @if (_selectedProfile is not null)
                {
                    <div class="card">
                        <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                            <div>
                                @if (_isEditingProfileName)
                                {
                                    <div class="input-group input-group-sm" style="max-width: 420px;">
                                        <input type="text" class="form-control" @bind="_editProfileName" />
                                        <button class="btn btn-success" @onclick="SaveProfileName" disabled="@_isBusy">Save</button>
                                        <button class="btn btn-outline-secondary" @onclick="() => _isEditingProfileName = false">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex flex-wrap align-items-center gap-2">
                                        <strong>@_selectedProfile.Name</strong>
                                        @if (_selectedProfile.IsDefault)
                                        {
                                            <span class="badge bg-warning text-dark">Default</span>
                                        }
                                    </div>
                                    <small class="text-muted">Theme preferences shape ranking and prompt steering across the app.</small>
                                }
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                @if (!_isEditingProfileName)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="StartEditProfileName">Rename</button>
                                }
                                @if (!_selectedProfile.IsDefault)
                                {
                                    <button class="btn btn-sm btn-outline-warning" @onclick="SetAsDefault" disabled="@_isBusy">Set Default</button>
                                }
                                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteProfile" disabled="@_isBusy">Delete</button>
                            </div>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(_themeError))
                            {
                                <div class="alert alert-danger">@_themeError</div>
                            }

                            <h6>Theme Preferences</h6>
                            @if (_themes.Count > 0)
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead>
                                            <tr>
                                                <th>Name</th>
                                                <th>Description</th>
                                                <th style="width: 170px;">Tier</th>
                                                <th style="width: 150px;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var theme in _themes)
                                            {
                                                if (_editingThemeId == theme.Id)
                                                {
                                                    <tr>
                                                        <td><input type="text" class="form-control form-control-sm" @bind="_editThemeName" /></td>
                                                        <td><input type="text" class="form-control form-control-sm" @bind="_editThemeDescription" /></td>
                                                        <td>
                                                            <select class="form-select form-select-sm" @bind="_editThemeTier">
                                                                @foreach (var tier in Enum.GetValues<ThemeTier>())
                                                                {
                                                                    <option value="@tier">@FormatTier(tier)</option>
                                                                }
                                                            </select>
                                                        </td>
                                                        <td>
                                                            <button class="btn btn-sm btn-success me-1" @onclick="SaveEditTheme" disabled="@_isBusy">Save</button>
                                                            <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEditTheme">Cancel</button>
                                                        </td>
                                                    </tr>
                                                }
                                                else
                                                {
                                                    <tr>
                                                        <td>@theme.Name</td>
                                                        <td class="text-muted small">@theme.Description</td>
                                                        <td><span class="badge @GetTierBadgeClass(theme.Tier)">@FormatTier(theme.Tier)</span></td>
                                                        <td>
                                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => StartEditTheme(theme)" disabled="@_isBusy">Edit</button>
                                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTheme(theme.Id)" disabled="@_isBusy">Delete</button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">No theme preferences in this profile yet.</p>
                            }

                            <div class="border rounded p-3 mt-3 bg-light-subtle">
                                <h6 class="mb-3">Add Theme</h6>
                                <div class="row g-2 align-items-end">
                                    <div class="col-md-4">
                                        <label class="form-label">Name</label>
                                        <input type="text" class="form-control form-control-sm" @bind="_newThemeName" placeholder="e.g. Slow-burn secrecy" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Description</label>
                                        <input type="text" class="form-control form-control-sm" @bind="_newThemeDescription" placeholder="LLM guidance for this theme" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label">Tier</label>
                                        <select class="form-select form-select-sm" @bind="_newThemeTier">
                                            @foreach (var tier in Enum.GetValues<ThemeTier>())
                                            {
                                                <option value="@tier">@FormatTier(tier)</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <button class="btn btn-sm btn-primary w-100" @onclick="AddTheme" disabled="@_isBusy">Add</button>
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(_themeValidationError))
                                {
                                    <div class="text-danger mt-2 small">@_themeValidationError</div>
                                }
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-body text-muted">Select a ranking profile to edit its theme preferences.</div>
                    </div>
                }
            </div>
        </div>
    }
    else if (_activeTab == "tone")
    {
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Tone Profiles</span>
                        <button class="btn btn-sm btn-primary" @onclick="StartCreateTone">New</button>
                    </div>
                    <div class="card-body">
                        @if (_toneProfiles.Count > 0)
                        {
                            <div class="list-group">
                                @foreach (var tone in _toneProfiles)
                                {
                                    <button type="button"
                                            class="list-group-item list-group-item-action @(tone.Id == _selectedToneId ? "active" : "")"
                                            @onclick="() => SelectTone(tone.Id)">
                                        <div class="d-flex justify-content-between align-items-start gap-2">
                                            <div>
                                                <strong>@tone.Name</strong>
                                                <small class="d-block @(tone.Id == _selectedToneId ? "text-light" : "text-muted")">@Truncate(tone.Description, 90)</small>
                                            </div>
                                            <span class="badge @(tone.Id == _selectedToneId ? "bg-light text-dark" : "bg-secondary")">@tone.Intensity</span>
                                        </div>
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No tone profiles yet.</p>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@(_selectedToneId is null ? "Create Tone Profile" : "Edit Tone Profile")</strong>
                            <div class="text-muted small">Tone profiles set the emotional intensity baseline and adaptive style floor or ceiling behavior.</div>
                        </div>
                        @if (_selectedToneId is not null)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="DeleteTone" disabled="@_isBusy">Delete</button>
                        }
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" @bind="_toneFormName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Intensity</label>
                                <select class="form-select" @bind="_toneFormIntensity">
                                    @foreach (var intensity in Enum.GetValues<ToneIntensity>())
                                    {
                                        <option value="@intensity">@intensity</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" rows="3" @bind="_toneFormDescription"></textarea>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(_toneError))
                        {
                            <div class="text-danger mt-3 small">@_toneError</div>
                        }
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button class="btn btn-primary" @onclick="SaveTone" disabled="@_isBusy">@(_selectedToneId is null ? "Create Tone" : "Save Changes")</button>
                            <button class="btn btn-outline-secondary" @onclick="StartCreateTone" disabled="@_isBusy">Reset</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (_activeTab == "style")
    {
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Style Profiles</span>
                        <button class="btn btn-sm btn-primary" @onclick="StartCreateStyle">New</button>
                    </div>
                    <div class="card-body">
                        @if (_styleProfiles.Count > 0)
                        {
                            <div class="list-group">
                                @foreach (var style in _styleProfiles)
                                {
                                    <button type="button"
                                            class="list-group-item list-group-item-action @(style.Id == _selectedStyleId ? "active" : "")"
                                            @onclick="() => SelectStyle(style.Id)">
                                        <strong>@style.Name</strong>
                                        <small class="d-block @(style.Id == _selectedStyleId ? "text-light" : "text-muted")">@Truncate(style.Description, 100)</small>
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No style profiles yet.</p>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@(_selectedStyleId is null ? "Create Style Profile" : "Edit Style Profile")</strong>
                            <div class="text-muted small">Styles capture reusable writing voice, example phrasing, and a simple rule of thumb for authors and prompts.</div>
                        </div>
                        @if (_selectedStyleId is not null)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="DeleteStyle" disabled="@_isBusy">Delete</button>
                        }
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" @bind="_styleFormName" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" rows="3" @bind="_styleFormDescription"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Example</label>
                                <textarea class="form-control" rows="3" @bind="_styleFormExample"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Rule of Thumb</label>
                                <textarea class="form-control" rows="2" @bind="_styleFormRuleOfThumb"></textarea>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(_styleError))
                        {
                            <div class="text-danger mt-3 small">@_styleError</div>
                        }
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button class="btn btn-primary" @onclick="SaveStyle" disabled="@_isBusy">@(_selectedStyleId is null ? "Create Style" : "Save Changes")</button>
                            <button class="btn btn-outline-secondary" @onclick="StartCreateStyle" disabled="@_isBusy">Reset</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (_activeTab == "base-stats")
    {
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Base Stat Profiles</span>
                        <button class="btn btn-sm btn-primary" @onclick="StartCreateBaseStatProfile">New</button>
                    </div>
                    <div class="card-body">
                        @if (_baseStatProfiles.Count > 0)
                        {
                            <div class="list-group">
                                @foreach (var profile in _baseStatProfiles)
                                {
                                    <button type="button"
                                            class="list-group-item list-group-item-action @(profile.Id == _selectedBaseStatProfileId ? "active" : "")"
                                            @onclick="() => SelectBaseStatProfile(profile.Id)">
                                        <strong>@profile.Name</strong>
                                        <small class="d-block @(profile.Id == _selectedBaseStatProfileId ? "text-light" : "text-muted")">@Truncate(profile.Description, 100)</small>
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No base stat profiles yet.</p>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@(_selectedBaseStatProfileId is null ? "Create Base Stat Profile" : "Edit Base Stat Profile")</strong>
                            <div class="text-muted small">Defines default per-character stat seeds for scenario session initialization.</div>
                        </div>
                        @if (_selectedBaseStatProfileId is not null)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="DeleteBaseStatProfile" disabled="@_isBusy">Delete</button>
                        }
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" @bind="_baseStatFormName" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">Description</label>
                                <textarea class="form-control" rows="2" @bind="_baseStatFormDescription"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Default Stats</label>
                                @foreach (var statName in BaseStatNames)
                                {
                                    <div class="input-group input-group-sm mb-2" style="max-width: 360px;">
                                        <span class="input-group-text" style="min-width: 140px;">@statName</span>
                                        <input type="number"
                                               class="form-control"
                                               min="0"
                                               max="100"
                                               value="@GetBaseStatValue(statName)"
                                               @onchange="@(e => SetBaseStatValue(statName, e.Value?.ToString()))" />
                                    </div>
                                }

                                <div class="border rounded p-3 mt-3 bg-light-subtle">
                                    <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                                        <strong>Adaptive Stat Guide</strong>
                                        <span class="badge bg-secondary-subtle text-secondary-emphasis border">Default seed: 50</span>
                                    </div>

                                    <div class="row g-2">
                                        @foreach (var stat in AdaptiveStatCatalog.CanonicalStats)
                                        {
                                            <div class="col-12 col-md-6">
                                                <div class="border rounded p-2 h-100 bg-white">
                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                        <strong>@stat.Name</strong>
                                                        <span class="badge bg-light text-dark border">@stat.DefaultValue</span>
                                                    </div>
                                                    <div class="small text-muted mb-1">@stat.Description</div>
                                                    <div class="small"><span class="text-muted">Low:</span> @stat.LowMeaning</div>
                                                    <div class="small"><span class="text-muted">High:</span> @stat.HighMeaning</div>
                                                    @if (StatEngineEffects.TryGetValue(stat.Name, out var effect))
                                                    {
                                                        <div class="small mt-1"><span class="text-muted">Engine:</span> @effect</div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    <div class="mt-3">
                                        <div class="fw-semibold mb-1">Interaction Patterns</div>
                                        <ul class="small mb-0">
                                            @foreach (var interaction in StatInteractionPatterns)
                                            {
                                                <li><strong>@interaction.Pair:</strong> @interaction.Effect</li>
                                            }
                                        </ul>
                                    </div>

                                    <div class="mt-3">
                                        <div class="fw-semibold mb-1">Cross-Character Behavior (Current)</div>
                                        <ul class="small mb-0">
                                            @foreach (var note in CrossCharacterBehaviorNotes)
                                            {
                                                <li>@note</li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(_baseStatError))
                        {
                            <div class="text-danger mt-3 small">@_baseStatError</div>
                        }
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button class="btn btn-primary" @onclick="SaveBaseStatProfile" disabled="@_isBusy">@(_selectedBaseStatProfileId is null ? "Create Profile" : "Save Changes")</button>
                            <button class="btn btn-outline-secondary" @onclick="StartCreateBaseStatProfile" disabled="@_isBusy">Reset</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var mode in CharacterPerspectiveModes.All)
            {
                <div class="col-12 col-md-6">
                    <div class="card h-100 border-secondary-subtle">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <strong>@mode.DisplayName</strong>
                            <span class="badge bg-dark-subtle text-dark-emphasis border">Reference</span>
                        </div>
                        <div class="card-body d-flex flex-column gap-3">
                            <div>
                                <div class="text-muted small text-uppercase mb-1">Description</div>
                                <div>@mode.Description</div>
                            </div>
                            <div>
                                <div class="text-muted small text-uppercase mb-1">Example</div>
                                <div class="fst-italic">@mode.Example</div>
                            </div>
                            <div>
                                <div class="text-muted small text-uppercase mb-1">Rule of Thumb</div>
                                <div>@mode.RuleOfThumb</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public string? ProfileId { get; set; }

    private string _activeTab = "ranking";
    private bool _isBusy;

    private List<RankingProfile> _profiles = [];
    private string? _selectedProfileId;
    private RankingProfile? _selectedProfile;
    private List<ThemePreference> _themes = [];
    private string _newProfileName = string.Empty;
    private string? _profileError;
    private bool _isEditingProfileName;
    private string _editProfileName = string.Empty;
    private string? _themeError;
    private string? _themeValidationError;
    private string _newThemeName = string.Empty;
    private string _newThemeDescription = string.Empty;
    private ThemeTier _newThemeTier = ThemeTier.NiceToHave;
    private string? _editingThemeId;
    private string _editThemeName = string.Empty;
    private string _editThemeDescription = string.Empty;
    private ThemeTier _editThemeTier = ThemeTier.NiceToHave;

    private List<ToneProfile> _toneProfiles = [];
    private string? _selectedToneId;
    private string _toneFormName = string.Empty;
    private string _toneFormDescription = string.Empty;
    private ToneIntensity _toneFormIntensity = ToneIntensity.Emotional;

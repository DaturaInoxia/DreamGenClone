    }

    private void ApplyCharacterProfile(Character character)
    {
        var selectedProfileId = GetCharacterProfileSelection(character);
        if (string.IsNullOrWhiteSpace(selectedProfileId))
        {
            return;
        }

        var profile = BaseStatProfiles.FirstOrDefault(x =>
            string.Equals(x.Id, selectedProfileId, StringComparison.OrdinalIgnoreCase)
            && CharacterGenderCatalog.IsProfileApplicableToCharacter(x.TargetGender, character.Gender)
            && CharacterRoleCatalog.IsProfileApplicableToCharacter(x.TargetRole, character.Role));
        if (profile is null)
        {
            return;
        }

        character.BaseStats = AdaptiveStatCatalog.NormalizeComplete(profile.DefaultStats);
        character.Gender = CharacterGenderCatalog.NormalizeForCharacter(profile.TargetGender);
        character.Role = CharacterRoleCatalog.Normalize(profile.TargetRole);
    }
    
    private void AddLocation(string name, string? templateId, string? description)
    {
        var location = new Location
        {
            Name = name,
            Description = description,
            TemplateId = templateId
        };
        
        CurrentScenario?.Locations.Add(location);
    }
    
    private void OnLocationCreated(DreamGenClone.Components.Scenarios.ScenarioEntityPicker.EntityCreatedArgs args)
    {
        AddLocation(args.Name, args.TemplateId, args.Description);
    }
    
    private void AddObject(string name, string? templateId, string? description)
    {
        var obj = new ScenarioObject
        {
            Name = name,
            Description = description,
            TemplateId = templateId
        };
        
        CurrentScenario?.Objects.Add(obj);
    }
    
    private void OnObjectCreated(DreamGenClone.Components.Scenarios.ScenarioEntityPicker.EntityCreatedArgs args)
    {

    private void RecalculateTokenCount()
    {
        if (CurrentScenario != null)
        {
            CurrentScenario.EstimatedTokenCount = TokenCounter.CalculateTokenCount(CurrentScenario);
            StateHasChanged();
        }
    }
    
    private async Task SaveScenario()
    {
        if (CurrentScenario != null)
        {
            EnsureBaseStatsInitialized();
            await ResolveScenarioBaseStatsAsync();
            RecalculateTokenCount();
            await ScenarioService.SaveScenarioAsync(CurrentScenario);
            Navigation.NavigateTo("/scenarios");
        }
    }

    private async Task ResolveScenarioBaseStatsAsync()
    {
        if (CurrentScenario is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(CurrentScenario.BaseStatProfileId))
        {
            CurrentScenario.ResolvedBaseStats.Clear();
            return;
        }

        var profile = await StoryAnalysisFacade.GetBaseStatProfileAsync(CurrentScenario.BaseStatProfileId);
        CurrentScenario.ResolvedBaseStats = profile is null
            ? new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase)
            : AdaptiveStatCatalog.NormalizeComplete(profile.DefaultStats);
    }

    private void EnsureBaseStatsInitialized()
    {
        if (CurrentScenario is null)
        {
            return;
        }

        foreach (var character in CurrentScenario.Characters)
        {
            EnsureBaseStats(character);
        }
    }

    private static void EnsureBaseStats(Character character)
    {
        character.Gender = CharacterGenderCatalog.NormalizeForCharacter(character.Gender);
        character.BaseStats = AdaptiveStatCatalog.NormalizeComplete(character.BaseStats);
    }

    private static int GetCharacterStat(Character character, string statName)
    {
        if (!character.BaseStats.TryGetValue(statName, out var value))
        {
            value = 50;
            character.BaseStats[statName] = value;
        }

        return value;
    }

    private static void SetCharacterStat(Character character, string statName, string? rawValue)
    {
        if (!int.TryParse(rawValue, out var value))
        {
            value = 50;
        }

        character.BaseStats[statName] = Math.Clamp(value, 0, 100);
    }

    private ScenarioAssistantContext BuildAssistantContext(Scenario scenario, string? sessionId = null, ScenarioAssistantTarget? target = null)
    {
        var characters = scenario.Characters
            .Where(c => !string.IsNullOrWhiteSpace(c.Name))
            .Select(c =>
            {
                var role = string.IsNullOrWhiteSpace(c.Role) ? string.Empty : $" ({c.Role.Trim()})";
                var description = string.IsNullOrWhiteSpace(c.Description) ? string.Empty : $": {c.Description.Trim()}";
                return $"{c.Name!.Trim()}{role}{description}";
            })
            .ToList();

        var locations = scenario.Locations
            .Where(l => !string.IsNullOrWhiteSpace(l.Name))
            .Select(l =>
            {
                var description = string.IsNullOrWhiteSpace(l.Description) ? string.Empty : $": {l.Description.Trim()}";
                return $"{l.Name!.Trim()}{description}";
            })
            .ToList();

        var objects = scenario.Objects
            .Where(o => !string.IsNullOrWhiteSpace(o.Name))
            .Select(o =>
            {
                var description = string.IsNullOrWhiteSpace(o.Description) ? string.Empty : $": {o.Description.Trim()}";
                return $"{o.Name!.Trim()}{description}";
            })
            .ToList();

        var openings = scenario.Openings
            .Where(o => !string.IsNullOrWhiteSpace(o.Title))
            .Select(o =>
            {
                var text = string.IsNullOrWhiteSpace(o.Text) ? string.Empty : $": {Truncate(o.Text.Trim(), 120)}";
                return $"{o.Title!.Trim()}{text}";
            })
            .ToList();

        var examples = scenario.Examples
            .Where(e => !string.IsNullOrWhiteSpace(e.Title))
            .Select(e =>
            {
                var text = string.IsNullOrWhiteSpace(e.Text) ? string.Empty : $": {Truncate(e.Text.Trim(), 120)}";
                return $"{e.Title!.Trim()}{text}";
            })
            .ToList();

        var snapshot = BuildScenarioSnapshot(scenario);

        return new ScenarioAssistantContext
        {
            SessionId = sessionId ?? $"scenario-editor:{scenario.Id}",
            ScenarioName = scenario.Name?.Trim() ?? "Unnamed Scenario",
            ScenarioDescription = scenario.Description?.Trim() ?? string.Empty,
            PlotDescription = scenario.Plot.Description?.Trim() ?? string.Empty,
            PlotConflicts = scenario.Plot.Conflicts,
            PlotGoals = scenario.Plot.Goals,
            WorldDescription = scenario.Setting.WorldDescription?.Trim() ?? string.Empty,
            TimeFrame = scenario.Setting.TimeFrame?.Trim() ?? string.Empty,
            WorldRules = scenario.Setting.WorldRules,
            EnvironmentalDetails = scenario.Setting.EnvironmentalDetails,
            Tone = scenario.Narrative.NarrativeTone?.Trim() ?? string.Empty,
            WritingStyle = scenario.Narrative.ProseStyle?.Trim() ?? string.Empty,
            PointOfView = scenario.Narrative.PointOfView?.Trim() ?? string.Empty,
            StyleGuidelines = scenario.Narrative.NarrativeGuidelines,
            CharacterSummaries = characters,
            LocationSummaries = locations,
            ObjectSummaries = objects,
            OpeningSummaries = openings,
            ExampleSummaries = examples,
            SavedScenarioSnapshot = snapshot,
            Target = target ?? ScenarioAssistantTarget.General
        };
    }

    private static string BuildScenarioSnapshot(Scenario scenario)
    {
        var snapshot = new
        {
            scenario.Name,
            scenario.Description,
            Plot = new
            {
                scenario.Plot.Title,
                scenario.Plot.Description,
                Conflicts = scenario.Plot.Conflicts,
                Goals = scenario.Plot.Goals
            },
            Setting = new
            {
                scenario.Setting.WorldDescription,
                scenario.Setting.TimeFrame,
                scenario.Setting.WorldRules,
                scenario.Setting.EnvironmentalDetails
            },
            Style = new
            {
                scenario.Narrative.NarrativeTone,
                scenario.Narrative.ProseStyle,
                scenario.Narrative.PointOfView,
                scenario.Narrative.NarrativeGuidelines
            },
            Characters = scenario.Characters.Select(c => new { c.Name, c.Role, c.Description }).ToList(),
            Locations = scenario.Locations.Select(l => new { l.Name, l.Description }).ToList(),
            Objects = scenario.Objects.Select(o => new { o.Name, o.Description }).ToList(),
            Openings = scenario.Openings.Select(o => new { o.Title, o.Text }).ToList(),
            Examples = scenario.Examples.Select(e => new { e.Title, e.Text }).ToList()
        };

        var json = System.Text.Json.JsonSerializer.Serialize(snapshot);
        return json.Length <= 8000 ? json : json[..8000];
    }

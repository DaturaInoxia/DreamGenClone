@page "/scenarios/editor/{ScenarioId?}"
@rendermode InteractiveServer
@using DreamGenClone.Web.Application.Assistants
@using DreamGenClone.Web.Application.Scenarios
@using DreamGenClone.Web.Application.StoryAnalysis
@using DreamGenClone.Application.Templates
@using DreamGenClone.Application.RolePlay
@using DreamGenClone.Domain.RolePlay
@using DreamGenClone.Web.Domain.RolePlay
@using DreamGenClone.Web.Domain.Scenarios
@using DreamGenClone.Application.StoryAnalysis
@using DreamGenClone.Domain.StoryAnalysis
@using DreamGenClone.Domain.Templates

@inject IScenarioService ScenarioService
@inject ITemplateService TemplateService
@inject IScenarioTokenCounter TokenCounter
@inject StoryAnalysisFacade StoryAnalysisFacade
@inject IScenarioAssistantService ScenarioAssistant
@inject IRPThemeService RPThemeService
@inject NavigationManager Navigation

<PageTitle>Scenario Editor - DreamGenClone</PageTitle>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-12">
            <h1>Scenario Editor</h1>
            <hr />
        </div>
    </div>
    
    @if (CurrentScenario != null)
    {
        <div class="row">
            <div class="col-12">
                <div class="card mb-4 sticky-top" style="top: 0.75rem; z-index: 1020;">
                    <div class="card-body py-3">
                        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                            <div class="d-flex flex-column flex-sm-row align-items-sm-center gap-2 gap-sm-3">
                                <span class="small text-muted text-uppercase fw-semibold">Token Count</span>
                                <span class="fs-4 fw-bold text-primary">@CurrentScenario.EstimatedTokenCount</span>
                                <button class="btn btn-outline-primary btn-sm" @onclick="RecalculateTokenCount">Recalculate</button>
                            </div>
                            <div class="d-flex flex-column flex-sm-row gap-2 ms-lg-auto">
                                <button class="btn btn-success" @onclick="SaveScenario">Save Scenario</button>
                                <button class="btn btn-outline-secondary" @onclick="@(() => Navigation.NavigateTo("/scenarios"))">Back to List</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Scenario Metadata -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5>Scenario Details</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Scenario Name</label>
                            <input type="text" class="form-control" @bind="CurrentScenario.Name" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" @bind="CurrentScenario.Description" rows="3"></textarea>
                        </div>
                    </div>
                </div>
                
                <!-- Plot -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5>Plot</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Plot Title</label>
                            <input type="text" class="form-control" @bind="CurrentScenario.Plot.Title" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Plot Description</label>
                            <textarea class="form-control" @bind="CurrentScenario.Plot.Description" rows="3"></textarea>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Conflicts</label>
                            <div class="conflict-list">
                                @foreach (var (conflict, index) in CurrentScenario.Plot.Conflicts.Select((c, i) => (c, i)))
                                {
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control" @bind="CurrentScenario.Plot.Conflicts[index]" />
                                        <button class="btn btn-outline-danger" @onclick="@(() => CurrentScenario.Plot.Conflicts.RemoveAt(index))">Remove</button>
                                    </div>
                                }
                            </div>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => CurrentScenario.Plot.Conflicts.Add(string.Empty))">+ Add Conflict</button>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Goals</label>
                            <div class="goal-list">
                                @foreach (var (goal, index) in CurrentScenario.Plot.Goals.Select((g, i) => (g, i)))
                                {
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control" @bind="CurrentScenario.Plot.Goals[index]" />
                                        <button class="btn btn-outline-danger" @onclick="@(() => CurrentScenario.Plot.Goals.RemoveAt(index))">Remove</button>
                                    </div>
                                }
                            </div>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => CurrentScenario.Plot.Goals.Add(string.Empty))">+ Add Goal</button>
                        </div>
                    </div>
                </div>
                
                <!-- Setting -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5>Setting / World</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">World Description</label>
                            <textarea class="form-control" @bind="CurrentScenario.Setting.WorldDescription" rows="3"></textarea>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Time Frame</label>
                            <input type="text" class="form-control" @bind="CurrentScenario.Setting.TimeFrame" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Environmental Details</label>
                            <div class="details-list">
                                @foreach (var (detail, index) in CurrentScenario.Setting.EnvironmentalDetails.Select((d, i) => (d, i)))
                                {
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control" @bind="CurrentScenario.Setting.EnvironmentalDetails[index]" />
                                        <button class="btn btn-outline-danger" @onclick="@(() => CurrentScenario.Setting.EnvironmentalDetails.RemoveAt(index))">Remove</button>
                                    </div>
                                }
                            </div>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => CurrentScenario.Setting.EnvironmentalDetails.Add(string.Empty))">+ Add Detail</button>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">World Rules</label>
                            <div class="rules-list">
                                @foreach (var (rule, index) in CurrentScenario.Setting.WorldRules.Select((r, i) => (r, i)))
                                {
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control" @bind="CurrentScenario.Setting.WorldRules[index]" />
                                        <button class="btn btn-outline-danger" @onclick="@(() => CurrentScenario.Setting.WorldRules.RemoveAt(index))">Remove</button>
                                    </div>
                                }
                            </div>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => CurrentScenario.Setting.WorldRules.Add(string.Empty))">+ Add Rule</button>
                        </div>
                    </div>
                </div>
                
                <!-- Story Direction, Intensity & Writing -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5>Story Direction, Intensity & Writing</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-text mb-3">RP Theme Profile steers role-play theme direction. Writing Style Profile only affects prose voice and texture.</div>
                        <div class="mb-3">
                            <label class="form-label">Default RP Theme Profile</label>
                            <select class="form-select" @bind="CurrentScenario.DefaultRPThemeProfileId">
                                <option value="">(None)</option>
                                @foreach (var profile in RpThemeProfiles)
                                {
                                    <option value="@profile.Id">@profile.Name</option>
                                }
                            </select>
                            <div class="form-text">Use this to steer RP theme selection and guidance for sessions created from this scenario.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Default Intensity Profile</label>
                            <select class="form-select" @bind="CurrentScenario.DefaultIntensityProfileId">
                                <option value="">(None)</option>
                                @foreach (var tone in ToneProfiles)
                                {
                                    <option value="@tone.Id">@tone.Name (@tone.Intensity)</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Default Character State Profile</label>
                            <select class="form-select" @bind="CurrentScenario.BaseStatProfileId">
                                <option value="">(None)</option>
                                @foreach (var profile in BaseStatProfiles)
                                {
                                    <option value="@profile.Id">@profile.Name</option>
                                }
                            </select>
                            <div class="form-text">Session seeding starts from this profile; each character's state overrides are applied on top.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Default Writing Style Profile</label>
                            <select class="form-select" @bind="CurrentScenario.DefaultSteeringProfileId">
                                <option value="">(None)</option>
                                @foreach (var style in StyleProfiles)
                                {
                                    <option value="@style.Id">@style.Name</option>
                                }
                            </select>
                            <div class="form-text">This controls how the prose is written, not what themes the story is driven toward.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Default Persona Perspective</label>
                            <select class="form-select" @bind="CurrentScenario.DefaultPersonaPerspectiveMode">
                                @foreach (var mode in CharacterPerspectiveModes.All)
                                {
                                    <option value="@mode.Mode">@mode.DisplayName</option>
                                }
                            </select>
                            <div class="form-text">This becomes the starting persona perspective for new role-play sessions created from the scenario.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Narrative Tone</label>
                            <input type="text" class="form-control" @bind="CurrentScenario.Narrative.NarrativeTone" placeholder="e.g., Dark, Humorous, Serious" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Prose Style</label>
                            <input type="text" class="form-control" @bind="CurrentScenario.Narrative.ProseStyle" placeholder="e.g., Descriptive, Minimalist, Prose" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Point of View</label>
                            <input type="text" class="form-control" @bind="CurrentScenario.Narrative.PointOfView" placeholder="e.g., First Person, Third Person" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Intensity Floor</label>
                            <select class="form-select" @bind="CurrentScenario.DefaultIntensityFloor">
                                <option value="">(None)</option>
                                @foreach (var option in StyleBoundOptions)
                                {
                                    <option value="@option.Value">@option.Label</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Intensity Ceiling</label>
                            <select class="form-select" @bind="CurrentScenario.DefaultIntensityCeiling">
                                <option value="">(None)</option>
                                @foreach (var option in StyleBoundOptions)
                                {
                                    <option value="@option.Value">@option.Label</option>
                                }
                            </select>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Narrative Guidelines</label>
                            <div class="guidelines-list">
                                @foreach (var (guideline, index) in CurrentScenario.Narrative.NarrativeGuidelines.Select((g, i) => (g, i)))
                                {
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control" @bind="CurrentScenario.Narrative.NarrativeGuidelines[index]" />
                                        <button class="btn btn-outline-danger" @onclick="@(() => CurrentScenario.Narrative.NarrativeGuidelines.RemoveAt(index))">Remove</button>
                                    </div>
                                }
                            </div>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="@(() => CurrentScenario.Narrative.NarrativeGuidelines.Add(string.Empty))">+ Add Guideline</button>
                        </div>
                    </div>
                </div>
                
                <!-- Characters -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5>Characters</h5>
                    </div>
                    <div class="card-body">
                        <div class="characters-list mb-3">
                            @if (CurrentScenario.Characters.Any())
                            {
                                @foreach (var (character, index) in CurrentScenario.Characters.Select((c, i) => (c, i)))
                                {
                                    <div class="card mb-2">
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-md-8">
                                                    <h6>@character.Name</h6>
                                                    <div class="mb-2">
                                                        <label class="form-label small">Description</label>
                                                        <textarea class="form-control form-control-sm" rows="3" @bind="character.Description"></textarea>
                                                    </div>
                                                    <div class="mb-2" style="max-width: 360px;">
                                                        <label class="form-label small">Role</label>
                                                        <select class="form-select form-select-sm" @bind="character.Role">
                                                            @foreach (var option in GetCharacterRoleOptions(character.Role))
                                                            {
                                                                <option value="@option">@option</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="mb-2" style="max-width: 260px;">
                                                        <label class="form-label small">Gender</label>
                                                        <select class="form-select form-select-sm" @bind="character.Gender">
                                                            @foreach (var option in CharacterGenderCatalog.CharacterGenders)
                                                            {
                                                                <option value="@option">@option</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="mb-2" style="max-width: 420px;">
                                                        <label class="form-label small">Relation</label>
                                                        <select class="form-select form-select-sm"
                                                                value="@(CharacterRelationCatalog.NormalizeTargetId(character.RelationTargetId) ?? string.Empty)"
                                                                @onchange="@(e => SetCharacterRelationTarget(character, e.Value?.ToString()))">
                                                            <option value="">(None)</option>
                                                            @foreach (var option in GetCharacterRelationTargetOptions(character))
                                                            {
                                                                <option value="@option.Value">@option.Label</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="mb-2" style="max-width: 360px;">
                                                        <label class="form-label small">Default Perspective</label>
                                                        <select class="form-select form-select-sm" @bind="character.PerspectiveMode">
                                                            @foreach (var mode in CharacterPerspectiveModes.All)
                                                            {
                                                                <option value="@mode.Mode">@mode.DisplayName</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="mt-2">
                                                        <div class="small text-muted mb-1">Character Stat Profile</div>
                                                        <div class="input-group input-group-sm mb-2" style="max-width: 520px;">
                                                            <select class="form-select" value="@GetCharacterProfileSelection(character)" @onchange="@(e => SetCharacterProfileSelection(character, e.Value?.ToString()))">
                                                                <option value="">(Select Profile)</option>
                                                                @foreach (var profile in GetApplicableBaseStatProfiles(character))
                                                                {
                                                                    <option value="@profile.Id">@profile.Name (@CharacterGenderCatalog.NormalizeForProfile(profile.TargetGender) / @CharacterRoleCatalog.Normalize(profile.TargetRole))</option>
                                                                }
                                                            </select>
                                                            <button class="btn btn-outline-primary" type="button" @onclick="@(() => ApplyCharacterProfile(character))">Apply</button>
                                                        </div>
                                                        <div class="small text-muted mb-1">Character State Overrides (applied after scenario profile defaults at session start)</div>
                                                        @foreach (var statName in BaseStatNames)
                                                        {
                                                            <div class="input-group input-group-sm mb-1">
                                                                <span class="input-group-text" style="min-width: 140px;">@statName</span>
                                                                <input type="number"
                                                                       class="form-control"
                                                                       min="0"
                                                                       max="100"
                                                                       value="@GetCharacterStat(character, statName)"
                                                                       @onchange="@(e => SetCharacterStat(character, statName, e.Value?.ToString()))" />
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                                <div class="col-md-4 text-end">
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="@(() => EditingCharacterIndex = index)">Edit</button>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="@(() => DeleteScenarioCharacter(index))">Delete</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No characters added yet.</p>
                            }
                        </div>
                        
                        <ScenarioEntityPicker 
                            Label="Add Character" 
                            TemplateTypeFilter="TemplateType.Character"
                            OnEntityCreated="@OnCharacterCreated" />
                    </div>
                </div>
                
                <!-- Locations -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5>Locations</h5>
                    </div>
                    <div class="card-body">
                        <div class="locations-list mb-3">
                            @if (CurrentScenario.Locations.Any())
                            {
                                @foreach (var (location, index) in CurrentScenario.Locations.Select((l, i) => (l, i)))
                                {
                                    <div class="card mb-2">
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-md-8">
                                                    <h6>@location.Name</h6>
                                                    <p class="text-muted">@location.Description</p>
                                                </div>
                                                <div class="col-md-4 text-end">
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="@(() => EditingLocationIndex = index)">Edit</button>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="@(() => CurrentScenario.Locations.RemoveAt(index))">Delete</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No locations added yet.</p>
                            }
                        </div>
                        
                        <ScenarioEntityPicker 
                            Label="Add Location" 
                            TemplateTypeFilter="TemplateType.Location"
                            OnEntityCreated="@OnLocationCreated" />
                    </div>
                </div>
                
                <!-- Objects -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5>Objects / Items</h5>
                    </div>
                    <div class="card-body">
                        <div class="objects-list mb-3">
                            @if (CurrentScenario.Objects.Any())
                            {
                                @foreach (var (obj, index) in CurrentScenario.Objects.Select((o, i) => (o, i)))
                                {
                                    <div class="card mb-2">
                                        <div class="card-body">
                                            <div class="row">
                                                <div class="col-md-8">
                                                    <h6>@obj.Name</h6>
                                                    <p class="text-muted">@obj.Description</p>
                                                </div>
                                                <div class="col-md-4 text-end">
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="@(() => EditingObjectIndex = index)">Edit</button>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="@(() => CurrentScenario.Objects.RemoveAt(index))">Delete</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No objects added yet.</p>
                            }
                        </div>
                        
                        <ScenarioEntityPicker 
                            Label="Add Object" 
                            TemplateTypeFilter="TemplateType.Object"
                            OnEntityCreated="@OnObjectCreated" />
                    </div>
                </div>
                
                <!-- Openings -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5>Openings / Starts</h5>
                    </div>
                    <div class="card-body">
                        <div class="openings-list mb-3">
                            @if (CurrentScenario.Openings.Any())
                            {
                                @foreach (var (opening, index) in CurrentScenario.Openings.Select((o, i) => (o, i)))
                                {
                                    <div class="card mb-2">
                                        <div class="card-header">
                                            <h6 class="mb-0">@opening.Title</h6>
                                        </div>
                                        <div class="card-body">
                                            <p>@opening.Text</p>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="@(() => CurrentScenario.Openings.RemoveAt(index))">Delete</button>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No openings added yet.</p>
                            }
                        </div>
                        
                        <div class="opening-form">
                            <input type="text" class="form-control mb-2" placeholder="Opening Title" @bind="NewOpeningTitle" />
                            <textarea class="form-control mb-2" placeholder="Opening Text" rows="3" @bind="NewOpeningText"></textarea>
                            <button class="btn btn-secondary" @onclick="AddOpening">+ Add Opening</button>
                        </div>
                    </div>
                </div>
                
                <!-- Examples -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5>Examples</h5>
                    </div>
                    <div class="card-body">
                        <div class="examples-list mb-3">
                            @if (CurrentScenario.Examples.Any())
                            {
                                @foreach (var (example, index) in CurrentScenario.Examples.Select((e, i) => (e, i)))
                                {
                                    <div class="card mb-2">
                                        <div class="card-header">
                                            <h6 class="mb-0">@example.Title</h6>
                                        </div>
                                        <div class="card-body">
                                            <p>@example.Text</p>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="@(() => CurrentScenario.Examples.RemoveAt(index))">Delete</button>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No examples added yet.</p>
                            }
                        </div>
                        
                        <div class="example-form">
                            <input type="text" class="form-control mb-2" placeholder="Example Title" @bind="NewExampleTitle" />
                            <textarea class="form-control mb-2" placeholder="Example Text" rows="3" @bind="NewExampleText"></textarea>
                            <button class="btn btn-secondary" @onclick="AddExample">+ Add Example</button>
                        </div>
                    </div>
                </div>

                <!-- Scenario Assistant -->
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Scenario Assistant</h5>
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleAssistantExpanded">
                                @(_assistantExpanded ? "Minimize" : "Expand")
                            </button>
                            <span class="badge text-bg-secondary">Chat</span>
                        </div>
                    </div>
                    <div class="card-body" style="@(_assistantExpanded ? "min-height: 58vh;" : null)">
                        <AssistantPanel Title="Scenario Assistant"
                                        SessionId="@GetScenarioAssistantSessionId()"
                                        Messages="@GetActiveAssistantMessages()"
                                        Chats="@GetAssistantChatSummaries()"
                                        ActiveChatId="@_activeAssistantChatId"
                                        OnSelectChatRequest="OnAssistantSelectChat"
                                        OnCreateChatRequest="OnAssistantCreateChat"
                                        OnDeleteChatRequest="OnAssistantDeleteChat"
                                        OnGenerateRequest="OnAssistantGenerateRequest"
                                        OnClearChatRequest="OnAssistantClearChat"
                                        ConversationMaxHeightCss="@AssistantConversationHeightCss" />

                        <div class="mt-3 border rounded p-3">
                            <div class="small text-muted mb-2">Apply Last Assistant Response</div>
                            <div class="row g-2 align-items-end">
                                <div class="col-md-4">
                                    <label class="form-label">Target Field (generation + apply)</label>
                                    <select class="form-select" @bind="_assistantApplyTarget">
                                        <option value="@ScenarioAssistantTarget.General">General (advisory)</option>
                                        <option value="@ScenarioAssistantTarget.PlotDescription">Plot Description</option>
                                        <option value="@ScenarioAssistantTarget.WorldDescription">World Description</option>
                                        <option value="@ScenarioAssistantTarget.StyleGuidelines">Style Guidelines</option>
                                        <option value="@ScenarioAssistantTarget.Locations">Locations</option>
                                        <option value="@ScenarioAssistantTarget.Objects">Objects / Items</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-check mt-4">
                                        <input class="form-check-input" type="checkbox" id="assistant-append-style" @bind="_assistantApplyAppendStyleGuidelines" />
                                        <label class="form-check-label" for="assistant-append-style">Append style guidelines (otherwise replace)</label>
                                    </div>
                                </div>
                                <div class="col-md-4 d-grid">
                                    <button class="btn btn-outline-primary" @onclick="ApplyLastAssistantResponse">
                                        Apply Last Assistant Response
                                    </button>
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_assistantApplyStatus))
                            {
                                <div class="form-text mt-2">@_assistantApplyStatus</div>
                            }
                        </div>
                    </div>

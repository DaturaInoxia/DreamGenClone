    private void ApplyLastAssistantResponse()
    {
        if (CurrentScenario is null)
        {
            _assistantApplyStatus = "No scenario loaded.";
            return;
        }

        if (_assistantApplyTarget == ScenarioAssistantTarget.General)
        {
            _assistantApplyStatus = "General target is advisory-only. Select a specific target field to apply content.";
            return;
        }

        var lastAssistantResponse = ActiveAssistantChat?.Messages
            .Where(m => string.Equals(m.Role, "assistant", StringComparison.OrdinalIgnoreCase) && !string.IsNullOrWhiteSpace(m.Content))
            .Select(m => m.Content)
            .LastOrDefault();

        if (string.IsNullOrWhiteSpace(lastAssistantResponse))
        {
            _assistantApplyStatus = "No assistant response found in this chat.";
            return;
        }

        var draft = ExtractAssistantApplyContent(lastAssistantResponse, _assistantApplyTarget);
        if (string.IsNullOrWhiteSpace(draft))
        {
            _assistantApplyStatus = "No structured draft found. Ask the assistant to include [[SCENARIO_FIELD:...]] blocks.";
            return;
        }

        switch (_assistantApplyTarget)
        {
            case ScenarioAssistantTarget.PlotDescription:
                CurrentScenario.Plot.Description = draft;
                _assistantApplyStatus = "Updated Plot Description.";
                break;
            case ScenarioAssistantTarget.WorldDescription:
                CurrentScenario.Setting.WorldDescription = draft;
                _assistantApplyStatus = "Updated World Description.";
                break;
            case ScenarioAssistantTarget.StyleGuidelines:
                var items = draft.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .Select(x => x.TrimStart('-', '*', ' '))
                    .Where(x => !string.IsNullOrWhiteSpace(x))
                    .ToList();

                if (!_assistantApplyAppendStyleGuidelines)
                {
                    CurrentScenario.Narrative.NarrativeGuidelines.Clear();
                }

                foreach (var item in items)
                {
                    if (!CurrentScenario.Narrative.NarrativeGuidelines.Any(x => string.Equals(x, item, StringComparison.OrdinalIgnoreCase)))
                    {
                        CurrentScenario.Narrative.NarrativeGuidelines.Add(item);
                    }
                }

                _assistantApplyStatus = _assistantApplyAppendStyleGuidelines
                    ? $"Added {items.Count} style guideline(s)."
                    : $"Replaced with {items.Count} style guideline(s).";
                break;
            case ScenarioAssistantTarget.Locations:
                var parsedLocations = ParseNameDescriptionPairs(draft);
                var addedLocations = 0;
                foreach (var (name, description) in parsedLocations)
                {
                    if (CurrentScenario.Locations.Any(l => string.Equals(l.Name?.Trim(), name, StringComparison.OrdinalIgnoreCase)))
                    {
                        continue;
                    }

                    CurrentScenario.Locations.Add(new Location
                    {
                        Name = name,
                        Description = description
                    });
                    addedLocations++;
                }

                _assistantApplyStatus = $"Added {addedLocations} location(s).";
                break;
            case ScenarioAssistantTarget.Objects:
                var parsedObjects = ParseNameDescriptionPairs(draft);
                var addedObjects = 0;
                foreach (var (name, description) in parsedObjects)
                {
                    if (CurrentScenario.Objects.Any(o => string.Equals(o.Name?.Trim(), name, StringComparison.OrdinalIgnoreCase)))
                    {
                        continue;
                    }

                    CurrentScenario.Objects.Add(new ScenarioObject
                    {
                        Name = name,
                        Description = description
                    });
                    addedObjects++;
                }

                _assistantApplyStatus = $"Added {addedObjects} object/item(s).";
                break;
        }

        RecalculateTokenCount();
    }

    private static List<(string Name, string Description)> ParseNameDescriptionPairs(string draft)
    {
        var pairs = new List<(string Name, string Description)>();
        var lines = draft.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        foreach (var raw in lines)
        {
            var line = raw.Trim().TrimStart('-', '*', ' ').Trim();
            if (string.IsNullOrWhiteSpace(line))
            {
                continue;
            }

            string name;
            string description;

            var pipeIndex = line.IndexOf('|');
            if (pipeIndex > 0)
            {
                name = line[..pipeIndex].Trim();
                description = line[(pipeIndex + 1)..].Trim();
            }
            else
            {
                var colonIndex = line.IndexOf(':');
                if (colonIndex > 0)
                {
                    name = line[..colonIndex].Trim();
                    description = line[(colonIndex + 1)..].Trim();
                }
                else
                {
                    name = line;
                    description = string.Empty;
                }
            }

            if (string.IsNullOrWhiteSpace(name))
            {
                continue;
            }

            pairs.Add((name, description));
        }

        return pairs;
    }

    private static string ExtractAssistantApplyContent(string response, ScenarioAssistantTarget target)
    {
        var token = target switch
        {
            ScenarioAssistantTarget.PlotDescription => "PlotDescription",
            ScenarioAssistantTarget.WorldDescription => "WorldDescription",
            ScenarioAssistantTarget.StyleGuidelines => "StyleGuidelines",
            ScenarioAssistantTarget.Locations => "Locations",
            ScenarioAssistantTarget.Objects => "Objects",
            _ => string.Empty
        };

        if (!string.IsNullOrWhiteSpace(token))
        {
            var startTag = $"[[SCENARIO_FIELD:{token}]]";
            const string endTag = "[[/SCENARIO_FIELD]]";

            var startIndex = response.IndexOf(startTag, StringComparison.OrdinalIgnoreCase);
            if (startIndex >= 0)
            {
                var contentStart = startIndex + startTag.Length;
                var endIndex = response.IndexOf(endTag, contentStart, StringComparison.OrdinalIgnoreCase);
                if (endIndex > contentStart)
                {
                    return response[contentStart..endIndex].Trim();
                }

                return response[contentStart..].Trim();
            }
        }

        var header = target switch
        {
            ScenarioAssistantTarget.PlotDescription => "## Draft: Plot Description",
            ScenarioAssistantTarget.WorldDescription => "## Draft: World Description",
            ScenarioAssistantTarget.StyleGuidelines => "## Draft: Style Guidelines",
            ScenarioAssistantTarget.Locations => "## Draft: Locations",
            ScenarioAssistantTarget.Objects => "## Draft: Objects",
            _ => string.Empty
        };

        if (string.IsNullOrWhiteSpace(header))
        {
            return string.Empty;
        }

        var headerIndex = response.IndexOf(header, StringComparison.OrdinalIgnoreCase);
        if (headerIndex < 0)
        {
            return string.Empty;
        }

        var fromHeader = response[(headerIndex + header.Length)..].TrimStart();
        var nextHeader = fromHeader.IndexOf("\n## ", StringComparison.Ordinal);
        return (nextHeader >= 0 ? fromHeader[..nextHeader] : fromHeader).Trim();
    }


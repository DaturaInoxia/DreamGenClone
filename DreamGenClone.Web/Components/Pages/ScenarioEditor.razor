    private async Task ApplyTemplateRelationDefaultsAsync(Character character)
    {
        if (CurrentScenario is null || string.IsNullOrWhiteSpace(character.TemplateId))
        {
            return;
        }

        if (CharacterLikeTemplates.Count == 0)
        {
            CharacterLikeTemplates = (await TemplateService.GetAllAsync())
                .Where(x => IsCharacterLikeTemplate(x.TemplateType))
                .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }

        var sourceTemplate = CharacterLikeTemplates.FirstOrDefault(x => string.Equals(x.Id.ToString(), character.TemplateId, StringComparison.OrdinalIgnoreCase));
        var targetTemplateId = CharacterRelationCatalog.NormalizeTargetId(sourceTemplate?.RelationTargetTemplateId);
        if (!string.IsNullOrWhiteSpace(targetTemplateId))
        {
            var targetCharacter = CurrentScenario.Characters.FirstOrDefault(x =>
                !string.Equals(x.Id, character.Id, StringComparison.OrdinalIgnoreCase)
                && string.Equals(x.TemplateId, targetTemplateId, StringComparison.OrdinalIgnoreCase));
            if (targetCharacter is not null)
            {
                UpdateScenarioCharacterRelation(CurrentScenario.Characters, character, targetCharacter.Id);
                return;
            }

            var targetPersonaTemplate = CharacterLikeTemplates.FirstOrDefault(x =>
                x.TemplateType == TemplateType.Persona
                && string.Equals(x.Id.ToString(), targetTemplateId, StringComparison.OrdinalIgnoreCase));
            if (targetPersonaTemplate is not null)
            {
                UpdateScenarioCharacterRelation(CurrentScenario.Characters, character, CharacterRelationCatalog.CreatePersonaTemplateTargetId(targetPersonaTemplate.Id.ToString()));
                return;
            }
        }

        foreach (var existingCharacter in CurrentScenario.Characters.Where(x => !string.Equals(x.Id, character.Id, StringComparison.OrdinalIgnoreCase)))
        {
            var existingTemplate = CharacterLikeTemplates.FirstOrDefault(x => string.Equals(x.Id.ToString(), existingCharacter.TemplateId, StringComparison.OrdinalIgnoreCase));
            var existingTargetTemplateId = CharacterRelationCatalog.NormalizeTargetId(existingTemplate?.RelationTargetTemplateId);
            if (string.Equals(existingTargetTemplateId, character.TemplateId, StringComparison.OrdinalIgnoreCase))
            {
                UpdateScenarioCharacterRelation(CurrentScenario.Characters, existingCharacter, character.Id);
                return;
            }
        }
    }


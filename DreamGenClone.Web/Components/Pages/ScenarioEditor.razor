    private void UpdateScenarioCharacterRelation(List<Character> characters, Character sourceCharacter, string? targetId)
    {
        var normalizedTargetId = CharacterRelationCatalog.NormalizeTargetId(targetId);
        if (string.Equals(normalizedTargetId, sourceCharacter.Id, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var previousTargetId = CharacterRelationCatalog.NormalizeTargetId(sourceCharacter.RelationTargetId);
        if (!string.Equals(previousTargetId, normalizedTargetId, StringComparison.OrdinalIgnoreCase))
        {
            ClearScenarioReciprocalRelation(characters, previousTargetId, sourceCharacter.Id);
        }

        sourceCharacter.RelationTargetId = normalizedTargetId;

        var targetCharacter = FindScenarioCharacterByTargetId(characters, normalizedTargetId);
        if (targetCharacter is null)
        {
            return;
        }

        var targetPreviousTargetId = CharacterRelationCatalog.NormalizeTargetId(targetCharacter.RelationTargetId);
        if (!string.Equals(targetPreviousTargetId, sourceCharacter.Id, StringComparison.OrdinalIgnoreCase))
        {
            ClearScenarioReciprocalRelation(characters, targetPreviousTargetId, targetCharacter.Id);
        }

        targetCharacter.RelationTargetId = sourceCharacter.Id;
    }

    private void ClearScenarioReciprocalRelation(List<Character> characters, string? targetId, string sourceCharacterId)
    {
        var reciprocalCharacter = FindScenarioCharacterByTargetId(characters, targetId);
        if (reciprocalCharacter is null)
        {
            return;
        }

        if (string.Equals(CharacterRelationCatalog.NormalizeTargetId(reciprocalCharacter.RelationTargetId), sourceCharacterId, StringComparison.OrdinalIgnoreCase))
        {

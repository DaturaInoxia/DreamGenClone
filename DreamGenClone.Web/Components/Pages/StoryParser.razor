@page "/storyparser"
@rendermode InteractiveServer

@using DreamGenClone.Application.StoryParser.Models
@using DreamGenClone.Domain.StoryParser
@using DreamGenClone.Web.Application.StoryParser

@inject StoryParserFacade ParserFacade
@inject StoryCatalogFacade CatalogFacade
@inject NavigationManager Navigation

<PageTitle>StoryParser</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>StoryParser</h1>
    </div>

    <div class="card mb-3">
        <div class="card-header">Parse Story URL</div>
        <div class="card-body">
            <div class="mb-2">
                <label class="form-label">Source URL</label>
                <input class="form-control" @bind="_sourceUrl" placeholder="https://www.literotica.com/s/example" />
            </div>
            <div class="mb-2">
                <label class="form-label">Error Mode</label>
                <select class="form-select" @bind="_selectedErrorMode">
                    <option value="FailFast">FailFast</option>
                    <option value="PartialSuccess">PartialSuccess</option>
                </select>
            </div>
            <button class="btn btn-primary" @onclick="ParseAsync" disabled="@_isParsing">@(_isParsing ? "Parsing..." : "Parse URL")</button>
            @if (!string.IsNullOrWhiteSpace(_parseMessage))
            {
                <div class="alert alert-info mt-3 mb-0">@_parseMessage</div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Parsed Stories</span>
            <div class="d-flex gap-2">
                <input class="form-control" style="width: 240px;" @bind="_searchQuery" placeholder="Search metadata" />
                <select class="form-select" style="width: 220px;" @bind="_selectedSortMode">
                    <option value="NewestFirst">Newest First</option>
                    <option value="UrlTitleAsc">URL/Title A-Z</option>
                </select>
                <button class="btn btn-outline-secondary" @onclick="LoadCatalogAsync">Refresh</button>
            </div>
        </div>
        <div class="card-body">
            @if (_catalog.Count == 0)
            {
                <div class="text-muted">No parsed stories found.</div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var entry in _catalog)
                    {
                        <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-start" @onclick="() => OpenDetail(entry.Id)" style="cursor: pointer;">
                            <div>
                                <div class="fw-semibold">@(string.IsNullOrWhiteSpace(entry.Title) ? entry.SourceUrl : entry.Title)</div>
                                @if (!string.IsNullOrWhiteSpace(entry.Author))
                                {
                                    <small class="text-muted">by @entry.Author</small>
                                }
                                <div><small class="text-muted">@entry.SourceUrl</small></div>
                            </div>
                            <div class="text-end d-flex align-items-start gap-2">
                                <div>
                                    <span class="badge text-bg-secondary">@entry.ParseStatus</span>
                                    <div><small>@entry.ParsedUtc.ToLocalTime().ToString("g")</small></div>
                                    <div><small>Pages: @entry.PageCount</small></div>
                                </div>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteStoryAsync(entry.Id)" @onclick:stopPropagation="true" title="Delete">
                                    <span>&#x2715;</span>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string _sourceUrl = string.Empty;
    private string _parseMessage = string.Empty;
    private string _searchQuery = string.Empty;
    private string _selectedSortMode = nameof(CatalogSortMode.NewestFirst);
    private string _selectedErrorMode = nameof(ParseErrorMode.FailFast);
    private bool _isParsing;
    private List<StoryCatalogEntry> _catalog = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadCatalogAsync();
    }

    private async Task ParseAsync()
    {
        _isParsing = true;
        _parseMessage = string.Empty;

        try
        {
            var request = new StoryParseRequest
            {
                SourceUrl = _sourceUrl,
                ErrorMode = Enum.TryParse<ParseErrorMode>(_selectedErrorMode, true, out var mode) ? mode : null
            };

            var result = await ParserFacade.ParseFromUrlAsync(request);
            _parseMessage = $"Status: {result.ParseStatus}, Pages: {result.PageCount}, Errors: {result.Diagnostics.Errors.Count}";
            await LoadCatalogAsync();
        }
        catch (Exception ex)
        {
            _parseMessage = ex.Message;
        }
        finally
        {
            _isParsing = false;
        }
    }

    private async Task LoadCatalogAsync()
    {
        var sortMode = Enum.TryParse<CatalogSortMode>(_selectedSortMode, true, out var parsed)
            ? parsed
            : CatalogSortMode.NewestFirst;

        IReadOnlyList<StoryCatalogEntry> rows;
        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            rows = await CatalogFacade.ListAsync(sortMode);
        }
        else
        {
            rows = await CatalogFacade.SearchAsync(_searchQuery, sortMode);
        }

        _catalog = rows.ToList();
    }

    private void OpenDetail(string id)
    {
        Navigation.NavigateTo($"/storyparser/detail/{id}");
    }

    private async Task DeleteStoryAsync(string id)
    {
        await ParserFacade.DeleteAsync(id);
        await LoadCatalogAsync();
    }
}

    private static string GetScoreBadgeClass(double score) => score switch
    {
        >= 80 => "bg-success",
        >= 60 => "bg-primary",
        >= 40 => "bg-warning text-dark",
        _ => "bg-danger"
    };

    private static bool IsRankingFullyVerified(StoryRankingResult ranking)
    {
        if (string.IsNullOrWhiteSpace(ranking.ThemeDetectionsJson) || ranking.ThemeDetectionsJson == "[]")
            return false;
        if (string.IsNullOrWhiteSpace(ranking.ThemeVerificationStatusJson) || ranking.ThemeVerificationStatusJson == "{}")
            return false;
        try
        {
            using var detDoc = JsonDocument.Parse(ranking.ThemeDetectionsJson);
            var themeIds = new List<string>();
            foreach (var elem in detDoc.RootElement.EnumerateArray())
            {
                if (elem.TryGetProperty("themeId", out var id))
                    themeIds.Add(id.GetString() ?? "");
            }
            if (themeIds.Count == 0) return false;

            using var verDoc = JsonDocument.Parse(ranking.ThemeVerificationStatusJson);
            foreach (var themeId in themeIds)
            {
                if (!verDoc.RootElement.TryGetProperty(themeId, out var statusVal))
                    return false;
                var statusStr = statusVal.GetString();
                if (statusStr == null || statusStr == nameof(ThemeVerificationStatus.Unverified))
                    return false;
            }
            return true;
        }
        catch { return false; }
    }


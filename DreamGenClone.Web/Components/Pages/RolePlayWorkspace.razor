    private CharacterPerspectiveMode GetCharacterPerspectiveMode(Character character)
    {
        if (_session is null)
        {
            return Enum.IsDefined(character.PerspectiveMode)
                ? character.PerspectiveMode
                : CharacterPerspectiveMode.ThirdPersonExternalOnly;
        }

        var configured = _session.CharacterPerspectives.FirstOrDefault(x =>
            string.Equals(x.CharacterId, character.Id, StringComparison.OrdinalIgnoreCase)
            || (!string.IsNullOrWhiteSpace(character.Name) && string.Equals(x.CharacterName, character.Name, StringComparison.OrdinalIgnoreCase)));

        if (configured is not null && Enum.IsDefined(configured.PerspectiveMode))
        {
            return configured.PerspectiveMode;
        }

        return Enum.IsDefined(character.PerspectiveMode)
            ? character.PerspectiveMode
            : CharacterPerspectiveMode.ThirdPersonExternalOnly;
    }

    private async Task OnCharacterPerspectiveChanged(Character character, ChangeEventArgs args)
    {
        if (_session is null)
        {
            return;
        }

        var mode = Enum.TryParse<CharacterPerspectiveMode>(args.Value?.ToString(), out var parsed)
            ? parsed
            : CharacterPerspectiveMode.ThirdPersonExternalOnly;

        var existing = _session.CharacterPerspectives.FirstOrDefault(x =>
            string.Equals(x.CharacterId, character.Id, StringComparison.OrdinalIgnoreCase)
            || (!string.IsNullOrWhiteSpace(character.Name) && string.Equals(x.CharacterName, character.Name, StringComparison.OrdinalIgnoreCase)));

        if (existing is null)
        {
            _session.CharacterPerspectives.Add(new RolePlayCharacterPerspective
            {
                CharacterId = character.Id,
                CharacterName = character.Name?.Trim() ?? string.Empty,
                PerspectiveMode = mode
            });
        }
        else
        {
            existing.CharacterId = character.Id;
            existing.CharacterName = character.Name?.Trim() ?? existing.CharacterName;
            existing.PerspectiveMode = mode;
        }

        await SaveSessionSettingsAsync();
    }

    private static bool EnsureCharacterPerspectiveEntries(RolePlaySession session, Scenario scenario)
    {
        var updated = false;

        foreach (var character in scenario.Characters.Where(x => !string.IsNullOrWhiteSpace(x.Name)))
        {
            var existing = session.CharacterPerspectives.FirstOrDefault(x =>
                string.Equals(x.CharacterId, character.Id, StringComparison.OrdinalIgnoreCase)
                || string.Equals(x.CharacterName, character.Name, StringComparison.OrdinalIgnoreCase));

            if (existing is null)
            {
                session.CharacterPerspectives.Add(new RolePlayCharacterPerspective
                {
                    CharacterId = character.Id,
                    CharacterName = character.Name!.Trim(),
                    PerspectiveMode = Enum.IsDefined(character.PerspectiveMode)
                        ? character.PerspectiveMode
                        : CharacterPerspectiveMode.ThirdPersonExternalOnly
                });
                updated = true;
                continue;
            }

            if (existing.CharacterId != character.Id)
            {
                existing.CharacterId = character.Id;
                updated = true;
            }

            var trimmedName = character.Name!.Trim();
            if (!string.Equals(existing.CharacterName, trimmedName, StringComparison.Ordinal))
            {
                existing.CharacterName = trimmedName;
                updated = true;
            }

            if (!Enum.IsDefined(existing.PerspectiveMode))
            {
                existing.PerspectiveMode = Enum.IsDefined(character.PerspectiveMode)
                    ? character.PerspectiveMode
                    : CharacterPerspectiveMode.ThirdPersonExternalOnly;
                updated = true;
            }
        }

        return updated;
    }


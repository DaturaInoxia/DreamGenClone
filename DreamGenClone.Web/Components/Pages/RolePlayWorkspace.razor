    private string IntentLabel => _selectedIntent switch
    {
        PromptIntent.Narrative => "narrative",
        PromptIntent.Instruction => "instruction",
        _ => "message"
    };

    private string CurrentIdentityLabel
    {
        get
        {
            if (_selectedIdentity is null)
            {
                return "?";
            }

            if (_selectedIdentity.SourceType == IdentityOptionSource.CustomCharacter
                && !string.IsNullOrWhiteSpace(_customIdentityName))
            {
                return _customIdentityName.Trim();
            }

            return _selectedIdentity.DisplayName;
        }
    }

    private string BuildPromptPendingResponseLabel() => _selectedIntent switch
    {
        PromptIntent.Message => $"Waiting for {CurrentIdentityLabel} to reply...",
        PromptIntent.Narrative => $"Waiting for {CurrentIdentityLabel} to continue the scene...",
        _ => "Waiting for the next response..."
    };

    private string BuildContinuePendingResponseLabel(ContinueAsRequest request)
    {
        var selectedOptions = ContinueIdentityOptions
            .Where(x => request.SelectedIdentityIds.Contains(x.Id, StringComparer.OrdinalIgnoreCase))
            .ToList();

        if (selectedOptions.Count == 1 && !request.IncludeNarrative)
        {
            return $"Waiting for {GetIdentityDisplayLabel(selectedOptions[0])} to continue...";
        }

        if (selectedOptions.Count > 1 && !request.IncludeNarrative)
        {
            return $"Waiting for {selectedOptions.Count} selected characters to continue...";
        }

        if (selectedOptions.Count == 0 && request.IncludeNarrative)
        {
            return "Waiting for narrative continuation...";
        }

        if (selectedOptions.Count == 1 && request.IncludeNarrative)
        {
            return $"Waiting for {GetIdentityDisplayLabel(selectedOptions[0])} and narrative continuation...";
        }

        if (selectedOptions.Count > 1 && request.IncludeNarrative)
        {
            return $"Waiting for {selectedOptions.Count} selected characters and narrative continuation...";
        }

        return "Waiting for the next response...";
    }

    private string GetIdentityDisplayLabel(IdentityOption option)
    {
        if (option.SourceType == IdentityOptionSource.CustomCharacter
            && !string.IsNullOrWhiteSpace(_customIdentityName))
        {
            return _customIdentityName.Trim();
        }

        return option.DisplayName;
    }

    private string CurrentIdentityInitial => GetInitial(CurrentIdentityLabel);

    private IEnumerable<IdentityOption> ContinueIdentityOptions =>
        _identityOptions.Where(x => x.IsAvailable);

    private IdentityOption? PersonaContinueOption => ContinueIdentityOptions
        .FirstOrDefault(x => x.SourceType == IdentityOptionSource.Persona);

    private IReadOnlyList<IdentityOption> NpcContinueOptions => ContinueIdentityOptions
        .Where(x => x.SourceType == IdentityOptionSource.SceneCharacter)
        .ToList();

    private IdentityOption? ContinueCustomIdentityOption => ContinueIdentityOptions
        .FirstOrDefault(x => x.SourceType == IdentityOptionSource.CustomCharacter);

    private bool HasNpcContinueSelection => NpcContinueOptions.Any(x => _continueSelectedIdentityIds.Contains(x.Id));

    private bool HasPersonaContinueSelection => PersonaContinueOption is not null
        && _continueSelectedIdentityIds.Contains(PersonaContinueOption.Id);

    private bool HasCustomContinueSelection => ContinueCustomIdentityOption is not null
        && _continueSelectedIdentityIds.Contains(ContinueCustomIdentityOption.Id);

    private bool IsContinueIdentitySelected(IdentityOption option) => _continueSelectedIdentityIds.Contains(option.Id);

    private int ContinueSelectionCount => ContinueIdentityOptions.Count(x => _continueSelectedIdentityIds.Contains(x.Id));

    private string ShellStyle => $"--rw-settings-width: {_workspaceSettings.SettingsPanelWidth}px;";
}

<PageTitle>Role-Play Workspace</PageTitle>

<div class="rw-shell" @onclick="CloseAllPopups" style="@ShellStyle">

    
    <div class="rw-main">

        <div class="rw-header">
            <div class="rw-header-left">
                <button class="rw-back-btn" @onclick="GoToSavedSessions" @onclick:stopPropagation>←</button>
                @if (_session is not null)
                {
                    <span class="rw-session-title">@_session.Title</span>
                    <span class="rw-session-meta">@_session.Interactions.Count interactions · @_session.BehaviorMode</span>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="rw-status-bar">@_statusMessage</div>
        }

        @if (_session is null)
        {
            <div class="rw-loading">Loading session...</div>
        }
        else
        {
            <div class="rw-story">
                @if (_session.Interactions.Count == 0)
                {
                    <p class="rw-empty-hint">No interactions yet. Type below and press Send to begin.</p>
                }
                else
                {
                    @foreach (var interaction in GetDisplayInteractions())
                    {
                        var interactionId = interaction.Id;
                        <div class="rw-interaction rw-type-@interaction.InteractionType.ToString().ToLower()">
                            <div class="rw-actor-badge">@GetInitial(interaction.ActorName)</div>
                            <div class="rw-interaction-body">
                                <div class="rw-actor-name">
                                    @interaction.ActorName
                                    @if (interaction.IsExcluded)
                                    {
                                        <span class="rw-flag-icon rw-flag-excluded" title="This interaction is hidden from the AI">&#x1F6AB;</span>
                                    }
                                    @if (interaction.IsHidden)
                                    {
                                        <span class="rw-flag-icon rw-flag-hidden" title="This interaction is hidden from the user interface">&#x1F441;</span>
                                    }
                                    @if (interaction.IsPinned)
                                    {
                                        <span class="rw-flag-icon rw-flag-pinned" title="This interaction is pinned for AI context retention">&#x1F4CC;</span>
                                    }
                                </div>
                                <div class="rw-interaction-text">
                                    @if (_generatingIds.Contains(interactionId))
                                    {
                                        <div class="rw-generating-indicator">Generating...</div>
                                    }
                                    @if (_editContent.ContainsKey(interactionId))
                                    {
                                        <textarea class="rw-edit-textarea" @bind="_editContent[interactionId]" @bind:event="oninput"></textarea>
                                    }
                                    else
                                    {
                                        @interaction.Content
                                    }
                                    @if (_retryErrors.TryGetValue(interactionId, out var errorMsg))
                                    {
                                        <div class="rw-error-inline">@errorMsg</div>
                                    }
                                </div>
                                @{
                                    var originalId = interaction.ParentInteractionId ?? interaction.Id;
                                    var altCount = GetAlternativeCount(originalId);
                                    var activeIdx = GetActiveAlternativeIndex(originalId);
                                }
                                @if (altCount > 0)
                                {
                                    <div class="rw-alt-navigation">
                                        <button class="rw-alt-nav-btn" disabled="@(activeIdx <= 0)" @onclick="@(() => NavigateAlternativeAsync(originalId, -1))">&#x25C0;</button>
                                        <span class="rw-alt-counter">@(activeIdx + 1) of @(altCount + 1)</span>
                                        <button class="rw-alt-nav-btn" disabled="@(activeIdx >= altCount)" @onclick="@(() => NavigateAlternativeAsync(originalId, 1))">&#x25B6;</button>
                                        @if (activeIdx > 0)
                                        {
                                            <button class="rw-alt-delete-btn" title="Delete this alternative" @onclick="@(() => ShowDeleteAlternativeConfirmation(interactionId))">
                                                <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:12px;height:12px"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="rw-interaction-toolbar">
                                @if (_editContent.ContainsKey(interactionId))
                                {
                                    @* Edit-mode toolbar: Delete | ⋮ Kebab | Undo | Save | Cancel *@
                                    <button class="rw-toolbar-btn rw-toolbar-btn-danger" title="Delete interaction"
                                            @onclick="@(() => ShowDeleteConfirmation(interactionId))">
                                        <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                    </button>
                                    <button class="rw-toolbar-btn" data-kebab-btn="@interactionId" title="More options" @onclick="@(() => ToggleKebabMenu(interactionId))">
                                        <svg class="rw-icon" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                                    </button>
                                    <button class="rw-toolbar-btn" title="Undo changes" @onclick="@(() => UndoEdit(interactionId))">
                                        <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                                    </button>
                                    <button class="rw-toolbar-btn" title="Save edit" @onclick="@(() => SaveEditAsync(interactionId))">
                                        <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                    </button>
                                    <button class="rw-toolbar-btn" title="Cancel edit" @onclick="@(() => CancelEdit(interactionId))">
                                        <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                    </button>
                                }
                                else
                                {
                                    @* Default toolbar: Retry | Edit | Info *@
                                    <button class="rw-toolbar-btn" data-retry-btn="@interactionId" title="Retry / Regenerate" @onclick="@(() => ToggleRetryMenu(interactionId))">
                                        <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"/><path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"/></svg>
                                    </button>
                                    <button class="rw-toolbar-btn" title="Edit interaction" @onclick="@(() => StartEdit(interactionId, interaction.Content))">
                                        <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </button>
                                    <button class="rw-toolbar-btn" title="Generation info" @onclick="@(() => ShowInteractionInfo(interactionId))">
                                        <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    @if (_deleteConfirmInteractionId is not null)
                    {
                        <div class="rw-modal-overlay" @onclick="CancelDelete">
                            <div class="rw-modal" @onclick:stopPropagation>
                                <div class="rw-modal-header">Delete Interaction</div>
                                <div class="rw-modal-body">
                                    <p>This can't be undone.</p>
                                </div>
                                <div class="rw-modal-actions">
                                    <button class="rw-btn rw-btn-secondary" @onclick="CancelDelete">Cancel</button>
                                    <button class="rw-btn rw-btn-danger" @onclick="@(() => ConfirmDeleteAsync(true))">Delete + below</button>
                                    <button class="rw-btn rw-btn-danger" @onclick="@(() => ConfirmDeleteAsync(false))">Delete</button>
                                </div>
                            </div>
                        </div>
                    }

                    @if (_deleteAlternativeConfirmId is not null)
                    {
                        <div class="rw-modal-overlay" @onclick="CancelDeleteAlternative">
                            <div class="rw-modal" @onclick:stopPropagation>
                                <div class="rw-modal-header">Delete Alternative</div>
                                <div class="rw-modal-body">
                                    <p>Delete this rewrite alternative? Remaining alternatives will be renumbered. This can't be undone.</p>
                                </div>
                                <div class="rw-modal-actions">
                                    <button class="rw-btn rw-btn-secondary" @onclick="CancelDeleteAlternative">Cancel</button>
                                    <button class="rw-btn rw-btn-danger" @onclick="ConfirmDeleteAlternativeAsync">Delete</button>
                                </div>
                            </div>
                        </div>
                    }

                    @if (_rewriteDialogInteractionId is not null)
                    {
                        <div class="rw-modal-overlay" @onclick="CancelRewriteDialog">
                            <div class="rw-modal" @onclick:stopPropagation>
                                <div class="rw-modal-header">Custom Rewrite Instruction</div>
                                <div class="rw-modal-body">
                                    <textarea class="rw-rewrite-textarea" @bind="_rewriteInstruction" @bind:event="oninput" placeholder="Describe how to rewrite this interaction..."></textarea>
                                </div>
                                <div class="rw-modal-actions">
                                    <button class="rw-btn rw-btn-secondary" @onclick="CancelRewriteDialog">Cancel</button>
                                    <button class="rw-btn rw-btn-primary" disabled="@string.IsNullOrWhiteSpace(_rewriteInstruction)" @onclick="ConfirmRewriteAsync">Rewrite</button>
                                </div>
                            </div>
                        </div>
                    }

                    @if (_infoPopupInteractionId is not null && _session is not null)
                    {
                        var infoInteraction = _session.Interactions.FirstOrDefault(i => i.Id == _infoPopupInteractionId);
                        if (infoInteraction is not null)
                        {
                            <div class="rw-modal-overlay" @onclick="CloseInteractionInfo">
                                <div class="rw-modal rw-modal-info" @onclick:stopPropagation>
                                    <div class="rw-modal-header">Interaction Info</div>
                                    <div class="rw-modal-body">
                                        <div class="rw-info-grid">
                                            <div class="rw-info-row"><span class="rw-info-label">Actor</span><span class="rw-info-value">@infoInteraction.ActorName</span></div>
                                            <div class="rw-info-row"><span class="rw-info-label">Type</span><span class="rw-info-value">@infoInteraction.InteractionType</span></div>
                                            <div class="rw-info-row"><span class="rw-info-label">Created</span><span class="rw-info-value">@infoInteraction.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</span></div>
                                            @if (infoInteraction.ParentInteractionId is not null)
                                            {
                                                <div class="rw-info-row"><span class="rw-info-label">Alternative #</span><span class="rw-info-value">@infoInteraction.AlternativeIndex</span></div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(infoInteraction.GeneratedByCommand))
                                            {
                                                <div class="rw-info-row"><span class="rw-info-label">Command</span><span class="rw-info-value">@infoInteraction.GeneratedByCommand</span></div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(infoInteraction.GeneratedByModelName))
                                            {
                                                <div class="rw-info-row"><span class="rw-info-label">Model</span><span class="rw-info-value">@infoInteraction.GeneratedByModelName</span></div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(infoInteraction.GeneratedByProvider))
                                            {
                                                <div class="rw-info-row"><span class="rw-info-label">Provider</span><span class="rw-info-value">@infoInteraction.GeneratedByProvider</span></div>
                                            }
                                            @if (infoInteraction.GeneratedTemperature.HasValue)
                                            {
                                                <div class="rw-info-row"><span class="rw-info-label">Temperature</span><span class="rw-info-value">@infoInteraction.GeneratedTemperature.Value.ToString("F2")</span></div>
                                            }
                                            @if (infoInteraction.GeneratedTopP.HasValue)
                                            {
                                                <div class="rw-info-row"><span class="rw-info-label">Top-P</span><span class="rw-info-value">@infoInteraction.GeneratedTopP.Value.ToString("F2")</span></div>
                                            }
                                            @if (infoInteraction.GeneratedMaxTokens.HasValue)
                                            {
                                                <div class="rw-info-row"><span class="rw-info-label">Max Tokens</span><span class="rw-info-value">@infoInteraction.GeneratedMaxTokens.Value</span></div>
                                            }
                                            <div class="rw-info-row"><span class="rw-info-label">Excluded</span><span class="rw-info-value">@(infoInteraction.IsExcluded ? "Yes" : "No")</span></div>
                                            <div class="rw-info-row"><span class="rw-info-label">Pinned</span><span class="rw-info-value">@(infoInteraction.IsPinned ? "Yes" : "No")</span></div>
                                            <div class="rw-info-row"><span class="rw-info-label">Hidden</span><span class="rw-info-value">@(infoInteraction.IsHidden ? "Yes" : "No")</span></div>
                                        </div>
                                    </div>
                                    <div class="rw-modal-actions">
                                        <button class="rw-btn rw-btn-secondary" @onclick="CloseInteractionInfo">Close</button>
                                    </div>
                                </div>
                            </div>
                        }
                    }

                    @if (ShowPendingResponseIndicator)
                    {
                        <div class="rw-interaction rw-interaction-pending" aria-live="polite" aria-busy="true">
                            <div class="rw-actor-badge rw-pending-badge">
                                <span class="rw-spinner rw-spinner-pending"></span>
                            </div>
                            <div class="rw-interaction-body">
                                <div class="rw-actor-name">Generating</div>
                                <div class="rw-pending-response-text">@_pendingResponseLabel</div>
                            </div>
                        </div>
                    }
                }
            </div>

            @* ─── Portal: Retry dropdown menu (fixed position, escapes scroll container) ─── *@
            @if (_retryMenuInteractionId is not null)
            {
                var retryId = _retryMenuInteractionId;
                <div class="rw-menu-backdrop" @onclick="@(() => { _retryMenuInteractionId = null; })"></div>
                <div class="rw-dropdown-menu rw-dropdown-fixed" style="top: @(_menuPosition.Top)px; left: @(_menuPosition.Left)px;">
                    <button class="rw-dropdown-item" @onclick="@(() => RetryAsync(retryId))">
                        <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"/><path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"/></svg>
                        Retry
                    </button>
                    <div class="rw-dropdown-submenu">
                        <button class="rw-dropdown-item rw-has-submenu">
                            <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"/><path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"/></svg>
                            Retry with model
                            <span class="rw-submenu-arrow">&#x25B6;</span>
                        </button>
                        <div class="rw-dropdown-submenu-content">
                            @if (_availableModels is not null)
                            {
                                @foreach (var model in _availableModels)
                                {
                                    <button class="rw-dropdown-item" @onclick="@(() => RetryWithModelAsync(retryId, model.Id))">@model.DisplayName</button>
                                }
                            }
                        </div>
                    </div>
                    <div class="rw-dropdown-submenu">
                        <button class="rw-dropdown-item rw-has-submenu">
                            <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"/><path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"/></svg>
                            Retry as...
                            <span class="rw-submenu-arrow">&#x25B6;</span>
                        </button>
                        <div class="rw-dropdown-submenu-content">
                            <button class="rw-dropdown-item" @onclick="@(() => RetryAsAsync(retryId, ContinueAsActor.Npc, "Narrative"))">
                                <span class="rw-identity-initial">&#x1F4D6;</span> Narrative
                            </button>
                            @if (_identityOptions is not null)
                            {
                                @foreach (var identity in _identityOptions)
                                {
                                    <button class="rw-dropdown-item" @onclick="@(() => RetryAsAsync(retryId, identity.Actor, identity.DisplayName))">
                                        <span class="rw-identity-initial">@GetInitial(identity.DisplayName)</span> @identity.DisplayName
                                    </button>
                                }
                            }
                        </div>
                    </div>
                    <button class="rw-dropdown-item" @onclick="@(() => MakeLongerAsync(retryId))">
                        <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="8" x2="21" y2="8"/><line x1="3" y1="12" x2="18" y2="12"/><line x1="3" y1="16" x2="15" y2="16"/></svg>
                        Make longer
                    </button>
                    <button class="rw-dropdown-item" @onclick="@(() => MakeShorterAsync(retryId))">
                        <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="8" x2="18" y2="8"/><line x1="3" y1="12" x2="13" y2="12"/><line x1="3" y1="16" x2="8" y2="16"/></svg>
                        Make shorter
                    </button>
                    <button class="rw-dropdown-item" @onclick="@(() => ShowRewriteDialog(retryId))">
                        <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                        Ask to rewrite
                    </button>
                </div>
            }

            @* ─── Portal: Kebab dropdown menu (fixed position, escapes scroll container) ─── *@
            @if (_kebabMenuInteractionId is not null && _session is not null)
            {
                var kebabId = _kebabMenuInteractionId;
                var kebabInteraction = _session.Interactions.FirstOrDefault(i => i.Id == kebabId);
                var kebabOriginalId = kebabInteraction?.ParentInteractionId ?? kebabId;
                <div class="rw-menu-backdrop" @onclick="@(() => { _kebabMenuInteractionId = null; })"></div>
                <div class="rw-dropdown-menu rw-dropdown-fixed" style="top: @(_menuPosition.Top)px; left: @(_menuPosition.Left)px;">
                    @if (kebabInteraction is not null)
                    {
                        <button class="rw-dropdown-item rw-flag-toggle" @onclick="@(() => ToggleFlagAsync(kebabId, InteractionFlag.Excluded))"
                                title="Excluded interactions are not sent to the AI, but are still visible in the user interface.">
                            <span class="rw-flag-check">@(kebabInteraction.IsExcluded ? "☑" : "☐")</span>
                            <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                            Excluded
                        </button>
                        <button class="rw-dropdown-item rw-flag-toggle" @onclick="@(() => ToggleFlagAsync(kebabId, InteractionFlag.Pinned))"
                                title="Pinned interactions are always included in AI context.">
                            <span class="rw-flag-check">@(kebabInteraction.IsPinned ? "☑" : "☐")</span>
                            <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v8l4 4v2H8v-2l4-4V2z"/><line x1="8" y1="22" x2="16" y2="22"/></svg>
                            Pinned
                        </button>
                        <button class="rw-dropdown-item rw-flag-toggle" @onclick="@(() => ToggleFlagAsync(kebabId, InteractionFlag.Hidden))"
                                title="Hiding will hide the interactions from the user interface, but will still be sent to the AI.">
                            <span class="rw-flag-check">@(kebabInteraction.IsHidden ? "☑" : "☐")</span>
                            <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                            Hidden
                        </button>
                    }
                    <div class="rw-dropdown-separator"></div>
                    <button class="rw-dropdown-item" @onclick="@(() => ForkAboveAsync(kebabOriginalId))">
                        <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17l5-5 5 5"/><path d="M7 7h10"/></svg>
                        Fork Here &amp; Above
                    </button>
                    <button class="rw-dropdown-item" @onclick="@(() => ForkBelowAsync(kebabOriginalId))">
                        <svg class="rw-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 7l5 5 5-5"/><path d="M7 17h10"/></svg>
                        Fork Here &amp; Below
                    </button>
                </div>
            }

            
            <div class="rw-prompt-area" @onclick:stopPropagation>

                
                @if (_intentPopupOpen)
                {
                    <div class="rw-popup rw-intent-popup">
                        <button class="rw-popup-item @(_selectedIntent == PromptIntent.Message ? "is-selected" : "")"
                                @onclick="@(() => SelectIntent(PromptIntent.Message))">
                            <div class="rw-popup-item-content">
                                <span class="rw-popup-item-title">Message</span>
                                <span class="rw-popup-item-desc">Act as one of the characters</span>
                            </div>
                            @if (_selectedIntent == PromptIntent.Message)
                            {
                                <span class="rw-popup-check">✓</span>
                            }
                        </button>
                        <button class="rw-popup-item @(_selectedIntent == PromptIntent.Narrative ? "is-selected" : "")"
                                @onclick="@(() => SelectIntent(PromptIntent.Narrative))">
                            <div class="rw-popup-item-content">
                                <span class="rw-popup-item-title">Narrative by Character</span>
                                <span class="rw-popup-item-desc">Expand tone or phrase from selected character POV</span>
                            </div>
                            @if (_selectedIntent == PromptIntent.Narrative)
                            {
                                <span class="rw-popup-check">✓</span>
                            }
                        </button>
                        <button class="rw-popup-item @(_selectedIntent == PromptIntent.Instruction ? "is-selected" : "")"
                                @onclick="@(() => SelectIntent(PromptIntent.Instruction))">
                            <div class="rw-popup-item-content">
                                <span class="rw-popup-item-title">Instruction</span>
                                <span class="rw-popup-item-desc">Tell the AI what to do</span>
                            </div>
                            @if (_selectedIntent == PromptIntent.Instruction)
                            {
                                <span class="rw-popup-check">✓</span>
                            }
                        </button>
                    </div>
                }

                
                @if (_identityPopupOpen)
                {
                    <div class="rw-popup rw-identity-popup">
                        <div class="rw-popup-header">
                            <span class="rw-popup-intent-label">@IntentLabel</span>
                        </div>
                        <div class="rw-identity-list">
                            @foreach (var option in _identityOptions)
                            {
                                <button class="rw-identity-item @(option.Id == _selectedIdentity?.Id ? "is-selected" : "") @(IsIdentityOptionDisabled(option) ? "is-disabled" : "")"
                                        @onclick="@(() => SelectIdentity(option))"
                                        disabled="@(IsIdentityOptionDisabled(option))"
                                        title="@GetIdentityOptionTitle(option)">
                                    <span class="rw-identity-badge">@GetInitial(option.DisplayName)</span>
                                    <span class="rw-identity-name">@option.DisplayName</span>
                                    @if (option.Id == _selectedIdentity?.Id)
                                    {
                                        <span class="rw-popup-check">✓</span>
                                    }
                                </button>
                            }
                        </div>
                        @if (_showCustomInput)
                        {
                            <div class="rw-custom-name-row">
                                <input class="rw-custom-name-input" placeholder="Character name..."
                                       @bind="_customIdentityName" @bind:event="oninput" />
                            </div>
                        }
                    </div>
                }

                <div class="rw-continue-row">
                    <span class="rw-continue-label">Continue As</span>
                    <button class="rw-continue-chip @(HasPersonaContinueSelection && !_continueIncludeNarrative ? "is-active" : string.Empty)"
                            @onclick="ContinueAsYouQuickAsync"
                            disabled="@_isSubmitting"
                            @onclick:stopPropagation>
                        You
                    </button>
                    <button class="rw-continue-chip @(HasNpcContinueSelection && _continueIncludeNarrative ? "is-active" : string.Empty)"
                            @onclick="ContinueAsNpcQuickAsync"
                            disabled="@_isSubmitting"
                            @onclick:stopPropagation>
                        NPC
                    </button>
                    <button class="rw-continue-chip rw-continue-chip-custom @((HasCustomContinueSelection || ContinueSelectionCount > 0 || _continueIncludeNarrative || _continueCustomPopupOpen) ? "is-active" : string.Empty)"
                            @onclick="ToggleContinueCustomPopup"
                            disabled="@_isSubmitting"
                            @onclick:stopPropagation>
                        Custom
                    </button>
                </div>

                @if (_continueCustomPopupOpen)
                {
                    <div class="rw-popup rw-continue-custom-popup">
                        <div class="rw-popup-header">
                            <span class="rw-popup-intent-label">continue as custom</span>
                        </div>
                        <div class="rw-continue-options-row">
                            <button class="rw-popup-action-btn @(_continueIncludeNarrative ? "is-primary" : string.Empty)"
                                    disabled="@_isSubmitting"
                                    @onclick="ToggleContinueNarrative">
                                Narrative @(_continueIncludeNarrative ? "✓" : string.Empty)
                            </button>
                            @if (ContinueCustomIdentityOption is not null)
                            {
                                <button class="rw-popup-action-btn @(HasCustomContinueSelection ? "is-primary" : string.Empty)"
                                        disabled="@_isSubmitting"
                                        @onclick="SelectContinueCustomIdentityShortcut">
                                    Custom @((HasCustomContinueSelection) ? "✓" : string.Empty)
                                </button>
                            }
                        </div>
                        <div class="rw-identity-list rw-continue-identity-list">
                            @foreach (var option in _identityOptions)
                            {
                                <button class="rw-identity-item @(IsContinueIdentitySelected(option) ? "is-selected" : string.Empty) @(_isSubmitting ? "is-disabled" : "")"
                                        disabled="@_isSubmitting"
                                        @onclick="@(() => ToggleContinueIdentitySelection(option.Id))">
                                    <span class="rw-identity-badge">@GetInitial(option.DisplayName)</span>
                                    <span class="rw-identity-name">@option.DisplayName</span>
                                    @if (IsContinueIdentitySelected(option))
                                    {
                                        <span class="rw-popup-check">✓</span>
                                    }
                                </button>
                            }
                        </div>
                        @if (HasCustomContinueSelection || _continueSelectedIdentityIds.Any(id => 
                            _identityOptions.FirstOrDefault(o => o.Id == id)?.SourceType == IdentityOptionSource.CustomCharacter))
                        {
                            <div class="rw-custom-name-row">
                                <input class="rw-custom-name-input" placeholder="Character name..."
                                       @bind="_customIdentityName" @bind:event="oninput" disabled="@_isSubmitting" />
                            </div>
                        }
                        <div class="rw-popup-actions rw-continue-popup-actions">
                            <button class="rw-popup-action-btn"
                                    disabled="@_isSubmitting"
                                    @onclick="ClearContinueAsAsync">Clear</button>
                            <button class="rw-popup-action-btn is-primary"
                                    disabled="@_isSubmitting"
                                    @onclick="ContinueFromIdentityPopupAsync">Continue</button>
                        </div>
                    </div>
                }

                
                <div class="rw-input-row">
                    @if (_selectedIntent == PromptIntent.Message)
                    {
                        <button class="rw-identity-btn rw-identity-btn-outside @(_selectedIdentity is not null ? "has-selection" : string.Empty)"
                                @onclick="ToggleIdentityPopup"
                                @onclick:stopPropagation
                                title="Select character: @CurrentIdentityLabel">
                            <span class="rw-identity-btn-initial">@CurrentIdentityInitial</span>
                        </button>
                    }

                    <div class="rw-prompt-box">
                        <textarea class="rw-prompt-textarea"
                                  placeholder="Write something..."
                                  rows="2"
                                  @bind="_promptText"
                                  @bind:event="oninput"
                                  disabled="@_isSubmitting"></textarea>
                        <div class="rw-prompt-toolbar">
                            <div class="rw-toolbar-left">
                                <button class="rw-intent-btn" @onclick="ToggleIntentPopup" @onclick:stopPropagation disabled="@_isSubmitting" title="Change message type">
                                    @IntentLabel <span class="rw-chevron">⌃</span>
                                </button>
                            </div>
                            <div class="rw-toolbar-right">
                                <button class="rw-add-btn"
                                        @onclick="AddPromptEntryAsync"
                                        disabled="@(!CanAddPromptEntry)"
                                        title="Add instruction or narrative">+</button>
                                <button class="rw-send-btn is-ready"
                                        @onclick="SubmitOrOverflowContinueAsync"
                                        disabled="@(_isSubmitting)"
                                        title="Send text or continue based on recent context">
                                    @if (_isSubmitting)
                                    {
                                        <span class="rw-spinner"></span>
                                    }
                                    else if (HasPromptText)
                                    {
                                        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M8 13V3M3 8l5-5 5 5"/>
                                        </svg>
                                    }
                                    else
                                    {
                                        <span class="rw-send-ellipsis">•••</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        }

    </div>

    
    <div class="rw-panel-resize-handle" @onclick:stopPropagation title="Resize settings panel"></div>
    <div class="rw-settings-panel" @onclick:stopPropagation>

        <div class="rw-settings-tabs">
            <button class="rw-settings-tab @(_activeSettingsTab == "scenario" ? "is-active" : "")"
                    @onclick="@(() => _activeSettingsTab = "scenario")">Scenario</button>
            <button class="rw-settings-tab @(_activeSettingsTab == "settings" ? "is-active" : "")"
                    @onclick="@(() => _activeSettingsTab = "settings")">
                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" style="margin-right:4px;vertical-align:-1px">
                    <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z"/>
                    <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52l-.094-.319zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.291-.16c.764-.415 1.6.42 1.184 1.185l-.159.292a1.873 1.873 0 0 0 1.116 2.692l.318.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.291c.415.764-.42 1.6-1.185 1.184l-.291-.159a1.873 1.873 0 0 0-2.693 1.116l-.094.318c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.692-1.115l-.292.16c-.764.415-1.6-.42-1.184-1.185l.159-.291A1.873 1.873 0 0 0 1.945 8.93l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094A1.873 1.873 0 0 0 3.06 4.47l-.16-.292c-.415-.764.42-1.6 1.185-1.184l.292.159a1.873 1.873 0 0 0 2.692-1.115l.094-.319z"/>
                </svg>Settings
            </button>
            <button class="rw-settings-tab @(_activeSettingsTab == "assistant" ? "is-active" : "")"
                    @onclick="@(() => _activeSettingsTab = "assistant")">
                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" style="margin-right:4px;vertical-align:-1px">
                    <path d="M2.678 11.894a1 1 0 0 1 .287.801 10.97 10.97 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8.06 8.06 0 0 0 8 14c3.996 0 7-2.807 7-6 0-3.192-3.004-6-7-6S1 4.808 1 8c0 1.468.617 2.83 1.678 3.894z"/>
                </svg>Assistant
            </button>
            <button class="rw-settings-tab @(_activeSettingsTab == "adaptive" ? "is-active" : "")"
                    @onclick="@(() => _activeSettingsTab = "adaptive")">
                Adaptive
            </button>
        </div>

        @if (_session is not null)
        {
            @if (_activeSettingsTab == "settings")
            {
                <div class="rw-settings-content">

                    <div class="rw-settings-section">
                        <div class="rw-settings-section-label">Behaviour</div>
                        <select class="rw-mode-select" @bind="_selectedBehaviorMode" @bind:after="ApplyBehaviorModeAsync">
                            <option value="@BehaviorMode.TakeTurns">↺  Take Turns</option>
                            <option value="@BehaviorMode.Spectate">👁  Spectate</option>
                            <option value="@BehaviorMode.NpcOnly">★  NPC Only</option>
                        </select>
                    </div>

                    <div class="rw-settings-section">
                        <div class="rw-settings-section-label">Model Override</div>
                        <ModelSettingsPanel SessionId="@_session.Id" OnSettingsUpdated="OnModelSettingsUpdated" />
                    </div>

                </div>
            }

            @if (_activeSettingsTab == "scenario")
            {
                <div class="rw-settings-content">
                    <div class="rw-settings-section">
                        <div class="rw-settings-section-label">Session Info</div>
                        <div class="rw-settings-info-row"><span>Status</span><span>@_session.Status</span></div>
                        <div class="rw-settings-info-row"><span>Mode</span><span>@_session.BehaviorMode</span></div>
                        <div class="rw-settings-info-row"><span>Persona</span><span>@_session.PersonaName</span></div>
                        <div class="rw-settings-info-row"><span>Created</span><span>@_session.CreatedAt.ToString("MMM d")</span></div>
                    </div>

                    @if (_loadedScenario is not null)
                    {
                        @* ── Style ── *@
                        <div class="rw-collapsible-section">
                            <button class="rw-collapsible-header" @onclick="@(() => ToggleScenarioSection("style"))">
                                <span class="rw-collapsible-chevron @(_expandedScenarioSections.Contains("style") ? "is-open" : "")">▸</span>
                                <span class="rw-collapsible-title">Style</span>
                            </button>
                            @if (_expandedScenarioSections.Contains("style"))
                            {
                                <div class="rw-collapsible-body">
                                    <div class="rw-scenario-field">
                                        <label class="rw-scenario-field-label">Tone</label>
                                        <input class="rw-settings-input" placeholder="e.g. slow-burn, tense, playful"
                                               value="@_loadedScenario.Style.Tone"
                                               @onchange="@(e => { _loadedScenario.Style.Tone = e.Value?.ToString(); MarkScenarioDirty(); })" />
                                    </div>
                                    <div class="rw-scenario-field">
                                        <label class="rw-scenario-field-label">Writing Style</label>
                                        <input class="rw-settings-input" placeholder="e.g. literary, dialog-driven"
                                               value="@_loadedScenario.Style.WritingStyle"
                                               @onchange="@(e => { _loadedScenario.Style.WritingStyle = e.Value?.ToString(); MarkScenarioDirty(); })" />
                                    </div>
                                    <div class="rw-scenario-field">
                                        <label class="rw-scenario-field-label">Point of View</label>
                                        <input class="rw-settings-input" placeholder="e.g. third-person limited"
                                               value="@_loadedScenario.Style.PointOfView"
                                               @onchange="@(e => { _loadedScenario.Style.PointOfView = e.Value?.ToString(); MarkScenarioDirty(); })" />
                                    </div>
                                    <div class="rw-scenario-field">
                                        <label class="rw-scenario-field-label">Style Guidelines</label>
                                        @for (var i = 0; i < _loadedScenario.Style.StyleGuidelines.Count; i++)
                                        {
                                            var idx = i;
                                            <div class="rw-list-item-row">
                                                <input class="rw-settings-input" value="@_loadedScenario.Style.StyleGuidelines[idx]"
                                                       @onchange="@(e => { _loadedScenario.Style.StyleGuidelines[idx] = e.Value?.ToString() ?? ""; MarkScenarioDirty(); })" />
                                                <button class="rw-list-remove-btn" @onclick="@(() => { _loadedScenario.Style.StyleGuidelines.RemoveAt(idx); MarkScenarioDirty(); })">✕</button>
                                            </div>
                                        }
                                        <button class="rw-list-add-btn" @onclick="@(() => _loadedScenario.Style.StyleGuidelines.Add(""))">+ Add Guideline</button>
                                    </div>
                                </div>
                            }
                        </div>

                        @* ── Plot ── *@
                        <div class="rw-collapsible-section">
                            <button class="rw-collapsible-header" @onclick="@(() => ToggleScenarioSection("plot"))">
                                <span class="rw-collapsible-chevron @(_expandedScenarioSections.Contains("plot") ? "is-open" : "")">▸</span>
                                <span class="rw-collapsible-title">Plot</span>
                            </button>
                            @if (_expandedScenarioSections.Contains("plot"))
                            {
                                <div class="rw-collapsible-body">
                                    <div class="rw-scenario-field">
                                        <label class="rw-scenario-field-label">Description</label>
                                        <textarea class="rw-settings-textarea" rows="3"
                                                  placeholder="The overarching story"
                                                  value="@_loadedScenario.Plot.Description"
                                                  @onchange="@(e => { _loadedScenario.Plot.Description = e.Value?.ToString(); MarkScenarioDirty(); })"></textarea>
                                    </div>
                                    <div class="rw-scenario-field">
                                        <label class="rw-scenario-field-label">Conflicts</label>
                                        @for (var i = 0; i < _loadedScenario.Plot.Conflicts.Count; i++)
                                        {
                                            var idx = i;
                                            <div class="rw-list-item-row">
                                                <input class="rw-settings-input" value="@_loadedScenario.Plot.Conflicts[idx]"
                                                       @onchange="@(e => { _loadedScenario.Plot.Conflicts[idx] = e.Value?.ToString() ?? ""; MarkScenarioDirty(); })" />
                                                <button class="rw-list-remove-btn" @onclick="@(() => { _loadedScenario.Plot.Conflicts.RemoveAt(idx); MarkScenarioDirty(); })">✕</button>
                                            </div>
                                        }
                                        <button class="rw-list-add-btn" @onclick="@(() => _loadedScenario.Plot.Conflicts.Add(""))">+ Add Conflict</button>
                                    </div>
                                    <div class="rw-scenario-field">
                                        <label class="rw-scenario-field-label">Goals</label>
                                        @for (var i = 0; i < _loadedScenario.Plot.Goals.Count; i++)
                                        {
                                            var idx = i;
                                            <div class="rw-list-item-row">
                                                <input class="rw-settings-input" value="@_loadedScenario.Plot.Goals[idx]"
                                                       @onchange="@(e => { _loadedScenario.Plot.Goals[idx] = e.Value?.ToString() ?? ""; MarkScenarioDirty(); })" />
                                                <button class="rw-list-remove-btn" @onclick="@(() => { _loadedScenario.Plot.Goals.RemoveAt(idx); MarkScenarioDirty(); })">✕</button>
                                            </div>
                                        }
                                        <button class="rw-list-add-btn" @onclick="@(() => _loadedScenario.Plot.Goals.Add(""))">+ Add Goal</button>
                                    </div>
                                </div>
                            }
                        </div>

                        @* ── Setting ── *@
                        <div class="rw-collapsible-section">
                            <button class="rw-collapsible-header" @onclick="@(() => ToggleScenarioSection("setting"))">
                                <span class="rw-collapsible-chevron @(_expandedScenarioSections.Contains("setting") ? "is-open" : "")">▸</span>
                                <span class="rw-collapsible-title">Setting</span>
                            </button>
                            @if (_expandedScenarioSections.Contains("setting"))
                            {
                                <div class="rw-collapsible-body">
                                    <div class="rw-scenario-field">
                                        <label class="rw-scenario-field-label">World Description</label>
                                        <textarea class="rw-settings-textarea" rows="2"
                                                  placeholder="The world/environment"
                                                  value="@_loadedScenario.Setting.WorldDescription"
                                                  @onchange="@(e => { _loadedScenario.Setting.WorldDescription = e.Value?.ToString(); MarkScenarioDirty(); })"></textarea>
                                    </div>
                                    <div class="rw-scenario-field">
                                        <label class="rw-scenario-field-label">World Rules</label>
                                        @for (var i = 0; i < _loadedScenario.Setting.WorldRules.Count; i++)
                                        {
                                            var idx = i;
                                            <div class="rw-list-item-row">
                                                <input class="rw-settings-input" value="@_loadedScenario.Setting.WorldRules[idx]"
                                                       @onchange="@(e => { _loadedScenario.Setting.WorldRules[idx] = e.Value?.ToString() ?? ""; MarkScenarioDirty(); })" />
                                                <button class="rw-list-remove-btn" @onclick="@(() => { _loadedScenario.Setting.WorldRules.RemoveAt(idx); MarkScenarioDirty(); })">✕</button>
                                            </div>
                                        }
                                        <button class="rw-list-add-btn" @onclick="@(() => _loadedScenario.Setting.WorldRules.Add(""))">+ Add Rule</button>
                                    </div>
                                </div>
                            }
                        </div>

                        @* ── Characters ── *@
                        <div class="rw-collapsible-section">
                            <button class="rw-collapsible-header" @onclick="@(() => ToggleScenarioSection("characters"))">
                                <span class="rw-collapsible-chevron @(_expandedScenarioSections.Contains("characters") ? "is-open" : "")">▸</span>
                                <span class="rw-collapsible-title">Characters (@_loadedScenario.Characters.Count)</span>
                            </button>
                            @if (_expandedScenarioSections.Contains("characters"))
                            {
                                <div class="rw-collapsible-body">
                                    @foreach (var character in _loadedScenario.Characters)
                                    {
                                        <div class="rw-scenario-character">
                                            <div class="rw-scenario-field">
                                                <label class="rw-scenario-field-label">@(character.Name ?? "Unnamed") @(!string.IsNullOrWhiteSpace(character.Role) ? $"({character.Role})" : "")</label>
                                                <textarea class="rw-settings-textarea" rows="3"
                                                          placeholder="Character description, personality, motivations..."
                                                          value="@character.Description"
                                                          @onchange="@(e => { character.Description = e.Value?.ToString(); MarkScenarioDirty(); })"></textarea>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        @* ── Persona ── *@
                        <div class="rw-collapsible-section">
                            <button class="rw-collapsible-header" @onclick="@(() => ToggleScenarioSection("persona"))">
                                <span class="rw-collapsible-chevron @(_expandedScenarioSections.Contains("persona") ? "is-open" : "")">▸</span>
                                <span class="rw-collapsible-title">Persona</span>
                            </button>
                            @if (_expandedScenarioSections.Contains("persona"))
                            {
                                <div class="rw-collapsible-body">
                                    <div class="rw-scenario-field">
                                        <label class="rw-scenario-field-label">Name</label>
                                        <input class="rw-settings-input"
                                               value="@_session.PersonaName"
                                               @onchange="@(e => { _session.PersonaName = e.Value?.ToString() ?? "You"; _ = SaveSessionSettingsAsync(); })" />
                                    </div>
                                    <div class="rw-scenario-field">
                                        <label class="rw-scenario-field-label">Description</label>
                                        <textarea class="rw-settings-textarea" rows="2"
                                                  placeholder="Persona description, perspective..."
                                                  value="@_session.PersonaDescription"
                                                  @onchange="@(e => { _session.PersonaDescription = e.Value?.ToString() ?? ""; _ = SaveSessionSettingsAsync(); })"></textarea>
                                    </div>
                                </div>
                            }
                        </div>

                        @* ── Save Button ── *@
                        <button class="rw-scenario-save-btn @(_scenarioDirty ? "" : "is-disabled")"
                                disabled="@(!_scenarioDirty)"
                                @onclick="OnSaveScenarioClicked">
                            @(_scenarioDirty ? "Save Scenario Changes" : "No Changes")
                        </button>
                    }
                    else
                    {
                        <div class="rw-settings-section">
                            <p class="rw-scenario-empty">No scenario linked to this session.</p>
                        </div>
                    }
                </div>
            }

            @if (_activeSettingsTab == "assistant")
            {
                <div class="rw-settings-content">
                    <div class="rw-settings-section">
                        <div class="rw-settings-section-label">Assistant Model</div>
                        <select class="rw-mode-select" @bind="_assistantSelectedModelId" @bind:after="OnAssistantModelChanged">
                            <option value="">(Use Function Default)</option>
                            @foreach (var group in _assistantGroupedModels)
                            {
                                <optgroup label="@group.Key">
                                    @foreach (var model in group.Value)
                                    {
                                        <option value="@model.Id">@(model.DisplayName ?? model.ModelIdentifier)</option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </div>
                    <AssistantPanel Title="Role-Play Assistant"
                                    SessionId="@_session.Id"
                                    Messages="@GetActiveAssistantMessages()"
                                    Chats="@GetAssistantChatSummaries()"
                                    ActiveChatId="@_activeAssistantChatId"
                                    OnSelectChatRequest="OnAssistantSelectChat"
                                    OnCreateChatRequest="OnAssistantCreateChat"
                                    OnDeleteChatRequest="OnAssistantDeleteChat"
                                    OnGenerateRequest="OnAssistantGenerateRequest"
                                    OnClearChatRequest="OnAssistantClearChat" />
                </div>
            }

            @if (_activeSettingsTab == "adaptive")
            {
                <div class="rw-settings-content">
                    <div class="rw-settings-section">
                        <div class="rw-settings-section-label">Active Profiles</div>
                        <div class="rw-scenario-field">
                            <label class="rw-scenario-field-label">Ranking Profile Id</label>
                            <input class="rw-settings-input"
                                   value="@_session.SelectedRankingProfileId"
                                   @onchange="@(e => { _session.SelectedRankingProfileId = e.Value?.ToString(); _ = SaveSessionSettingsAsync(); })" />
                        </div>
                        <div class="rw-scenario-field">
                            <label class="rw-scenario-field-label">Tone Profile Id</label>
                            <input class="rw-settings-input"
                                   value="@_session.SelectedToneProfileId"
                                   @onchange="@(e => { _session.SelectedToneProfileId = e.Value?.ToString(); _ = SaveSessionSettingsAsync(); })" />
                        </div>
                        <div class="rw-scenario-field">
                            <label class="rw-scenario-field-label">Style Floor</label>
                            <input class="rw-settings-input"
                                   value="@_session.StyleFloorOverride"
                                   @onchange="@(e => { _session.StyleFloorOverride = e.Value?.ToString(); _ = SaveSessionSettingsAsync(); })" />
                        </div>
                        <div class="rw-scenario-field">
                            <label class="rw-scenario-field-label">Style Ceiling</label>
                            <input class="rw-settings-input"
                                   value="@_session.StyleCeilingOverride"
                                   @onchange="@(e => { _session.StyleCeilingOverride = e.Value?.ToString(); _ = SaveSessionSettingsAsync(); })" />
                        </div>
                        <div class="rw-settings-info-row">
                            <span>Manual Tone Pin</span>
                            <input type="checkbox"
                                   checked="@_session.IsToneManuallyPinned"
                                   @onchange="@(e => { _session.IsToneManuallyPinned = e.Value is bool b && b; _ = SaveSessionSettingsAsync(); })" />
                        </div>
                        <div class="rw-settings-info-row">
                            <span>Effective Style Mode</span>
                            <span>@GetEffectiveStyleLabel()</span>
                        </div>
                        <div class="rw-settings-info-row">
                            <span>Style Resolution</span>
                            <span>@GetEffectiveStyleReason()</span>
                        </div>
                    </div>

                    <div class="rw-settings-section">
                        <div class="rw-settings-section-label">Profile Steering (Prompt Input)</div>
                        @if (string.IsNullOrWhiteSpace(_session.SelectedRankingProfileId))
                        {
                            <p class="rw-scenario-empty">No ranking profile selected for this session.</p>
                        }
                        else if (_activeProfileThemes.Count == 0)
                        {
                            <p class="rw-scenario-empty">Selected profile has no themes.</p>
                        }
                        else
                        {
                            @foreach (var group in _activeProfileThemes.GroupBy(x => x.Tier).OrderBy(g => GetTierPriority(g.Key)))
                            {
                                <div class="rw-scenario-field" style="margin-bottom:10px;">
                                    <label class="rw-scenario-field-label">@FormatTier(group.Key) (@group.Count())</label>
                                    @foreach (var theme in group.OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase))
                                    {
                                        <div class="rw-settings-info-row">
                                            <span>@theme.Name</span>
                                            <span>@(string.IsNullOrWhiteSpace(theme.Description) ? "(no description)" : theme.Description)</span>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <div class="rw-settings-section">
                        <div class="rw-settings-section-label">Character Stats</div>
                        @if (_session.AdaptiveState.CharacterStats.Count == 0)
                        {
                            <p class="rw-scenario-empty">No adaptive stats yet. Generate interactions to populate.</p>
                        }
                        else
                        {
                            @foreach (var actorStats in _session.AdaptiveState.CharacterStats.OrderBy(x => x.Key))
                            {
                                <div class="rw-scenario-field" style="margin-bottom:10px;">
                                    <label class="rw-scenario-field-label">@actorStats.Key</label>
                                    @foreach (var stat in actorStats.Value.Stats.OrderBy(x => x.Key))
                                    {
                                        <div class="rw-settings-info-row"><span>@stat.Key</span><span>@stat.Value</span></div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <div class="rw-settings-section">
                        <div class="rw-settings-section-label">Theme Tracker</div>
                        <div class="rw-settings-info-row"><span>Selection Rule</span><span>@_session.AdaptiveState.ThemeTracker.ThemeSelectionRule</span></div>
                        <div class="rw-settings-info-row">
                            <span>Primary Theme</span>
                            <span>
                                @if (!string.IsNullOrWhiteSpace(_session.AdaptiveState.ThemeTracker.PrimaryThemeId)
                                    && _session.AdaptiveState.ThemeTracker.Themes.TryGetValue(_session.AdaptiveState.ThemeTracker.PrimaryThemeId, out var primaryTheme))
                                {
                                    @primaryTheme.ThemeName
                                }
                                else
                                {
                                    @("(none)")
                                }
                            </span>
                        </div>
                        <div class="rw-settings-info-row">
                            <span>Secondary Theme</span>
                            <span>
                                @if (!string.IsNullOrWhiteSpace(_session.AdaptiveState.ThemeTracker.SecondaryThemeId)
                                    && _session.AdaptiveState.ThemeTracker.Themes.TryGetValue(_session.AdaptiveState.ThemeTracker.SecondaryThemeId, out var secondaryTheme))
                                {
                                    @secondaryTheme.ThemeName
                                }
                                else
                                {
                                    @("(none)")
                                }
                            </span>
                        </div>
                        @if (_session.AdaptiveState.ThemeTracker.Themes.Count == 0)
                        {
                            <p class="rw-scenario-empty">No tracked themes yet.</p>
                        }
                        else
                        {
                            @foreach (var theme in _session.AdaptiveState.ThemeTracker.Themes.Values.OrderByDescending(x => x.Score))
                            {
                                <div class="rw-scenario-field" style="margin-bottom:10px;">
                                    <label class="rw-scenario-field-label">@theme.ThemeName</label>
                                    <div class="rw-settings-info-row"><span>Intensity</span><span>@theme.Intensity</span></div>
                                    <div class="rw-settings-info-row"><span>Score</span><span>@theme.Score.ToString("F1")</span></div>
                                    <div class="rw-settings-info-row"><span>Choice Signal</span><span>@theme.Breakdown.ChoiceSignal.ToString("F1")</span></div>
                                    <div class="rw-settings-info-row"><span>Character Signal</span><span>@theme.Breakdown.CharacterStateSignal.ToString("F1")</span></div>
                                    <div class="rw-settings-info-row"><span>Interaction Signal</span><span>@theme.Breakdown.InteractionEvidenceSignal.ToString("F1")</span></div>
                                    <div class="rw-settings-info-row"><span>Phase Signal</span><span>@theme.Breakdown.ScenarioPhaseSignal.ToString("F1")</span></div>
                                </div>
                            }
                        }
                    </div>

                    <div class="rw-settings-section">
                        <div class="rw-settings-section-label">Explainability Events</div>
                        @if (_session.AdaptiveState.ThemeTracker.RecentEvidence.Count == 0)
                        {
                            <p class="rw-scenario-empty">No evidence events yet.</p>
                        }
                        else
                        {
                            @foreach (var ev in _session.AdaptiveState.ThemeTracker.RecentEvidence.TakeLast(20).Reverse())
                            {
                                <div class="rw-scenario-field" style="margin-bottom:10px;">
                                    <div class="rw-settings-info-row"><span>Theme</span><span>@ev.ThemeId</span></div>
                                    <div class="rw-settings-info-row"><span>Signal</span><span>@ev.SignalType</span></div>
                                    <div class="rw-settings-info-row"><span>Delta</span><span>@ev.Delta.ToString("F1")</span></div>
                                    <div class="rw-settings-info-row"><span>Confidence</span><span>@ev.Confidence.ToString("F2")</span></div>
                                    <div class="rw-settings-info-row"><span>Interaction</span><span>@ev.InteractionId</span></div>
                                    <div class="rw-settings-info-row"><span>Why</span><span>@ev.Rationale</span></div>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        }

    </div>

</div>

@code {
    private sealed record MenuRect(double Top, double Left, double Bottom, double Right, double Width, double Height);
}

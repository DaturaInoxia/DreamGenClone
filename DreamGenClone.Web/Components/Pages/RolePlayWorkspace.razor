    // --- Retry / Regenerate Commands ---

    private async Task ToggleRetryMenu(string interactionId)
    {
        if (_retryMenuInteractionId == interactionId)
        {
            _retryMenuInteractionId = null;
            return;
        }

        var rect = await JS.InvokeAsync<MenuRect?>("rolePlayWorkspace.getElementRect", $"[data-retry-btn='{interactionId}']");
        if (rect is not null)
        {
            _menuPosition = (rect.Bottom + 4, rect.Left);
        }

        _retryMenuInteractionId = interactionId;
        _kebabMenuInteractionId = null;
        _availableModels ??= await RegisteredModelRepository.GetAllEnabledAsync();
    }

    private async Task RetryAsync(string interactionId)
    {
        _retryMenuInteractionId = null;
        await RunRetryAsync(interactionId, () => InteractionRetryService.RetryAsync(_session!, interactionId));
    }

    private async Task RetryWithModelAsync(string interactionId, string modelId)
    {
        _retryMenuInteractionId = null;
        await RunRetryAsync(interactionId, () => InteractionRetryService.RetryWithModelAsync(_session!, interactionId, modelId));
    }

    private async Task RetryAsAsync(string interactionId, ContinueAsActor actor, string actorName)
    {
        _retryMenuInteractionId = null;
        await RunRetryAsync(interactionId, () => InteractionRetryService.RetryAsAsync(_session!, interactionId, actor, actorName));
    }

    private async Task MakeLongerAsync(string interactionId)
    {
        _retryMenuInteractionId = null;
        await RunRetryAsync(interactionId, () => InteractionRetryService.MakeLongerAsync(_session!, interactionId));
    }

    private async Task MakeShorterAsync(string interactionId)
    {
        _retryMenuInteractionId = null;
        await RunRetryAsync(interactionId, () => InteractionRetryService.MakeShorterAsync(_session!, interactionId));
    }

    private void ShowRewriteDialog(string interactionId)
    {
        _retryMenuInteractionId = null;
        _rewriteDialogInteractionId = interactionId;
        _rewriteInstruction = null;
    }

    private void CancelRewriteDialog()
    {
        _rewriteDialogInteractionId = null;
        _rewriteInstruction = null;
    }

    private async Task ConfirmRewriteAsync()
    {
        if (_session is null || _rewriteDialogInteractionId is null || string.IsNullOrWhiteSpace(_rewriteInstruction)) return;
        var interactionId = _rewriteDialogInteractionId;
        _rewriteDialogInteractionId = null;
        await RunRetryAsync(interactionId, () => InteractionRetryService.AskToRewriteAsync(_session, interactionId, _rewriteInstruction!));
        _rewriteInstruction = null;
    }

    private async Task RunRetryAsync(string interactionId, Func<Task<RolePlayInteraction>> retryFunc)
    {
        if (_session is null) return;
        _retryErrors.Remove(interactionId);
        _generatingIds.Add(interactionId);
        StateHasChanged();
        try
        {
            await retryFunc();
        }
        catch (Exception ex)
        {
            _retryErrors[interactionId] = ex.Message;
            Logger.LogWarning(ex, "Retry failed for interaction {InteractionId}", interactionId);
        }
        finally
        {
            _generatingIds.Remove(interactionId);
            StateHasChanged();
        }
    }

    // --- Alternative Navigation ---

    private int GetAlternativeCount(string originalId)
    {
        if (_session is null) return 0;
        return _session.Interactions.Count(i => i.ParentInteractionId == originalId);

    private (string Label, string Reason) ResolveEffectiveStyle(RolePlaySession session)
    {
        IntensityLevel? selectedIntensityLevel = IntensityLevel.SuggestivePg12;
        IntensityLevel? adaptiveIntensityLevel = null;

        if (!string.IsNullOrWhiteSpace(session.SelectedIntensityProfileId)
            && _intensityProfilesById.TryGetValue(session.SelectedIntensityProfileId, out var intensityProfile))
        {
            selectedIntensityLevel = intensityProfile.Intensity;
        }

        if (!string.IsNullOrWhiteSpace(session.AdaptiveIntensityProfileId)
            && _intensityProfilesById.TryGetValue(session.AdaptiveIntensityProfileId, out var adaptiveProfile))
        {
            adaptiveIntensityLevel = adaptiveProfile.Intensity;
        }

        return RolePlayStyleResolver.ResolveEffectiveStyle(session, selectedIntensityLevel, adaptiveIntensityLevel);
    }

    private string? GetIntensityDropdownValue()
    {
        if (_session is null)
        {
            return null;
        }

        if (_session.IsIntensityManuallyPinned)
        {
            return _session.SelectedIntensityProfileId;
        }

        return GetResolvedIntensityProfileId(_session) ?? _session.SelectedIntensityProfileId;
    }

    private string? GetResolvedIntensityProfileId(RolePlaySession session)
    {
        var (label, _) = ResolveEffectiveStyle(session);
        var resolvedScale = RolePlayStyleResolver.ParseBoundScale(label);
        if (!resolvedScale.HasValue)
        {
            return null;
        }

        var matches = _intensityProfiles.Where(profile => (int)profile.Intensity == resolvedScale.Value).Take(2).ToList();
        if (matches.Count != 1)
        {
            return null;
        }

        return matches[0].Id;
    }

    private void CaptureResolvedIntensitySnapshot(RolePlaySession session)
    {
        var (label, reason) = ResolveEffectiveStyle(session);
        session.LastResolvedIntensityLabel = label;
        session.LastResolvedIntensityReason = reason;
        session.LastResolvedIntensityUtc = DateTime.UtcNow;

        if (!session.IsIntensityManuallyPinned)
        {
            var resolvedProfileId = GetResolvedIntensityProfileId(session);
            if (!string.IsNullOrWhiteSpace(resolvedProfileId))
            {
                session.SelectedIntensityProfileId = resolvedProfileId;
            }
        }
    }


        if (option is not null)
        {
            _continueSelectedIdentityIds.Add(option.Id);
        }

        _continueIncludeNarrative = false;
        if (_isSubmitting)
        {
            return;
        }

        var request = BuildContinueRequest(SubmissionSource.ContinueAsPopupContinue);
        await ExecuteContinueAsync(request, "Continue As failed.");
    }

    private async Task ContinueAsNpcQuickAsync()
    {
        _continueCustomPopupOpen = false;
        _continueSelectedIdentityIds.Clear();
        foreach (var npcOption in NpcContinueOptions)
        {
            _continueSelectedIdentityIds.Add(npcOption.Id);
        }

        _continueIncludeNarrative = true;
        if (_isSubmitting)
        {
            return;
        }

        var request = BuildContinueRequest(SubmissionSource.ContinueAsPopupContinue);
        await ExecuteContinueAsync(request, "Continue As failed.");
    }

    private void ToggleContinueNarrative()
    {
        _continueIncludeNarrative = !_continueIncludeNarrative;
    }

    private void SelectContinueCustomIdentityShortcut()
    {
        var customOption = ContinueCustomIdentityOption;
        if (customOption is null)
        {
            return;
        }

        ToggleContinueIdentitySelection(customOption.Id);
    }

    private async Task ClearContinueAsAsync()
    {
        if (_session is null)
        {
            return;
        }

        _continueSelectedIdentityIds.Clear();
        _continueIncludeNarrative = false;

        var result = await RolePlayEngine.ContinueAsAsync(new ContinueAsRequest
        {
            SessionId = _session.Id,
            IsClearAction = true,
            TriggeredBy = SubmissionSource.ContinueAsPopupContinue
        });

        if (!result.Success)
        {
            _statusMessage = result.ValidationError ?? "Unable to clear Continue As selections.";
        }
    }

    private ContinueAsRequest BuildContinueRequest(SubmissionSource source, bool useCustomSelections = true)
    {
        var selectedOptions = useCustomSelections
            ? ContinueIdentityOptions.Where(x => _continueSelectedIdentityIds.Contains(x.Id)).ToList()
            : [];

        return new ContinueAsRequest
        {
            SessionId = _session!.Id,
            SelectedIdentityIds = selectedOptions.Select(x => x.Id).ToList(),
            SelectedParticipants = selectedOptions.Select(x => x.Actor).ToList(),
            IncludeNarrative = useCustomSelections && _continueIncludeNarrative,
            CustomIdentityName = useCustomSelections && !string.IsNullOrWhiteSpace(_customIdentityName)
                ? _customIdentityName.Trim()
                : null,
            TriggeredBy = source
        };
    }

    private async Task<bool> ExecuteContinueAsync(ContinueAsRequest request, string defaultErrorMessage)
    {
        _isSubmitting = true;
        _statusMessage = string.Empty;
        CloseAllPopups();
        _shouldFollowStoryUpdates = true;
        _isAwaitingModelResponse = true;
        _pendingResponseLabel = BuildContinuePendingResponseLabel(request);
        _pendingResponseText = string.Empty;
        _pendingResponseBuilder.Clear();
        _lastPendingResponseRenderAt = DateTime.MinValue;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        _shouldFollowStoryUpdates = await IsStoryNearBottomAsync();

        try
        {
            var result = await RolePlayEngine.ContinueAsAsync(request, OnRolePlayResponseChunkAsync);
            if (!result.Success)
            {
                _statusMessage = result.ValidationError ?? defaultErrorMessage;
                return false;
            }

            _statusMessage = string.Empty;
            await LoadSessionAsync();
            return true;
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
            Logger.LogError(ex, "Continue action failed for session {SessionId}", sessionId);
            return false;
        }
        finally
        {
            _isAwaitingModelResponse = false;
            _pendingResponseLabel = string.Empty;
            _pendingResponseText = string.Empty;
            _pendingResponseBuilder.Clear();
            _lastPendingResponseRenderAt = DateTime.MinValue;
            _isSubmitting = false;
        }
    }

    private static string FormatDecisionDeltas(string statDeltaJson)
    {
        if (string.IsNullOrWhiteSpace(statDeltaJson) || statDeltaJson == "{}")
        {
            return "Narrative impact without explicit stat deltas.";
        }

        try
        {
            var deltas = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, int>>(statDeltaJson);
            if (deltas is null || deltas.Count == 0)
            {
                return "Narrative impact without explicit stat deltas.";
            }

            return string.Join(", ", deltas.Select(x => $"{x.Key} {(x.Value >= 0 ? "+" : string.Empty)}{x.Value}"));
        }
        catch
        {
            return "Unable to parse stat impact.";
        }
    }

    private string ResolveDecisionThemeLabel(string scenarioId)
    {
        if (_session?.AdaptiveState?.ThemeTracker?.Themes is null
            || string.IsNullOrWhiteSpace(scenarioId))
        {
            return scenarioId;
        }

        if (_session.AdaptiveState.ThemeTracker.Themes.TryGetValue(scenarioId, out var theme)
            && !string.IsNullOrWhiteSpace(theme.ThemeName))
        {
            return $"{theme.ThemeName} ({scenarioId})";
        }

        return scenarioId;
    }

    private async Task ApplyDecisionOptionAsync(DreamGenClone.Domain.RolePlay.DecisionOption option)
    {
        if (_session is null || _pendingDecisionPrompt is null)
        {
            return;
        }

        _decisionPromptSubmitting = true;
        _decisionPromptError = string.Empty;
        try
        {
            var customResponse = option.IsCustomResponseFallback
                ? (string.IsNullOrWhiteSpace(_decisionCustomResponse) ? null : _decisionCustomResponse.Trim())
                : null;

            var outcome = await RolePlayEngine.ApplyDecisionAsync(
                _session.Id,
                _pendingDecisionPrompt.DecisionPoint.DecisionPointId,
                option.OptionId,
                customResponse);

            if (outcome is null || !outcome.Applied)
            {
                _decisionPromptError = "Could not apply the selected decision.";
                return;
            }

            _decisionCustomResponse = string.Empty;
            _dismissedDecisionPointId = null;
            await LoadSessionAsync();
        }
        catch (Exception ex)
        {
            _decisionPromptError = ex.Message;
        }
        finally
        {
            _decisionPromptSubmitting = false;
        }
    }

    private async Task<bool> IsStoryNearBottomAsync()
    {
        try
        {
            return await JS.InvokeAsync<bool>("rolePlayWorkspace.isStoryNearBottom", 120);
        }
        catch
        {
            return true;
        }
    }

    private Task OnRolePlayResponseChunkAsync(string chunk)
    {
        if (string.IsNullOrEmpty(chunk) || _isDisposed)
        {
            return Task.CompletedTask;
        }

        _pendingResponseBuilder.Append(chunk);

        var now = DateTime.UtcNow;
        if (now - _lastPendingResponseRenderAt < PendingResponseRenderInterval)
        {
            return Task.CompletedTask;
        }

        _lastPendingResponseRenderAt = now;
        _pendingResponseText = _pendingResponseBuilder.ToString();
        return InvokeAsync(StateHasChanged);
    }

    private void GoToSavedSessions() => Navigation.NavigateTo(RolePlayRoutes.Sessions);

    private async Task OpenDebugWindowAsync()
    {

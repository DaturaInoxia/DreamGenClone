        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to save edit for interaction {InteractionId}", interactionId);
        }
        _editContent.Remove(interactionId);
        _editSnapshots.Remove(interactionId);
        StateHasChanged();

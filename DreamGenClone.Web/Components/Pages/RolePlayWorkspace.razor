@page "/roleplay/workspace/{sessionId}"
@rendermode InteractiveServer

@using DreamGenClone.Web.Application.RolePlay
@using DreamGenClone.Web.Domain.RolePlay

@inject IRolePlayEngineService RolePlayEngine
@inject IRolePlayBranchService RolePlayBranchService
@inject IRolePlayIdentityOptionsService IdentityOptionsService
@inject IBehaviorModeService BehaviorModeService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<RolePlayWorkspace> Logger
@implements IAsyncDisposable

@code {
    [Parameter]
    public string sessionId { get; set; } = string.Empty;

    private RolePlaySession? _session;
    private string _statusMessage = string.Empty;
    private bool _isSubmitting = false;

    // Settings panel
    private BehaviorMode _selectedBehaviorMode = BehaviorMode.TakeTurns;
    private string _activeSettingsTab = "settings";
    private readonly WorkspaceSettingsState _workspaceSettings = new();
    private DotNetObjectReference<RolePlayWorkspace>? _dotNetRef;
    private bool _resizeInitialized;
    private int _lastRenderedInteractionCount = -1;

    // Unified prompt
    private string _promptText = string.Empty;
    private PromptIntent _selectedIntent = PromptIntent.Message;
    private bool _intentPopupOpen = false;
    private bool _identityPopupOpen = false;
    private bool _continueCustomPopupOpen = false;

    // Identity
    private List<IdentityOption> _identityOptions = [];
    private IdentityOption? _selectedIdentity = null;
    private string _customIdentityName = string.Empty;
    private bool _showCustomInput = false;
    private readonly HashSet<string> _continueSelectedIdentityIds = new(StringComparer.OrdinalIgnoreCase);
    private bool _continueIncludeNarrative;

    // Fork
    private string _branchTitle = "Forked Path";
    private int _branchFromIndex = -1;

    protected override async Task OnParametersSetAsync()
    {
        await LoadSessionAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_resizeInitialized)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync(
                "rolePlayWorkspace.initPanelResize",
                ".rw-shell",
                ".rw-panel-resize-handle",
                _workspaceSettings.SettingsPanelWidth,
                WorkspaceSettingsState.MinPanelWidth,
                WorkspaceSettingsState.MaxPanelWidth,
                _dotNetRef);

            _resizeInitialized = true;
        }

        var interactionCount = _session?.Interactions.Count ?? 0;
        if (interactionCount != _lastRenderedInteractionCount)
        {
            await JS.InvokeVoidAsync("rolePlayWorkspace.scrollStoryToBottom");
            _lastRenderedInteractionCount = interactionCount;
        }
    }

    private async Task LoadSessionAsync()
    {
        _session = await RolePlayEngine.GetSessionAsync(sessionId);
        if (_session is null)
        {
            _statusMessage = "Session not found.";
            Navigation.NavigateTo(RolePlayRoutes.Sessions);
            return;
        }

        _selectedBehaviorMode = _session.BehaviorMode;

        _identityOptions = (await IdentityOptionsService.GetIdentityOptionsAsync(_session)).ToList();

        var continueIds = _identityOptions
            .Where(x => x.IsAvailable)
            .Select(x => x.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        _continueSelectedIdentityIds.RemoveWhere(id => !continueIds.Contains(id));

        if (_selectedIdentity is null || !_identityOptions.Any(x => x.Id == _selectedIdentity.Id))
        {
            _selectedIdentity = _identityOptions.FirstOrDefault(x => x.IsAvailable);
        }
    }

    private void ToggleIntentPopup()
    {
        _intentPopupOpen = !_intentPopupOpen;
        _identityPopupOpen = false;
        _continueCustomPopupOpen = false;
    }

    private void SelectIntent(PromptIntent intent)
    {
        _selectedIntent = intent;
        _intentPopupOpen = false;
    }

    private void ToggleIdentityPopup()
    {
        _identityPopupOpen = !_identityPopupOpen;
        _intentPopupOpen = false;
        _continueCustomPopupOpen = false;
    }

    private void SelectIdentity(IdentityOption option)
    {
        if (!option.IsAvailable) return;
        _selectedIdentity = option;
        _showCustomInput = option.SourceType == IdentityOptionSource.CustomCharacter;
        if (!_showCustomInput)
        {
            _identityPopupOpen = false;
        }
    }

    private void CloseAllPopups()
    {
        _intentPopupOpen = false;
        _identityPopupOpen = false;
        _continueCustomPopupOpen = false;
    }

    private async Task ApplyBehaviorModeAsync()
    {
        if (_session is null) return;
        await RolePlayEngine.UpdateBehaviorModeAsync(_session.Id, _selectedBehaviorMode);
        Logger.LogInformation(
            "Role-play workspace behavior mode changed from settings panel: session={SessionId}, mode={Mode}",
            _session.Id,
            _selectedBehaviorMode);
        await LoadSessionAsync();
    }

    private bool CanSubmit =>
        _session is not null &&
        HasPromptText &&
        IsIdentitySelectionValidForIntent &&
        !_isSubmitting;

    private bool HasPromptText => !string.IsNullOrWhiteSpace(_promptText);

    private bool IsIdentitySelectionValidForIntent
    {
        get
        {
            if (_selectedIntent == PromptIntent.Instruction)
            {
                return true;
            }

            if (_selectedIdentity is null || !_selectedIdentity.IsAvailable)
            {
                return false;
            }

            if (_selectedIdentity.SourceType == IdentityOptionSource.CustomCharacter)
            {
                return !string.IsNullOrWhiteSpace(_customIdentityName);
            }

            return true;
        }
    }

    private async Task SubmitPromptAsync()
    {
        if (!CanSubmit) return;

        _isSubmitting = true;
        _statusMessage = string.Empty;
        CloseAllPopups();

        try
        {
            var submission = new UnifiedPromptSubmission
            {
                SessionId = _session!.Id,
                PromptText = _promptText.Trim(),
                Intent = _selectedIntent,
                SelectedIdentityId = _selectedIntent == PromptIntent.Instruction ? string.Empty : (_selectedIdentity?.Id ?? string.Empty),
                SelectedIdentityType = _selectedIntent == PromptIntent.Instruction ? IdentityOptionSource.Persona : (_selectedIdentity?.SourceType ?? IdentityOptionSource.Persona),
                CustomIdentityName = string.IsNullOrWhiteSpace(_customIdentityName) ? null : _customIdentityName.Trim(),
                BehaviorModeAtSubmit = _selectedBehaviorMode,
                SubmittedVia = _selectedIntent == PromptIntent.Instruction ? SubmissionSource.PlusButton : SubmissionSource.SendButton
            };

            Logger.LogInformation(
                "Role-play unified prompt submitted with settings snapshot: session={SessionId}, mode={Mode}",
                _session.Id,
                _selectedBehaviorMode);

            await RolePlayEngine.SubmitPromptAsync(submission);
            _promptText = string.Empty;
            await LoadSessionAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
            Logger.LogError(ex, "Unified prompt submission failed for session {SessionId}", sessionId);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task SubmitOrOverflowContinueAsync()
    {
        if (CanSubmit)
        {
            await SubmitPromptAsync();
            return;
        }

        if (_session is null)
        {
            return;
        }

        var request = BuildContinueRequest(SubmissionSource.MainOverflowContinue);

        await ExecuteContinueAsync(request, "Continue failed.");
    }

    private async Task AddManualInteractionAsync()
    {
        if (_session is null || string.IsNullOrWhiteSpace(_promptText) || _selectedIdentity is null)
            return;

        CloseAllPopups();
        var customName = _selectedIdentity.SourceType == IdentityOptionSource.CustomCharacter
            ? (string.IsNullOrWhiteSpace(_customIdentityName) ? "Custom" : _customIdentityName.Trim())
            : null;

        await RolePlayEngine.AddInteractionAsync(_session.Id, _selectedIdentity.Actor, _promptText, customName);
        _promptText = string.Empty;
        await LoadSessionAsync();
    }

    private async Task ContinueFromIdentityPopupAsync()
    {
        if (_session is null)
        {
            return;
        }

        var request = BuildContinueRequest(SubmissionSource.ContinueAsPopupContinue);
        var success = await ExecuteContinueAsync(request, "Continue As failed.");
        if (success)
        {
            _continueCustomPopupOpen = false;
        }
    }

    private void ToggleContinueCustomPopup()
    {
        _continueCustomPopupOpen = !_continueCustomPopupOpen;
        _intentPopupOpen = false;
        _identityPopupOpen = false;
    }

    private void ToggleContinueIdentitySelection(string optionId)
    {
        if (_continueSelectedIdentityIds.Contains(optionId))
        {
            _continueSelectedIdentityIds.Remove(optionId);
            return;
        }

        _continueSelectedIdentityIds.Add(optionId);
    }

    private async Task ContinueAsYouQuickAsync()
    {
        _continueCustomPopupOpen = false;
        var option = PersonaContinueOption;
        _continueSelectedIdentityIds.Clear();
        if (option is not null)
        {
            _continueSelectedIdentityIds.Add(option.Id);
        }

        _continueIncludeNarrative = false;
        var request = BuildContinueRequest(SubmissionSource.ContinueAsPopupContinue);
        await ExecuteContinueAsync(request, "Continue As failed.");
    }

    private async Task ContinueAsNpcQuickAsync()
    {
        _continueCustomPopupOpen = false;
        _continueSelectedIdentityIds.Clear();
        foreach (var npcOption in NpcContinueOptions)
        {
            _continueSelectedIdentityIds.Add(npcOption.Id);
        }

        _continueIncludeNarrative = true;
        var request = BuildContinueRequest(SubmissionSource.ContinueAsPopupContinue);
        await ExecuteContinueAsync(request, "Continue As failed.");
    }

    private void ToggleContinueNarrative()
    {
        _continueIncludeNarrative = !_continueIncludeNarrative;
    }

    private void SelectContinueCustomIdentityShortcut()
    {
        var customOption = ContinueCustomIdentityOption;
        if (customOption is null)
        {
            return;
        }

        ToggleContinueIdentitySelection(customOption.Id);
    }

    private async Task ClearContinueAsAsync()
    {
        if (_session is null)
        {
            return;
        }

        _continueSelectedIdentityIds.Clear();
        _continueIncludeNarrative = false;

        var result = await RolePlayEngine.ContinueAsAsync(new ContinueAsRequest
        {
            SessionId = _session.Id,
            IsClearAction = true,
            TriggeredBy = SubmissionSource.ContinueAsPopupContinue
        });

        if (!result.Success)
        {
            _statusMessage = result.ValidationError ?? "Unable to clear Continue As selections.";
        }
    }

    private ContinueAsRequest BuildContinueRequest(SubmissionSource source)
    {
        var selectedOptions = ContinueIdentityOptions
            .Where(x => _continueSelectedIdentityIds.Contains(x.Id))
            .ToList();

        return new ContinueAsRequest
        {
            SessionId = _session!.Id,
            SelectedIdentityIds = selectedOptions.Select(x => x.Id).ToList(),
            SelectedParticipants = selectedOptions.Select(x => x.Actor).ToList(),
            IncludeNarrative = _continueIncludeNarrative,
            CustomIdentityName = string.IsNullOrWhiteSpace(_customIdentityName) ? null : _customIdentityName.Trim(),
            TriggeredBy = source
        };
    }

    private async Task<bool> ExecuteContinueAsync(ContinueAsRequest request, string defaultErrorMessage)
    {
        var result = await RolePlayEngine.ContinueAsAsync(request);
        if (!result.Success)
        {
            _statusMessage = result.ValidationError ?? defaultErrorMessage;
            return false;
        }

        _statusMessage = string.Empty;
        await LoadSessionAsync();
        return true;
    }

    private async Task ForkAsync()
    {
        if (_session is null) return;
        var title = string.IsNullOrWhiteSpace(_branchTitle) ? $"Fork of {_session.Title}" : _branchTitle.Trim();
        var fork = await RolePlayBranchService.ForkSessionAsync(_session.Id, title, _branchFromIndex);
        if (fork is null) { _statusMessage = "Fork failed."; return; }
        Navigation.NavigateTo(RolePlayRoutes.GetWorkspace(fork.Id));
    }

    private void GoToSavedSessions() => Navigation.NavigateTo(RolePlayRoutes.Sessions);

    [JSInvokable]
    public Task OnSettingsPanelResized(int width)
    {
        var oldWidth = _workspaceSettings.SettingsPanelWidth;
        _workspaceSettings.SettingsPanelWidth = width;

        if (oldWidth != _workspaceSettings.SettingsPanelWidth)
        {
            Logger.LogInformation(
                "Role-play settings panel resized: session={SessionId}, width={Width}",
                sessionId,
                _workspaceSettings.SettingsPanelWidth);
        }

        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        if (_resizeInitialized)
        {
            await JS.InvokeVoidAsync("rolePlayWorkspace.disposePanelResize", ".rw-panel-resize-handle");
        }

        _dotNetRef?.Dispose();
    }

    private static string GetInitial(string name) =>
        string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[0].ToString().ToUpper();

    private string IntentLabel => _selectedIntent switch
    {
        PromptIntent.Narrative => "narrative",
        PromptIntent.Instruction => "instruction",
        _ => "message"
    };

    private string CurrentIdentityLabel
    {
        get
        {
            if (_selectedIdentity is null)
            {
                return "?";
            }

            if (_selectedIdentity.SourceType == IdentityOptionSource.CustomCharacter
                && !string.IsNullOrWhiteSpace(_customIdentityName))
            {
                return _customIdentityName.Trim();
            }

            return _selectedIdentity.DisplayName;
        }
    }

    private string CurrentIdentityInitial => GetInitial(CurrentIdentityLabel);

    private IEnumerable<IdentityOption> ContinueIdentityOptions =>
        _identityOptions.Where(x => x.IsAvailable);

    private IdentityOption? PersonaContinueOption => ContinueIdentityOptions
        .FirstOrDefault(x => x.SourceType == IdentityOptionSource.Persona);

    private IReadOnlyList<IdentityOption> NpcContinueOptions => ContinueIdentityOptions
        .Where(x => x.SourceType == IdentityOptionSource.SceneCharacter)
        .ToList();

    private IdentityOption? ContinueCustomIdentityOption => ContinueIdentityOptions
        .FirstOrDefault(x => x.SourceType == IdentityOptionSource.CustomCharacter);

    private bool HasNpcContinueSelection => NpcContinueOptions.Any(x => _continueSelectedIdentityIds.Contains(x.Id));

    private bool HasPersonaContinueSelection => PersonaContinueOption is not null
        && _continueSelectedIdentityIds.Contains(PersonaContinueOption.Id);

    private bool HasCustomContinueSelection => ContinueCustomIdentityOption is not null
        && _continueSelectedIdentityIds.Contains(ContinueCustomIdentityOption.Id);

    private bool IsContinueIdentitySelected(IdentityOption option) => _continueSelectedIdentityIds.Contains(option.Id);

    private int ContinueSelectionCount => ContinueIdentityOptions.Count(x => _continueSelectedIdentityIds.Contains(x.Id));

    private string ShellStyle => $"--rw-settings-width: {_workspaceSettings.SettingsPanelWidth}px;";
}

<PageTitle>Role-Play Workspace</PageTitle>

<div class="rw-shell" @onclick="CloseAllPopups" style="@ShellStyle">

    
    <div class="rw-main">

        <div class="rw-header">
            <div class="rw-header-left">
                <button class="rw-back-btn" @onclick="GoToSavedSessions" @onclick:stopPropagation>←</button>
                @if (_session is not null)
                {
                    <span class="rw-session-title">@_session.Title</span>
                    <span class="rw-session-meta">@_session.Interactions.Count interactions · @_session.BehaviorMode</span>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="rw-status-bar">@_statusMessage</div>
        }

        @if (_session is null)
        {
            <div class="rw-loading">Loading session...</div>
        }
        else
        {
            <div class="rw-story">
                @if (_session.Interactions.Count == 0)
                {
                    <p class="rw-empty-hint">No interactions yet. Type below and press Send to begin.</p>
                }
                else
                {
                    @foreach (var interaction in _session.Interactions)
                    {
                        <div class="rw-interaction rw-type-@interaction.InteractionType.ToString().ToLower()">
                            <div class="rw-actor-badge">@GetInitial(interaction.ActorName)</div>
                            <div class="rw-interaction-body">
                                <div class="rw-actor-name">@interaction.ActorName</div>
                                <div class="rw-interaction-text">@interaction.Content</div>
                            </div>
                        </div>
                    }
                }
            </div>

            
            <div class="rw-prompt-area" @onclick:stopPropagation>

                
                @if (_intentPopupOpen)
                {
                    <div class="rw-popup rw-intent-popup">
                        <button class="rw-popup-item @(_selectedIntent == PromptIntent.Message ? "is-selected" : "")"
                                @onclick="@(() => SelectIntent(PromptIntent.Message))">
                            <div class="rw-popup-item-content">
                                <span class="rw-popup-item-title">Message</span>
                                <span class="rw-popup-item-desc">Act as one of the characters</span>
                            </div>
                            @if (_selectedIntent == PromptIntent.Message)
                            {
                                <span class="rw-popup-check">✓</span>
                            }
                        </button>
                        <button class="rw-popup-item @(_selectedIntent == PromptIntent.Narrative ? "is-selected" : "")"
                                @onclick="@(() => SelectIntent(PromptIntent.Narrative))">
                            <div class="rw-popup-item-content">
                                <span class="rw-popup-item-title">Narrative by Character</span>
                                <span class="rw-popup-item-desc">Expand tone or phrase from selected character POV</span>
                            </div>
                            @if (_selectedIntent == PromptIntent.Narrative)
                            {
                                <span class="rw-popup-check">✓</span>
                            }
                        </button>
                        <button class="rw-popup-item @(_selectedIntent == PromptIntent.Instruction ? "is-selected" : "")"
                                @onclick="@(() => SelectIntent(PromptIntent.Instruction))">
                            <div class="rw-popup-item-content">
                                <span class="rw-popup-item-title">Instruction</span>
                                <span class="rw-popup-item-desc">Tell the AI what to do</span>
                            </div>
                            @if (_selectedIntent == PromptIntent.Instruction)
                            {
                                <span class="rw-popup-check">✓</span>
                            }
                        </button>
                    </div>
                }

                
                @if (_identityPopupOpen)
                {
                    <div class="rw-popup rw-identity-popup">
                        <div class="rw-popup-header">
                            <span class="rw-popup-intent-label">@IntentLabel</span>
                        </div>
                        <div class="rw-identity-list">
                            @foreach (var option in _identityOptions)
                            {
                                <button class="rw-identity-item @(option == _selectedIdentity ? "is-selected" : "") @(!option.IsAvailable ? "is-disabled" : "")"
                                        @onclick="@(() => SelectIdentity(option))"
                                        disabled="@(!option.IsAvailable)"
                                        title="@option.AvailabilityReason">
                                    <span class="rw-identity-badge">@GetInitial(option.DisplayName)</span>
                                    <span class="rw-identity-name">@option.DisplayName</span>
                                    @if (option == _selectedIdentity)
                                    {
                                        <span class="rw-popup-check">✓</span>
                                    }
                                </button>
                            }
                        </div>
                        @if (_showCustomInput)
                        {
                            <div class="rw-custom-name-row">
                                <input class="rw-custom-name-input" placeholder="Character name..."
                                       @bind="_customIdentityName" @bind:event="oninput" />
                            </div>
                        }
                    </div>
                }

                <div class="rw-continue-row">
                    <span class="rw-continue-label">Continue As</span>
                    <button class="rw-continue-chip @(HasPersonaContinueSelection && !_continueIncludeNarrative ? "is-active" : string.Empty)"
                            @onclick="ContinueAsYouQuickAsync"
                            @onclick:stopPropagation>
                        You
                    </button>
                    <button class="rw-continue-chip @(HasNpcContinueSelection && _continueIncludeNarrative ? "is-active" : string.Empty)"
                            @onclick="ContinueAsNpcQuickAsync"
                            @onclick:stopPropagation>
                        NPC
                    </button>
                    <button class="rw-continue-chip rw-continue-chip-custom @((HasCustomContinueSelection || ContinueSelectionCount > 0 || _continueIncludeNarrative || _continueCustomPopupOpen) ? "is-active" : string.Empty)"
                            @onclick="ToggleContinueCustomPopup"
                            @onclick:stopPropagation>
                        Custom
                    </button>
                </div>

                @if (_continueCustomPopupOpen)
                {
                    <div class="rw-popup rw-continue-custom-popup">
                        <div class="rw-popup-header">
                            <span class="rw-popup-intent-label">continue as custom</span>
                        </div>
                        <div class="rw-continue-options-row">
                            <button class="rw-popup-action-btn @(_continueIncludeNarrative ? "is-primary" : string.Empty)"
                                    @onclick="ToggleContinueNarrative">
                                Narrative @(_continueIncludeNarrative ? "✓" : string.Empty)
                            </button>
                            @if (ContinueCustomIdentityOption is not null)
                            {
                                <button class="rw-popup-action-btn @(HasCustomContinueSelection ? "is-primary" : string.Empty)"
                                        @onclick="SelectContinueCustomIdentityShortcut">
                                    Custom @((HasCustomContinueSelection) ? "✓" : string.Empty)
                                </button>
                            }
                        </div>
                        <div class="rw-identity-list rw-continue-identity-list">
                            @foreach (var option in ContinueIdentityOptions)
                            {
                                <button class="rw-identity-item @(IsContinueIdentitySelected(option) ? "is-selected" : string.Empty)"
                                        @onclick="@(() => ToggleContinueIdentitySelection(option.Id))">
                                    <span class="rw-identity-badge">@GetInitial(option.DisplayName)</span>
                                    <span class="rw-identity-name">@option.DisplayName</span>
                                    @if (IsContinueIdentitySelected(option))
                                    {
                                        <span class="rw-popup-check">✓</span>
                                    }
                                </button>
                            }
                        </div>
                        <div class="rw-popup-actions rw-continue-popup-actions">
                            <button class="rw-popup-action-btn"
                                    @onclick="ClearContinueAsAsync">Clear</button>
                            <button class="rw-popup-action-btn is-primary"
                                    @onclick="ContinueFromIdentityPopupAsync">Continue</button>
                        </div>
                    </div>
                }

                
                <div class="rw-input-row">
                    @if (_selectedIntent == PromptIntent.Message)
                    {
                        <button class="rw-identity-btn rw-identity-btn-outside @(_selectedIdentity is not null ? "has-selection" : string.Empty)"
                                @onclick="ToggleIdentityPopup"
                                @onclick:stopPropagation
                                title="Select character: @CurrentIdentityLabel">
                            <span class="rw-identity-btn-initial">@CurrentIdentityInitial</span>
                        </button>
                    }

                    <div class="rw-prompt-box">
                        <textarea class="rw-prompt-textarea"
                                  placeholder="Write something..."
                                  rows="2"
                                  @bind="_promptText"
                                  @bind:event="oninput"
                                  disabled="@_isSubmitting"></textarea>
                        <div class="rw-prompt-toolbar">
                            <div class="rw-toolbar-left">
                                <button class="rw-intent-btn" @onclick="ToggleIntentPopup" @onclick:stopPropagation title="Change message type">
                                    @IntentLabel <span class="rw-chevron">⌃</span>
                                </button>
                            </div>
                            <div class="rw-toolbar-right">
                                <button class="rw-add-btn"
                                        @onclick="SubmitPromptAsync"
                                        disabled="@(!CanSubmit)"
                                        title="Submit with +">+</button>
                                <button class="rw-send-btn @(CanSubmit ? "is-ready" : "")"
                                        @onclick="SubmitOrOverflowContinueAsync"
                                        disabled="@(_isSubmitting)"
                                        title="Send to AI">
                                    @if (_isSubmitting)
                                    {
                                        <span class="rw-spinner"></span>
                                    }
                                    else if (CanSubmit)
                                    {
                                        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M8 13V3M3 8l5-5 5 5"/>
                                        </svg>
                                    }
                                    else
                                    {
                                        <span style="letter-spacing:1px">···</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        }

    </div>

    
    <div class="rw-panel-resize-handle" @onclick:stopPropagation title="Resize settings panel"></div>
    <div class="rw-settings-panel" @onclick:stopPropagation>

        <div class="rw-settings-tabs">
            <button class="rw-settings-tab @(_activeSettingsTab == "scenario" ? "is-active" : "")"
                    @onclick="@(() => _activeSettingsTab = "scenario")">Scenario</button>
            <button class="rw-settings-tab @(_activeSettingsTab == "settings" ? "is-active" : "")"
                    @onclick="@(() => _activeSettingsTab = "settings")">
                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" style="margin-right:4px;vertical-align:-1px">
                    <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492zM5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0z"/>

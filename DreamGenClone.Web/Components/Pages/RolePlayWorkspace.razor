    [JSInvokable]
    public Task OnSettingsPanelResized(int width)
    {
        var oldWidth = _workspaceSettings.SettingsPanelWidth;
        _workspaceSettings.SettingsPanelWidth = width;

        if (oldWidth != _workspaceSettings.SettingsPanelWidth)
        {
            Logger.LogInformation(
                "Role-play settings panel resized: session={SessionId}, width={Width}",
                sessionId,
                _workspaceSettings.SettingsPanelWidth);
        }

        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;
        _jsInteropUnavailable = true;

        if (_resizeInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("rolePlayWorkspace.disposePanelResize", ".rw-panel-resize-handle");
            }
            catch (Microsoft.JSInterop.JSDisconnectedException)
            {
            }
            catch (TaskCanceledException)
            {
            }
            catch (OperationCanceledException)
            {
            }
        }

        _dotNetRef?.Dispose();
    }

    private static string GetInitial(string name) =>
        string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[0].ToString().ToUpper();


    private void NormalizeStyleBounds(RolePlaySession session, bool preferFloor)
    {
        var floor = RolePlayStyleResolver.ParseBoundScale(session.IntensityFloorOverride);
        var ceiling = RolePlayStyleResolver.ParseBoundScale(session.IntensityCeilingOverride);
        if (!floor.HasValue || !ceiling.HasValue || floor.Value <= ceiling.Value)
        {
            return;
        }

        if (preferFloor)
        {
            session.IntensityCeilingOverride = session.IntensityFloorOverride;
        }
        else
        {
            session.IntensityFloorOverride = session.IntensityCeilingOverride;
        }
    }


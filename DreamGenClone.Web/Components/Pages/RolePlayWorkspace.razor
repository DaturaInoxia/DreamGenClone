    private async Task ClearContinueAsAsync()
    {
        if (_session is null)
        {
            return;
        }

        _continueSelectedIdentityIds.Clear();
        _continueIncludeNarrative = false;

        var result = await RolePlayEngine.ContinueAsAsync(new ContinueAsRequest
        {
            SessionId = _session.Id,
            IsClearAction = true,
            TriggeredBy = SubmissionSource.ContinueAsPopupContinue
        });

        if (!result.Success)
        {
            _statusMessage = result.ValidationError ?? "Unable to clear Continue As selections.";
        }
    }

    private ContinueAsRequest BuildContinueRequest(SubmissionSource source)
    {
        var selectedOptions = ContinueIdentityOptions
            .Where(x => _continueSelectedIdentityIds.Contains(x.Id))
            .ToList();

        return new ContinueAsRequest
        {
            SessionId = _session!.Id,
            SelectedIdentityIds = selectedOptions.Select(x => x.Id).ToList(),
            SelectedParticipants = selectedOptions.Select(x => x.Actor).ToList(),
            IncludeNarrative = _continueIncludeNarrative,
            CustomIdentityName = string.IsNullOrWhiteSpace(_customIdentityName) ? null : _customIdentityName.Trim(),
            TriggeredBy = source
        };
    }

    private async Task<bool> ExecuteContinueAsync(ContinueAsRequest request, string defaultErrorMessage)
    {
        _isSubmitting = true;
        _statusMessage = string.Empty;
        CloseAllPopups();
        _isAwaitingModelResponse = true;
        _pendingResponseLabel = BuildContinuePendingResponseLabel(request);
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = await RolePlayEngine.ContinueAsAsync(request);
            if (!result.Success)
            {
                _statusMessage = result.ValidationError ?? defaultErrorMessage;
                return false;
            }

            _statusMessage = string.Empty;
            await LoadSessionAsync();
            return true;
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
            Logger.LogError(ex, "Continue action failed for session {SessionId}", sessionId);
            return false;
        }
        finally
        {
            _isAwaitingModelResponse = false;
            _pendingResponseLabel = string.Empty;
            _isSubmitting = false;
        }
    }


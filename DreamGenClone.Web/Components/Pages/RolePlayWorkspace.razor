@page "/roleplay/workspace/{sessionId}"
@rendermode InteractiveServer

@using DreamGenClone.Web.Application.RolePlay
@using DreamGenClone.Web.Domain.RolePlay
@using DreamGenClone.Web.Domain.Models
@using DreamGenClone.Web.Application.Models
@using DreamGenClone.Web.Application.Assistants
@using DreamGenClone.Web.Application.Scenarios
@using DreamGenClone.Web.Application.StoryAnalysis
@using DreamGenClone.Web.Domain.Scenarios
@using DreamGenClone.Application.ModelManager
@using DreamGenClone.Domain.StoryAnalysis
@using DreamGenClone.Domain.ModelManager

@inject IRolePlayEngineService RolePlayEngine
@inject IRolePlayBranchService RolePlayBranchService
@inject IInteractionCommandService InteractionCommandService
@inject IInteractionRetryService InteractionRetryService
@inject IRolePlayIdentityOptionsService IdentityOptionsService
@inject IRegisteredModelRepository RegisteredModelRepository
@inject IModelSettingsService ModelSettingsService
@inject IBehaviorModeService BehaviorModeService
@inject IRolePlayAssistantService RolePlayAssistant
@inject IAssistantContextManager AssistantContextManager
@inject IScenarioService ScenarioService
@inject StoryAnalysisFacade StoryAnalysisFacade
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject ILogger<RolePlayWorkspace> Logger
@implements IAsyncDisposable

@code {
    [Parameter]
    public string sessionId { get; set; } = string.Empty;

    private RolePlaySession? _session;
    private string _statusMessage = string.Empty;
    private bool _isSubmitting = false;
    private bool _isAwaitingModelResponse = false;
    private string _pendingResponseLabel = string.Empty;

    // Settings panel
    private BehaviorMode _selectedBehaviorMode = BehaviorMode.TakeTurns;
    private string _activeSettingsTab = "settings";
    private readonly WorkspaceSettingsState _workspaceSettings = new();

    // Assistant panel
    private Scenario? _loadedScenario;
    private string _assistantSelectedModelId = string.Empty;
    private Dictionary<string, List<RegisteredModel>> _assistantGroupedModels = new();
    private List<RolePlayAssistantChatThread> _assistantChats = [];
    private string? _activeAssistantChatId;
    private DotNetObjectReference<RolePlayWorkspace>? _dotNetRef;
    private bool _resizeInitialized;
    private int _lastRenderedInteractionCount = -1;
    private bool _scenarioDirty;

    // Scenario section collapse state (all collapsed by default)
    private readonly HashSet<string> _expandedScenarioSections = new();

    // Unified prompt
    private string _promptText = string.Empty;
    private PromptIntent _selectedIntent = PromptIntent.Message;
    private bool _intentPopupOpen = false;
    private bool _identityPopupOpen = false;
    private bool _continueCustomPopupOpen = false;

    // Identity
    private List<IdentityOption> _identityOptions = [];
    private IdentityOption? _selectedIdentity = null;
    private string _customIdentityName = string.Empty;
    private bool _showCustomInput = false;
    private readonly HashSet<string> _continueSelectedIdentityIds = new(StringComparer.OrdinalIgnoreCase);
    private bool _continueIncludeNarrative;
    private List<ThemePreference> _activeProfileThemes = [];
    private Dictionary<string, ToneProfile> _toneProfilesById = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnParametersSetAsync()
    {
        await LoadSessionAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_resizeInitialized)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync(
                "rolePlayWorkspace.initPanelResize",
                ".rw-shell",
                ".rw-panel-resize-handle",
                _workspaceSettings.SettingsPanelWidth,
                WorkspaceSettingsState.MinPanelWidth,
                WorkspaceSettingsState.MaxPanelWidth,
                _dotNetRef);

            _resizeInitialized = true;
        }

        var interactionCount = _session?.Interactions.Count ?? 0;
        if (interactionCount != _lastRenderedInteractionCount)
        {
            await JS.InvokeVoidAsync("rolePlayWorkspace.scrollStoryToBottom");
            _lastRenderedInteractionCount = interactionCount;
        }
    }

    private async Task LoadSessionAsync()
    {
        _session = await RolePlayEngine.GetSessionAsync(sessionId);
        if (_session is null)
        {
            _statusMessage = "Session not found.";
            Navigation.NavigateTo(RolePlayRoutes.Sessions);
            return;
        }

        var sessionUpdated = false;
        if (_session.AssistantMaxTokens < 2000)
        {
            _session.AssistantMaxTokens = 2000;
            sessionUpdated = true;
        }

        EnsureAssistantChatsInitialized(_session);
        _assistantChats = _session.AssistantChats
            .OrderByDescending(c => c.ModifiedAt)
            .ToList();
        _activeAssistantChatId = _session.ActiveAssistantChatId;

        if (sessionUpdated)
        {
            await RolePlayEngine.SaveSessionAsync(_session);
        }

        _selectedBehaviorMode = _session.BehaviorMode;

        // Sync persisted model settings into the in-memory service
        var persistedSettings = new ModelSettings
        {
            SessionModelId = _session.SessionModelId,
            Temperature = _session.SessionTemperature,
            TopP = _session.SessionTopP,
            MaxTokens = _session.SessionMaxTokens
        };
        ModelSettingsService.UpdateSettings(_session.Id, persistedSettings);

        _identityOptions = (await IdentityOptionsService.GetIdentityOptionsAsync(_session)).ToList();

        // Load scenario for assistant context
        if (!string.IsNullOrWhiteSpace(_session.ScenarioId) && _loadedScenario?.Id != _session.ScenarioId)
        {
            _loadedScenario = await ScenarioService.GetScenarioAsync(_session.ScenarioId);
        }

        // Backfill adaptive profile/style fields for sessions that were created before defaults were copied.
        if (_loadedScenario is not null)
        {
            if (string.IsNullOrWhiteSpace(_session.SelectedRankingProfileId) && !string.IsNullOrWhiteSpace(_loadedScenario.DefaultRankingProfileId))
            {
                _session.SelectedRankingProfileId = _loadedScenario.DefaultRankingProfileId;
                sessionUpdated = true;
            }

            var defaultToneId = _loadedScenario.DefaultToneProfileId ?? _loadedScenario.Style.ToneProfileId;
            if (string.IsNullOrWhiteSpace(_session.SelectedToneProfileId) && !string.IsNullOrWhiteSpace(defaultToneId))
            {
                _session.SelectedToneProfileId = defaultToneId;
                sessionUpdated = true;
            }

            if (string.IsNullOrWhiteSpace(_session.StyleFloorOverride) && !string.IsNullOrWhiteSpace(_loadedScenario.Style.StyleFloor))
            {
                _session.StyleFloorOverride = _loadedScenario.Style.StyleFloor;
                sessionUpdated = true;
            }

            if (string.IsNullOrWhiteSpace(_session.StyleCeilingOverride) && !string.IsNullOrWhiteSpace(_loadedScenario.Style.StyleCeiling))
            {
                _session.StyleCeilingOverride = _loadedScenario.Style.StyleCeiling;
                sessionUpdated = true;
            }
        }

        if (EnsureAdaptiveThemeSelections(_session))
        {
            sessionUpdated = true;
        }

        // Load assistant model selection
        _assistantSelectedModelId = _session.AssistantModelId ?? string.Empty;
        var enabledModels = await RegisteredModelRepository.GetAllEnabledAsync();
        _assistantGroupedModels = enabledModels
            .GroupBy(m => m.ProviderName ?? "Unknown")
            .ToDictionary(g => g.Key, g => g.ToList());

        var selectedIdentityId = _selectedIdentity?.Id;
        if (!string.IsNullOrWhiteSpace(selectedIdentityId))
        {
            _selectedIdentity = _identityOptions.FirstOrDefault(x =>
                string.Equals(x.Id, selectedIdentityId, StringComparison.OrdinalIgnoreCase));
        }

        var continueIds = _identityOptions
            .Where(x => x.IsAvailable)
            .Select(x => x.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        _continueSelectedIdentityIds.RemoveWhere(id => !continueIds.Contains(id));

        if (_selectedIdentity is null)
        {
            _selectedIdentity = _identityOptions.FirstOrDefault(x => x.IsAvailable)
                ?? _identityOptions.FirstOrDefault();
        }

        _showCustomInput = _selectedIdentity?.SourceType == IdentityOptionSource.CustomCharacter;

        await RefreshActiveProfileThemesAsync();

        if (sessionUpdated)
        {
            await RolePlayEngine.SaveSessionAsync(_session);
        }
    }

    private void ToggleIntentPopup()
    {
        _intentPopupOpen = !_intentPopupOpen;
        _identityPopupOpen = false;
        _continueCustomPopupOpen = false;
    }

    private void SelectIntent(PromptIntent intent)
    {
        _selectedIntent = intent;
        _intentPopupOpen = false;
    }

    private void ToggleIdentityPopup()
    {
        _identityPopupOpen = !_identityPopupOpen;
        _intentPopupOpen = false;
        _continueCustomPopupOpen = false;
    }

    private void SelectIdentity(IdentityOption option)
    {
        if (IsIdentityOptionDisabled(option)) return;
        _selectedIdentity = option;
        _showCustomInput = option.SourceType == IdentityOptionSource.CustomCharacter;
        if (!_showCustomInput)
        {
            _identityPopupOpen = false;
        }
    }

    private void CloseAllPopups()
    {
        _intentPopupOpen = false;
        _identityPopupOpen = false;
        _continueCustomPopupOpen = false;
    }

    private async Task ApplyBehaviorModeAsync()
    {
        if (_session is null) return;
        await RolePlayEngine.UpdateBehaviorModeAsync(_session.Id, _selectedBehaviorMode);
        Logger.LogInformation(
            "Role-play workspace behavior mode changed from settings panel: session={SessionId}, mode={Mode}",
            _session.Id,
            _selectedBehaviorMode);
        await LoadSessionAsync();
    }

    private async Task OnModelSettingsUpdated()
    {
        if (_session is null) return;
        var settings = ModelSettingsService.GetSettings(_session.Id);
        _session.SessionModelId = settings.SessionModelId;
        _session.SessionTemperature = settings.Temperature;
        _session.SessionTopP = settings.TopP;
        _session.SessionMaxTokens = settings.MaxTokens;
        await RolePlayEngine.SaveSessionAsync(_session);
        Logger.LogInformation(
            "Model settings persisted to session {SessionId}: model={ModelId}, temp={Temp}, topP={TopP}, maxTokens={MaxTokens}",
            _session.Id,
            settings.SessionModelId ?? "(default)",
            settings.Temperature,
            settings.TopP,
            settings.MaxTokens);
    }

    // --- Assistant Panel ---

    private RolePlayAssistantChatThread? ActiveAssistantChat =>
        _assistantChats.FirstOrDefault(c => c.Id == _activeAssistantChatId);

    private static void EnsureAssistantChatsInitialized(RolePlaySession session)
    {
        if (session.AssistantChats.Count == 0)
        {
            var chat = CreateAssistantChatThread("Chat 1");
            session.AssistantChats.Add(chat);
            session.ActiveAssistantChatId = chat.Id;
            return;
        }

        if (string.IsNullOrWhiteSpace(session.ActiveAssistantChatId) ||
            session.AssistantChats.All(c => c.Id != session.ActiveAssistantChatId))
        {
            session.ActiveAssistantChatId = session.AssistantChats
                .OrderByDescending(c => c.ModifiedAt)
                .Select(c => c.Id)
                .First();
        }
    }

    private static bool EnsureAdaptiveThemeSelections(RolePlaySession session)
    {
        var tracker = session.AdaptiveState.ThemeTracker;
        var ordered = tracker.Themes.Values
            .OrderByDescending(x => x.Score)
            .ThenBy(x => x.ThemeId, StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (ordered.Count < 2)
        {
            return false;
        }

        var changed = false;
        if (!string.Equals(tracker.PrimaryThemeId, ordered[0].ThemeId, StringComparison.OrdinalIgnoreCase))
        {
            tracker.PrimaryThemeId = ordered[0].ThemeId;
            changed = true;
        }

        if (!string.Equals(tracker.SecondaryThemeId, ordered[1].ThemeId, StringComparison.OrdinalIgnoreCase))
        {
            tracker.SecondaryThemeId = ordered[1].ThemeId;
            changed = true;
        }

        if (!string.Equals(tracker.ThemeSelectionRule, "Top2Blend", StringComparison.Ordinal))
        {
            tracker.ThemeSelectionRule = "Top2Blend";
            changed = true;
        }

        return changed;
    }

    private static RolePlayAssistantChatThread CreateAssistantChatThread(string title) => new()
    {
        Id = Guid.NewGuid().ToString(),
        Title = title,
        CreatedAt = DateTime.UtcNow,
        ModifiedAt = DateTime.UtcNow,
        Messages = []
    };

    private List<AssistantChatSummary> GetAssistantChatSummaries() =>
        _assistantChats
            .OrderByDescending(c => c.ModifiedAt)
            .Select(c => new AssistantChatSummary
            {
                Id = c.Id,
                Title = c.Title,
                ModifiedAt = c.ModifiedAt
            })
            .ToList();

    private List<string> GetActiveAssistantMessages() =>
        ActiveAssistantChat?.Messages
            .Select(m => m.Role == "user" ? $"[User] {m.Content}" : $"[Assistant] {m.Content}")
            .ToList() ?? [];

    private void HydrateAssistantContextFromActiveChat()
    {
        if (_session is null) return;

        AssistantContextManager.ClearChat(_session.Id);

        foreach (var message in ActiveAssistantChat?.Messages ?? [])
        {
            if (message.Role == "user")
            {
                AssistantContextManager.AddUserMessage(_session.Id, message.Content);
            }
            else
            {
                AssistantContextManager.AddAssistantResponse(_session.Id, message.Content);
            }
        }
    }

    private async Task PersistAssistantChatsAsync()
    {
        if (_session is null) return;
        _session.AssistantChats = _assistantChats;
        _session.ActiveAssistantChatId = _activeAssistantChatId;
        await RolePlayEngine.SaveSessionAsync(_session);
    }

    private async Task OnAssistantGenerateRequest(string userPrompt)
    {
        if (_session is null || string.IsNullOrWhiteSpace(userPrompt)) return;

        var activeChat = ActiveAssistantChat;
        if (activeChat is null) return;

        try
        {
            HydrateAssistantContextFromActiveChat();

            var context = BuildAssistantContext();
            var assistantModelId = string.IsNullOrEmpty(_assistantSelectedModelId) ? null : _assistantSelectedModelId;

            var response = await RolePlayAssistant.GenerateSuggestionAsync(
                context,
                userPrompt,
                assistantModelId: assistantModelId,
                assistantTemperature: _session.AssistantTemperature,
                assistantTopP: _session.AssistantTopP,
                assistantMaxTokens: _session.AssistantMaxTokens);

            var now = DateTime.UtcNow;
            activeChat.Messages.Add(new RolePlayAssistantChatMessage { Role = "user", Content = userPrompt, CreatedAt = now });
            activeChat.Messages.Add(new RolePlayAssistantChatMessage { Role = "assistant", Content = response, CreatedAt = DateTime.UtcNow });

            if (activeChat.Messages.Count == 2 && string.Equals(activeChat.Title, "New Chat", StringComparison.Ordinal))
            {
                activeChat.Title = Truncate(userPrompt.Trim(), 36);
            }

            activeChat.ModifiedAt = DateTime.UtcNow;
            _assistantChats = _assistantChats.OrderByDescending(c => c.ModifiedAt).ToList();
            await PersistAssistantChatsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Assistant generation failed for session {SessionId}", _session.Id);
            var now = DateTime.UtcNow;
            activeChat.Messages.Add(new RolePlayAssistantChatMessage { Role = "user", Content = userPrompt, CreatedAt = now });
            activeChat.Messages.Add(new RolePlayAssistantChatMessage { Role = "assistant", Content = $"(Error: {ex.Message})", CreatedAt = DateTime.UtcNow });
            activeChat.ModifiedAt = DateTime.UtcNow;
            _assistantChats = _assistantChats.OrderByDescending(c => c.ModifiedAt).ToList();
            await PersistAssistantChatsAsync();
        }
    }

    private async Task OnAssistantClearChat()
    {
        if (_session is null) return;
        var activeChat = ActiveAssistantChat;
        if (activeChat is null) return;

        activeChat.Messages.Clear();
        activeChat.ModifiedAt = DateTime.UtcNow;
        RolePlayAssistant.ClearChat(_session.Id);
        await PersistAssistantChatsAsync();
    }

    private async Task OnAssistantCreateChat()
    {
        if (_session is null) return;

        var index = _assistantChats.Count + 1;
        var chat = CreateAssistantChatThread($"Chat {index}");
        _assistantChats.Insert(0, chat);
        _activeAssistantChatId = chat.Id;
        RolePlayAssistant.ClearChat(_session.Id);
        await PersistAssistantChatsAsync();
    }

    private async Task OnAssistantSelectChat(string chatId)
    {
        if (_session is null) return;
        if (_assistantChats.All(c => c.Id != chatId)) return;

        _activeAssistantChatId = chatId;
        await PersistAssistantChatsAsync();
    }

    private async Task OnAssistantDeleteChat()
    {
        if (_session is null || _assistantChats.Count <= 1) return;
        if (string.IsNullOrWhiteSpace(_activeAssistantChatId)) return;

        var removed = _assistantChats.RemoveAll(c => c.Id == _activeAssistantChatId);
        if (removed == 0) return;

        var nextChat = _assistantChats.OrderByDescending(c => c.ModifiedAt).First();
        _activeAssistantChatId = nextChat.Id;
        RolePlayAssistant.ClearChat(_session.Id);
        await PersistAssistantChatsAsync();
    }

    private async Task OnAssistantModelChanged()
    {
        if (_session is null) return;
        _session.AssistantModelId = string.IsNullOrEmpty(_assistantSelectedModelId) ? null : _assistantSelectedModelId;
        await RolePlayEngine.SaveSessionAsync(_session);
        Logger.LogInformation(
            "Assistant model changed for session {SessionId}: model={ModelId}",
            _session.Id,
            _session.AssistantModelId ?? "(default)");
    }

    private RolePlayAssistantContext BuildAssistantContext()
    {
        var recentInteractions = (_session?.Interactions ?? [])
            .Where(i => !i.IsExcluded && i.ParentInteractionId is null)
            .TakeLast(8)
            .Select(i => $"[{i.InteractionType}] {i.ActorName}: {Truncate(i.Content, 200)}")
            .ToList();

        var characterSummaries = (_loadedScenario?.Characters ?? [])
            .Select(c => $"{c.Name ?? "Unnamed"}" + (string.IsNullOrWhiteSpace(c.Role) ? "" : $" ({c.Role})") +
                         (string.IsNullOrWhiteSpace(c.Description) ? "" : $" — {Truncate(c.Description, 100)}"))
            .ToList();

        var fullCharacterDetails = (_loadedScenario?.Characters ?? [])
            .Select(c =>
            {
                var parts = new List<string> { $"Name: {c.Name ?? "Unnamed"}" };
                if (!string.IsNullOrWhiteSpace(c.Role)) parts.Add($"Role: {c.Role}");
                if (!string.IsNullOrWhiteSpace(c.Description)) parts.Add($"Description: {c.Description}");
                return string.Join(" | ", parts);
            })
            .ToList();

        var scenarioSummary = _loadedScenario is not null
            ? $"{_loadedScenario.Name ?? "Unnamed Scenario"}: {_loadedScenario.Plot.Description ?? _loadedScenario.Description ?? ""}"
            : null;

        var pinnedCount = (_session?.Interactions ?? []).Count(i => i.IsPinned);
        var profileSteeringThemes = _activeProfileThemes
            .OrderBy(x => GetTierPriority(x.Tier))
            .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
            .Select(x => $"[{FormatTier(x.Tier)}] {x.Name}: {(string.IsNullOrWhiteSpace(x.Description) ? "(no description)" : x.Description)}")
            .ToList();

        return new RolePlayAssistantContext
        {
            SessionId = _session!.Id,
            ScenarioSummary = scenarioSummary,
            RecentInteractions = recentInteractions,
            BehaviorMode = _session.BehaviorMode.ToString(),
            PersonaName = _session.PersonaName,
            PersonaDescription = _session.PersonaDescription,
            CharacterSummaries = characterSummaries,
            ContextWindowSize = _session.ContextWindowSize,
            PinnedInteractionCount = pinnedCount,
            SessionModelId = _session.SessionModelId,
            SessionTemperature = _session.SessionTemperature,
            SessionTopP = _session.SessionTopP,
            SessionMaxTokens = _session.SessionMaxTokens,
            // Rich scenario fields
            ScenarioTone = _loadedScenario?.Style?.Tone,
            ScenarioWritingStyle = _loadedScenario?.Style?.WritingStyle,
            ScenarioPointOfView = _loadedScenario?.Style?.PointOfView,
            ScenarioStyleGuidelines = _loadedScenario?.Style?.StyleGuidelines ?? [],
            ScenarioConflicts = _loadedScenario?.Plot?.Conflicts ?? [],
            ScenarioGoals = _loadedScenario?.Plot?.Goals ?? [],
            ScenarioWorldDescription = _loadedScenario?.Setting?.WorldDescription,
            ScenarioWorldRules = _loadedScenario?.Setting?.WorldRules ?? [],
            FullCharacterDetails = fullCharacterDetails,
            SelectedRankingProfileId = _session.SelectedRankingProfileId,
            SelectedToneProfileId = _session.SelectedToneProfileId,
            StyleFloorOverride = _session.StyleFloorOverride,
            StyleCeilingOverride = _session.StyleCeilingOverride,
            EffectiveStyleMode = GetEffectiveStyleLabel(),
            StyleResolutionReason = GetEffectiveStyleReason(),
            ProfileSteeringThemes = profileSteeringThemes
        };
    }

    private static string Truncate(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength) return text;
        return text[..maxLength] + "…";
    }

    private static List<string> ParseLines(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return [];
        return text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                   .Where(l => !string.IsNullOrWhiteSpace(l))
                   .ToList();
    }

    private void MarkScenarioDirty() => _scenarioDirty = true;

    private void ToggleScenarioSection(string section)
    {
        if (!_expandedScenarioSections.Remove(section))
            _expandedScenarioSections.Add(section);
    }

    private async Task OnSaveScenarioClicked()
    {
        await SaveScenarioAsync();
        _scenarioDirty = false;
    }

    private async Task SaveScenarioAsync()
    {
        if (_loadedScenario is null) return;
        try
        {
            await ScenarioService.SaveScenarioAsync(_loadedScenario);
            Logger.LogInformation("Scenario saved from workspace: {ScenarioId}", _loadedScenario.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save scenario {ScenarioId}", _loadedScenario.Id);
        }
    }

    private async Task SaveSessionSettingsAsync()
    {
        if (_session is null) return;
        try
        {
            await RolePlayEngine.SaveSessionAsync(_session);
            await RefreshActiveProfileThemesAsync();
            Logger.LogInformation("Session settings saved: {SessionId}", _session.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save session settings {SessionId}", _session.Id);
        }
    }

    private async Task RefreshActiveProfileThemesAsync()
    {
        if (_session is null)
        {
            _activeProfileThemes = [];
            _toneProfilesById = new(StringComparer.OrdinalIgnoreCase);
            return;
        }

        var toneProfiles = await StoryAnalysisFacade.ListToneProfilesAsync();
        _toneProfilesById = toneProfiles.ToDictionary(x => x.Id, StringComparer.OrdinalIgnoreCase);

        if (string.IsNullOrWhiteSpace(_session.SelectedRankingProfileId))
        {
            _activeProfileThemes = [];
            return;
        }

        _activeProfileThemes = await StoryAnalysisFacade.ListThemesByProfileAsync(_session.SelectedRankingProfileId);
    }

    private string GetEffectiveStyleLabel()
    {
        if (_session is null)
        {
            return "(session unavailable)";
        }

        var (label, _) = ResolveEffectiveStyle(_session);
        return label;
    }

    private string GetEffectiveStyleReason()
    {
        if (_session is null)
        {
            return string.Empty;
        }

        var (_, reason) = ResolveEffectiveStyle(_session);
        return reason;
    }

    private (string Label, string Reason) ResolveEffectiveStyle(RolePlaySession session)
    {
        var baseScale = 2;
        var reasonParts = new List<string>
        {
            "base=SuggestivePg12"
        };

        if (!string.IsNullOrWhiteSpace(session.SelectedToneProfileId)
            && _toneProfilesById.TryGetValue(session.SelectedToneProfileId, out var toneProfile))
        {
            baseScale = (int)toneProfile.Intensity;
            reasonParts[0] = $"base={toneProfile.Intensity}";
        }

        var arousalValues = session.AdaptiveState.CharacterStats.Values
            .SelectMany(x => x.Stats.Where(kvp => string.Equals(kvp.Key, "Arousal", StringComparison.OrdinalIgnoreCase)).Select(kvp => kvp.Value))
            .ToList();
        if (arousalValues.Count > 0)
        {
            var avgArousal = arousalValues.Average();
            if (avgArousal >= 85)
            {
                baseScale += 2;
                reasonParts.Add("arousal=very-high(+2)");
            }
            else if (avgArousal >= 70)
            {
                baseScale += 1;
                reasonParts.Add("arousal=high(+1)");
            }
            else if (avgArousal <= 35)
            {
                baseScale -= 1;
                reasonParts.Add("arousal=low(-1)");
            }
        }

        if (session.Interactions.Count >= 14)
        {
            baseScale += 1;
            reasonParts.Add("progression=late(+1)");
        }
        else if (session.Interactions.Count <= 4)
        {
            baseScale -= 1;
            reasonParts.Add("progression=early(-1)");
        }

        var primary = session.AdaptiveState.ThemeTracker.PrimaryThemeId ?? string.Empty;
        var secondary = session.AdaptiveState.ThemeTracker.SecondaryThemeId ?? string.Empty;
        if (IsEscalatingTheme(primary) || IsEscalatingTheme(secondary))
        {
            baseScale += 1;
            reasonParts.Add("theme=escalating(+1)");
        }

        var floor = ParseBoundScale(session.StyleFloorOverride);
        var ceiling = ParseBoundScale(session.StyleCeilingOverride);

        var clamped = Math.Clamp(baseScale, 0, 5);
        if (floor.HasValue && clamped < floor.Value)
        {
            clamped = floor.Value;
            reasonParts.Add($"floor={ToStyleLabel(floor.Value)}");
        }

        if (ceiling.HasValue && clamped > ceiling.Value)
        {
            clamped = ceiling.Value;
            reasonParts.Add($"ceiling={ToStyleLabel(ceiling.Value)}");
        }

        return (ToStyleLabel(clamped), string.Join(", ", reasonParts));
    }

    private static bool IsEscalatingTheme(string themeId)
    {
        return string.Equals(themeId, "dominance", StringComparison.OrdinalIgnoreCase)
            || string.Equals(themeId, "power-dynamics", StringComparison.OrdinalIgnoreCase)
            || string.Equals(themeId, "forbidden-risk", StringComparison.OrdinalIgnoreCase)
            || string.Equals(themeId, "humiliation", StringComparison.OrdinalIgnoreCase)
            || string.Equals(themeId, "infidelity", StringComparison.OrdinalIgnoreCase);
    }

    private static int? ParseBoundScale(string? bound)
    {
        if (string.IsNullOrWhiteSpace(bound))
        {
            return null;
        }

        var value = bound.Trim().ToLowerInvariant();
        if (value.Contains("intro") || value.Contains("pg12") || value.Contains("pg-12")) return 0;
        if (value.Contains("emotional") || value.Contains("pg13") || value.Contains("pg-13")) return 1;
        if (value.Contains("suggestive")) return 2;
        if (value.Contains("sensual") || value.Contains("mature")) return 3;
        if (value.Contains("explicit") || value.Contains("erotic")) return 4;
        if (value.Contains("hardcore")) return 5;
        return null;
    }

    private static string ToStyleLabel(int scale)
    {
        return scale switch
        {
            0 => "Intro / PG-12",
            1 => "Emotional / PG-13",
            2 => "Suggestive / PG-13+",
            3 => "Sensual / Mature",
            4 => "Erotic / Explicit",
            _ => "Hardcore / Explicit+"
        };
    }

    private static int GetTierPriority(ThemeTier tier)
    {
        return tier switch
        {
            ThemeTier.MustHave => 0,
            ThemeTier.StronglyPrefer => 1,
            ThemeTier.NiceToHave => 2,
            ThemeTier.Neutral => 3,
            ThemeTier.Dislike => 4,
            ThemeTier.HardDealBreaker => 5,
            _ => 99
        };
    }

    private static string FormatTier(ThemeTier tier)
    {
        return tier switch
        {
            ThemeTier.MustHave => "Must Have",
            ThemeTier.StronglyPrefer => "Strongly Prefer",
            ThemeTier.NiceToHave => "Nice To Have",
            ThemeTier.Neutral => "Neutral",
            ThemeTier.Dislike => "Dislike",
            ThemeTier.HardDealBreaker => "Hard Dealbreaker",
            _ => tier.ToString()
        };
    }

    private bool CanAddPromptEntry =>
        _session is not null &&
        HasPromptText &&
        IsAddIntent &&
        !_isSubmitting;

    private bool CanSendPrompt =>
        _session is not null &&
        HasPromptText &&
        IsIdentitySelectionValidForIntent &&
        !_isSubmitting;

    private bool HasPromptText => !string.IsNullOrWhiteSpace(_promptText);

    private bool ShowPendingResponseIndicator =>
        _isAwaitingModelResponse && !string.IsNullOrWhiteSpace(_pendingResponseLabel);

    private bool IsAddIntent =>
        _selectedIntent == PromptIntent.Instruction ||
        _selectedIntent == PromptIntent.Narrative ||
        _selectedIntent == PromptIntent.Message;

    private bool IsIdentitySelectionValidForIntent
    {
        get
        {
            if (_selectedIntent == PromptIntent.Instruction)
            {
                return true;
            }

            if (_selectedIdentity is null || !_selectedIdentity.IsAvailable)
            {
                return false;
            }

            if (_selectedIdentity.SourceType == IdentityOptionSource.CustomCharacter)
            {
                return !string.IsNullOrWhiteSpace(_customIdentityName);
            }

            return true;
        }
    }

    private bool IsIdentityOptionDisabled(IdentityOption option) => _isSubmitting;

    private string? GetIdentityOptionTitle(IdentityOption option)
    {
        if (_isSubmitting)
        {
            return "Please wait for the current action to finish.";
        }

        return option.IsAvailable ? null : option.AvailabilityReason;
    }

    private async Task AddPromptEntryAsync()
    {
        if (!CanAddPromptEntry) return;

        _isSubmitting = true;
        _statusMessage = string.Empty;
        CloseAllPopups();

        try
        {
            var selectedIdentity = _selectedIntent == PromptIntent.Instruction ? null : _selectedIdentity;
            if (_selectedIntent != PromptIntent.Instruction && selectedIdentity is null)
            {
                _statusMessage = "Select a character before adding the interaction.";
                return;
            }

            var submission = new UnifiedPromptSubmission
            {
                SessionId = _session!.Id,
                PromptText = _promptText.Trim(),
                Intent = _selectedIntent,
                SelectedIdentityId = selectedIdentity?.Id ?? string.Empty,
                SelectedIdentityType = selectedIdentity?.SourceType ?? IdentityOptionSource.Persona,
                CustomIdentityName = string.IsNullOrWhiteSpace(_customIdentityName) ? null : _customIdentityName.Trim(),
                BehaviorModeAtSubmit = _selectedBehaviorMode,
                SubmittedVia = SubmissionSource.PlusButton
            };

            Logger.LogInformation(
                "Role-play entry added from + button without continuation: session={SessionId}, intent={Intent}, identity={IdentityId}",
                _session.Id,
                _selectedIntent,
                submission.SelectedIdentityId);

            await RolePlayEngine.SubmitPromptAsync(submission);

            _promptText = string.Empty;
            await LoadSessionAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
            Logger.LogError(ex, "Prompt entry via + failed for session {SessionId}", sessionId);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task SubmitOrOverflowContinueAsync()
    {
        if (CanSendPrompt)
        {
            await SubmitPromptWithContinuationAsync();
            return;
        }

        if (_session is null)
        {
            return;
        }

        var request = BuildContinueRequest(SubmissionSource.MainOverflowContinue);

        await ExecuteContinueAsync(request, "Continue failed.");
    }

    private async Task SubmitPromptWithContinuationAsync()
    {
        if (!CanSendPrompt)
        {
            if (HasPromptText)
            {
                _statusMessage = "Select a valid identity for this intent before sending.";
            }

            return;
        }

        _isSubmitting = true;
        _statusMessage = string.Empty;
        CloseAllPopups();

        try
        {
            var awaitsModelResponse = _selectedIntent != PromptIntent.Instruction;
            if (awaitsModelResponse)
            {
                _isAwaitingModelResponse = true;
                _pendingResponseLabel = BuildPromptPendingResponseLabel();
                await InvokeAsync(StateHasChanged);
            }

            var submission = new UnifiedPromptSubmission
            {
                SessionId = _session!.Id,
                PromptText = _promptText.Trim(),
                Intent = _selectedIntent,
                SelectedIdentityId = _selectedIntent == PromptIntent.Instruction ? string.Empty : (_selectedIdentity?.Id ?? string.Empty),
                SelectedIdentityType = _selectedIntent == PromptIntent.Instruction ? IdentityOptionSource.Persona : (_selectedIdentity?.SourceType ?? IdentityOptionSource.Persona),
                CustomIdentityName = string.IsNullOrWhiteSpace(_customIdentityName) ? null : _customIdentityName.Trim(),
                BehaviorModeAtSubmit = _selectedBehaviorMode,
                SubmittedVia = SubmissionSource.SendButton
            };

            Logger.LogInformation(
                "Role-play prompt submitted from send button: session={SessionId}, intent={Intent}, mode={Mode}",
                _session.Id,
                _selectedIntent,
                _selectedBehaviorMode);

            await RolePlayEngine.SubmitPromptAsync(submission);
            _promptText = string.Empty;
            await LoadSessionAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
            Logger.LogError(ex, "Prompt submission via send failed for session {SessionId}", sessionId);
        }
        finally
        {
            _isAwaitingModelResponse = false;
            _pendingResponseLabel = string.Empty;
            _isSubmitting = false;
        }
    }

    private async Task ContinueFromIdentityPopupAsync()
    {
        if (_session is null)
        {
            return;
        }

        var request = BuildContinueRequest(SubmissionSource.ContinueAsPopupContinue);
        var success = await ExecuteContinueAsync(request, "Continue As failed.");
        if (success)

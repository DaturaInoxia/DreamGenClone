            .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

        _husbandAwarenessProfiles = (await StoryAnalysisFacade.ListHusbandAwarenessProfilesAsync())
            .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase)

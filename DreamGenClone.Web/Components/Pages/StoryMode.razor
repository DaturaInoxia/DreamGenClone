@page "/story"
@rendermode InteractiveServer

@using DreamGenClone.Web.Application.Assistants
@using DreamGenClone.Web.Application.Scenarios
@using DreamGenClone.Web.Application.Story
@using DreamGenClone.Web.Domain.Story

@inject IStoryEngineService StoryEngine
@inject IStoryCommandService StoryCommands
@inject IWritingAssistantService WritingAssistant
@inject IScenarioService ScenarioService

<PageTitle>Story Mode</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Story Mode</h1>
        <button class="btn btn-primary" @onclick="CreateSessionAsync">+ New Story Session</button>
    </div>

    @if (_sessions.Count == 0)
    {
        <div class="alert alert-info">No story sessions yet. Create one to begin writing.</div>
    }
    else
    {
        <div class="row g-3">
            <div class="col-12 col-lg-4">
                <div class="card">
                    <div class="card-header">Sessions</div>
                    <div class="list-group list-group-flush">
                        @foreach (var session in _sessions)
                        {
                            <button class="list-group-item list-group-item-action @(session.Id == _selectedSessionId ? "active" : string.Empty)"
                                    @onclick="() => SelectSessionAsync(session.Id)">
                                <div class="fw-semibold">@session.Title</div>
                                <small>@session.ModifiedAt.ToLocalTime().ToString("g")</small>
                            </button>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-8">
                @if (_selectedSession is not null)
                {
                    <div class="card mb-3">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <span>@_selectedSession.Title</span>
                            <span class="badge text-bg-secondary">Blocks: @_selectedSession.Blocks.Count</span>
                        </div>
                        <div class="card-body" style="max-height: 420px; overflow-y: auto;">
                            @if (_selectedSession.Blocks.Count == 0)
                            {
                                <p class="text-muted mb-0">Start by adding text or an instruction.</p>
                            }
                            else
                            {
                                @for (var i = 0; i < _selectedSession.Blocks.Count; i++)
                                {
                                    var block = _selectedSession.Blocks[i];
                                    <div class="border rounded p-2 mb-2">
                                        <div class="d-flex justify-content-between">
                                            <strong>@block.Author (@block.BlockType)</strong>
                                            <small class="text-muted">#@i</small>
                                        </div>
                                        <div style="white-space: pre-wrap;">@block.Content</div>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <div class="card mb-3">
                        <div class="card-header">Compose</div>
                        <div class="card-body">
                            <div class="mb-2">
                                <label class="form-label">Your Story Text</label>
                                <textarea class="form-control" rows="3" @bind="_userTextInput"></textarea>
                            </div>
                            <div class="d-flex gap-2 mb-3">
                                <button class="btn btn-outline-primary" @onclick="AddUserTextAsync">Add Text Block</button>
                                <button class="btn btn-outline-secondary" @onclick="AddInstructionAsync">Add Instruction Block</button>
                            </div>

                            <div class="mb-2">
                                <label class="form-label">Continue Instruction (optional)</label>
                                <input class="form-control" @bind="_continueInstruction" />
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-success" @onclick="ContinueAsync">Continue (AI)</button>
                                <button class="btn btn-warning" @onclick="RewindAsync">Rewind Last Block</button>
                                <button class="btn btn-outline-dark" @onclick="UndoAsync">Undo</button>
                            </div>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">Writing Assistant</div>
                        <div class="card-body">
                            <div class="mb-2">
                                <label class="form-label">Ask Assistant</label>
                                <input class="form-control" @bind="_assistantPrompt" placeholder="Suggest next beat, improve pacing, etc." />
                            </div>
                            <button class="btn btn-outline-info" @onclick="AskAssistantAsync">Get Suggestion</button>
                            @if (!string.IsNullOrWhiteSpace(_assistantResponse))
                            {
                                <hr />
                                <div style="white-space: pre-wrap;">@_assistantResponse</div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private readonly List<StorySession> _sessions = [];
    private StorySession? _selectedSession;
    private string? _selectedSessionId;

    private string _userTextInput = string.Empty;
    private string _continueInstruction = string.Empty;
    private string _assistantPrompt = string.Empty;
    private string _assistantResponse = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await ReloadSessionsAsync();
    }

    private async Task CreateSessionAsync()
    {
        var created = await StoryEngine.CreateSessionAsync($"Story Session {DateTime.Now:HH:mm:ss}");
        await ReloadSessionsAsync();
        await SelectSessionAsync(created.Id);
    }

    private async Task SelectSessionAsync(string sessionId)
    {
        _selectedSessionId = sessionId;
        _selectedSession = await StoryEngine.GetSessionAsync(sessionId);
        _assistantResponse = string.Empty;
    }

    private async Task ReloadSessionsAsync()
    {
        _sessions.Clear();
        var loaded = await StoryEngine.GetSessionsAsync();
        _sessions.AddRange(loaded);

        if (_selectedSessionId is not null)
        {
            _selectedSession = await StoryEngine.GetSessionAsync(_selectedSessionId);
        }
        else if (_sessions.Count > 0)
        {
            await SelectSessionAsync(_sessions[0].Id);
        }
    }

    private async Task AddUserTextAsync()
    {
        if (_selectedSession is null)
        {
            return;
        }

        await StoryCommands.AppendUserTextAsync(_selectedSession.Id, _userTextInput);
        _userTextInput = string.Empty;
        await ReloadSessionsAsync();
    }

    private async Task AddInstructionAsync()
    {
        if (_selectedSession is null)
        {
            return;
        }

        await StoryCommands.AppendInstructionAsync(_selectedSession.Id, _userTextInput);
        _userTextInput = string.Empty;
        await ReloadSessionsAsync();
    }

    private async Task ContinueAsync()
    {
        if (_selectedSession is null)
        {
            return;
        }

        await StoryCommands.CaptureCheckpointAsync(_selectedSession.Id);
        await StoryEngine.ContinueAsync(_selectedSession.Id, _continueInstruction);
        _continueInstruction = string.Empty;
        await ReloadSessionsAsync();
    }

    private async Task RewindAsync()
    {
        if (_selectedSession is null || _selectedSession.Blocks.Count == 0)
        {
            return;
        }

        await StoryCommands.RewindAsync(_selectedSession.Id, _selectedSession.Blocks.Count - 2);
        await ReloadSessionsAsync();
    }

    private async Task UndoAsync()
    {
        if (_selectedSession is null)
        {
            return;
        }

        await StoryCommands.UndoAsync(_selectedSession.Id);
        await ReloadSessionsAsync();
    }

    private async Task AskAssistantAsync()
    {
        if (_selectedSession is null || string.IsNullOrWhiteSpace(_assistantPrompt))
        {
            return;
        }

        var scenarioSummary = string.Empty;
        if (!string.IsNullOrWhiteSpace(_selectedSession.ScenarioId))
        {
            var scenario = await ScenarioService.GetScenarioAsync(_selectedSession.ScenarioId);
            if (scenario is not null)
            {
                scenarioSummary = $"{scenario.Name}\n{scenario.Description}\n{scenario.Plot.Description}\n{scenario.Setting.WorldDescription}";
            }
        }

        var recent = _selectedSession.Blocks
            .TakeLast(8)
            .Select(b => $"{b.Author} ({b.BlockType}): {b.Content}")
            .ToList();

        _assistantResponse = await WritingAssistant.GenerateSuggestionAsync(
            _selectedSession.Id,
            scenarioSummary,
            recent,
            _assistantPrompt);
    }
}

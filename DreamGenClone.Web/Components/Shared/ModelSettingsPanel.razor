@using DreamGenClone.Application.ModelManager
@using DreamGenClone.Domain.ModelManager
@using DreamGenClone.Web.Domain.Models
@using DreamGenClone.Web.Application.Models

@inject IModelSettingsService ModelSettingsService
@inject IRegisteredModelRepository ModelRepository

<div class="model-settings-panel">
    <h4>Model Settings</h4>
    
    <div class="form-group">
        <label for="model-@SessionId">Model</label>
        <select id="model-@SessionId" class="form-control" @bind="SelectedModelId" @bind:event="onchange" @bind:after="OnModelChanged">
            <option value="">(Use Function Default)</option>
            @foreach (var group in _groupedModels)
            {
                <optgroup label="@group.Key">
                    @foreach (var model in group.Value)
                    {
                        <option value="@model.Id">@(model.DisplayName ?? model.ModelIdentifier)</option>
                    }
                </optgroup>
            }
        </select>
    </div>

    <div class="form-group">
        <label for="temperature-@SessionId">Temperature (@CurrentSettings.Temperature.ToString("F2"))</label>
        <input type="range" id="temperature-@SessionId" class="form-control" min="0" max="2" step="0.1" @bind="CurrentSettings.Temperature" @bind:event="oninput" @onchange="OnSettingsChanged" />
    </div>

    <div class="form-group">
        <label for="topp-@SessionId">Top-P (@CurrentSettings.TopP.ToString("F2"))</label>
        <input type="range" id="topp-@SessionId" class="form-control" min="0" max="1" step="0.05" @bind="CurrentSettings.TopP" @bind:event="oninput" @onchange="OnSettingsChanged" />
    </div>

    <div class="form-group">
        <label for="maxtokens-@SessionId">Max Tokens (@CurrentSettings.MaxTokens)</label>
        <input type="number" id="maxtokens-@SessionId" class="form-control" min="50" max="4000" step="50" @bind="CurrentSettings.MaxTokens" @bind:event="oninput" @onchange="OnSettingsChanged" />
    </div>
</div>

@code {
    [Parameter]
    public string SessionId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnSettingsUpdated { get; set; }

    private ModelSettings CurrentSettings { get; set; } = new();
    private string SelectedModelId { get; set; } = string.Empty;
    private Dictionary<string, List<RegisteredModel>> _groupedModels = new();

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(SessionId))
        {
            CurrentSettings = ModelSettingsService.GetSettings(SessionId);
            SelectedModelId = CurrentSettings.SessionModelId ?? string.Empty;
        }

        var enabledModels = await ModelRepository.GetAllEnabledAsync();
        _groupedModels = enabledModels
            .GroupBy(m => m.ProviderName ?? "Unknown")
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    private async Task OnModelChanged()
    {
        CurrentSettings.SessionModelId = string.IsNullOrEmpty(SelectedModelId) ? null : SelectedModelId;
        await OnSettingsChanged();
    }

    private async Task OnSettingsChanged()
    {
        if (!string.IsNullOrEmpty(SessionId))
        {
            ModelSettingsService.UpdateSettings(SessionId, CurrentSettings);
            await OnSettingsUpdated.InvokeAsync();
        }
    }
}

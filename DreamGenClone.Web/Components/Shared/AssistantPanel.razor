@using DreamGenClone.Web.Application.Assistants

<div class="assistant-panel">
    <h4>@Title</h4>
    
    <div class="assistant-conversation">
        @if (ConversationHistory.Count == 0)
        {
            <p class="empty-state">No conversation yet. Ask the assistant for help!</p>
        }
        else
        {
            @foreach (var message in ConversationHistory)
            {
                <div class="message @(message.StartsWith("[User]") ? "user-message" : "assistant-message")">
                    @message
                </div>
            }
        }
    </div>

    <div class="assistant-input-group">
        <textarea class="form-control" rows="3" placeholder="Ask for assistance..." @bind="UserPrompt" @bind:event="oninput"></textarea>
        <div class="button-group">
            <button class="btn btn-primary" @onclick="OnSendRequest" disabled="@(string.IsNullOrWhiteSpace(UserPrompt) || IsProcessing)">
                @if (IsProcessing)
                {
                    <span>Generating...</span>
                }
                else
                {
                    <span>Send</span>
                }
            </button>
            <button class="btn btn-secondary" @onclick="OnClearChat" disabled="@(ConversationHistory.Count == 0)">
                Clear Chat
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-danger">
            @ErrorMessage
        </div>
    }
</div>

@code {
    [Parameter]
    public string Title { get; set; } = "Assistant";

    [Parameter]
    public string SessionId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> OnGenerateRequest { get; set; }

    [Parameter]
    public EventCallback OnClearChatRequest { get; set; }

    private string UserPrompt { get; set; } = string.Empty;
    private bool IsProcessing { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private List<string> ConversationHistory { get; set; } = new();

    private async Task OnSendRequest()
    {
        if (string.IsNullOrWhiteSpace(UserPrompt)) return;

        IsProcessing = true;
        ErrorMessage = string.Empty;

        try
        {
            // Add user message to display
            ConversationHistory.Add($"[User] {UserPrompt}");
            var promptToSend = UserPrompt;
            UserPrompt = string.Empty;

            // Invoke callback to parent component
            await OnGenerateRequest.InvokeAsync(promptToSend);

            // Note: Parent component should call AddAssistantResponse after generation
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsProcessing = false;
        }
    }

    private async Task OnClearChat()
    {
        ConversationHistory.Clear();
        UserPrompt = string.Empty;
        ErrorMessage = string.Empty;
        await OnClearChatRequest.InvokeAsync();
    }

    /// <summary>
    /// Call this from parent component after receiving assistant response.
    /// </summary>
    public void AddAssistantResponse(string response)
    {
        ConversationHistory.Add($"[Assistant] {response}");
        StateHasChanged();
    }
}

<style>
    .assistant-panel {
        border: 1px solid #ddd;
        border-radius: 4px;
        padding: 1rem;
        background-color: #f9f9f9;
        max-width: 600px;
    }

    .assistant-panel h4 {
        margin-top: 0;
        margin-bottom: 1rem;
        font-size: 1.125rem;
        font-weight: 600;
    }

    .assistant-conversation {
        max-height: 400px;
        overflow-y: auto;
        margin-bottom: 1rem;
        padding: 0.5rem;
        background-color: white;
        border: 1px solid #ddd;
        border-radius: 4px;
    }

    .empty-state {
        color: #999;
        font-style: italic;
        text-align: center;
        padding: 2rem;
    }

    .message {
        margin-bottom: 0.5rem;
        padding: 0.5rem;
        border-radius: 4px;
    }

    .user-message {
        background-color: #e3f2fd;
        margin-left: 2rem;
    }

    .assistant-message {
        background-color: #f5f5f5;
        margin-right: 2rem;
    }

    .assistant-input-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .button-group {
        display: flex;
        gap: 0.5rem;
    }

    .alert {
        margin-top: 1rem;
    }
</style>

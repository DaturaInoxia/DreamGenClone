@using DreamGenClone.Web.Application.Assistants

<div class="assistant-panel">
    <div class="assistant-header-row">
        <h4>@Title</h4>
        <button class="btn btn-secondary btn-xs" @onclick="OnCreateChat" disabled="@IsProcessing">New Chat</button>
    </div>

    <div class="assistant-chat-picker-row">
        <select class="assistant-chat-select" value="@ActiveChatId" @onchange="OnChatSelectionChanged" disabled="@IsProcessing">
            @foreach (var chat in Chats)
            {
                <option value="@chat.Id">@chat.Title</option>
            }
        </select>
        <button class="btn btn-secondary btn-xs" @onclick="OnDeleteChat" disabled="@(IsProcessing || Chats.Count <= 1 || string.IsNullOrWhiteSpace(ActiveChatId))">Delete</button>
    </div>
    
    <div class="assistant-conversation">
        @if (Messages.Count == 0)
        {
            <p class="empty-state">No conversation yet. Ask the assistant for help!</p>
        }
        else
        {
            @foreach (var message in Messages)
            {
                <div class="message @(message.StartsWith("[User]") ? "user-message" : "assistant-message")">
                    @message
                </div>
            }
        }
    </div>

    <div class="assistant-input-group">
        <textarea rows="3" placeholder="Ask for assistance..." @bind="UserPrompt" @bind:event="oninput"></textarea>
        <div class="button-group">
            <button class="btn btn-primary" @onclick="OnSendRequest" disabled="@(string.IsNullOrWhiteSpace(UserPrompt) || IsProcessing)">
                @if (IsProcessing)
                {
                    <span>Generating...</span>
                }
                else
                {
                    <span>Send</span>
                }
            </button>
            <button class="btn btn-secondary" @onclick="OnClearChat" disabled="@(Messages.Count == 0 || IsProcessing)">
                Clear Chat
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-danger">
            @ErrorMessage
        </div>
    }
</div>

@code {
    [Parameter]
    public string Title { get; set; } = "Assistant";

    [Parameter]
    public string SessionId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> OnGenerateRequest { get; set; }

    [Parameter]
    public EventCallback OnClearChatRequest { get; set; }

    [Parameter]
    public IReadOnlyList<string> Messages { get; set; } = [];

    [Parameter]
    public IReadOnlyList<AssistantChatSummary> Chats { get; set; } = [];

    [Parameter]
    public string? ActiveChatId { get; set; }

    [Parameter]
    public EventCallback<string> OnSelectChatRequest { get; set; }

    [Parameter]
    public EventCallback OnCreateChatRequest { get; set; }

    [Parameter]
    public EventCallback OnDeleteChatRequest { get; set; }

    private string UserPrompt { get; set; } = string.Empty;
    private bool IsProcessing { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;

    private async Task OnSendRequest()
    {
        if (string.IsNullOrWhiteSpace(UserPrompt)) return;

        IsProcessing = true;
        ErrorMessage = string.Empty;

        try
        {
            var promptToSend = UserPrompt;
            UserPrompt = string.Empty;

            await OnGenerateRequest.InvokeAsync(promptToSend);
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsProcessing = false;
        }
    }

    private async Task OnClearChat()
    {
        UserPrompt = string.Empty;
        ErrorMessage = string.Empty;
        await OnClearChatRequest.InvokeAsync();
    }

    private async Task OnCreateChat()
    {
        ErrorMessage = string.Empty;
        await OnCreateChatRequest.InvokeAsync();
    }

    private async Task OnDeleteChat()
    {
        ErrorMessage = string.Empty;
        await OnDeleteChatRequest.InvokeAsync();
    }

    private async Task OnChatSelectionChanged(ChangeEventArgs args)
    {
        var chatId = args.Value?.ToString();
        if (string.IsNullOrWhiteSpace(chatId)) return;
        ErrorMessage = string.Empty;
        await OnSelectChatRequest.InvokeAsync(chatId);
    }
}

<style>
    .assistant-panel {
        display: flex;
        flex-direction: column;
        gap: 12px;
        width: 100%;
    }

    .assistant-panel h4 {
        margin: 0;
        font-size: 11px;
        font-weight: 600;
        color: #808080;
        text-transform: uppercase;
        letter-spacing: 0.6px;
    }

    .assistant-header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }

    .assistant-chat-picker-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .assistant-chat-select {
        flex: 1;
        min-width: 0;
        background: #222;
        border: 1px solid #363636;
        border-radius: 8px;
        color: #e0e0e0;
        font-size: 12px;
        padding: 6px 10px;
        outline: none;
    }

    .assistant-chat-select:focus {
        border-color: #505050;
    }

    .assistant-conversation {
        max-height: 450px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 10px;
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 8px;
    }

    .empty-state {
        color: #606060;
        font-style: italic;
        text-align: center;
        padding: 2rem 1rem;
        font-size: 13px;
    }

    .message {
        padding: 10px 12px;
        border-radius: 8px;
        font-size: 13px;
        line-height: 1.55;
        white-space: pre-wrap;
        word-wrap: break-word;
    }

    .user-message {
        background: #1e2a3a;
        color: #c8ddf0;
        border: 1px solid #2a3a50;
        margin-left: 24px;
        align-self: flex-end;
    }

    .assistant-message {
        background: #222222;
        color: #d4d4d4;
        border: 1px solid #333333;
        margin-right: 24px;
        align-self: flex-start;
    }

    .assistant-input-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .assistant-input-group textarea {
        background: #222;
        border: 1px solid #363636;
        border-radius: 8px;
        color: #e0e0e0;
        font-size: 13px;
        padding: 8px 10px;
        outline: none;
        resize: vertical;
        min-height: 60px;
    }

    .assistant-input-group textarea:focus {
        border-color: #505050;
    }

    .assistant-input-group textarea::placeholder {
        color: #555;
    }

    .button-group {
        display: flex;
        gap: 8px;
    }

    .button-group .btn-primary {
        background: #2a5a9a;
        border-color: #2a5a9a;
        color: #e0e0e0;
        font-size: 12px;
        padding: 6px 16px;
        border-radius: 6px;
    }

    .btn-xs {
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 6px;
    }

    .button-group .btn-primary:hover:not(:disabled) {
        background: #3468a8;
    }

    .button-group .btn-primary:disabled {
        opacity: 0.4;
    }

    .button-group .btn-secondary {
        background: #2a2a2a;
        border-color: #3a3a3a;
        color: #999;
        font-size: 12px;
        padding: 6px 16px;
        border-radius: 6px;
    }

    .button-group .btn-secondary:hover:not(:disabled) {
        background: #333;
        color: #bbb;
    }

    .button-group .btn-secondary:disabled {
        opacity: 0.4;
    }

    .assistant-panel .alert-danger {
        background: #3a1a1a;
        border: 1px solid #5a2a2a;
        color: #e8a0a0;
        border-radius: 6px;
        font-size: 12px;
        padding: 8px 12px;
        margin-top: 0;
    }
</style>

{
  "LmStudio": {
    "BaseUrl": "http://127.0.0.1:1234",
    "ChatCompletionsPath": "/v1/chat/completions",
    "Model": "Dolphin3.0-Llama3.1-8B",
    "TimeoutSeconds": 120
  },
  "Persistence": {
    "Provider": "SQLite",
    "ConnectionString": "Data Source=data/dreamgenclone.db",
    "TemplateImageRoot": "data/template-images"
  },
  "StoryParser": {
    "TimeoutSeconds": 10,
    "MaxHtmlBytes": 5242880,
    "MaxPageCount": 20,
    "ErrorModeDefault": "FailFast",
    "SupportedDomains": [
      "www.literotica.com",
      "literotica.com"
    ]
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "DreamGenClone": "Information",
        "DreamGenClone.Infrastructure.StoryParser": "Information",
        "DreamGenClone.Web.Application.StoryParser": "Information",
        "DreamGenClone.Web.Application.RolePlay": "Information",
        "DreamGenClone.Web.Components.Pages.RolePlayWorkspace": "Information",
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/dreamgenclone-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

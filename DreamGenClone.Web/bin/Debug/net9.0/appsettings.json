{
  "LmStudio": {
    "BaseUrl": "http://127.0.0.1:1234",
    "ChatCompletionsPath": "/v1/chat/completions",
    "Model": "utena-7b-nsfw-v2-i1",
    "TimeoutSeconds": 120
  },
  "Persistence": {
    "Provider": "SQLite",
    "ConnectionString": "Data Source=data/dreamgenclone.db",
    "TemplateImageRoot": "data/template-images"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/dreamgenclone-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}

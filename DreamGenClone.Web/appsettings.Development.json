{
  "LmStudio": {
    "BaseUrl": "http://127.0.0.1:1234",
    "TimeoutSeconds": 180
  },
  "Persistence": {
    "ConnectionString": "Data Source=data/dreamgenclone.dev.db"
  },
  "StoryAnalysis": {
    "SummarizeTemperature": 0.3,
    "SummarizeMaxTokens": 500,
    "AnalyzeTemperature": 0.3,
    "AnalyzeMaxTokens": 800,
    "RankTemperature": 0.1,
    "RankMaxTokens": 200,
    "MaxStoryTextLength": 12000,
    "RpThemeMarkdownSourcePath": "specs/v2/ThemeDefinitaions",
    "AdaptiveThemeAffinityStackLimit": 1,
    "AdaptiveEarlyTurnInteractionThreshold": 3,
    "AdaptiveEarlyTurnPerStatDeltaCap": 2,
    "AdaptivePerInteractionTotalDeltaBudget": 10,
    "AdaptiveThemeAffinityCapBuildUp": 0,
    "AdaptiveThemeAffinityCapCommitted": 1,
    "AdaptiveThemeAffinityCapApproaching": 1,
    "AdaptiveThemeAffinityCapClimax": 2,
    "AdaptiveThemeAffinityCapReset": 0,
    "SuppressedEvidenceMultiplier": 0.20,
    "SuppressedEvidencePerTurnCap": 1.5,
    "GateFailScorePenaltyMultiplier": 0.35,
    "CompletedScenarioRepeatPenaltyPerRun": 0.20,
    "CompletedScenarioRepeatPenaltyFloor": 0.40,
    "CompletedScenarioRecentPenaltyMultiplier": 0.65,
    "CompletedScenarioThemeScorePenalty": 10,
    "ResetDecayReductionPerCycle": 0.10,
    "ResetDecayReductionCap": 0.60,
    "ResetStatBaselines": {
      "Desire": 40,
      "Restraint": 50,
      "Tension": 40,
      "Connection": 50,
      "Dominance": 50,
      "Loyalty": 50,
      "SelfRespect": 50
    },
    "ResetStatBaselinePullSchedule": [
      0.8333,
      0.5833,
      0.3333,
      0.2,
      0.1667
    ],
    "ResetDesireBaseline": 40,
    "ResetDesireBaselinePullSchedule": [
      0.8333,
      0.5833,
      0.3333,
      0.2,
      0.1667
    ],
    "BuildUpMinInteractionsBeforeCommit": 2
  },
  "RolePlayDecision": {
    "SuppressNarrativeAfterDecision": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "DreamGenClone": "Verbose",
        "DreamGenClone.Infrastructure.RolePlay": "Verbose",
        "DreamGenClone.Infrastructure.RolePlay.Diagnostics": "Verbose",
        "DreamGenClone.Domain.RolePlay": "Verbose",
        "DreamGenClone.Application.RolePlay": "Verbose",
        "DreamGenClone.Web.Application.RolePlay": "Information",
        "DreamGenClone.Web.Components.Pages.RolePlayWorkspace": "Information",
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  }

{
  "LmStudio": {
    "BaseUrl": "http://127.0.0.1:1234",
    "TimeoutSeconds": 180
  },
  "Persistence": {
    "ConnectionString": "Data Source=data/dreamgenclone.dev.db"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "DreamGenClone": "Verbose",
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  }
}
